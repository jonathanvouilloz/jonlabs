dist/

# generated types
.astro/

# dependencies
node_modules/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# environment variables
.env
.env.production

# MCP config (contains API keys)
.mcp.json
.nano-banana-config.json

# SSH keys and secrets
file
file.pub
*.pem
*.key
id_*
