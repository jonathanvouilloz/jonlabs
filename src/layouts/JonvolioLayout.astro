---
import '../styles/jonvolio.css';

interface Props {
	title?: string;
	description?: string;
	ogImage?: string;
	ogType?: 'website' | 'article';
	article?: {
		publishedTime: Date;
		modifiedTime?: Date;
		author: string;
		tags?: string[];
	};
	robots?: string;
}

const {
	title = "jonvolio",
	description = "I build things on the internet. Indie hacker from Geneva, Switzerland.",
	ogImage = "/og-jonvolio.png",
	ogType = "website",
	article,
	robots
} = Astro.props;

const siteUrl = "https://jonlabs.ch";
const fullTitle = title === "jonvolio" ? title : `${title} | jonvolio`;
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;

// Navigation items
const navItems = [
	{ href: "/jonvolio", label: "Home" },
	{ href: "/jonvolio/projects", label: "Projects" },
	{ href: "/jonvolio/blog", label: "Blog" },
	{ href: "/jonvolio/inspirations", label: "Inspirations" },
];

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />

		<!-- Preconnect -->
		<link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />

		<!-- Geist font from Vercel -->
		<link href="https://cdn.jsdelivr.net/npm/geist@1.3.1/dist/fonts/geist-sans/style.min.css" rel="stylesheet" />

		<!-- Favicons -->
		<link rel="icon" type="image/svg+xml" href="/favicon/favicon.svg" />
		<link rel="icon" type="image/png" sizes="96x96" href="/favicon/favicon-96x96.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
		<meta name="theme-color" content="#FAFAF8" />

		<!-- SEO -->
		<title>{fullTitle}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalUrl} />
		{robots && <meta name="robots" content={robots} />}

		<!-- Open Graph -->
		<meta property="og:type" content={ogType} />
		<meta property="og:title" content={fullTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:site_name" content="jonvolio" />
		<meta property="og:image" content={`${siteUrl}${ogImage}`} />
		<meta property="og:locale" content="en_US" />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:site" content="@jonvolio" />
		<meta name="twitter:creator" content="@jonvolio" />
		<meta name="twitter:title" content={fullTitle} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

		<!-- Article meta (for blog posts) -->
		{article && (
			<>
				<meta property="article:published_time" content={article.publishedTime.toISOString()} />
				{article.modifiedTime && <meta property="article:modified_time" content={article.modifiedTime.toISOString()} />}
				<meta property="article:author" content={article.author} />
				{article.tags?.map(tag => <meta property="article:tag" content={tag} />)}
			</>
		)}

		<!-- hreflang for multilingual SEO -->
		<link rel="alternate" hreflang="en" href={canonicalUrl} />
		<link rel="alternate" hreflang="fr" href={`${siteUrl}/`} />
		<link rel="alternate" hreflang="x-default" href={`${siteUrl}/`} />

		<meta name="generator" content={Astro.generator} />
	</head>
	<body class="jonvolio">
		<!-- Navigation -->
		<header class="jonvolio-nav">
			<div class="container">
				<div class="flex items-end justify-between">
					<!-- Left: username -->
					<a href="/jonvolio" class="font-semibold text-base">@jonvolio</a>

					<!-- Right: social icons (top) + nav (bottom) -->
					<div class="flex flex-col items-end gap-2">
						<!-- Social icons -->
						<div class="flex gap-2">
							<a href="https://linkedin.com/in/jonvouilloz" target="_blank" rel="noopener" class="text-[var(--jv-text-muted)] hover:text-[var(--jv-text)] transition-colors" title="LinkedIn">
								<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
									<path d="M20.5 2h-17A1.5 1.5 0 002 3.5v17A1.5 1.5 0 003.5 22h17a1.5 1.5 0 001.5-1.5v-17A1.5 1.5 0 0020.5 2zM8 19H5v-9h3zM6.5 8.25A1.75 1.75 0 118.3 6.5a1.78 1.78 0 01-1.8 1.75zM19 19h-3v-4.74c0-1.42-.6-1.93-1.38-1.93A1.74 1.74 0 0013 14.19a.66.66 0 000 .14V19h-3v-9h2.9v1.3a3.11 3.11 0 012.7-1.4c1.55 0 3.36.86 3.36 3.66z"/>
								</svg>
							</a>
							<a href="https://twitter.com/jonvolio" target="_blank" rel="noopener" class="text-[var(--jv-text-muted)] hover:text-[var(--jv-text)] transition-colors" title="Twitter/X">
								<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
									<path d="M18.205 2.25h3.308l-7.227 8.26 8.502 11.24H16.13l-5.214-6.817L4.95 21.75H1.64l7.73-8.835L1.215 2.25H8.04l4.713 6.231 5.45-6.231zm-1.161 17.52h1.833L7.045 4.126H5.078L17.044 19.77z"/>
								</svg>
							</a>
							<a href="https://github.com/jonvolio" target="_blank" rel="noopener" class="text-[var(--jv-text-muted)] hover:text-[var(--jv-text)] transition-colors" title="GitHub">
								<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
									<path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
								</svg>
							</a>
						</div>
						<!-- Navigation -->
						<nav class="flex items-center gap-4">
							{navItems.filter(item => item.href !== "/jonvolio").map(item => (
								<a
									href={item.href}
									class:list={[
										"btn-stabilo",
										currentPath === item.href || currentPath.startsWith(item.href)
											? "active"
											: ""
									]}
								>
									{item.label}
								</a>
							))}
							<span class="text-[var(--jv-border)]">|</span>
							<a href="/" class="btn-stabilo text-[var(--jv-text-muted)]" title="Switch to Jon Labs (FR)">
								FR
							</a>
						</nav>
					</div>
				</div>
			</div>
		</header>

		<!-- Main content -->
		<main>
			<div class="container">
				<slot />
			</div>
		</main>

		<!-- Footer -->
		<footer class="jonvolio-footer">
			<div class="container">
				<div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
					<div>
						<span>jonvolio</span>
						<span class="mx-2">&middot;</span>
						<a href="https://twitter.com/jonvolio" target="_blank" rel="noopener">Twitter</a>
						<span class="mx-2">&middot;</span>
						<a href="https://github.com/jonvolio" target="_blank" rel="noopener">GitHub</a>
					</div>
					<div>
						<a href="/">Jon Labs (FR)</a>
					</div>
				</div>
			</div>
		</footer>
	</body>
</html>
