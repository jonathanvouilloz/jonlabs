---
import SEO from '../components/SEO.astro';
import type { SchemaType, JSONLDSchema } from '../lib/seo';
// Design system blueprint (tokens .co-root/.co-chrome + primitives .co-*).
// Global : le chrome blueprint (Header/Footer) l'utilise sur toutes les pages.
import '../styles/blueprint.css';

interface Props {
	title?: string;
	description?: string;
	ogImage?: string;
	ogType?: 'website' | 'article';
	// NEW: Array of schemas (preferred)
	schemas?: Array<{ type: SchemaType; data?: any }> | JSONLDSchema[];
	// Legacy: Single schema (backward compatibility)
	schema?: SchemaType;
	schemaData?: Record<string, any>;
	article?: {
		publishedTime: Date;
		modifiedTime?: Date;
		author: string;
		section?: string;
		tags?: string[];
	};
	robots?: string;
}

const {
	title = "Jon Labs - Solutions Digitales",
	description = "Développement web, automatisation, applications. De l'idée au produit fini, j'accompagne entrepreneurs et petites équipes dans leurs projets digitaux.",
	ogImage = "/og-image.png",
	ogType = "website",
	schemas,
	schema,
	schemaData,
	article,
	robots
} = Astro.props;
---

<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />

		<!-- Preconnect pour performances -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />

		<!-- Google Fonts - chargement non-bloquant -->
		<link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@200..800&display=swap" />
		<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@200..800&display=swap" media="print" onload="this.media='all'" />

		<!-- Fonts blueprint (pairing 04) - Inter Tight × Instrument Serif, chargement non-bloquant -->
		<link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter+Tight:ital,wght@0,300..700;1,300..700&family=Instrument+Serif:ital@0;1&display=swap" />
		<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter+Tight:ital,wght@0,300..700;1,300..700&family=Instrument+Serif:ital@0;1&display=swap" media="print" onload="this.media='all'" />

		<!-- Remix Icon - chargement différé -->
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/remixicon@4.6.0/fonts/remixicon.css" media="print" onload="this.media='all'" />

		<!-- Fallback pour navigateurs sans JS -->
		<noscript>
			<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@200..800&display=swap" />
			<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter+Tight:ital,wght@0,300..700;1,300..700&family=Instrument+Serif:ital@0;1&display=swap" />
			<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/remixicon@4.6.0/fonts/remixicon.css" />
		</noscript>

		<!-- Favicons -->
		<link rel="icon" type="image/svg+xml" href="/favicon/favicon.svg" />
		<link rel="icon" type="image/png" sizes="96x96" href="/favicon/favicon-96x96.png" />
		<link rel="icon" type="image/x-icon" href="/favicon/favicon.ico" />
		<link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
		<link rel="manifest" href="/favicon/site.webmanifest" />
		<meta name="theme-color" content="#F5F4F0" />

		<meta name="generator" content={Astro.generator} />
		<link rel="alternate" type="application/rss+xml" title="Blog Jon Labs" href="/rss.xml" />

		<SEO
			title={title}
			description={description}
			ogImage={ogImage}
			ogType={ogType}
			schemas={schemas}
			schema={schema}
			schemaData={schemaData}
			article={article}
			robots={robots}
		/>

		<title>{title}</title>
	</head>
	<body>
		<slot />
		<script>
			import '../scripts/animations';
		</script>
	</body>
</html>

<style>

:root{
	/* ------------------------------------------------------------
	   ALIAS LEGACY → tokens canoniques (@theme dans global.css)
	   Transition : les anciens noms mensongers pointent vers les
	   nouveaux tokens. Le magenta est retiré (→ teal foncé), les
	   couleurs mortes (orange/cyan) → accent. À supprimer en Phase 2
	   une fois les usages migrés vers bg-accent/text-ink/etc.
	   ------------------------------------------------------------ */
	--main-bg: var(--color-bg);
	--text: var(--color-ink);
	--blue: var(--color-accent);            /* accent teal (inchangé) */
	--yellow: var(--color-accent-strong);   /* ex "vert foncé" = hover teal */
	--violet: var(--color-accent-strong);   /* ex magenta → teal foncé (dégradés gardent de la profondeur) */
	--accent: var(--color-accent-soft);     /* ex soulignement magenta → wash teal */
	--orange: var(--color-accent);          /* déprécié */
	--cyan: var(--color-accent);            /* déprécié */
}

html,
body {
	margin: 0;
	width: 100%;
	min-height: 100%;
	background-color: var(--color-bg);
	color: var(--color-ink);
	font-family: var(--font-sans);
	scroll-behavior: smooth;
}


</style>
