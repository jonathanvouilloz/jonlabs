---
// Page Tarifs - Jon Labs
// Packages combinés création de site web + référencement local

import "../styles/global.css";
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

import { SITE_URL } from '../data/schema';
import { getWebPageSchema, getBreadcrumbSchema } from '../lib/seo';

const pageTitle = "Tarifs site web & référencement freelance Genève";
const pageDescription = "Tarifs transparents pour la création de site web et le référencement local à Genève. Packages freelance dès 1'490 CHF, sans contrat 12 mois. Devis gratuit.";

const webPageSchema = getWebPageSchema({
  url: `${SITE_URL}/tarifs`,
  name: pageTitle,
  description: pageDescription
});

// Breadcrumb schema
const breadcrumbSchema = getBreadcrumbSchema([
  { name: "Accueil", url: SITE_URL },
  { name: "Tarifs", url: `${SITE_URL}/tarifs` }
]);

// Service + AggregateOffer schema (page-specific, inline)
const serviceWithPricing = {
  "@context": "https://schema.org",
  "@type": "Service",
  "@id": `${SITE_URL}/tarifs#service`,
  "name": "Création de site web et référencement à Genève",
  "description": "Packages combinant création de site web et référencement local pour PME et indépendants en Suisse romande.",
  "provider": { "@id": `${SITE_URL}/#organization` },
  "areaServed": ["Genève", "Vaud", "Suisse Romande"],
  "serviceType": "Création de site web et référencement",
  "url": `${SITE_URL}/tarifs`,
  "offers": {
    "@type": "AggregateOffer",
    "priceCurrency": "CHF",
    "lowPrice": "1490",
    "highPrice": "2490",
    "offerCount": 3,
    "offers": [
      {
        "@type": "Offer",
        "name": "Présence",
        "description": "Site vitrine + référencement local de base + Google Business Profile",
        "price": "1490",
        "priceCurrency": "CHF",
        "url": `${SITE_URL}/tarifs#packages`
      },
      {
        "@type": "Offer",
        "name": "Visibilité",
        "description": "Site vitrine jusqu'à 30 pages + blog + 5 articles + suivi 3 mois + formation",
        "price": "2490",
        "priceCurrency": "CHF",
        "url": `${SITE_URL}/tarifs#packages`
      },
      {
        "@type": "Offer",
        "name": "Autorité",
        "description": "Solution sur-mesure pour projets complexes et stratégie de référencement long terme",
        "priceCurrency": "CHF",
        "url": `${SITE_URL}/tarifs#packages`
      }
    ]
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Quels sont les délais de livraison ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Le pack Présence est livré en 2-3 semaines. Le pack Visibilité en 4-8 semaines (incluant la rédaction des 5 articles). Pour le pack Autorité, le planning est défini ensemble selon la complexité du projet."
      }
    },
    {
      "@type": "Question",
      "name": "Est-ce que le référencement est inclus dans tous les packs ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Oui. Chaque pack inclut une optimisation technique de référencement de base (balises, vitesse, mobile, schema). Les packs Visibilité et Autorité ajoutent une stratégie de contenu et un suivi des positions Google via Search Console."
      }
    },
    {
      "@type": "Question",
      "name": "Qu'est-ce qui n'est PAS inclus ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "L'hébergement (environ 10-20 CHF/mois), le nom de domaine (environ 15 CHF/an), et les abonnements à des outils tiers (newsletter, CRM). Je vous guide dans les choix."
      }
    },
    {
      "@type": "Question",
      "name": "Et si j'ai besoin de modifications après la livraison ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Le pack Visibilité inclut 3 mois de suivi avec modifications mineures. Pour les autres packs, je propose une maintenance à 90 CHF/h ou un forfait mensuel adapté à vos besoins."
      }
    },
    {
      "@type": "Question",
      "name": "Vous travaillez avec quelles technologies ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Principalement Astro et Framer pour les sites vitrines (rapides, optimisés référencement). Pour les projets plus complexes : React, SvelteKit, ou la stack adaptée à votre besoin."
      }
    },
    {
      "@type": "Question",
      "name": "Comment se passe le paiement ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "50% à la signature du devis, 50% à la livraison. Pour le pack Autorité, un échéancier sur mesure est proposé selon la durée du projet."
      }
    },
    {
      "@type": "Question",
      "name": "Pourquoi vos tarifs sont moins chers qu'une agence à Genève ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Une agence web à Genève facture en moyenne 8'000 à 15'000 CHF pour un site équivalent à mon pack Visibilité (2'490 CHF). La différence : pas de locaux à payer, pas de commerciaux, pas de chef de projet entre vous et le développeur. Vous parlez directement à la personne qui code. Le tarif finance le travail, pas la structure. Pour les projets très volumineux qui demandent plusieurs profils en parallèle (design, dev, marketing, ops), l'agence reste pertinente."
      }
    },
    {
      "@type": "Question",
      "name": "Y a-t-il un contrat d'engagement de 12 mois ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Non. Les packs Présence et Visibilité sont des forfaits one-shot, sans abonnement. Pour le pack Autorité avec suivi mensuel, le mensuel est résiliable avec 1 mois de préavis. Je ne crois pas aux engagements 12 mois fermes : si le travail est sérieux, vous n'aurez pas envie de partir. Si vous partez, j'ai mal fait mon job."
      }
    }
  ]
};

const schemas = [webPageSchema, breadcrumbSchema, serviceWithPricing, faqSchema];

// Pricing data
const packages = [
  {
    name: "Présence",
    price: "1'490",
    subtitle: "Exister en ligne, bien",
    highlighted: false,
    features: [
      "Site vitrine jusqu'à 5 pages",
      "Design responsive sur-mesure",
      "Optimisation référencement technique",
      "Google Business Profile configuré",
      "Formulaire de contact",
      "Score Lighthouse 90+",
      "Formation utilisation (1h)",
    ],
    ideal: "Indépendants et micro-entreprises qui veulent un site pro rapidement.",
    delay: "2-3 semaines",
    cta: "Lancer mon site",
  },
  {
    name: "Visibilité",
    price: "2'490",
    subtitle: "Être trouvé sur Google",
    highlighted: true,
    features: [
      "Tout le pack Présence +",
      "Site jusqu'à 30 pages",
      "Blog intégré avec 5 articles optimisés référencement",
      "Recherche de mots-clés locale",
      "Stratégie de contenu initiale",
      "Suivi Google Search Console",
      "3 mois de suivi & ajustements",
      "Formation référencement autonomie (2h)",
    ],
    ideal: "PME locales qui veulent attirer des clients via Google.",
    delay: "4-8 semaines",
    cta: "Devenir visible sur Google",
  },
  {
    name: "Autorité",
    price: "Sur devis",
    subtitle: "Dominer votre marché local",
    highlighted: false,
    features: [
      "Tout le pack Visibilité +",
      "Site complexe ou e-commerce",
      "Stratégie de référencement long terme",
      "Contenu mensuel (articles, landing pages)",
      "Automatisations sur-mesure",
      "Suivi mensuel avec reporting",
      "Support prioritaire",
    ],
    ideal: "Entreprises ambitieuses qui veulent une présence digitale complète.",
    delay: "Sur mesure",
    cta: "Construire mon autorité",
  },
];

// Inclusion grid
const inclusions = [
  { feature: "Pages du site", presence: "Jusqu'à 5", visibilite: "Jusqu'à 30", autorite: "Illimité" },
  { feature: "Design responsive", presence: true, visibilite: true, autorite: true },
  { feature: "Référencement technique", presence: true, visibilite: true, autorite: true },
  { feature: "Google Business Profile", presence: true, visibilite: true, autorite: true },
  { feature: "Blog intégré", presence: false, visibilite: true, autorite: true },
  { feature: "Articles rédigés", presence: "—", visibilite: "5 articles", autorite: "Mensuel" },
  { feature: "Recherche mots-clés", presence: false, visibilite: true, autorite: true },
  { feature: "Suivi Search Console", presence: false, visibilite: true, autorite: true },
  { feature: "Suivi post-livraison", presence: "—", visibilite: "3 mois", autorite: "6-12 mois" },
  { feature: "Formation", presence: "1h", visibilite: "2h", autorite: "Sur mesure" },
  { feature: "Automatisations", presence: false, visibilite: false, autorite: true },
  { feature: "Support prioritaire", presence: false, visibilite: false, autorite: true },
];

// FAQ data
const faqs = [
  {
    question: "Quels sont les délais de livraison ?",
    answer: "Le pack Présence est livré en 2-3 semaines. Le pack Visibilité en 4-8 semaines (incluant la rédaction des 5 articles). Pour le pack Autorité, le planning est défini ensemble selon la complexité du projet.",
  },
  {
    question: "Est-ce que le référencement est inclus dans tous les packs ?",
    answer: "Oui. Chaque pack inclut une optimisation technique de référencement de base (balises, vitesse, mobile, schema). Les packs Visibilité et Autorité ajoutent une stratégie de contenu et un suivi des positions Google via Search Console.",
  },
  {
    question: "Qu'est-ce qui n'est PAS inclus ?",
    answer: "L'hébergement (environ 10-20 CHF/mois), le nom de domaine (environ 15 CHF/an), et les abonnements à des outils tiers (newsletter, CRM). Je vous guide dans les choix.",
  },
  {
    question: "Et si j'ai besoin de modifications après la livraison ?",
    answer: "Le pack Visibilité inclut 3 mois de suivi avec modifications mineures. Pour les autres packs, je propose une maintenance à 90 CHF/h ou un forfait mensuel adapté à vos besoins.",
  },
  {
    question: "Vous travaillez avec quelles technologies ?",
    answer: "Principalement Astro et Framer pour les sites vitrines (rapides, optimisés référencement). Pour les projets plus complexes : React, SvelteKit, ou la stack adaptée à votre besoin.",
  },
  {
    question: "Comment se passe le paiement ?",
    answer: "50% à la signature du devis, 50% à la livraison. Pour le pack Autorité, un échéancier sur mesure est proposé selon la durée du projet.",
  },
  {
    question: "Pourquoi vos tarifs sont moins chers qu'une agence à Genève ?",
    answer: "Une agence web à Genève facture en moyenne 8'000 à 15'000 CHF pour un site équivalent à mon pack Visibilité (2'490 CHF). La différence : pas de locaux à payer, pas de commerciaux, pas de chef de projet entre vous et le développeur. Vous parlez directement à la personne qui code. Le tarif finance le travail, pas la structure. Pour les projets très volumineux qui demandent plusieurs profils en parallèle (design, dev, marketing, ops), l'agence reste pertinente.",
  },
  {
    question: "Y a-t-il un contrat d'engagement de 12 mois ?",
    answer: "Non. Les packs Présence et Visibilité sont des forfaits one-shot, sans abonnement. Pour le pack Autorité avec suivi mensuel, le mensuel est résiliable avec 1 mois de préavis. Je ne crois pas aux engagements 12 mois fermes : si le travail est sérieux, vous n'aurez pas envie de partir. Si vous partez, j'ai mal fait mon job.",
  },
];
---

<Layout
  title={pageTitle}
  description={pageDescription}
  schemas={schemas}
>
  <Header />

  <main class="co-root">

    <!-- ══ INTRO ══ -->
    <section class="co-sec co-pad" style="padding:64px 40px 40px;">
      <h1 style="font-size:clamp(2.2rem,5.5vw,3.5rem);margin-top:14px;" data-animate data-delay="0.1">
        Tarifs freelance — site web &amp; <span class="co-ser">référencement à Genève.</span>
      </h1>
      <p class="co-mut" style="margin-top:16px;max-width:60ch;line-height:1.65;font-size:1.05rem;" data-animate data-delay="0.2">
        Des packages clairs combinant création de site web et référencement local.
        Tarif fixe, pas de contrat 12 mois, pas de marge cachée d'agence. Vous savez ce que vous payez.
      </p>
      <div style="margin-top:26px;" data-animate data-delay="0.3">
        <a href="#packages" class="co-btn co-btn--ghost">Voir les packages <i class="ri-arrow-down-line"></i></a>
      </div>
    </section>

    <!-- ══ 01 · PACKAGES ══ -->
    <section id="packages" class="co-sec co-pad" style="padding:var(--sec-pad-y) var(--sec-pad-x);scroll-margin-top:80px;">
      <p class="co-eyebrow">01 — Offre</p>
      <h2 style="margin-top:var(--space-eyebrow);">Choisissez votre package</h2>
      <p class="co-mut" style="margin-top:var(--space-eyebrow);max-width:52ch;">Site web + référencement local. Tout inclus, prix fixe.</p>

      <div class="tr-grid" data-animate-stagger>
        {packages.map((plan) => (
          <div class={`tr-tier co-frame${plan.highlighted ? " tr-tier--reco" : ""}`} data-animate-item>
            {plan.highlighted && <span class="co-badge co-badge--solid tr-reco">Recommandé</span>}
            <div class="tr-tier-head">
              <p class="co-eyebrow tr-tier-name">{plan.name}</p>
              <p class="co-mut tr-tier-sub">{plan.subtitle}</p>
            </div>
            <div class="tr-price">
              <b>{plan.price}</b>
              {plan.price !== "Sur devis" && <span>CHF</span>}
            </div>
            <ul class="tr-features co-list co-list--check">
              {plan.features.map((feature) => (
                <li><i class="ri-check-line" aria-hidden="true"></i><span>{feature}</span></li>
              ))}
            </ul>
            <dl class="co-spec tr-spec">
              <div class="co-spec-row"><dt>Idéal pour</dt><dd>{plan.ideal}</dd></div>
              <div class="co-spec-row"><dt>Délai</dt><dd>{plan.delay}</dd></div>
            </dl>
            <a href="/contact" class={`co-btn tr-tier-cta${plan.highlighted ? "" : " co-btn--ghost"}`}>
              {plan.cta}
              <i class="ri-arrow-right-line"></i>
            </a>
          </div>
        ))}
      </div>

      <!-- Bon à savoir -->
      <div class="tr-notes co-frame" data-animate>
        <span class="co-x tl"></span><span class="co-x tr"></span>
        <span class="co-x bl"></span><span class="co-x br"></span>
        <p class="co-eyebrow tr-notes-title">Bon à savoir</p>
        <div class="tr-notes-grid">
          <ul class="co-list">
            <li>Paiement : 50% à la commande, 50% à la livraison</li>
            <li>Hébergement et domaine non inclus (~30 CHF/an)</li>
            <li>Pas de contrat 12 mois — engagement projet par projet</li>
          </ul>
          <ul class="co-list">
            <li>Chaque projet commence par un appel découverte gratuit</li>
            <li>Tous les prix sont en CHF, HT (exonéré TVA)</li>
            <li>Service détaillé : <a href="/services/referencement-local" class="tr-inline">page référencement local</a></li>
          </ul>
        </div>
      </div>
    </section>

    <!-- ══ 02 · INCLUSIONS ══ -->
    <section class="co-sec co-pad" style="padding:var(--sec-pad-y) var(--sec-pad-x);">
      <p class="co-eyebrow">02 — Comparatif</p>
      <h2 style="margin-top:var(--space-eyebrow);">Ce qui est inclus</h2>
      <p class="co-mut" style="margin-top:var(--space-eyebrow);max-width:52ch;">Comparaison détaillée des 3 packages.</p>

      <div class="tr-table-wrap" data-animate>
        <table class="tr-table">
          <thead>
            <tr>
              <th>Fonctionnalité</th>
              <th>Présence</th>
              <th class="tr-col-reco">Visibilité</th>
              <th>Autorité</th>
            </tr>
          </thead>
          <tbody>
            {inclusions.map((row) => (
              <tr>
                <td class="tr-cell-feat">{row.feature}</td>
                {[row.presence, row.visibilite, row.autorite].map((val, colIdx) => (
                  <td class={colIdx === 1 ? "tr-col-reco" : ""}>
                    {typeof val === 'boolean'
                      ? (val
                        ? <i class="ri-check-line tr-yes" aria-hidden="true"></i>
                        : <i class="ri-close-line tr-no" aria-hidden="true"></i>)
                      : <span>{val}</span>
                    }
                  </td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- ══ 03 · FAQ (accordéon natif, zéro JS) ══ -->
    <section class="co-sec co-pad" style="padding:var(--sec-pad-y) var(--sec-pad-x);">
      <p class="co-eyebrow">03 — FAQ</p>
      <h2 style="margin-top:var(--space-eyebrow);">Questions fréquentes</h2>
      <p class="co-mut" style="margin-top:var(--space-eyebrow);max-width:52ch;">Les réponses aux questions que vous vous posez sûrement.</p>

      <div class="tr-faq" style="margin-top:var(--space-block);">
        {faqs.map((item, i) => (
          <details open={i === 0}>
            <summary>
              {item.question}
              <i class="ri-arrow-down-s-line" aria-hidden="true"></i>
            </summary>
            <p class="tr-faq-answer">{item.answer}</p>
          </details>
        ))}
      </div>
    </section>

    <!-- ══ 04 · RESSOURCES ══ -->
    <section class="co-sec co-pad" style="padding:var(--sec-pad-y) var(--sec-pad-x) 64px;">
      <p class="co-eyebrow">04 — Ressources</p>
      <h2 style="margin-top:var(--space-eyebrow);">Aller <span class="co-ser">plus loin.</span></h2>
      <p class="co-mut" style="margin-top:var(--space-title-lead);max-width:56ch;line-height:1.6;">
        Quelques articles pour creuser le sujet avant de te décider.
      </p>

      <div class="tr-res-grid" data-animate-stagger>
        <a href="/blog/prix-site-web-suisse-2026" class="tr-res-card co-frame co-frame--reveal" data-animate-item>
          <h3 class="tr-res-title">Combien coûte vraiment un site web en Suisse en 2026 ?</h3>
          <p class="tr-res-teaser">Un guide transparent des fourchettes en CHF, par type de projet et par profil de prestataire.</p>
          <span class="tr-res-cta">Lire l'article <i class="ri-arrow-right-line"></i></span>
        </a>

        <a href="/blog/specialiste-developpement-web-suisse" class="tr-res-card co-frame co-frame--reveal" data-animate-item>
          <h3 class="tr-res-title">Spécialiste développement web Suisse : comment bien choisir</h3>
          <p class="tr-res-teaser">Freelance vs agence, 5 critères concrets pour choisir le bon prestataire en Suisse romande.</p>
          <span class="tr-res-cta">Lire l'article <i class="ri-arrow-right-line"></i></span>
        </a>

        <a href="/blog/freelance-ou-agence-web" class="tr-res-card co-frame co-frame--reveal" data-animate-item>
          <h3 class="tr-res-title">Freelance ou agence web ? Le comparatif honnête</h3>
          <p class="tr-res-teaser">Tableau décisionnel et critères clairs pour trancher selon ton budget et ton projet.</p>
          <span class="tr-res-cta">Lire l'article <i class="ri-arrow-right-line"></i></span>
        </a>
      </div>
    </section>

    <!-- ══ 05 · CTA FINAL (primitive .co-cta) ══ -->
    <section class="co-cta">
      <span class="co-x tl"></span><span class="co-x tr"></span>
      <div class="co-cta-inner">
        <h2 class="co-cta-title">Prêt à lancer votre <span class="co-ser">projet ?</span></h2>
        <p class="co-cta-lead">Discutons de votre besoin. Premier appel découverte gratuit et sans engagement.</p>
        <div class="co-cta-btns">
          <a href="/contact" class="co-btn co-cta-btn">Prendre rendez-vous <i class="ri-calendar-line"></i></a>
        </div>
        <div class="co-cta-trust">
          <span><i class="ri-time-line"></i> Réponse sous 48 h</span>
          <span><i class="ri-file-list-3-line"></i> Devis gratuit</span>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style is:global>
  /* ══ TARIFS — styles .tr-* (namespace scopé, corps .co-root) ══ */

  /* ── Packages ── */
  .tr-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; align-items: start; margin-top: 40px; }
  .tr-tier {
    position: relative; display: flex; flex-direction: column; gap: 20px;
    padding: 32px 28px; background: var(--surface); border: 1px solid var(--line-2);
  }
  .tr-tier--reco { border-color: var(--accent); box-shadow: 0 0 0 1px var(--accent); }
  .tr-reco { position: absolute; top: -12px; left: 28px; z-index: 4; }
  .tr-tier-name { color: var(--ink); }
  .co-root .tr-tier-sub { margin-top: 6px; font-size: 14px; }
  .tr-price { display: flex; align-items: baseline; gap: 6px; }
  .tr-price b { font-size: 2.5rem; font-weight: 700; letter-spacing: -0.03em; line-height: 1; }
  .tr-price span { font-size: 14px; color: var(--muted); }
  .tr-features { gap: 11px; }
  .tr-features li { font-size: 14px; line-height: 1.45; }
  .tr-spec { margin-top: auto; }
  .tr-tier-cta { justify-content: center; }
  .tr-tier-cta i { transition: transform .18s ease-out; }
  .tr-tier-cta:hover i { transform: translateX(3px); }

  /* ── Bon à savoir ── */
  .tr-notes { position: relative; margin-top: 40px; padding: 32px; background: var(--surface); border: 1px solid var(--line-2); }
  .co-root .tr-notes-title { color: var(--ink); }
  .tr-notes-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px 40px; margin-top: 18px; }
  .tr-notes-grid .co-list li { font-size: 14px; }
  .tr-inline { color: var(--accent); text-decoration: underline; text-underline-offset: 2px; }
  .tr-inline:hover { color: var(--ink); }

  /* ── Table comparatif ── */
  .tr-table-wrap { margin-top: var(--space-block); overflow-x: auto; border: 1px solid var(--line-2); }
  .tr-table { width: 100%; border-collapse: collapse; font-size: 14px; background: var(--surface); }
  .tr-table th, .tr-table td { padding: 14px 16px; text-align: center; border-bottom: 1px solid var(--line); }
  .tr-table thead th { font-size: 12px; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: var(--muted); border-bottom: 1px solid var(--line-2); white-space: nowrap; }
  .tr-table th:first-child, .tr-table .tr-cell-feat { text-align: left; }
  .tr-cell-feat { font-weight: 500; color: var(--ink); }
  .tr-table tbody tr:last-child td { border-bottom: 0; }
  .tr-col-reco { background: rgba(0, 168, 125, 0.05); }
  .tr-table thead .tr-col-reco { color: var(--accent); }
  .tr-yes { color: var(--accent); font-size: 18px; }
  .tr-no { color: var(--line-2); font-size: 18px; }

