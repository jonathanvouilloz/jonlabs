---
import "../styles/global.css";
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { getWebPageSchema, getBreadcrumbSchema, getFAQPageSchema, getServiceItemSchema } from "../lib/seo";
import { SITE_URL, localBusinessData } from "../data/schema";

// ============================================
// SEO META
// ============================================
const pageUrl = `${SITE_URL}/hermes`;
const pageTitle = "Hermès — agent IA pour PME romandes | Jon Labs";
const metaDescription = "Hermès : agent IA prêt à déployer pour ta PME romande. Tri d'e-mails, relances, préparation de documents. Prix CHF affichés, cadrage rapide, conformité nLPD.";

// ============================================
// FAQ (locale)
// ============================================
const faqs = [
  {
    question: "Hermès, c'est un produit fini ou un développement sur mesure ?",
    answer: "Les deux à la fois. Hermès est un agent IA que j'ai déjà éprouvé sur des tâches concrètes de PME (tri d'e-mails, relances, préparation de documents). On part de cette base éprouvée, puis on le branche sur tes outils et tes process. Tu ne payes pas six mois de R&D : tu récupères un agent qui tourne, adapté à ton contexte."
  },
  {
    question: "Combien ça coûte, concrètement ?",
    answer: "Un cadrage + un agent simple part de CHF 2'500 à 4'000 selon le nombre de tâches. Un agent métier intégré à plusieurs outils (CRM, boîte mail, facturation) se situe entre CHF 6'000 et 15'000. À cela s'ajoute un coût récurrent de CHF 50 à 150 par mois (hébergement + API du modèle de langage). Tout est affiché sur cette page, sans devis-surprise."
  },
  {
    question: "Combien de temps avant que l'agent tourne ?",
    answer: "Compte deux à trois semaines entre le cadrage et un premier agent en production sur une tâche précise. Pas un chantier de six mois : on vise un résultat mesurable rapidement, puis on élargit le périmètre si ça vaut le coup."
  },
  {
    question: "Est-ce que l'agent va envoyer des choses tout seul à mes clients ?",
    answer: "Seulement si tu le décides. Par défaut, sur tout ce qui a un enjeu (e-mails clients, devis, relances), l'agent prépare et tu valides avant l'envoi. La validation humaine est un garde-fou câblé dès la configuration, pas une option qu'on ajoute après coup."
  },
  {
    question: "Mes données restent-elles en Suisse et conformes nLPD ?",
    answer: "On cadre dès le départ ce qui sort de chez toi et ce qui reste. Hébergement conforme, minimisation des données envoyées au modèle, et documentation de ce qui transite. Je travaille depuis Genève et je connais les contraintes des PME romandes sur ce point."
  },
  {
    question: "Quelle différence avec le guide gratuit sur Hermès ?",
    answer: "Le guide explique ce qu'est l'agent, ce qu'il fait et ce qu'il coûte si tu l'installes toi-même. Cette page-ci, c'est l'offre : je m'occupe du cadrage, de l'intégration, des garde-fous et de la prise en main pour que tu n'aies pas à devenir technique. Le guide informe, l'offre livre."
  }
];

// ============================================
// SCHEMA.ORG
// ============================================
const webPageSchema = getWebPageSchema({
  url: pageUrl,
  name: pageTitle,
  description: metaDescription
});

const breadcrumbSchema = getBreadcrumbSchema([
  { name: "Accueil", url: SITE_URL },
  { name: "Consultant IA", url: `${SITE_URL}/consultant-ia` },
  { name: "Hermès", url: pageUrl }
]);

const faqSchema = getFAQPageSchema(faqs);
const serviceSchema = getServiceItemSchema("hermes");

const schemas = [
  webPageSchema,
  breadcrumbSchema,
  faqSchema,
  ...(serviceSchema ? [serviceSchema] : []),
  localBusinessData
];

// ============================================
// TRUST LINE (hero)
// ============================================
const preuvesHero = ["Basé à Genève", "Prix en CHF", "Conforme nLPD"];

// ============================================
// CE QUE FAIT HERMÈS (capacités)
// ============================================
const capacites = [
  {
    icon: "ri-mail-settings-line",
    titre: "Tri et priorisation des e-mails",
    description: "Il lit ta boîte de réception, repère ce qui est prioritaire et prépare des réponses contextualisées en tenant compte de l'historique. Tu gardes la main sur l'envoi."
  },
  {
    icon: "ri-mail-send-line",
    titre: "Relances clients autonomes",
    description: "Il suit l'état de tes devis ouverts et génère des relances personnalisées selon le contexte (date de l'offre, montant, historique). Zéro devis oublié."
  },
  {
    icon: "ri-file-text-line",
    titre: "Préparation de documents",
    description: "À partir du contexte d'un prospect et de tes offres, il structure une proposition commerciale en quelques minutes. Un premier draft au lieu d'une page blanche."
  },
  {
    icon: "ri-customer-service-2-line",
    titre: "Réponses de premier niveau",
    description: "Il traite les demandes récurrentes et les questions simples, et fait remonter à toi ce qui demande un vrai jugement. Ton temps va où il compte."
  },
  {
    icon: "ri-search-eye-line",
    titre: "Veille continue",
    description: "Il surveille l'activité de tes concurrents ou de ton marché et t'envoie un résumé prêt à lire chaque semaine. 2 à 3 heures récupérées sur la veille manuelle."
  },
  {
    icon: "ri-plug-line",
    titre: "Intégration à tes outils",
    description: "On le branche sur ce que tu utilises déjà (boîte mail, CRM, facturation) plutôt que de tout remplacer. La mémoire persistante lui évite de repartir de zéro à chaque fois."
  }
];

// ============================================
// CAS D'USAGE CONCRETS
// ============================================
const casUsage = [
  {
    icon: "ri-scales-3-line",
    secteur: "Fiduciaire à Lausanne",
    description: "Relances automatiques des pièces manquantes avant les décomptes, avec un résumé hebdomadaire des dossiers en retard. Le collaborateur valide, l'agent rédige."
  },
  {
    icon: "ri-megaphone-line",
    secteur: "Agence de communication à Genève",
    description: "Veille concurrentielle sur cinq comptes clients et pré-rédaction des propositions commerciales. Le premier draft passe d'une heure à dix minutes."
  },
  {
    icon: "ri-building-line",
    secteur: "Régie immobilière",
    description: "Tri des e-mails entrants par urgence et préparation des réponses de premier niveau aux locataires. Les cas sensibles remontent directement au gestionnaire."
  },
  {
    icon: "ri-store-2-line",
    secteur: "PME de services (5-15 personnes)",
    description: "Suivi des devis ouverts et relances contextualisées selon l'historique client. Le dirigeant approuve avant chaque envoi, rien ne part sans son feu vert."
  }
];

// ============================================
// L'OFFRE — grille de prix CHF
// ============================================
const paliers = [
  {
    nom: "Cadrage + agent simple",
    prix: "CHF 2'500 – 4'000",
    tag: "Pour démarrer",
    highlight: false,
    pour: "Une tâche précise qui te mange du temps chaque semaine.",
    inclus: [
      "Audit de tes process et repérage de la tâche à automatiser",
      "Un agent branché sur un outil (boîte mail ou CRM)",
      "Garde-fous et validation humaine sur les envois",
      "Prise en main de ton équipe"
    ]
  },
  {
    nom: "Agent métier intégré",
    prix: "CHF 6'000 – 15'000",
    tag: "Le plus demandé",
    highlight: true,
    pour: "Plusieurs tâches et plusieurs outils à connecter.",
    inclus: [
      "Agent multi-tâches connecté à tes outils (CRM, mail, facturation)",
      "Enchaînements automatiques et mémoire persistante",
      "Cadrage nLPD : ce qui sort, ce qui reste chez toi",
      "Tests en conditions réelles avant mise en production",
      "Formation et documentation pour piloter en autonomie"
    ]
  },
  {
    nom: "Fonctionnement mensuel",
    prix: "CHF 50 – 150 / mois",
    tag: "Récurrent",
    highlight: false,
    pour: "Ce que coûte l'agent une fois en route.",
    inclus: [
      "Hébergement de l'agent (VPS ou serveur)",
      "API du modèle de langage, facturée à l'usage",
      "Fourchette basse pour un volume PME classique",
      "Sans engagement de durée"
    ]
  }
];

// ============================================
// COMMENT ÇA SE PASSE — étapes
// ============================================
const etapes = [
  {
    step: "01",
    title: "Cadrage",
    description: "On regarde tes process réels et on repère les 2-3 tâches qui pèsent le plus. Je te dis franchement où Hermès aide et où il n'apporte rien. Pas de promesse en l'air."
  },
  {
    step: "02",
    title: "Intégration",
    description: "Je branche l'agent sur tes outils et je le configure sur la première tâche. Un résultat en production en deux à trois semaines, pas un chantier interminable."
  },
  {
    step: "03",
    title: "Garde-fous",
    description: "Validation humaine sur ce qui l'exige, cadrage des données (ce qui sort, ce qui reste chez toi), hébergement conforme nLPD. L'agent ne décide pas à ta place."
  },
  {
    step: "04",
    title: "Prise en main",
    description: "Je forme ton équipe à l'usage quotidien. L'objectif n'est jamais de te rendre dépendant : c'est de te donner un outil qui tourne et que tu pilotes."
  }
];

// ============================================
// MAILLAGE
// ============================================
const liens = [
  {
    icon: "ri-brain-line",
    title: "Consultant IA (hub)",
    description: "La page de référence sur le conseil IA pour PME romandes : méthode, types d'agents, conformité et tarifs.",
    href: "/consultant-ia",
    cta: "Découvrir"
  },
  {
    icon: "ri-book-open-line",
    title: "Le guide complet sur Hermès",
    description: "Ce qu'est l'agent, ce qu'il fait, ses limites et ce qu'il coûte si tu l'installes toi-même. Le regard terrain, sans hype.",
    href: "/blog/hermes-agent-ia-pme",
    cta: "Lire le guide"
  },
  {
    icon: "ri-terminal-box-line",
    title: "OpenClaw pour PME",
    description: "L'autre agent IA open source, orienté usage individuel et mobile. Comparaison honnête avec Hermès.",
    href: "/blog/openclaw-pme-suisse",
    cta: "Lire l'article"
  },
  {
    icon: "ri-flow-chart",
    title: "Workflows vs agents IA",
    description: "Quand un simple automatisme suffit, et quand il faut vraiment un agent qui raisonne. Pour choisir juste.",
    href: "/blog/workflows-vs-agents-ia-pme",
    cta: "Lire l'article"
  }
];
---

<Layout
  title={pageTitle}
  description={metaDescription}
  schemas={schemas}
>
  <Header />

  <main class="co-root">

    <!-- ══ HERO ══ -->
    <section class="co-sec co-pad hm-hero">
      <div class="co-guides"></div>
      <div class="hm-hero-inner">
        <div class="hm-hero-badges" data-animate>
          <span class="co-badge">Disponible</span>
          <span class="co-badge"><i class="ri-robot-2-line" aria-hidden="true"></i> Agent IA · prêt à déployer</span>
        </div>
        <h1 class="hm-hero-title" data-animate data-delay="0.1">Hermès</h1>
        <p class="hm-hero-lead" data-animate data-delay="0.2">
          L'agent IA qui prend en charge tes tâches répétitives — tri d'e-mails, relances,
          préparation de documents — et te rend le temps que tu passes à les faire à la main.
        </p>
        <div class="hm-hero-ctas" data-animate data-delay="0.3">
          <a href="/contact" class="co-btn"><i class="ri-calendar-check-line" aria-hidden="true"></i> Cadrer mon déploiement</a>
          <a href="/blog/hermes-agent-ia-pme" class="co-btn co-btn--ghost">Lire le guide complet <i class="ri-arrow-right-line" aria-hidden="true"></i></a>
        </div>
        <div class="hm-hero-trust" data-animate data-delay="0.4">
          {preuvesHero.map((p) => (
            <span class="hm-hero-proof"><i class="ri-checkbox-circle-line" aria-hidden="true"></i>{p}</span>
          ))}
        </div>
      </div>
    </section>

    <!-- ══ 01 · CE QUE FAIT HERMÈS ══ -->
    <section class="co-sec co-pad hm-sec">
      <div class="hm-head">
        <p class="co-eyebrow" data-animate>01 — Capacités</p>
        <h2 class="hm-h2" data-animate data-delay="0.1">Ce que fait <span class="co-ser">Hermès.</span></h2>
        <p class="co-mut hm-lead" data-animate data-delay="0.15">
          Pas une démo de labo. Des tâches réelles de PME, avec la validation humaine là où elle compte.
        </p>
      </div>

      <div class="hm-grid hm-grid--3" data-animate-stagger>
        {capacites.map((cap) => (
          <div class="hm-cap co-frame co-frame--reveal" data-animate-item>
            <div class="hm-cap-icon"><i class={cap.icon} aria-hidden="true"></i></div>
            <h3 class="hm-cap-title">{cap.titre}</h3>
            <p class="co-mut hm-cap-desc">{cap.description}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- ══ 02 · CAS D'USAGE ══ -->
    <section class="co-sec co-pad hm-sec">
      <div class="hm-head">
        <p class="co-eyebrow" data-animate>02 — Sur le terrain</p>
        <h2 class="hm-h2" data-animate data-delay="0.1">Des exemples <span class="co-ser">de PME romande.</span></h2>
        <p class="co-mut hm-lead" data-animate data-delay="0.15">
          Voici à quoi ressemble Hermès une fois branché sur un vrai métier.
        </p>
      </div>

      <div class="hm-grid hm-grid--2" data-animate-stagger>
        {casUsage.map((cas) => (
          <div class="hm-cas co-frame" data-animate-item>
            <div class="hm-cas-icon"><i class={cas.icon} aria-hidden="true"></i></div>
            <div class="hm-cas-body">
              <h3 class="hm-cas-title">{cas.secteur}</h3>
              <p class="co-mut hm-cas-desc">{cas.description}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ══ 03 · L'OFFRE — grille de prix CHF ══ -->
    <section class="co-sec co-pad hm-sec" id="offre">
      <div class="hm-head">
        <p class="co-eyebrow" data-animate>03 — L'offre</p>
        <h2 class="hm-h2" data-animate data-delay="0.1">Des <span class="co-ser">prix affichés</span>, en CHF.</h2>
        <p class="co-mut hm-lead" data-animate data-delay="0.15">
          Pas de devis-mystère à réclamer par e-mail. Tu vois les fourchettes, le format de cadrage
          et le délai avant de me contacter.
        </p>
      </div>

      <div class="hm-paliers" data-animate-stagger>
        {paliers.map((palier) => (
          <div class={`hm-palier co-frame ${palier.highlight ? "hm-palier--hot" : ""}`} data-animate-item>
            <span class={palier.highlight ? "co-badge co-badge--solid" : "co-badge"}>{palier.tag}</span>
            <h3 class="hm-palier-nom">{palier.nom}</h3>
            <p class="co-mut hm-palier-pour">{palier.pour}</p>
            <div class="hm-palier-prix">{palier.prix}</div>
            <ul class="co-list co-list--check hm-palier-inclus">
              {palier.inclus.map((item) => (
                <li><i class="ri-check-line" aria-hidden="true"></i><span>{item}</span></li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <div class="hm-delai co-frame" data-animate>
        <div class="hm-delai-icon"><i class="ri-timer-flash-line" aria-hidden="true"></i></div>
        <div class="hm-delai-body">
          <h3 class="hm-delai-title">Délai de déploiement : 2 à 3 semaines</h3>
          <p class="co-mut hm-delai-text">
            Entre le cadrage et un premier agent en production sur une tâche précise. On élargit
            ensuite le périmètre seulement si le gain le justifie.
          </p>
        </div>
        <a href="/contact" class="co-btn hm-delai-cta">
          <i class="ri-calendar-check-line" aria-hidden="true"></i> Cadrer mon déploiement
        </a>
      </div>
    </section>

    <!-- ══ 04 · COMMENT ÇA SE PASSE ══ -->
    <section class="co-sec co-pad hm-sec">
      <div class="hm-head">
        <p class="co-eyebrow" data-animate>04 — Méthode</p>
        <h2 class="hm-h2" data-animate data-delay="0.1">Comment <span class="co-ser">ça se passe.</span></h2>
        <p class="co-mut hm-lead" data-animate data-delay="0.15">
          Une méthode qui part de tes process réels et garde l'humain aux commandes.
        </p>
      </div>

      <div class="co-grid-cells hm-etapes" data-animate-stagger>
        {etapes.map((e) => (
          <div class="hm-etape" data-animate-item>
            <span class="co-index hm-etape-num">{e.step}</span>
            <h3 class="hm-etape-title">{e.title}</h3>
            <p class="co-mut hm-etape-desc">{e.description}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- ══ 05 · FAQ ══ -->
    <section class="co-sec co-pad hm-sec">
      <div class="hm-head">
        <p class="co-eyebrow" data-animate>05 — FAQ</p>
        <h2 class="hm-h2" data-animate data-delay="0.1">Questions <span class="co-ser">fréquentes.</span></h2>
        <p class="co-mut hm-lead" data-animate data-delay="0.15">
          Ce qu'on me demande avant de déployer Hermès.
        </p>
      </div>

      <div class="hm-faq" data-animate-stagger>
        {faqs.map((faq, index) => (
          <div class="hm-faq-item" data-faq-item data-animate-item>
            <button class="hm-faq-trigger" aria-expanded="false" data-faq-trigger>
              <span class="hm-faq-q">
                <span class="co-index hm-faq-num">{String(index + 1).padStart(2, '0')}</span>
                <span>{faq.question}</span>
              </span>
              <span class="hm-faq-icon"><i class="ri-add-line" aria-hidden="true"></i></span>
            </button>
            <div class="hm-faq-content" style="max-height: 0;" data-faq-content>
              <div class="hm-faq-answer"><p class="co-mut">{faq.answer}</p></div>
            </div>
          </div>
        ))}
      </div>

      <p class="co-mut hm-faq-foot">
        Une autre question ? <a href="/contact" class="hm-inline">Écris-moi</a>, je réponds sous 24h.
      </p>
    </section>

    <!-- ══ 06 · MAILLAGE ══ -->
    <section class="co-sec co-pad hm-sec">
      <div class="hm-head">
        <p class="co-eyebrow" data-animate>06 — Aller plus loin</p>
        <h2 class="hm-h2" data-animate data-delay="0.1">Pour creuser le <span class="co-ser">sujet.</span></h2>
      </div>

      <div class="hm-grid hm-grid--2" data-animate-stagger>
        {liens.map((lien) => (
          <a href={lien.href} class="hm-lien co-frame co-frame--reveal" data-animate-item>
            <div class="hm-lien-icon"><i class={lien.icon} aria-hidden="true"></i></div>
            <h3 class="hm-lien-title">{lien.title}</h3>
            <p class="co-mut hm-lien-desc">{lien.description}</p>
            <span class="hm-lien-cta">{lien.cta} <i class="ri-arrow-right-line" aria-hidden="true"></i></span>
          </a>
        ))}
      </div>
    </section>

    <!-- ══ 07 · CTA FINAL (primitive .co-cta) ══ -->
    <section class="co-cta">
      <span class="co-x tl"></span><span class="co-x tr"></span>
      <div class="co-cta-inner">
        <p class="co-cta-eyebrow">Prêt ?</p>
        <h2 class="co-cta-title">On regarde ensemble ce qu'Hermès peut <span class="co-ser">t'enlever.</span></h2>
        <p class="co-cta-lead">
          Premier échange gratuit, sans engagement. On identifie les 2-3 tâches qui te mangent le
          plus de temps, et je te dis franchement si Hermès y répond. Réponse sous 24h.
        </p>
        <div class="co-cta-btns">
          <a href="/contact" class="co-btn co-cta-btn"><i class="ri-calendar-check-line" aria-hidden="true"></i> Cadrer mon déploiement</a>
          <a href="mailto:hello@jonlabs.ch" class="co-btn co-cta-btn co-cta-btn--ghost"><i class="ri-mail-line" aria-hidden="true"></i> hello@jonlabs.ch</a>
        </div>
        <div class="co-cta-trust">
          <span><i class="ri-time-line" aria-hidden="true"></i> Réponse sous 24h</span>
          <span><i class="ri-calendar-line" aria-hidden="true"></i> Lun-Ven, 9h-18h (CET)</span>
          <span><i class="ri-money-franc-circle-line" aria-hidden="true"></i> Facturation en CHF</span>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style is:global>
  /* ══ HERMÈS — styles .hm-* (namespace scopé sous .co-root) ══ */

  .co-root section[id] { scroll-margin-top: 100px; }

  /* ── En-tête de section commun ── */
  .hm-sec { padding: 64px 40px; }
  .hm-head { max-width: 62ch; }
  .hm-h2 { font-size: clamp(1.8rem, 4vw, 2.6rem); margin-top: 10px; }
  .co-root .hm-lead { margin-top: 14px; font-size: 1.05rem; line-height: 1.65; max-width: 52ch; }

  /* ── Grilles ── */
  .hm-grid { display: grid; gap: 16px; margin-top: 44px; }
  .hm-grid--3 { grid-template-columns: repeat(3, 1fr); }
  .hm-grid--2 { grid-template-columns: repeat(2, 1fr); }

  /* ── Hero ── */
  .hm-hero { position: relative; overflow: hidden; }
  .hm-hero-inner {
    position: relative; display: flex; flex-direction: column; align-items: flex-start;
    gap: 22px; padding: 76px 40px 68px; max-width: 44ch;
  }
  .hm-hero-badges { display: flex; flex-wrap: wrap; gap: 10px; }
  .hm-hero-badges .co-badge i { font-size: 13px; }
  .hm-hero-title { font-size: clamp(2.8rem, 8vw, 4.4rem); letter-spacing: -0.03em; }
  .hm-hero-lead { font-size: clamp(1.1rem, 2.2vw, 1.35rem); line-height: 1.5; color: var(--ink); max-width: 40ch; }
  .hm-hero-ctas { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 4px; }
  .hm-hero-ctas .co-btn i { transition: transform .18s ease-out; }
  .hm-hero-ctas .co-btn:hover i { transform: translateX(3px); }
  .hm-hero-trust {
    display: flex; flex-wrap: wrap; gap: 10px 22px; margin-top: 8px; padding-top: 22px;
    border-top: 1px solid var(--line); width: 100%; font-size: 14px; color: var(--muted);
  }
  .hm-hero-proof { display: inline-flex; align-items: center; gap: 7px; }
  .hm-hero-proof i { color: var(--accent); font-size: 16px; }

  /* ── Capacités ── */
  .hm-cap {
    position: relative; display: flex; flex-direction: column; gap: 12px; padding: 24px;
    background: var(--surface); border: 1px solid var(--line-2);
