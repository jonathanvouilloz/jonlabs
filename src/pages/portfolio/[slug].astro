---
// Détail d'étude de cas / side-project — page programmatique portfolio (blueprint).
// Migrée du brutaliste vers le design system .co-* : colonne de lecture cadrée filets,
// accent teal unique, Inter Tight × Instrument Serif. Namespace scopé .psl-*.
// Le corps markdown rendu (<Content />) est enveloppé dans la primitive .co-prose.
//
// HARD-PRESERVE :
//  - getStaticPaths() intact + getCollection('portfolio', ({data}) => !data.draft)
//    (signature + filtre draft + tri fallback « projets similaires » inchangés).
//  - Rendu du corps markdown (entry.render() → <Content />) — juste wrappé .co-prose.
//  - Schema.org caseStudySchema (branche about via client Organization), tableau schemas,
//    injection Layout schemas={schemas} — data + logique + ordre.
//  - Tous les bindings dynamiques de l'entrée (titre, client, projet, résultats, contexte,
//    approche, images, tags, testimonial, learnings, liveUrl…) — rien en dur.
//  - seoData dynamique (pageTitle/pageDescription), deep-links internes (/portfolio,
//    serviceLink, related), liens externes du projet (liveUrl, client.website).
//  - inlineLinks() sur les champs éditoriaux, lightbox (JS + classes .gallery-img/.lightbox).
//  - Import global.css gardé. CTASection remplacé par .co-cta inline (composant non touché).

import '../../styles/global.css';
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_URL } from '../../data/schema';
import { inlineLinks } from '../../lib/markdown';
import { portfolioServiceLinks } from '../../data/portfolio-relations';

export async function getStaticPaths() {
  const portfolioEntries = await getCollection('portfolio', ({ data }) => !data.draft);
  // Tri par date décroissante : sert de fallback pour « Projets similaires »
  const sorted = [...portfolioEntries].sort(
    (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
  );

  return portfolioEntries.map(entry => {
    const others = sorted.filter(e => e.slug !== entry.slug);
    // Priorité : même project.category ; complété par les plus récents si < 2
    const sameCategory = others.filter(
      e => e.data.project?.category === entry.data.project?.category
    );
    const relatedEntries = [
      ...sameCategory,
      ...others.filter(e => !sameCategory.includes(e)),
    ].slice(0, 2);

    return {
      params: { slug: entry.slug },
      props: { entry, relatedEntries },
    };
  });
}

const { entry, relatedEntries } = Astro.props;
const serviceLink = portfolioServiceLinks[entry.slug];
const { Content } = await entry.render();

const {
  title,
  description,
  heroImage,
  client,
  project,
  results,
  context,
  approach,
  entryType,
  successFactors,
  learnings,
  testimonial,
  resultImages,
  liveUrl,
  tags,
} = entry.data;

const isSideProject = entryType === 'side-project';
const pageTitle = `${title} | Portfolio`;
const pageDescription = description;

// Format date
const formattedDate = new Date(entry.data.date).toLocaleDateString('fr-CH', {
  year: 'numeric',
  month: 'long'
});

// Build TOC items dynamically
const tocItems: { id: string; label: string }[] = [];
tocItems.push({ id: 'fiche-projet', label: 'Fiche projet' });
if (results && results.length > 0) {
  tocItems.push({ id: 'resultats', label: 'Résultats' });
}
if (context) {
  tocItems.push({ id: 'contexte', label: 'Contexte' });
}
if (approach && approach.length > 0) {
  tocItems.push({ id: 'approche', label: 'Approche' });
}
if (resultImages && resultImages.length > 0) {
  tocItems.push({ id: 'captures', label: 'Captures' });
}
if (successFactors && successFactors.length > 0) {
  tocItems.push({ id: 'facteurs-succes', label: 'Facteurs de succès' });
}
if (learnings && (learnings.limitations?.length || learnings.insights?.length)) {
  tocItems.push({ id: 'apprentissages', label: 'Apprentissages' });
}
if (testimonial) {
  tocItems.push({ id: 'temoignage', label: 'Témoignage' });
}

// Schema.org for case study / side-project
const caseStudySchema: Record<string, any> = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "image": heroImage.url.startsWith('http') ? heroImage.url : `${SITE_URL}${heroImage.url}`,
  "author": {
    "@type": "Person",
    "name": "Jonathan Vouilloz",
    "url": SITE_URL
  },
  "publisher": {
    "@type": "Organization",
    "name": "Jon Labs",
    "url": SITE_URL
  },
  "mainEntityOfPage": `${SITE_URL}/portfolio/${entry.slug}`,
};

if (client) {
  caseStudySchema["about"] = {
    "@type": "Organization",
    "name": client.name,
    "url": client.website
  };
}

const schemas = [caseStudySchema];
---

<Layout
  title={pageTitle}
  description={pageDescription}
  schemas={schemas}
>
  <Header />

  <main class="co-root">

    <!-- ══ ARTICLE — étude de cas ══ -->
    <article class="psl-wrap">

      <!-- Retour -->
      <a href="/portfolio" class="psl-back">
        <i class="ri-arrow-left-line"></i> Retour au portfolio
      </a>

      <!-- Hero image cadrée filets -->
      {heroImage && (
        <div class="psl-hero-media co-frame">
          <span class="co-x tl"></span><span class="co-x tr"></span>
          <span class="co-x bl"></span><span class="co-x br"></span>
          <img src={heroImage.url} alt={heroImage.alt} />
        </div>
      )}

      <!-- En-tête -->
      <header class="psl-header">
        <div class="psl-meta">
          <span class="co-cat">{isSideProject ? 'side-project' : project.category}</span>
          {client && (
            <>
              <span class="psl-dot" aria-hidden="true">·</span>
              <span>{client.sector}</span>
            </>
          )}
          <span class="psl-dot" aria-hidden="true">·</span>
          <span>{formattedDate}</span>
        </div>

        <h1 class="psl-title">{title}</h1>
        <p class="psl-lead">{description}</p>

        {tags && tags.length > 0 && (
          <div class="psl-tags">
            {tags.map(tag => (
              <span class="psl-tag">{tag}</span>
            ))}
          </div>
        )}

        <div class="psl-btns">
          {liveUrl && (
            <a href={liveUrl} target="_blank" rel="noopener noreferrer" class="co-btn">
              <i class="ri-external-link-line"></i> Voir le projet
            </a>
          )}
          {client?.website && client.website !== liveUrl && (
            <a href={client.website} target="_blank" rel="noopener noreferrer" class="co-btn co-btn--ghost">
              <i class="ri-global-line"></i> Site client
            </a>
          )}
        </div>
      </header>

      <!-- TLDR -->
      <div class="psl-tldr co-frame">
        <span class="co-x tl"></span><span class="co-x tr"></span>
        <span class="co-x bl"></span><span class="co-x br"></span>
        <p class="psl-tldr-title"><i class="ri-flashlight-line"></i> En bref</p>
        <p class="psl-tldr-text">{description}</p>
        {results && results.length > 0 && (
          <div class="psl-tldr-metrics">
            {results.slice(0, 4).map(result => (
              <div class="psl-tldr-metric">
                <span class="psl-tldr-value">{result.value}</span>
                <span class="psl-tldr-label">{result.label}</span>
              </div>
            ))}
          </div>
        )}
      </div>

      <!-- Sommaire -->
      <nav class="psl-toc" aria-label="Sommaire">
        <p class="psl-toc-title">Sommaire</p>
        <ol class="psl-toc-list">
          {tocItems.map((item) => (
            <li><a href={`#${item.id}`} class="psl-toc-link">{item.label}</a></li>
          ))}
        </ol>
      </nav>

      <!-- Fiche projet -->
      <section id="fiche-projet" class="psl-sec">
        <h2 class="psl-h2">Fiche projet</h2>
        <dl class="co-spec psl-spec">
          {client ? (
            <>
              <div class="co-spec-row"><dt>Client</dt><dd>{client.name}</dd></div>
              <div class="co-spec-row"><dt>Secteur</dt><dd>{client.sector}</dd></div>
            </>
          ) : (
            <div class="co-spec-row"><dt>Type</dt><dd>Projet personnel</dd></div>
          )}
          <div class="co-spec-row"><dt>Durée</dt><dd>{project.duration}</dd></div>
          <div class="co-spec-row"><dt>Période</dt><dd>{project.period}</dd></div>
          {project.measurementPeriod && (
            <div class="co-spec-row"><dt>Mesure</dt><dd>{project.measurementPeriod}</dd></div>
          )}
          <div class="co-spec-row"><dt>Plateforme</dt><dd>{project.platform}</dd></div>
          {liveUrl && (
            <div class="co-spec-row">
              <dt>URL</dt>
              <dd><a href={liveUrl} target="_blank" rel="noopener noreferrer">{liveUrl.replace('https://', '')}</a></dd>
            </div>
          )}
        </dl>
      </section>

      <!-- Résultats -->
      {results && results.length > 0 && (
        <section id="resultats" class="psl-sec">
          <h2 class="psl-h2">Résultats</h2>
          <div class="psl-results">
            {results.map(result => (
              <div class="psl-result">
                <i class={`${result.icon} psl-result-icon`} aria-hidden="true"></i>
                <span class="psl-result-value">{result.value}</span>
                <span class="psl-result-label">{result.label}</span>
                {result.detail && <span class="psl-result-detail">{result.detail}</span>}
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- Contexte -->
      {context && (
        <section id="contexte" class="psl-sec">
          <h2 class="psl-h2">Contexte</h2>
          {context.clientDescription && (
            <>
              <h3 class="psl-h3">Le client</h3>
              <p class="psl-text" set:html={inlineLinks(context.clientDescription)} />
            </>
          )}
          {context.challenge && (
            <>
              <h3 class="psl-h3">Le défi</h3>
              <p class="psl-text" set:html={inlineLinks(context.challenge)} />
            </>
          )}
          {context.whyThisProject && (
            <>
              <h3 class="psl-h3">Pourquoi ce projet</h3>
              <p class="psl-text" set:html={inlineLinks(context.whyThisProject)} />
            </>
          )}
        </section>
      )}

      <!-- Approche -->
      {approach && approach.length > 0 && (
        <section id="approche" class="psl-sec">
          <h2 class="psl-h2">Approche</h2>
          <div class="psl-steps">
            {approach.map((phase) => (
              <div class="psl-step">
                <span class="psl-step-num co-index">{String(phase.phase).padStart(2, '0')}</span>
                <div class="psl-step-body">
                  <h3 class="psl-step-title">{phase.title}</h3>
                  <p class="psl-step-desc" set:html={inlineLinks(phase.description)} />
                  {phase.tasks && phase.tasks.length > 0 && (
                    <ul class="psl-step-tasks">
                      {phase.tasks.map(task => <li set:html={inlineLinks(task)} />)}
                    </ul>
                  )}
                </div>
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- Captures -->
      {resultImages && resultImages.length > 0 && (
        <section id="captures" class="psl-sec">
          <h2 class="psl-h2">Captures</h2>
          <div class="psl-gallery">
            {resultImages.map(image => (
              <figure class="psl-fig">
                <img src={image.url} alt={image.alt} class="gallery-img" />
                {image.caption && <figcaption>{image.caption}</figcaption>}
              </figure>
            ))}
          </div>
        </section>
      )}

      <!-- Facteurs de succès -->
      {successFactors && successFactors.length > 0 && (
        <section id="facteurs-succes" class="psl-sec">
          <h2 class="psl-h2">Facteurs de succès</h2>
          <ul class="psl-success">
            {successFactors.map(factor => (
              <li class="psl-success-item">
                <i class={`${factor.icon} psl-success-icon`} aria-hidden="true"></i>
                <div>
                  <strong>{factor.title}</strong>
                  <span class="psl-success-desc" set:html={inlineLinks(factor.description)} />
                </div>
              </li>
            ))}
          </ul>
        </section>
      )}

      <!-- Apprentissages -->
      {learnings && (learnings.limitations?.length || learnings.insights?.length) && (
        <section id="apprentissages" class="psl-sec">
          <h2 class="psl-h2">Apprentissages</h2>
          {learnings.insights && learnings.insights.length > 0 && (
            <>
              <h3 class="psl-h3">Ce que j'ai appris</h3>
              <ul class="co-list">
                {learnings.insights.map(insight => (
                  <li set:html={inlineLinks(insight)} />
                ))}
              </ul>
            </>
          )}
          {learnings.limitations && learnings.limitations.length > 0 && (
            <>
              <h3 class="psl-h3">Limites &amp; améliorations</h3>
              <ul class="co-list">
                {learnings.limitations.map(limitation => (
                  <li set:html={inlineLinks(limitation)} />
                ))}
              </ul>
            </>
          )}
        </section>
      )}

      <!-- Témoignage -->
      {testimonial && (
        <section id="temoignage" class="psl-sec">
          <h2 class="psl-h2">Témoignage</h2>
          <blockquote class="psl-quote">
            <p>« {testimonial.quote} »</p>
            <footer>
              <strong>{testimonial.author}</strong>{testimonial.role && <span>, {testimonial.role}</span>}
            </footer>
          </blockquote>
        </section>
      )}

      <!-- Corps markdown additionnel (primitive .co-prose) -->
      <div class="co-prose psl-content">
        <Content />
      </div>

      <!-- Retour bas de page -->
      <div class="psl-foot">
        <a href="/portfolio" class="psl-back">
          <i class="ri-arrow-left-line"></i> Voir tous les projets
        </a>
      </div>
    </article>

    <!-- ══ MAILLAGE — service lié + projets similaires ══ -->
    <section class="psl-maillage">
      {serviceLink && (
        <div class="psl-service-block">
          <p class="psl-maillage-label">Service lié</p>
          <a href={serviceLink.href} class="psl-service">
            <span class="psl-service-text">
              Ce projet illustre mon offre <b>{serviceLink.label}</b>
            </span>
            <i class="ri-arrow-right-line" aria-hidden="true"></i>
          </a>
        </div>
      )}

      {relatedEntries && relatedEntries.length > 0 && (
        <div>
          <p class="psl-maillage-label">Projets similaires</p>
          <div class="psl-related">
            {relatedEntries.map((related) => (
              <a href={`/portfolio/${related.slug}`} class="psl-related-card">
                {related.data.tags?.[0] && (
                  <span class="co-cat">{related.data.tags[0]}</span>
                )}
                <h3 class="psl-related-title">{related.data.title}</h3>
                <span class="psl-related-cta">
                  Voir le projet <i class="ri-arrow-right-line" aria-hidden="true"></i>
                </span>
              </a>
            ))}
          </div>
        </div>
      )}
    </section>

    <!-- ══ CTA FINAL (primitive .co-cta — remplace CTASection) ══ -->
    <section class="co-cta">
      <span class="co-x tl"></span><span class="co-x tr"></span>
      <div class="co-cta-inner">
        <h2 class="co-cta-title">Le vôtre mérite le même <span class="co-ser">soin.</span></h2>
        <p class="co-cta-lead">Je travaille avec des indépendants et PME locales qui veulent développer leur visibilité en ligne.</p>
        <div class="co-cta-btns">
          <a href="/contact" class="co-btn co-cta-btn"><i class="ri-chat-3-line"></i> Discuter de votre projet</a>
        </div>
        <div class="co-cta-trust">
          <span><i class="ri-time-line"></i> Réponse sous 48h</span>
        </div>
      </div>
    </section>
  </main>

  <Footer />

  <!-- Lightbox -->
  <div id="lightbox" class="lightbox" role="dialog" aria-modal="true" aria-hidden="true">
    <button class="lightbox-close" aria-label="Fermer">
      <i class="ri-close-line"></i>
    </button>
    <button class="lightbox-prev" aria-label="Image précédente">
      <i class="ri-arrow-left-s-line"></i>
    </button>
    <button class="lightbox-next" aria-label="Image suivante">
      <i class="ri-arrow-right-s-line"></i>
    </button>
    <figure class="lightbox-content">
      <img id="lightbox-img" src="" alt="" />
      <figcaption id="lightbox-caption"></figcaption>
    </figure>
    <span id="lightbox-counter"></span>
  </div>
</Layout>

<style is:global>
  /* ══ PORTFOLIO DÉTAIL — styles scopés .psl-* (blueprint) ══ */

  /* Colonne de lecture cadrée */
  .psl-wrap { max-width: 780px; margin: 0 auto; padding: 40px 40px 8px; }

  /* Liens retour / bas de page */
  .co-root .psl-back { display: inline-flex; align-items: center; gap: 8px; font-size: 0.9rem; font-weight: 500; color: var(--muted); transition: color .16s ease-out; }
  .co-root .psl-back:hover { color: var(--accent); }

  /* Hero image */
  .psl-hero-media { position: relative; margin: 24px 0 30px; overflow: hidden; }
  .psl-hero-media img { display: block; width: 100%; aspect-ratio: 16 / 9; object-fit: cover; background: var(--bg); }

  /* En-tête */
  .psl-header { display: flex; flex-direction: column; align-items: flex-start; }
  .psl-meta { display: flex; flex-wrap: wrap; align-items: center; gap: 10px; font-size: 13px; color: var(--muted); margin-bottom: 16px; }
  .psl-meta .psl-dot { color: var(--line-2); }
  .co-root .psl-title { font-size: clamp(1.9rem, 4.4vw, 2.8rem); line-height: 1.08; letter-spacing: -0.03em; margin: 0 0 16px; }
  .co-root .psl-lead { font-size: 1.15rem; line-height: 1.6; color: var(--muted); margin: 0 0 22px; max-width: 60ch; }
  .psl-tags { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 24px; }
  .psl-tag { font-size: 0.8rem; color: var(--muted); padding: 4px 11px; border: 1px solid var(--line-2); border-radius: 999px; }
  .psl-btns { display: flex; flex-wrap: wrap; gap: 12px; }

  /* Titres de section */
  .psl-sec { margin-top: 52px; }
  .co-root .psl-h2 { font-size: clamp(1.4rem, 2.6vw, 1.7rem); line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 20px; padding-bottom: 12px; border-bottom: 1px solid var(--line); }
  .co-root .psl-h3 { font-size: 1.15rem; font-weight: 600; margin: 26px 0 8px; }
  .co-root .psl-text { color: var(--ink); line-height: 1.7; margin: 0 0 14px; }
  .psl-text a { color: var(--ink); text-decoration: underline; text-decoration-color: var(--accent); text-decoration-thickness: 1px; text-underline-offset: 3px; transition: text-decoration-thickness .16s ease-out; }
  .psl-text a:hover { text-decoration-thickness: 2px; }

  /* TLDR — callout cadré */
  .psl-tldr { position: relative; background: var(--surface); border: 1px solid var(--line-2); padding: 22px 24px; margin-top: 30px; }
  .co-root .psl-tldr-title { display: inline-flex; align-items: center; gap: 8px; font-size: 12px; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); margin: 0 0 12px; }
  .co-root .psl-tldr-title i { color: var(--accent); }
  .co-root .psl-tldr-text { line-height: 1.6; margin: 0; }
  .psl-tldr-metrics { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; margin-top: 18px; padding-top: 18px; border-top: 1px solid var(--line); }
  .psl-tldr-metric { display: flex; flex-direction: column; gap: 3px; }
  .psl-tldr-value { font-size: 1.5rem; font-weight: 700; letter-spacing: -0.03em; line-height: 1; }
  .psl-tldr-label { font-size: 12px; color: var(--muted); }
  @media (min-width: 640px) { .psl-tldr-metrics { grid-template-columns: repeat(4, 1fr); } }

  /* Sommaire */
  .psl-toc { background: var(--surface); border: 1px solid var(--line-2); padding: 18px 22px; margin-top: 24px; }
  .co-root .psl-toc-title { font-size: 12px; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); margin: 0 0 12px; }
  .psl-toc-list { display: flex; flex-direction: column; gap: 8px; counter-reset: psl-toc; }
  .psl-toc-list li { counter-increment: psl-toc; }
  .co-root .psl-toc-link { display: inline-flex; align-items: baseline; gap: 10px; font-size: 0.95rem; color: var(--ink); transition: color .16s ease-out; }
  .psl-toc-link::before { content: counter(psl-toc, decimal-leading-zero); color: var(--accent); font-variant-numeric: tabular-nums; font-weight: 600; font-size: 0.82em; }
  .co-root .psl-toc-link:hover { color: var(--accent); }

  /* Fiche projet (primitive .co-spec) */
  .psl-spec { margin-top: 4px; }
  .psl-spec dd a { color: var(--ink); text-decoration: underline; text-decoration-color: var(--accent); text-underline-offset: 3px; }

  /* Résultats — tuiles */
  .psl-results { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; margin-top: 4px; }
  @media (min-width: 640px) { .psl-results { grid-template-columns: repeat(3, 1fr); } }
  .psl-result { display: flex; flex-direction: column; gap: 4px; padding: 18px 20px; background: var(--surface); border: 1px solid var(--line-2); }
  .psl-result-icon { font-size: 17px; color: var(--accent); line-height: 1; }
  .psl-result-value { font-size: 1.5rem; font-weight: 700; letter-spacing: -0.03em; line-height: 1.15; }
  .psl-result-label { font-size: 13px; font-weight: 500; }
  .psl-result-detail { font-size: 12px; color: var(--muted); font-style: italic; }

  /* Approche — étapes */
  .psl-steps { display: flex; flex-direction: column; gap: 16px; margin-top: 4px; }
  .psl-step { display: grid; grid-template-columns: auto 1fr; gap: 20px; padding: 22px 24px; background: var(--surface); border: 1px solid var(--line-2); }
  .psl-step-num { font-size: 1.6rem; font-weight: 700; letter-spacing: -0.03em; line-height: 1; }
  .co-root .psl-step-title { font-size: 1.1rem; font-weight: 600; margin: 0 0 8px; }
  .co-root .psl-step-desc { color: var(--muted); line-height: 1.6; margin: 0 0 12px; }
  .psl-step-tasks { display: flex; flex-direction: column; gap: 6px; }
  .psl-step-tasks li { position: relative; padding-left: 20px; font-size: 0.92rem; color: var(--muted); line-height: 1.5; }
  .psl-step-tasks li::before { content: ""; position: absolute; left: 2px; top: 0.66em; width: 6px; height: 6px; border-radius: 999px; background: var(--accent); }

  /* Captures — galerie */
  .psl-gallery { display: flex; flex-direction: column; gap: 24px; margin-top: 4px; }
  .psl-fig { margin: 0; }
  .psl-fig .gallery-img { display: block; width: 100%; height: auto; cursor: zoom-in; border: 1px solid var(--line-2); transition: opacity .18s ease-out; }
  .psl-fig .gallery-img:hover { opacity: 0.92; }
  .psl-fig figcaption { font-size: 13px; color: var(--muted); text-align: center; margin-top: 8px; }

  /* Facteurs de succès */
  .psl-success { display: flex; flex-direction: column; gap: 16px; margin-top: 4px; }
  .psl-success-item { display: flex; gap: 12px; }
  .psl-success-icon { font-size: 18px; color: var(--accent); flex: none; margin-top: 2px; }
  .co-root .psl-success-item strong { display: block; margin-bottom: 2px; font-weight: 650; }
  .psl-success-desc { display: block; font-size: 0.95rem; color: var(--muted); line-height: 1.6; }

  /* Témoignage */
  .psl-quote { margin-top: 4px; padding: 4px 0 4px 22px; border-left: 2px solid var(--accent); }
  .co-root .psl-quote p { font-family: "Instrument Serif", Georgia, serif; font-style: italic; font-size: 1.35rem; line-height: 1.4; margin: 0 0 10px; }
  .psl-quote footer { font-size: 0.9rem; color: var(--muted); }
  .psl-quote footer strong { color: var(--ink); font-weight: 650; }

  /* Corps markdown (.co-prose) — espacement */
  .psl-content { margin-top: 44px; }

  /* Retour bas de page */
  .psl-foot { margin-top: 44px; padding-top: 24px; border-top: 1px solid var(--line); }

  /* Maillage interne */
  .psl-maillage { max-width: 780px; margin: 0 auto; padding: 24px 40px 8px; }
  .co-root .psl-maillage-label { font-size: 12px; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); margin: 0 0 12px; }
  .psl-service-block { margin-bottom: 40px; }
  .psl-service { display: flex; align-items: center; justify-content: space-between; gap: 16px; padding: 20px 24px; background: var(--surface); border: 1px solid var(--line-2); transition: box-shadow .18s ease-out, transform .18s ease-out; }
  .psl-service:hover { transform: translateY(-2px); box-shadow: 0 10px 28px rgba(20, 22, 26, .08); }
  .psl-service-text { font-size: 1.05rem; font-weight: 600; line-height: 1.35; }
  .psl-service-text b { color: var(--accent); font-weight: 700; }
  .psl-service > i { font-size: 1.4rem; color: var(--accent); flex: none; transition: transform .18s ease-out; }
  .psl-service:hover > i { transform: translateX(4px); }

  .psl-related { display: grid; gap: 14px; }
  @media (min-width: 640px) { .psl-related { grid-template-columns: repeat(2, 1fr); } }
  .psl-related-card { display: flex; flex-direction: column; align-items: flex-start; gap: 9px; padding: 18px 20px; background: var(--surface); border: 1px solid var(--line-2); transition: box-shadow .18s ease-out, transform .18s ease-out; }
  .psl-related-card:hover { transform: translateY(-2px); box-shadow: 0 10px 28px rgba(20, 22, 26, .08); }
  .co-root .psl-related-title { font-size: 1.05rem; line-height: 1.25; font-weight: 650; }
  .psl-related-cta { display: inline-flex; align-items: center; gap: 6px; font-size: 0.9rem; font-weight: 500; color: var(--accent); margin-top: auto; }
  .psl-related-cta i { transition: transform .18s ease-out; }
  .psl-related-card:hover .psl-related-cta i { transform: translateX(3px); }

  /* Responsive */
  @media (max-width: 720px) {
    .psl-wrap, .psl-maillage { padding-left: 20px; padding-right: 20px; }
    .psl-step { grid-template-columns: 1fr; gap: 10px; }
    .psl-results { grid-template-columns: repeat(2, 1fr); }
  }
  @media (prefers-reduced-motion: reduce) {
    .co-root .psl-back, .psl-service, .psl-service > i, .psl-related-card,
    .psl-related-cta i, .psl-fig .gallery-img, .co-root .psl-toc-link, .psl-text a { transition: none; }
  }

  /* ══ Lightbox (préservée — overlay sombre neutre) ══ */
  .lightbox {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.95);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.2s ease-out, visibility 0.2s ease-out;
    z-index: 9999;
  }

  .lightbox.active {
    opacity: 1;
    visibility: visible;
  }

  .lightbox-content {
    text-align: center;
    margin: 0;
  }

  .lightbox-content img {
    max-width: 90vw;
    max-height: 80vh;
    object-fit: contain;
  }

  .lightbox-close,
  .lightbox-prev,
  .lightbox-next {
    position: absolute;
    background: none;
    border: none;
    color: white;
    font-size: 2rem;
    cursor: pointer;
    padding: 1rem;
    opacity: 0.7;
    transition: opacity 0.2s ease-out;
  }

  .lightbox-close:hover,
  .lightbox-prev:hover,
  .lightbox-next:hover {
    opacity: 1;
  }

  .lightbox-close {
    top: 1rem;
    right: 1rem;
  }

  .lightbox-prev {
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
  }

  .lightbox-next {
    right: 1rem;
    top: 50%;
    transform: translateY(-50%);
  }

  .lightbox-caption {
    color: rgba(255, 255, 255, 0.7);
    margin-top: 1rem;
    font-size: 0.9rem;
  }

  .lightbox-counter {
    position: absolute;
    top: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.85rem;
  }
</style>

<script is:inline>
  const lightbox = document.getElementById('lightbox');
  const lbImg = document.getElementById('lightbox-img');
  const lbCaption = document.getElementById('lightbox-caption');
  const lbCounter = document.getElementById('lightbox-counter');

  const images = Array.from(document.querySelectorAll('.gallery-img'));
  let current = 0;

  function openLightbox(i) {
    current = i;
    updateLightbox();
    lightbox.classList.add('active');
    lightbox.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lightbox.classList.remove('active');
    lightbox.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  function updateLightbox() {
    const img = images[current];
    lbImg.src = img.src;
    lbImg.alt = img.alt;
    lbCaption.textContent = img.alt;
    lbCounter.textContent = `${current + 1} / ${images.length}`;
  }

  function nextImage() {
    current = (current + 1) % images.length;
    updateLightbox();
  }

  function prevImage() {
    current = (current - 1 + images.length) % images.length;
    updateLightbox();
  }

  // Event listeners
  images.forEach((img, i) => img.addEventListener('click', () => openLightbox(i)));

  const closeBtn = document.querySelector('.lightbox-close');
  const prevBtn = document.querySelector('.lightbox-prev');
  const nextBtn = document.querySelector('.lightbox-next');

  if (closeBtn) closeBtn.addEventListener('click', closeLightbox);
  if (prevBtn) prevBtn.addEventListener('click', prevImage);
  if (nextBtn) nextBtn.addEventListener('click', nextImage);
  if (lightbox) lightbox.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });

  document.addEventListener('keydown', (e) => {
    if (!lightbox || !lightbox.classList.contains('active')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowRight') nextImage();
    if (e.key === 'ArrowLeft') prevImage();
  });
</script>
