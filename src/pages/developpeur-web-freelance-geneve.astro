---
import "../styles/global.css";
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

import { getWebPageSchema, getBreadcrumbSchema, getFAQPageSchema } from "../lib/seo";
import { SITE_URL, localBusinessData } from "../data/schema";

// ============================================
// SEO META
// ============================================
const pageTitle = "Développeur web freelance à Genève | Jon Labs";
const pageDescription = "Développeur web freelance à Genève : sites sur-mesure, MVP, refonte. 8 ans d'expérience, devis transparent, code propre pour PME et indépendants romands.";
const pageUrl = `${SITE_URL}/developpeur-web-freelance-geneve`;

// ============================================
// SCHEMA.ORG
// ============================================
const webPageSchema = getWebPageSchema({
  url: pageUrl,
  name: pageTitle,
  description: pageDescription
});

const breadcrumbSchema = getBreadcrumbSchema([
  { name: "Accueil", url: SITE_URL },
  { name: "Développeur web freelance Genève", url: pageUrl },
]);

// ============================================
// COMPARAISON FREELANCE VS AGENCE
// ============================================
const freelanceVsAgency = [
  {
    type: "freelance",
    icon: "ri-user-star-line",
    title: "Interlocuteur unique",
    description: "Tu parles à la personne qui code. Pas de chef de projet entre toi et le clavier, pas de téléphone arabe."
  },
  {
    type: "freelance",
    icon: "ri-price-tag-3-line",
    title: "Prix transparent",
    description: "Devis détaillé, tarif horaire affiché, zéro marge cachée. Tu sais exactement ce que tu paies."
  },
  {
    type: "freelance",
    icon: "ri-rocket-2-line",
    title: "Agilité",
    description: "Décisions rapides, adaptations en cours de route, MVP en 2-3 semaines. Pas de comité à convaincre."
  },
  {
    type: "freelance",
    icon: "ri-code-s-slash-line",
    title: "Code propre, pas de WordPress par défaut",
    description: "Astro, Next.js, Tailwind. Stack moderne, performance Google native, zéro plugin qui rame."
  },
  {
    type: "agency",
    icon: "ri-team-line",
    title: "Équipe dédiée (mais cloisonnée)",
    description: "Account manager, chef de projet, designer, dev, QA. Pratique sur de gros projets, lourd sur des sites de PME."
  },
  {
    type: "agency",
    icon: "ri-stack-line",
    title: "Process en plusieurs strates",
    description: "Brief → présentations → validations → cycles. Plus de structure, mais plus de délais (3 à 6 mois en moyenne)."
  },
  {
    type: "agency",
    icon: "ri-money-dollar-circle-line",
    title: "Marge cachée 30-50%",
    description: "Le tarif horaire affiché finance les locaux, le commercial et les fonctions support. Normal, mais ça coûte plus cher."
  },
  {
    type: "agency",
    icon: "ri-tools-line",
    title: "Stack souvent verrouillée",
    description: "Beaucoup d'agences romandes restent sur WordPress par habitude. Maintenance, sécurité, performance — tu paies l'addition."
  }
];

// ============================================
// SERVICES (5 cards)
// ============================================
const services = [
  {
    icon: "ri-window-line",
    title: "Création de site web",
    description: "Site vitrine sur-mesure pour indépendants et PME. Design unique, performance Google, livré en 3-4 semaines.",
    price: "Dès CHF 1'490",
    href: "/services/creation-site-web"
  },
  {
    icon: "ri-refresh-line",
    title: "Refonte de site web",
    description: "Modernisation d'un site existant. Migration depuis WordPress, Wix ou Squarespace vers une stack rapide et maintenable.",
    price: "Dès CHF 2'500",
    href: "/services/refonte-site-web"
  },
  {
    icon: "ri-rocket-line",
    title: "Développement MVP",
    description: "Prototype fonctionnel en 2-3 semaines pour tester ton idée auprès de vrais utilisateurs avant de t'engager plus loin.",
    price: "Dès CHF 4'500",
    href: "/services/developpement-mvp"
  },
  {
    icon: "ri-tools-line",
    title: "Outils sur mesure",
    description: "Applications internes, tableaux de bord, portails clients. Pour automatiser ce qu'Excel ne sait plus faire seul.",
    price: "Sur devis",
    href: "/services/outils-sur-mesure"
  },
  {
    icon: "ri-map-pin-2-line",
    title: "Référencement local",
    description: "SEO local pour exister sur Google quand un Genevois cherche ton métier. Audit, GMB, contenu, technique.",
    price: "Dès CHF 800/mois",
    href: "/services/referencement-local"
  }
];

// ============================================
// MÉTHODOLOGIE (4 étapes)
// ============================================
const methodSteps = [
  {
    step: "01",
    title: "Brief",
    description: "Échange gratuit de 30-45 minutes. Tu m'expliques ton activité, tes objectifs, ce que tu attends concrètement.",
    duration: "Sous 48h"
  },
  {
    step: "02",
    title: "Devis",
    description: "Proposition écrite : périmètre, livrables, planning, montant en CHF. Pas de surprise, pas d'option cachée.",
    duration: "3-5 jours"
  },
  {
    step: "03",
    title: "Sprint",
    description: "Maquette validée puis développement. Démos régulières, accès staging, ajustements en continu.",
    duration: "2-4 semaines"
  },
  {
    step: "04",
    title: "Livraison",
    description: "Mise en ligne, transfert des accès, formation rapide. Ton site t'appartient — code, hébergement, domaine.",
    duration: "1 jour"
  }
];

// ============================================
// STACK TECHNIQUE
// ============================================
const techStack = [
  "Astro", "Next.js", "React", "Svelte", "TypeScript",
  "Tailwind CSS", "Supabase", "Vercel", "Cloudflare",
  "Stripe", "TWINT", "Webflow", "Framer"
];

// ============================================
// ZONES D'INTERVENTION
// ============================================
const cities = [
  { name: "Genève", primary: true },
  { name: "Lausanne", primary: false },
  { name: "Vevey", primary: false },
  { name: "Montreux", primary: false },
  { name: "Sion", primary: false },
  { name: "Sierre", primary: false },
  { name: "Nyon", primary: false },
  { name: "Morges", primary: false }
];

const frontierCities = ["Annemasse", "Gaillard", "Saint-Julien", "Ferney-Voltaire"];

// ============================================
// RÉALISATIONS
// ============================================
const projects = [
  {
    title: "Lecureux Conseil",
    sector: "Juriste — Genève",
    description: "Site Framer + SEO local : de zéro à Top 1 Google sur 'juriste restauration Genève' en 5 mois.",
    href: "/portfolio/leo-lecureux-seo",
    tag: "SEO local"
  },
  {
    title: "Ugo Mighali",
    sector: "Coutelier d'art — Genève",
    description: "Portfolio minimaliste pour un jeune artisan formé à Genève. Design épuré, narration visuelle.",
    href: "/portfolio/ugo-mighali-coutelier",
    tag: "Site vitrine"
  },
  {
    title: "Barber Concept",
    sector: "Chaîne de salons — Romandie",
    description: "Site Webflow multi-salon avec CMS, page franchise et système de recrutement intégré.",
    href: "/portfolio/barber-concept",
    tag: "Site multi-pages"
  }
];

// ============================================
// TARIFS
// ============================================
const pricingPlans = [
  {
    name: "Site vitrine",
    price: "1'490",
    priceLabel: "CHF dès",
    description: "Pour indépendants et artisans qui veulent une présence en ligne propre.",
    features: ["1 à 5 pages", "Design sur-mesure", "Responsive", "SEO de base", "Hébergement 1 an"],
    highlighted: false
  },
  {
    name: "Site sur-mesure",
    price: "4'000",
    priceLabel: "CHF dès",
    description: "Pour PME romandes avec contenu, blog, intégrations spécifiques.",
    features: ["Pages illimitées", "CMS / blog", "SEO avancé", "Intégrations (Stripe, GMB...)", "Formation incluse"],
    highlighted: true
  },
  {
    name: "Application web",
    price: "8'000",
    priceLabel: "CHF dès",
    description: "Pour outils internes, MVP, plateformes avec authentification et données.",
    features: ["Backend custom", "Base de données", "Authentification", "API tiers", "Maintenance évolutive"],
    highlighted: false
  }
];

// ============================================
// ARTICLES BLOG
// ============================================
const blogArticles = [
  {
    title: "Combien coûte vraiment un site web en Suisse en 2026 ?",
    description: "Fourchettes en CHF par profil de prestataire (freelance, agence, no-code) et par type de projet.",
    href: "/blog/prix-site-web-suisse-2026",
    icon: "ri-money-cny-circle-line"
  },
  {
    title: "Spécialiste dev web Suisse : comment bien choisir",
    description: "Les 7 critères pour différencier un bon développeur d'un copieur de templates en 2026.",
    href: "/blog/specialiste-developpement-web-suisse",
    icon: "ri-user-search-line"
  },
  {
    title: "15 signes que ton site web dort",
    description: "Checklist rapide en 4 minutes pour savoir si ton site travaille pour toi ou s'il prend la poussière.",
    href: "/blog/15-signes-site-web-dort",
    icon: "ri-alarm-warning-line"
  }
];

// ============================================
// FAQ LOCALE (8 questions)
// ============================================
const faqs = [
  {
    question: "Pourquoi choisir un freelance plutôt qu'une agence à Genève ?",
    answer: "Avec un freelance, tu parles directement à la personne qui code, sans chef de projet intermédiaire. Le tarif horaire est en général 30 à 50% inférieur à une agence pour un travail équivalent, parce qu'il n'y a pas de locaux, de commerciaux ni de fonctions support à financer. L'agilité est aussi supérieure : décisions rapides, ajustements en cours de route, MVP livré en 2-3 semaines. L'agence reste pertinente pour des projets très volumineux qui demandent plusieurs profils en parallèle (design, dev, marketing, ops)."
  },
  {
    question: "Quel est le tarif d'un développeur web freelance à Genève ?",
    answer: "À Genève, le tarif horaire d'un freelance senior se situe entre CHF 90 et CHF 150 selon l'expérience et la spécialisation. Pour Jon Labs, un site vitrine démarre à CHF 1'490, un site sur-mesure à CHF 4'000, une application web à CHF 8'000. Le devis est toujours forfaitaire (pas au temps passé) pour que tu connaisses le coût total avant de signer."
  },
  {
    question: "Combien de temps pour créer un site web ?",
    answer: "Un site vitrine est livré en 3 à 4 semaines, un site sur-mesure avec blog et intégrations en 6 à 8 semaines, une application web en 2 à 3 mois selon la complexité. Le délai dépend surtout de la rapidité avec laquelle tu peux fournir tes contenus (textes, photos, accès) et valider les étapes intermédiaires."
  },
  {
    question: "Travaillez-vous avec des clients hors Genève ?",
    answer: "Oui. Je travaille régulièrement avec des clients de Lausanne, Vevey, Montreux, Sion, Sierre, Nyon et Morges, ainsi qu'avec des entreprises basées en zone frontalière française (Annemasse, Gaillard, Saint-Julien). La plupart des échanges se font en visio, avec des rendez-vous en personne quand tu es de passage à Genève ou quand le projet le justifie."
  },
  {
    question: "Faut-il être à Genève pour vous engager ?",
    answer: "Non. Toute la collaboration peut se faire à distance : visio, partage d'écran, accès staging, démos vidéo. Être basé à Genève apporte simplement deux avantages aux clients romands : possibilité de se voir en personne pour le brief ou les ateliers, et bonne connaissance du marché local (LPD, facturation CHF, attentes des clients suisses)."
  },
  {
    question: "Quelles technologies utilisez-vous ?",
    answer: "Stack moderne : Astro et Next.js pour les sites web, Svelte ou React pour les applications, TypeScript et Tailwind CSS partout, Supabase pour la base de données, Vercel et Cloudflare pour l'hébergement. Pour les sites vitrines avec CMS visuel, j'utilise aussi Webflow et Framer selon le profil du client. Le choix se fait toujours en fonction du projet, pas d'un dogme technique."
  },
  {
    question: "Vous faites du WordPress ?",
    answer: "Pas par défaut. WordPress reste pertinent pour certains cas (gros blog éditorial, équipe habituée), mais sur la plupart des projets de PME romandes, c'est une mauvaise réponse en 2026 : performance Google médiocre, mises à jour permanentes, vulnérabilités, plugins qui se cassent. Je propose des stacks plus rapides et plus sûres dès que c'est possible. Si tu as un site WordPress existant, je peux faire la migration."
  },
  {
    question: "Comment se passe le paiement (CHF, EUR) ?",
    answer: "Facturation en CHF par défaut pour les clients suisses, en EUR pour les clients de la zone frontalière française qui le préfèrent. Paiement par virement bancaire ou TWINT. Le calendrier standard : 30% à la signature, 30% à la validation de la maquette, 40% à la mise en ligne. Pour des projets supérieurs à CHF 10'000, on peut découper en plus de tranches."
  }
];

const faqSchema = getFAQPageSchema(faqs);

// ============================================
// SCHEMAS (assemblage final)
// ============================================
const schemas = [webPageSchema, breadcrumbSchema, faqSchema, localBusinessData];
---

<Layout
  title={pageTitle}
  description={pageDescription}
  schemas={schemas}
>
  <Header />

  <!-- ============================================== -->
  <!-- HERO LOCAL -->
  <!-- ============================================== -->
  <section class="hero-section -mt-[120px] pt-[150px] pb-16 md:pt-[160px] md:pb-20 px-4 relative overflow-hidden">
    <!-- Gradient mesh background -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-0 -left-20 w-[500px] h-[500px] bg-[var(--blue)] opacity-20 blur-[120px] rounded-full"></div>
      <div class="absolute top-1/3 -right-20 w-[400px] h-[400px] bg-[var(--violet)] opacity-15 blur-[100px] rounded-full"></div>
      <div class="absolute bottom-0 left-1/3 w-[300px] h-[300px] bg-[var(--blue)] opacity-10 blur-[80px] rounded-full"></div>
    </div>

    <div class="max-w-4xl mx-auto relative z-10 text-center">
      <!-- Badges -->
      <div class="flex flex-wrap justify-center gap-3 mb-8">
        <span class="inline-flex items-center gap-2 bg-white border-2 border-black px-3 py-1 text-xs font-mono shadow-[2px_2px_0px_rgba(0,0,0,1)]">
          <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
          Disponible
        </span>
        <span class="inline-flex items-center gap-2 bg-[var(--blue)] border-2 border-black px-3 py-1 text-xs font-mono shadow-[2px_2px_0px_rgba(0,0,0,1)]">
          <i class="ri-map-pin-fill"></i>
          Genève · Suisse romande
        </span>
      </div>

      <!-- H1 -->
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-black tracking-tight mb-6 leading-[1.05]">
        Développeur web<br/>
        freelance à
        <span class="relative inline-block">
          <span class="relative z-10">Genève</span>
          <span class="absolute bg-[var(--yellow)] w-full h-[35%] left-0 bottom-1 -z-1"></span>
        </span>
      </h1>

      <!-- Sous-titre -->
      <p class="text-lg md:text-2xl text-gray-700 mb-8 leading-relaxed max-w-3xl mx-auto">
        Sites sur-mesure, MVP et refonte pour <strong>PME et indépendants romands</strong>.<br class="hidden md:block"/>
        Devis transparent, code propre, performance Google.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-10">
        <a
          href="/contact"
          class="
            bg-[var(--blue)]
            border-2 border-black
            px-6 py-4
            text-lg font-bold
            shadow-[4px_4px_0px_rgba(0,0,0,1)]
            transition-all duration-200
            hover:bg-[var(--yellow)]
            hover:shadow-[2px_2px_0px_rgba(0,0,0,1)]
            hover:translate-x-[2px] hover:translate-y-[2px]
            flex items-center justify-center gap-2
          "
        >
          <i class="ri-mail-send-line"></i>
          Demander un devis
        </a>
        <a
          href="/portfolio"
          class="
            bg-white
            border-2 border-black
            px-6 py-4
            text-lg font-medium
            transition-all duration-200
            hover:bg-gray-100
            flex items-center justify-center gap-2
          "
        >
          Voir mes réalisations
          <i class="ri-arrow-right-line"></i>
        </a>
      </div>

      <!-- Trust line -->
      <div class="flex flex-wrap justify-center gap-x-6 gap-y-2 text-sm text-gray-600">
        <span class="flex items-center gap-2">
          <i class="ri-time-line text-[var(--blue)]"></i>
          8 ans d'expérience
        </span>
        <span class="flex items-center gap-2">
          <i class="ri-stack-line text-[var(--blue)]"></i>
          50+ sites livrés
        </span>
        <span class="flex items-center gap-2">
          <i class="ri-map-pin-line text-[var(--blue)]"></i>
          Clients romands
        </span>
      </div>
    </div>
  </section>

  <!-- ============================================== -->
  <!-- FREELANCE VS AGENCE -->
  <!-- ============================================== -->
  <section class="py-20 md:py-28 px-4 bg-white border-y-2 border-black">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12 md:mb-16">
        <span class="inline-flex items-center gap-2 text-xs font-mono uppercase tracking-[0.2em] text-gray-500 mb-4">
          <span class="w-8 h-px bg-gray-400"></span>
          comparaison
          <span class="w-8 h-px bg-gray-400"></span>
        </span>
        <h2 class="text-3xl md:text-5xl font-black mb-4">
          Pourquoi un freelance plutôt qu'une agence ?
        </h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Les deux options sont valides selon le contexte. Voilà ce qui change concrètement quand tu choisis un <strong>freelance web à Genève</strong>.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Freelance -->
        <div>
          <div class="bg-[var(--blue)] border-3 border-black px-4 py-2 inline-block mb-6 shadow-[3px_3px_0px_rgba(0,0,0,1)]">
            <h3 class="font-black text-lg flex items-center gap-2">
              <i class="ri-user-star-fill"></i>
              Freelance
            </h3>
          </div>
          <div class="space-y-4">
            {freelanceVsAgency.filter(c => c.type === "freelance").map((card) => (
              <div class="bg-[var(--main-bg)] border-2 border-black p-5 transition-all duration-200 hover:translate-x-[-2px] hover:translate-y-[-2px] hover:shadow-[6px_6px_0px_rgba(0,0,0,0.3)] shadow-[4px_4px_0px_rgba(0,0,0,0.3)]">
                <div class="flex items-start gap-4">
                  <div class="w-10 h-10 bg-[var(--blue)] border-2 border-black flex items-center justify-center flex-shrink-0">
                    <i class={`${card.icon} text-lg`}></i>
                  </div>
                  <div>
                    <h4 class="font-bold mb-1">{card.title}</h4>
                    <p class="text-sm text-gray-600">{card.description}</p>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Agence -->
        <div>
          <div class="bg-white border-3 border-black px-4 py-2 inline-block mb-6 shadow-[3px_3px_0px_rgba(0,0,0,1)]">
            <h3 class="font-black text-lg flex items-center gap-2">
              <i class="ri-building-line"></i>
              Agence
            </h3>
          </div>
          <div class="space-y-4">
            {freelanceVsAgency.filter(c => c.type === "agency").map((card) => (
              <div class="bg-[var(--main-bg)] border-2 border-black p-5 transition-all duration-200 hover:translate-x-[-2px] hover:translate-y-[-2px] hover:shadow-[6px_6px_0px_rgba(0,0,0,0.3)] shadow-[4px_4px_0px_rgba(0,0,0,0.3)]">
                <div class="flex items-start gap-4">
                  <div class="w-10 h-10 bg-gray-200 border-2 border-black flex items-center justify-center flex-shrink-0">
                    <i class={`${card.icon} text-lg`}></i>
                  </div>
                  <div>
                    <h4 class="font-bold mb-1">{card.title}</h4>
                    <p class="text-sm text-gray-600">{card.description}</p>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- CTA vers article comparatif -->
      <div class="mt-12 text-center">
        <a href="/blog/freelance-ou-agence-web" class="inline-flex items-center gap-2 bg-white border-2 border-black px-5 py-3 font-medium hover:bg-[var(--yellow)] transition-all shadow-[3px_3px_0px_rgba(0,0,0,1)]">
          <i class="ri-article-line"></i>
          Voir le comparatif détaillé
          <i class="ri-arrow-right-line"></i>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================== -->
  <!-- SERVICES -->
  <!-- ============================================== -->
  <section class="py-20 md:py-28 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12 md:mb-16">
        <span class="inline-flex items-center gap-2 text-xs font-mono uppercase tracking-[0.2em] text-gray-500 mb-4">
          <span class="w-8 h-px bg-gray-400"></span>
          services
          <span class="w-8 h-px bg-gray-400"></span>
        </span>
        <h2 class="text-3xl md:text-5xl font-black mb-4">
          Mes services
        </h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Du site vitrine au MVP en passant par les outils internes — un <strong>spécialiste développement web Suisse</strong> qui couvre toute la chaîne.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((service) => (
          <a
            href={service.href}
            class="group bg-white border-2 border-black p-6 shadow-[4px_4px_0px_rgba(0,0,0,0.3)] transition-all duration-200 hover:translate-x-[-2px] hover:translate-y-[-2px] hover:shadow-[6px_6px_0px_rgba(0,0,0,0.3)] hover:bg-[var(--main-bg)] flex flex-col"
          >
            <div class="w-12 h-12 bg-[var(--blue)] border-2 border-black flex items-center justify-center mb-4 group-hover:bg-[var(--yellow)] transition-colors">
              <i class={`${service.icon} text-2xl`}></i>
            </div>
            <h3 class="text-xl font-bold mb-2">{service.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed mb-4 flex-grow">{service.description}</p>
            <div class="pt-4 border-t border-dashed border-gray-300 flex items-center justify-between">
              <span class="text-sm font-mono text-[var(--blue)]">{service.price}</span>
              <i class="ri-arrow-right-line text-lg group-hover:translate-x-1 transition-transform"></i>
            </div>
          </a>
        ))}

        <!-- Card "Tous les services" -->
        <a
          href="/services"
          class="group bg-[var(--blue)] border-2 border-black p-6 shadow-[4px_4px_0px_rgba(0,0,0,0.3)] transition-all duration-200 hover:translate-x-[-2px] hover:translate-y-[-2px] hover:shadow-[6px_6px_0px_rgba(0,0,0,0.3)] flex flex-col items-center justify-center text-center"
        >
          <div class="w-12 h-12 bg-white border-2 border-black flex items-center justify-center mb-4">
