          <div>
            <p class="co-eyebrow">Cas vedette</p>
            <h3 class="dfg-proof-title">{proofLecureux.company}</h3>
            <p class="dfg-card-text">{proofLecureux.metier} — {proofLecureux.accrocheShort}.</p>
          </div>
          <a href={proofLecureux.portfolioUrl} class="dfg-inline dfg-proof-link">
            Voir l'étude de cas <i class="ri-arrow-right-line"></i>
          </a>
        </div>

        <div class="dfg-stats" data-animate-stagger>
          {caseStudyStats.map((stat) => (
            <div class="dfg-stat" data-animate-item>
              <i class={`${stat.icon} dfg-stat-icon`} aria-hidden="true"></i>
              <div class="dfg-stat-value">{stat.value}</div>
              <div class="dfg-stat-label">{stat.label}</div>
            </div>
          ))}
        </div>

        {proofLecureux.testimonial && (
          <blockquote class="dfg-quote">
            <p class="co-ser">« {proofLecureux.testimonial.quote.split("\n")[0]} »</p>
            <cite>{proofLecureux.testimonial.author} — {proofLecureux.testimonial.role}</cite>
          </blockquote>
        )}
      </div>

      <div class="dfg-projects" data-animate-stagger>
        {projects.map((project) => (
          <a href={project.href} class="dfg-project co-frame co-frame--reveal" data-animate-item>
            <div class="dfg-project-top">
              <span class="co-badge">{project.tag}</span>
              <i class="ri-external-link-line dfg-project-ext"></i>
            </div>
            <h3 class="dfg-card-title">{project.title}</h3>
            <p class="dfg-project-sector">{project.sector}</p>
            <p class="dfg-card-text">{project.description}</p>
            <span class="dfg-project-link">
              Voir le projet <i class="ri-arrow-right-line"></i>
            </span>
          </a>
        ))}
      </div>

      <div class="dfg-center" data-animate>
        <a href="/portfolio" class="co-btn">
          Voir tout le portfolio <i class="ri-arrow-right-line"></i>
        </a>
      </div>
    </section>

    <!-- ══ 07 · TARIFS ══ -->
    <section id="tarifs" class="co-sec co-pad" style="padding:56px 40px;">
      <p class="co-eyebrow">07 — Tarifs</p>
      <h2 style="margin-top:8px;">Combien ça <span class="co-ser">coûte ?</span></h2>
      <p class="co-mut" style="margin-top:10px;max-width:60ch;line-height:1.6;">
        Trois fourchettes en CHF pour situer ton projet. Devis personnalisé après notre premier échange.
      </p>

      <div class="dfg-tiers" data-animate-stagger>
        {pricingPlans.map((plan) => (
          <div class={`dfg-tier ${plan.highlighted ? 'dfg-tier--reco' : ''}`} data-animate-item>
            {plan.highlighted && <span class="co-badge co-badge--solid dfg-tier-reco">Le plus demandé</span>}
            <h3 class="dfg-tier-name">{plan.name}</h3>
            <p class="dfg-card-text">{plan.description}</p>
            <div class="dfg-tier-price">
              <span class="dfg-tier-pricelabel">{plan.priceLabel}</span>
              <b>{plan.price}<span class="dfg-tier-cur"> CHF</span></b>
            </div>
            <ul class="co-list co-list--check dfg-tier-features">
              {plan.features.map((feature) => (
                <li><i class="ri-check-line"></i><span>{feature}</span></li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <div class="dfg-center" data-animate>
        <a href="/tarifs" class="co-btn co-btn--ghost">
          <i class="ri-price-tag-3-line"></i> Voir tous les tarifs <i class="ri-arrow-right-line"></i>
        </a>
      </div>
    </section>

    <!-- ══ 08 · RESSOURCES — À LIRE AVANT DE TE DÉCIDER ══ -->
    <section id="ressources" class="co-sec co-pad" style="padding:56px 40px;">
      <p class="co-eyebrow">08 — Ressources</p>
      <h2 style="margin-top:8px;">À lire avant de te <span class="co-ser">décider</span></h2>
      <p class="co-mut" style="margin-top:10px;max-width:62ch;line-height:1.6;">
