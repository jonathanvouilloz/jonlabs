      </p>

      <div class="dfg-cards dfg-cards--3" data-animate-stagger>
        {blogArticles.map((article) => (
          <a href={article.href} class="dfg-card co-frame co-frame--reveal" data-animate-item>
            <i class={`${article.icon} dfg-card-icon`} aria-hidden="true"></i>
            <h3 class="dfg-card-title">{article.title}</h3>
            <p class="dfg-card-text">{article.description}</p>
            <div class="dfg-card-foot">
              <span class="dfg-card-price">Lire l'article</span>
              <i class="ri-arrow-right-line dfg-card-arrow"></i>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- ══ 09 · FAQ LOCALE (accordéon natif <details>, zéro JS) ══ -->
    <section id="faq" class="co-sec co-pad" style="padding:56px 40px;">
      <div class="dfg-faq-grid">
        <!-- Illustration contextuelle (cadrée blueprint, Halo supprimé) -->
        <div class="dfg-illu-col">
          <div class="dfg-illu co-frame">
            <span class="co-x tl"></span><span class="co-x tr"></span>
            <span class="co-x bl"></span><span class="co-x br"></span>
            <Image
              src={illuFreelance}
              alt=""
              class="dfg-illu-img"
              aria-hidden="true"
            />
          </div>
        </div>

        <!-- Colonne FAQ -->
        <div>
          <p class="co-eyebrow">09 — FAQ</p>
          <h2 style="margin-top:8px;">Questions fréquentes</h2>
          <p class="co-mut" style="margin-top:10px;max-width:58ch;line-height:1.6;">
