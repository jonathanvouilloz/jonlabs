---
// Devis client — document privé sous mot de passe (noindex).
// Migré du brutaliste standalone vers le design system .co-* : sections cadrées,
// filets fins, accent teal, Inter Tight × Instrument Serif. Namespace scopé .dv-*.
// Gabarit-or de référence : services/referencement-local.astro.
//
// Pas de Header/Footer : c'est un doc client, pas une page du site. Le chrome se
// limite à l'en-tête logo/client/date et au CTA de contact final.
//
// Ordre = arc de proposition : problème → raisonnement → plan → preuve → limites
// → PRIX. Le prix arrive après l'argument qui le justifie, jamais avant.
//
// HARD-PRESERVE : le JS du lock screen (IDs, clé localStorage, define:vars), les
// bindings du schéma devis (constat/postponed/comparison/pack/excluded servent
// encore les devis Constantin), le split(' — ') des noms d'offres du tableau
// comparatif, les prix exacts, noindex/nofollow.

import { getCollection } from 'astro:content';
import '../../styles/global.css';
import Layout from '../../layouts/Layout.astro';
import Logo from '../../components/Logo.astro';

export async function getStaticPaths() {
  const quotes = await getCollection('devis');
  return quotes.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const dateFormat = new Intl.DateTimeFormat('fr-CH', {
  day: 'numeric',
  month: 'long',
  year: 'numeric'
});

const {
  hero, audit, offers, showComparison, timeline, advice, proof, constat,
  roi, portfolio, postponed, disclaimer, comparison, options, legal
} = entry.data;

// `proof` accepte une preuve unique ou plusieurs. On normalise.
const proofs = proof ? (Array.isArray(proof) ? proof : [proof]) : [];
const hasBody = Boolean(entry.body.trim());

// Numérotation des eyebrows : calculée sur les sections réellement présentes.
// Un numéro en dur mentirait dès qu'un devis omet un bloc (les 2 Constantin
// n'ont ni audit ni preuve).
const sections = [
  audit && 'audit',
  constat && 'constat',
  hasBody && 'body',
  timeline?.length && 'timeline',
  proofs.length && 'proofs',
  advice && 'advice',
  disclaimer && 'disclaimer',
  offers?.length && 'offers',
  portfolio?.length && 'portfolio',
  postponed && 'postponed',
].filter(Boolean) as string[];
const num = (key: string) => String(sections.indexOf(key) + 1).padStart(2, '0');

// Les références pointent soit sur une étude de cas interne, soit sur le site du
// client. Le drapeau est calculé ici : un spread d'attributs conditionnel dans le
// template est plus fragile à compiler.
const refs = (portfolio ?? []).map(p => ({ ...p, external: p.url.startsWith('http') }));

// Contact WhatsApp — numéro canonique du site (cf. Footer.astro, data/schema.ts).
// waMessage est extrait volontairement : imbriquer un template literal dans
// l'interpolation d'un autre désynchronise le scanner esbuild qui relit le
// frontmatter, et fait échouer le build sur un « Unexpected export » sans rapport
// (15.07.2026). Même famille de piège que la balise script écrite en commentaire.
const WHATSAPP = '41789447707';
const waMessage = `Bonjour Jonathan, j'ai une question sur la proposition pour ${entry.data.client}.`;
const waHref = `https://wa.me/${WHATSAPP}?text=${encodeURIComponent(waMessage)}`;
---

<Layout title={`Proposition — ${entry.data.client}`} robots="noindex, nofollow">

  <div id="lock-screen" class="co-chrome">
    <div class="dv-lock-card">
      <i class="ri-lock-line dv-lock-ic" aria-hidden="true"></i>
      <h2 class="dv-lock-title">Document privé</h2>
      <p class="dv-lock-lead">Entrez le code d'accès qui vous a été transmis.</p>
      <form id="unlock-form" class="dv-lock-form">
        <input
          type="password"
          id="password-input"
          class="dv-lock-input"
          placeholder="Code d'accès"
          autocomplete="current-password"
          aria-label="Code d'accès"
        />
        <button type="submit" class="co-btn dv-lock-btn">
          Ouvrir le document <i class="ri-arrow-right-line"></i>
        </button>
        <p id="error-msg" class="dv-lock-err hidden">
          <i class="ri-error-warning-line"></i> Code incorrect
        </p>
      </form>
    </div>
  </div>

  <main id="main-content" class="co-root hidden">

    <!-- En-tête document -->
    <header class="dv-head co-pad">
      <div class="dv-head-brand">
        <Logo />
      </div>
      <dl class="co-spec dv-head-spec">
        <div class="co-spec-row"><dt>Pour</dt><dd>{entry.data.client}</dd></div>
        <div class="co-spec-row"><dt>Date</dt><dd>{dateFormat.format(entry.data.date)}</dd></div>
      </dl>
    </header>

    <!-- Hero : H1 + cadrage. Pas d'eyebrow au-dessus du H1 (règle gravée). -->
    <section class="co-sec co-pad co-hero dv-sec" style="padding:64px 40px 56px;">
      <h1 class="dv-h1" data-animate data-delay="0.1">{entry.data.title}</h1>
      {hero && (
        <div class="dv-hero-box co-frame" data-animate data-delay="0.2">
          <dl class="dv-hero-list">
            <div class="dv-hero-row">
              <dt>Priorité</dt>
              <dd>{hero.priority}</dd>
            </div>
            <div class="dv-hero-row">
              <dt>Problème</dt>
              <dd>{hero.problem}</dd>
            </div>
            <div class="dv-hero-row">
              <dt>Solution</dt>
              <dd>{hero.solution}</dd>
            </div>
          </dl>
        </div>
      )}
    </section>

    <!-- Le diagnostic -->
    {audit && (
      <section class="co-sec co-pad dv-sec" style="padding:56px 40px;">
        <p class="co-eyebrow">{num('audit')} — Le diagnostic</p>
        <h2 style="margin-top:8px;">{audit.title}</h2>
        {audit.intro && <p class="dv-lead" set:html={audit.intro} />}

        {audit.moments && (
          <div class="dv-moments" data-animate-stagger>
            {audit.moments.map(m => (
              <div class="dv-moment" data-animate-item>
                <p class="dv-moment-q">{m.query}</p>
                <p class="dv-moment-f" set:html={m.finding} />
              </div>
            ))}
          </div>
        )}

        {audit.scores && (
          <div class="dv-scores" data-animate-stagger>
            {audit.scores.map(s => (
              <div class={`dv-score dv-score--${s.tone}`} data-animate-item>
                <div class="dv-score-val">{s.value}</div>
                <div class="dv-score-lbl">{s.label}</div>
              </div>
            ))}
          </div>
        )}

        {audit.screenshot && (
          <figure class="dv-shot co-frame" data-animate>
            <img src={audit.screenshot.image} alt={audit.title} loading="lazy" />
            {audit.screenshot.caption && <figcaption set:html={audit.screenshot.caption} />}
          </figure>
        )}

        {audit.nuance && (
          <div class="dv-callout" data-animate>
            <h3 class="dv-callout-title">{audit.nuance.title}</h3>
            <p class="dv-callout-text" set:html={audit.nuance.content} />
          </div>
        )}

        <div class="dv-ask">
          <p class="dv-ask-text">Une question sur ce constat ?</p>
          <a href={waHref} target="_blank" rel="noopener" class="co-btn co-btn--ghost dv-wa">
            <i class="ri-whatsapp-line"></i> Écrivez-moi sur WhatsApp
          </a>
        </div>
      </section>
    )}

    <!-- Constat (devis sans bloc audit) -->
    {constat && (
      <section class="co-sec co-pad dv-sec" style="padding:56px 40px;">
        <p class="co-eyebrow">{num('constat')} — Le constat</p>
        <h2 style="margin-top:8px;">Ce que j'ai relevé</h2>
        <div class="dv-callout" style="margin-top:24px;">
          <p class="dv-callout-text" set:html={constat} />
        </div>
      </section>
    )}

    <!-- Le raisonnement (corps markdown) -->
    {hasBody && (
      <section class="co-sec co-pad dv-sec" style="padding:56px 40px;">
        <p class="co-eyebrow">{num('body')} — Le raisonnement</p>
        <div class="co-prose dv-prose">
          <Content />
        </div>
      </section>
    )}

    <!-- Le plan -->
    {timeline && timeline.length > 0 && (
      <section class="co-sec co-pad dv-sec" style="padding:56px 40px;">
        <p class="co-eyebrow">{num('timeline')} — Le plan</p>
        <h2 style="margin-top:8px;">Comment ça <span class="co-ser">se déroule</span></h2>
        <div class="dv-steps">
          {timeline.map((t, i) => (
            <div class="dv-step">
              <span class="co-index dv-step-num">{String(i + 1).padStart(2, '0')}</span>
              <div>
                <h3 class="dv-step-title">{t.step}</h3>
                <p class="dv-step-text" set:html={t.description} />
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Les preuves -->
    {proofs.length > 0 && (
      <section class="co-sec co-pad dv-sec" style="padding:56px 40px;">
        <p class="co-eyebrow">{num('proofs')} — Les preuves</p>
        <h2 style="margin-top:8px;">
          {proofs.length > 1 ? 'Des dossiers comparables' : 'Un dossier comparable'}
        </h2>
        <div class="dv-proofs">
          {proofs.map(p => (
            <article class="dv-proof co-frame">
              <h3 class="dv-proof-title">{p.title}</h3>
              <img src={p.image} alt={p.title} class="dv-proof-img" loading="lazy" />
              <div class="dv-proof-stats">
                {p.stats.map(stat => (
                  <div class="dv-proof-stat">
                    <div class="dv-proof-val">{stat.value}</div>
                    <div class="dv-proof-lbl">{stat.label}</div>
                  </div>
                ))}
              </div>
              {p.caption && <p class="dv-proof-cap" set:html={p.caption} />}
              {p.caseStudy && (
                <a href={p.caseStudy} class="dv-proof-link">
                  Voir l'étude de cas <i class="ri-arrow-right-line"></i>
                </a>
              )}
            </article>
          ))}
        </div>

        <div class="dv-ask">
          <p class="dv-ask-text">Vous voulez en parler de vive voix ?</p>
          <a href={waHref} target="_blank" rel="noopener" class="co-btn co-btn--ghost dv-wa">
            <i class="ri-whatsapp-line"></i> Écrivez-moi sur WhatsApp
          </a>
        </div>
      </section>
    )}

    <!-- Mon conseil -->
    {advice && (
      <section class="co-sec co-pad dv-sec" style="padding:56px 40px;">
        <p class="co-eyebrow">{num('advice')} — Mon conseil</p>
        <div class="dv-advice">
          <i class="ri-lightbulb-line" aria-hidden="true"></i>
          <p class="dv-advice-text">{advice}</p>
        </div>
      </section>
    )}

    <!-- Ce que je ne promets pas -->
    {disclaimer && (
      <section class="co-sec co-pad dv-sec" style="padding:56px 40px;">
        <p class="co-eyebrow">{num('disclaimer')} — Les limites</p>
        <h2 style="margin-top:8px;">{disclaimer.title}</h2>
        <div class="dv-callout" style="margin-top:24px;">
          <p class="dv-callout-text" set:html={disclaimer.content} />
        </div>
      </section>
    )}

    <!-- La proposition : le prix arrive ici, après l'argument -->
    {offers && offers.length > 0 && (
      <section class="co-sec co-pad dv-sec" style="padding:56px 40px;">
        <p class="co-eyebrow">{num('offers')} — La proposition</p>
        <h2 style="margin-top:8px;">
          {showComparison ? 'Comparaison des offres' : 'Le détail et le prix'}
        </h2>

        {showComparison && (
          <div class="dv-table-wrap">
            <table class="dv-table">
              <thead>
                <tr>
                  <th>Caractéristique</th>
                  {offers.map(o => <th style="text-align:center">{o.name.split(' — ')[1] || o.name}</th>)}
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td><strong>Prix</strong></td>
                  {offers.map(o => <td style="text-align:center" class="dv-table-price">{o.price}</td>)}
                </tr>
                {comparison ? (
                  comparison.map(row => (
                    <tr>
                      <td>{row.label}</td>
                      <td style="text-align:center">
                        {typeof row.starter === 'boolean'
                          ? (row.starter
                              ? <i class="ri-check-line dv-yes" aria-label="Inclus"></i>
                              : <i class="ri-close-line dv-no" aria-label="Non inclus"></i>)
                          : row.starter}
                      </td>
                      <td style="text-align:center">
                        {typeof row.premium === 'boolean'
                          ? (row.premium
                              ? <i class="ri-check-line dv-yes" aria-label="Inclus"></i>
                              : <i class="ri-close-line dv-no" aria-label="Non inclus"></i>)
                          : row.premium}
                      </td>
                    </tr>
                  ))
                ) : (
                  <>
                    <tr>
                      <td>SEO Local</td>
                      {offers.map(o => <td style="text-align:center">{o.name.includes('Starter') ? <i class="ri-close-line dv-no" aria-label="Non inclus"></i> : <i class="ri-check-line dv-yes" aria-label="Inclus"></i>}</td>)}
                    </tr>
                    <tr>
                      <td>Bilingue FR/EN</td>
                      {offers.map(o => <td style="text-align:center">{o.name.includes('Starter') ? <i class="ri-close-line dv-no" aria-label="Non inclus"></i> : <i class="ri-check-line dv-yes" aria-label="Inclus"></i>}</td>)}
                    </tr>
                    <tr>
                      <td>Avis Automatisés</td>
                      {offers.map(o => <td style="text-align:center">{o.name.includes('Starter') ? <i class="ri-close-line dv-no" aria-label="Non inclus"></i> : <i class="ri-check-line dv-yes" aria-label="Inclus"></i>}</td>)}
                    </tr>
                  </>
                )}
              </tbody>
            </table>
          </div>
        )}

        <div class="dv-tiers">
          {offers.map(o => (
            <div class={`dv-tier ${o.recommended ? 'dv-tier--reco' : ''}`}>
              {o.recommended && (
                <span class="co-badge co-badge--solid dv-tier-badge">Recommandé</span>
              )}
              <h3 class="dv-tier-name">{o.name}</h3>
              <div class="dv-tier-price"><b>{o.price}</b></div>
              {o.subtitle && <p class="dv-tier-sub">{o.subtitle}</p>}
              <ul class="dv-tier-features">
                {o.features.map(f => (
                  f === f.toUpperCase() && /[A-ZÀ-Ý]/.test(f)
                    ? <li class="dv-feature-group">{f}</li>
                    : <li class="dv-feature"><i class="ri-check-line"></i><span>{f}</span></li>
                ))}
                {o.excluded?.map(e => (
                  <li class="dv-feature dv-feature--out"><i class="ri-close-line"></i><span>{e}</span></li>
                ))}
              </ul>
            </div>
          ))}
        </div>

        {roi && (
          <div class="dv-roi">
            <h3 class="dv-roi-title">Le calcul</h3>
            <p class="dv-roi-context">{roi.context}</p>
            <p class="dv-roi-calc">{roi.calculation}</p>
            <p class="dv-roi-result">{roi.result}</p>
          </div>
        )}

        {options && options.length > 0 && (
          <div class="dv-options">
            <h3 class="dv-options-title">À discuter ensemble</h3>
            <p class="dv-options-lead">
              Rien de tout ça n'est nécessaire au démarrage, et rien n'est chiffré ici :
              ça dépend de ce que vous avez déjà en interne. On en parle, je regarde, et
              je vous dis ce qui vaut le coup.
            </p>
            <ul class="dv-options-list">
              {options.map(o => (
                <li class="dv-option">
                  <div class="dv-option-main">
                    <span class="dv-option-name">{o.name}</span>
                    <span class="dv-option-benefit">{o.benefit}</span>
                  </div>
                  {o.price && <span class="dv-option-price">{o.price}</span>}
                </li>
              ))}
            </ul>
          </div>
        )}

        {legal && <p class="dv-legal" set:html={legal} />}
      </section>
    )}

    <!-- Références -->
    {portfolio && portfolio.length > 0 && (
      <section class="co-sec co-pad dv-sec" style="padding:56px 40px;">
        <p class="co-eyebrow">{num('portfolio')} — Références</p>
        <h2 style="margin-top:8px;">Quelques <span class="co-ser">réalisations</span></h2>
        <div class="dv-refs">
          {refs.map(p => (
            <a
              href={p.url}
              class="dv-ref co-frame co-frame--reveal"
              target={p.external ? '_blank' : undefined}
              rel={p.external ? 'noopener' : undefined}
            >
              <h3 class="dv-ref-name">{p.name}</h3>
              <p class="dv-ref-desc">{p.description}</p>
              <span class="dv-ref-go">
                {p.external ? 'Voir le site' : "Voir l'étude de cas"}
                <i class={p.external ? 'ri-external-link-line' : 'ri-arrow-right-line'}></i>
              </span>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Reporté -->
    {postponed && (
      <section class="co-sec co-pad dv-sec" style="padding:56px 40px;">
        <p class="co-eyebrow">{num('postponed')} — Reporté</p>
        <h2 style="margin-top:8px;">{postponed.title}</h2>
        <div class="dv-callout" style="margin-top:24px;">
          <p class="dv-callout-text">{postponed.reason}</p>
          {postponed.action && postponed.link && (
            <p class="dv-callout-text" style="margin-top:12px;">
              {postponed.action} : <a href={postponed.link} target="_blank" rel="noopener" class="dv-inline">{postponed.link}</a>
            </p>
          )}
        </div>
      </section>
    )}

    <!-- CTA final -->
    <section class="co-cta dv-cta">
      <span class="co-x tl"></span><span class="co-x tr"></span>
      <div class="co-cta-inner">
        <h2 class="co-cta-title">Une question sur <span class="co-ser">ce devis ?</span></h2>
        <p class="co-cta-lead">
          Envoyez-moi un message sur WhatsApp, même pour un détail. Je réponds
          dans la journée, et il n'y a pas de mauvaise question.
        </p>
        <div class="co-cta-btns">
          <a href={waHref} target="_blank" rel="noopener" class="co-btn co-cta-btn dv-cta-wa">
            <i class="ri-whatsapp-line"></i> M'écrire sur WhatsApp
          </a>
        </div>
        <div class="co-cta-trust">
          <a href="tel:+41789447707"><i class="ri-phone-line"></i> 078 944 77 07</a>
          <a href="mailto:contact@jonlabs.ch"><i class="ri-mail-line"></i> contact@jonlabs.ch</a>
        </div>
      </div>
    </section>

  </main>

  

  <script define:vars={{ correctPassword: entry.data.password, slug: entry.slug }}>
    const storageKey = `unlocked_devis_${slug}`;
    const lockScreen = document.getElementById('lock-screen');
    const mainContent = document.getElementById('main-content');
    const form = document.getElementById('unlock-form');
    const input = document.getElementById('password-input');

    if (localStorage.getItem(storageKey) === 'true' || !correctPassword) {
      lockScreen.classList.add('hidden');
      mainContent.classList.remove('hidden');
    }

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      if (input.value === correctPassword) {
        localStorage.setItem(storageKey, 'true');
        lockScreen.classList.add('hidden');
        mainContent.classList.remove('hidden');
      } else {
        document.getElementById('error-msg').classList.remove('hidden');
      }
    });
  </script>

</Layout>

<style is:global>
  /* ══ DEVIS CLIENT — styles .dv-* (namespace scopé, corps .co-root) ══ */

  .hidden { display: none !important; }

  /* Sévérité du diagnostic : exception assumée à l'accent unique.
     Sur un diagnostic, rouge/vert EST l'information (Jonathan, 15.07.2026).
     Intensité tenue : le chiffre porte la couleur, la carte reste neutre. */
  .co-root, .co-chrome {
    --dv-bad: #C4342B;
    --dv-mid: #B0741A;
  }

  /* ── Lock screen ── */
  #lock-screen {
    position: fixed; inset: 0; z-index: 100;
    background: var(--bg);
    display: flex; align-items: center; justify-content: center; padding: 20px;
  }
  .dv-lock-card {
    display: flex; flex-direction: column; align-items: center; text-align: center;
    gap: 10px; width: 100%; max-width: 420px; padding: 40px 32px;
    background: var(--surface); border: 1px solid var(--line-2);
  }
  .dv-lock-ic { font-size: 30px; color: var(--accent); line-height: 1; }
  .dv-lock-title { font-size: 1.4rem; font-weight: 700; letter-spacing: -0.025em; margin: 0; }
  .dv-lock-lead { margin: 0; font-size: 14.5px; line-height: 1.55; color: var(--muted); }
  .dv-lock-form { display: flex; flex-direction: column; gap: 12px; width: 100%; margin-top: 14px; }
  .dv-lock-input {
    /* min-width:0 — un input en flex/grid garde sa largeur min-content et déborde,
       débordement invisible car clippé par .co-root{overflow:hidden}. */
    width: 100%; min-width: 0;
    font-family: "Inter Tight", ui-sans-serif, sans-serif; font-size: 15px; color: var(--ink);
    background: var(--bg); border: 1px solid var(--line-2); padding: 12px 14px; text-align: center;
    letter-spacing: 0.08em;
    transition: border-color .18s ease-out, box-shadow .18s ease-out;
  }
  .dv-lock-input::placeholder { color: var(--muted); opacity: .7; letter-spacing: 0; }
  .dv-lock-input:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 3px rgba(0,168,125,.15); }
  .dv-lock-btn { justify-content: center; border: 0; cursor: pointer; font-family: inherit; }
  .dv-lock-err { margin: 0; font-size: 13px; color: var(--dv-bad); display: inline-flex; align-items: center; justify-content: center; gap: 6px; }

  /* ── En-tête document ── */
  .dv-head {
    display: flex; align-items: flex-end; justify-content: space-between;
    gap: 32px; flex-wrap: wrap; padding: 28px 40px;
  }
  .dv-head-brand { line-height: 0; }
  .dv-head-spec { min-width: 240px; border-top: 0; }

  /* ── Hero ── */
  .co-root .dv-h1 { font-size: clamp(2.1rem, 4.8vw, 3.2rem); line-height: 1.06; letter-spacing: -0.03em; max-width: 20ch; }
  .dv-hero-box {
    position: relative; margin-top: 32px; padding: 30px 32px;
    background: var(--surface); border: 1px solid var(--line-2);
  }
  .dv-hero-list { display: flex; flex-direction: column; gap: 20px; margin: 0; }
  .dv-hero-row { display: grid; grid-template-columns: 96px 1fr; gap: 18px; align-items: baseline; }
  .dv-hero-row dt { font-size: 11px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); }
  .dv-hero-row dd { margin: 0; font-size: 1.02rem; line-height: 1.6; }

  /* ── Corps de section ── */
