---
import '../../styles/global.css';
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import AppHeader from '../../components/Header.astro';
import AppFooter from '../../components/Footer.astro';
import CategoryBadge from '../../components/blog/CategoryBadge.astro';
import VideoEmbed from '../../components/blog/VideoEmbed.astro';
import AuthorBio from '../../components/blog/AuthorBio.astro';
import RelatedPosts from '../../components/blog/RelatedPosts.astro';
import ReadingProgress from '../../components/blog/ReadingProgress.astro';
import { formatDate, getRelatedPosts, isPublished } from '../../lib/blog';
import { author } from '../../sample';
import { getBlogPostingSchema, getBreadcrumbSchema, getFAQPageSchema } from '../../lib/seo';
import { SITE_URL, personData, organizationData } from '../../data/schema';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => isPublished(data));
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post, allPosts: posts },
  }));
}

const { post, allPosts } = Astro.props;
const { title, h1, description, image, category, tags, pubDate, readingTime, youtubeId, youtubeTitle } = post.data;
const { Content } = await post.render();

const relatedPosts = getRelatedPosts(post, allPosts, 3);

// Generate schemas
const blogPostingSchema = getBlogPostingSchema({
  title,
  description,
  url: Astro.url.href,
  image: new URL(image.url, Astro.site).toString(),
  datePublished: pubDate,
  dateModified: post.data.updatedDate || pubDate,
  author: author.name,
  category,
  tags,
  readingTime
});

const breadcrumbSchema = getBreadcrumbSchema([
  { name: 'Accueil', url: SITE_URL },
  { name: 'Blog', url: `${SITE_URL}/blog` },
  { name: title, url: Astro.url.href },
]);

const schemas = [
  personData,
  organizationData,
  blogPostingSchema,
  breadcrumbSchema,
];
if (post.data.faqs && post.data.faqs.length > 0) {
  schemas.push(getFAQPageSchema(post.data.faqs));
}
---

<Layout
  title={title}
  description={description}
  ogImage={image.url}
  ogType="article"
  schemas={schemas}
  article={{
    publishedTime: pubDate,
    modifiedTime: post.data.updatedDate,
    author: author.name,
    section: category,
    tags
  }}
>
  <AppHeader />

  <main class="co-root">
    <article class="ar-wrap co-pad">
      <div class="ar-grid">
        <!-- Article content -->
        <div class="ar-main">
          <!-- Mobile TOC - visible only below xl -->
          <div class="ar-mtoc">
            <button
              id="mobile-toc-toggle"
              class="ar-mtoc-btn"
              aria-expanded="false"
              aria-controls="mobile-toc-content"
            >
              <span class="ar-mtoc-label"><i class="ri-list-unordered"></i> Sommaire</span>
              <i class="ri-arrow-down-s-line ar-mtoc-caret" id="mobile-toc-icon"></i>
            </button>
            <div id="mobile-toc-content" class="ar-mtoc-content hidden">
              <nav id="mobile-toc-nav" aria-label="Table des matières mobile">
                <ul id="mobile-toc-list" class="bl-rp-toc"></ul>
              </nav>
            </div>
          </div>

          <!-- Top bar: back + share -->
          <div class="ar-topbar">
            <a href="/blog" class="ar-back">
              <i class="ri-arrow-left-line"></i>
              Retour au blog
            </a>
            <div class="ar-share">
              <a
                href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(Astro.url.href)}`}
                target="_blank" rel="noopener noreferrer" aria-label="Partager sur X"
              ><i class="ri-twitter-x-line"></i></a>
              <a
                href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(Astro.url.href)}`}
                target="_blank" rel="noopener noreferrer" aria-label="Partager sur LinkedIn"
              ><i class="ri-linkedin-fill"></i></a>
              <button
                aria-label="Copier le lien"
                onclick="navigator.clipboard.writeText(window.location.href); this.innerHTML='<i class=\'ri-check-line\'></i>'; setTimeout(() => this.innerHTML='<i class=\'ri-link\'></i>', 2000)"
              ><i class="ri-link"></i></button>
            </div>
          </div>

          <!-- Meta -->
          <div class="ar-meta">
            <CategoryBadge category={category} size="md" />
            <span class="ar-date">{formatDate(pubDate)}</span>
            {readingTime && (
              <span class="ar-rt"><i class="ri-time-line"></i> {readingTime} min de lecture</span>
            )}
          </div>

          <!-- Title (H1 distinct du title SEO ; fallback sur title si absent) -->
          <h1 class="ar-title">{h1 ?? title}</h1>

          <!-- Vidéo YouTube (optionnelle, pilotée par le frontmatter youtubeId) -->
          {youtubeId && <VideoEmbed youtubeId={youtubeId} title={youtubeTitle ?? title} />}

          <!-- Tags -->
          {tags.length > 0 && (
            <div class="ar-tags">
              {tags.map((tag) => (
                <a href={`/blog/tag/${tag}`} class="ar-tag">#{tag}</a>
              ))}
            </div>
          )}

          <!-- Article content -->
          <div class="co-prose">
            <Content />
          </div>

          <!-- Share section -->
          <div class="ar-foot">
            <a href="/blog" class="ar-back">
              <i class="ri-arrow-left-line"></i>
              Retour au blog
            </a>
            <button
              class="ar-foot-share"
              aria-label="Partager"
              onclick="navigator.share ? navigator.share({title: document.title, url: window.location.href}) : null"
            ><i class="ri-share-forward-line"></i></button>
          </div>
        </div>

        <!-- Sidebar TOC - sticky -->
        <aside class="ar-side">
          <div class="ar-side-sticky">
            <ReadingProgress readingTime={readingTime} />
          </div>
        </aside>
      </div>
    </article>

    <RelatedPosts posts={relatedPosts} />
    <AuthorBio />
  </main>

  <AppFooter />
</Layout>
