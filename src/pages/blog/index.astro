---
import '../../styles/global.css';
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import AppHeader from '../../components/Header.astro';
import AppFooter from '../../components/Footer.astro';
import BlogHero from '../../components/blog/BlogHero.astro';
import BlogFilters from '../../components/blog/BlogFilters.astro';
import PostCard from '../../components/blog/PostCard.astro';
import { isPublished, getCategorySlug, formatDateShort } from '../../lib/blog';

// Schema.org
import { blogSchema } from '../../data/schema';

// Get all published posts (drafts excluded + future pubDate gated)
const allPosts = await getCollection('blog', ({ data }) => isPublished(data));

// Sort by date (newest first)
const sortedPosts = allPosts.sort((a, b) =>
  b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// Article à la une = le plus récent (statique, hors filtrage). Grille = le reste.
const featured = sortedPosts[0];
const gridPosts = sortedPosts.slice(1);

const schemas = [blogSchema];
---

<Layout
  title="Blog | Développement Web & Automatisation | Jon Labs"
  description="Articles et réflexions sur le développement web, l'automatisation et l'entrepreneuriat digital. Retours d'expérience concrets par Jonathan Vouilloz."
  schemas={schemas}
>
  <AppHeader />

  <main class="co-root">

    <!-- ══ HERO ══ -->
    <BlogHero />

    <!-- ══ 01 · ARTICLE À LA UNE ══ -->
    {featured && (
      <section class="co-sec co-pad" style="padding:48px 40px;">
        <p class="co-eyebrow">01 — À la une</p>
        <a href={`/blog/${featured.slug}`} class="bl-feature co-frame" data-animate>
          <div class="bl-feature-cover">
            <img src={featured.data.image.url} alt={featured.data.image.alt} loading="lazy" />
          </div>
          <div class="bl-feature-body">
            <span class="bl-cat">{getCategorySlug(featured.data.category)}</span>
            <h2 class="bl-feature-title">{featured.data.title}</h2>
            <p class="co-mut bl-feature-desc">{featured.data.description}</p>
            <div class="bl-meta">
              <time datetime={featured.data.pubDate.toISOString()}>{formatDateShort(featured.data.pubDate)}</time>
              {featured.data.readingTime && <span>· {featured.data.readingTime} min de lecture</span>}
            </div>
            <span class="bl-feature-cta">Lire l'article <i class="ri-arrow-right-line"></i></span>
          </div>
        </a>
      </section>
    )}

    <!-- ══ 02 · LISTE + FILTRES + VUES ══ -->
    <section class="co-sec co-pad" style="padding:48px 40px 64px;">
      <div class="bl-listhead">
        <div>
          <p class="co-eyebrow">02 — Tous les articles</p>
          <h2 style="margin-top:8px;">Explorer le blog</h2>
        </div>
        <div class="bl-viewtoggle" role="group" aria-label="Mode d'affichage">
          <button class="bl-view-btn is-active" data-view-btn="grid" aria-pressed="true" aria-label="Vue grille"><i class="ri-grid-fill"></i></button>
          <button class="bl-view-btn" data-view-btn="list" aria-pressed="false" aria-label="Vue liste"><i class="ri-list-check"></i></button>
        </div>
      </div>

      <!-- Filtres (catégories + recherche) + JS (filtre / recherche / toggle / pagination) -->
      <BlogFilters />

      <!-- Grille d'articles -->
      <div id="posts-list" class="bl-grid" data-view="grid" data-animate>
        {gridPosts.map((post) => (
          <PostCard post={post} />
        ))}
      </div>

      <!-- Empty state -->
      <p id="no-results" class="bl-noresult co-mut" hidden>Aucun article ne correspond à votre recherche.</p>

      <!-- Pagination (générée par JS dans #page-numbers) -->
      <nav id="pagination" class="bl-pagination" aria-label="Pagination">
        <button id="prev-page" class="bl-page bl-page--nav" aria-label="Page précédente" disabled>
          <i class="ri-arrow-left-s-line"></i>
        </button>
        <div id="page-numbers" class="bl-pagination"></div>
        <button id="next-page" class="bl-page bl-page--nav" aria-label="Page suivante">
          <i class="ri-arrow-right-s-line"></i>
        </button>
      </nav>
    </section>

  </main>

  <AppFooter />
</Layout>

<style is:global>
  /* ══ Blog index blueprint — .bl-* (dans .co-root) ══ */

  /* Article à la une */
  .bl-feature {
    position: relative; display: grid; grid-template-columns: 1.1fr 1fr; gap: 0; margin-top: 28px;
    border: 1px solid var(--line-2); background: var(--surface);
    transition: box-shadow .2s ease-out;
  }
  .bl-feature:hover { box-shadow: 0 8px 26px rgba(20, 22, 26, .08); }
  .bl-feature-cover { position: relative; overflow: hidden; border-right: 1px solid var(--line-2); min-height: 300px; }
  .bl-feature-cover img { width: 100%; height: 100%; object-fit: cover; transition: transform .5s ease-out; }
  .bl-feature:hover .bl-feature-cover img { transform: scale(1.04); }
  .bl-feature-body { padding: 36px; display: flex; flex-direction: column; align-items: flex-start; gap: 14px; justify-content: center; }
  .bl-feature-title { font-size: clamp(1.5rem, 2.4vw, 2.1rem); line-height: 1.1; }
  .co-root .bl-feature-desc { line-height: 1.6; font-size: 1.02rem; max-width: 46ch; }
  .bl-feature-cta { display: inline-flex; align-items: center; gap: 8px; margin-top: 6px; font-weight: 600; color: var(--accent); }
  .bl-feature-cta i { transition: transform .18s ease-out; }
  .bl-feature:hover .bl-feature-cta i { transform: translateX(4px); }

  /* Meta (partagé avec .bl-meta de PostCard) */
  .bl-feature .bl-meta { display: flex; align-items: center; gap: 6px; font-size: 13px; color: var(--muted); }

  /* En-tête de liste + toggle vue */
  .bl-listhead { display: flex; align-items: flex-end; justify-content: space-between; gap: 16px; flex-wrap: wrap; }
  .bl-viewtoggle { display: flex; gap: 4px; border: 1px solid var(--line-2); padding: 3px; }
  .bl-view-btn {
    display: inline-flex; align-items: center; justify-content: center; width: 34px; height: 30px;
    background: none; border: 0; cursor: pointer; color: var(--muted); font-size: 17px;
    transition: background .16s ease-out, color .16s ease-out;
  }
  .bl-view-btn.is-active { background: var(--ink); color: #fff; }

  /* Grille */
  .bl-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  /* Mode liste : une seule colonne, cartes empilées (id+attr > media queries) */
  #posts-list[data-view="list"] { grid-template-columns: 1fr; gap: 0; border-top: 1px solid var(--line); }

  /* Empty state */
  .co-root .bl-noresult { margin-top: 24px; }

  /* Pagination */
  .bl-pagination { display: flex; align-items: center; gap: 6px; margin-top: 36px; justify-content: center; }
  #page-numbers.bl-pagination { margin-top: 0; }
  .bl-page {
    display: inline-flex; align-items: center; justify-content: center; min-width: 38px; height: 38px;
    padding: 0 10px; font-family: inherit; font-size: 14px; font-weight: 500; cursor: pointer;
    background: var(--surface); border: 1px solid var(--line-2); color: var(--ink);
    transition: all .16s ease-out;
  }
  .bl-page:hover:not(:disabled):not(.is-active) { border-color: var(--ink); }
  .bl-page.is-active { background: var(--ink); color: #fff; border-color: var(--ink); }
  .bl-page:disabled { opacity: .4; cursor: not-allowed; }
  .bl-page--nav { font-size: 18px; }

  /* Responsive */
  @media (max-width: 980px) {
    .bl-grid { grid-template-columns: repeat(2, 1fr); }
    .bl-feature { grid-template-columns: 1fr; }
    .bl-feature-cover { border-right: 0; border-bottom: 1px solid var(--line-2); min-height: 220px; }
  }
  @media (max-width: 720px) {
    .bl-grid { grid-template-columns: 1fr; }
  }
  @media (prefers-reduced-motion: reduce) {
    .bl-feature, .bl-feature-cover img, .bl-feature-cta i { transition: none; }
  }
</style>
