---
// Page Mentions légales & Confidentialité — Jon Labs (blueprint)
// Migrée du brutaliste : chrome blueprint, corps .co-root, prose légale cadrée.
import '../styles/global.css'
import Layout from "../layouts/Layout.astro"
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'

const pageTitle = "Mentions légales & Politique de confidentialité";
const pageDescription = "Mentions légales, conditions d'utilisation et politique de confidentialité du site jonlabs.ch. Responsable : Jonathan Vouilloz, Genève.";
---

<Layout
  title={pageTitle}
  description={pageDescription}
  robots="noindex, follow"
>
  <Header />

  <main class="co-root">

    <!-- ══ INTRO ══ -->
    <section class="co-sec co-pad" style="padding:64px 40px 40px;">
      <div class="ml-col">
        <h1 style="font-size:clamp(2.1rem,5vw,3.2rem);margin-top:14px;" data-animate data-delay="0.1">
          Mentions légales &amp; <span class="co-ser">confidentialité.</span>
        </h1>
        <p class="co-mut ml-lead" data-animate data-delay="0.2">
          Responsable, hébergement, propriété intellectuelle et traitement des données
          personnelles du site jonlabs.ch, conformément à la Loi fédérale sur la
          protection des données (LPD).
        </p>
      </div>
    </section>

    <!-- ══ 01 · MENTIONS LÉGALES ══ -->
    <section class="co-sec co-pad" style="padding:48px 40px;">
      <div class="ml-col">
        <p class="co-eyebrow">01 — Mentions légales</p>
        <h2 class="ml-h2">Mentions légales</h2>

        <!-- Coordonnées / infos légales -->
        <dl class="co-spec ml-spec">
          <div class="co-spec-row">
            <dt>Responsable</dt>
            <dd>
              Jonathan Vouilloz<br>
              Jon Labs — Raison individuelle
            </dd>
          </div>
          <div class="co-spec-row">
            <dt>Adresse</dt>
            <dd>
              120, chemin de la montagne<br>
              1224 Chêne-Bougeries, Genève<br>
              Suisse
            </dd>
          </div>
          <div class="co-spec-row">
            <dt>Contact</dt>
            <dd>
              Email : <a href="mailto:contact@jonlabs.ch" class="ml-link">contact@jonlabs.ch</a><br>
              Téléphone : +41 78 944 77 07
            </dd>
          </div>
          <div class="co-spec-row">
            <dt>Hébergement</dt>
            <dd>
              Le site est hébergé par <strong>Vercel Inc.</strong><br>
              440 N Barranca Ave #4133, Covina, CA 91723, États-Unis<br>
              <a href="https://vercel.com" target="_blank" rel="noopener noreferrer" class="ml-link">vercel.com</a>
            </dd>
          </div>
        </dl>

        <div class="ml-prose">
          <div class="ml-block">
            <h3>Propriété intellectuelle</h3>
            <p>
              L'ensemble du contenu de ce site (textes, images, code, design) est la propriété de Jonathan Vouilloz / Jon Labs, sauf mention contraire. Toute reproduction, même partielle, est interdite sans autorisation préalable.
            </p>
          </div>

          <div class="ml-block">
            <h3>Responsabilité</h3>
            <p>
              Les informations publiées sur ce site sont fournies à titre indicatif. Jon Labs ne saurait être tenu responsable de l'utilisation qui en est faite, ni des éventuelles erreurs ou omissions. Les liens vers des sites externes sont fournis à titre informatif et n'engagent pas la responsabilité de Jon Labs.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ══ 02 · POLITIQUE DE CONFIDENTIALITÉ ══ -->
    <section id="confidentialite" class="co-sec co-pad" style="padding:48px 40px 64px;">
      <div class="ml-col">
        <p class="co-eyebrow">02 — Confidentialité (LPD)</p>
        <h2 class="ml-h2">Politique de confidentialité</h2>

        <p class="ml-intro">
          Cette politique de confidentialité s'applique au site <strong>jonlabs.ch</strong> et est conforme à la Loi fédérale sur la protection des données (LPD) en vigueur en Suisse.
        </p>

        <div class="ml-prose">
          <div class="ml-block">
            <h3>Responsable du traitement</h3>
            <p>
              Jonathan Vouilloz — Jon Labs<br>
              Email : <a href="mailto:contact@jonlabs.ch" class="ml-link">contact@jonlabs.ch</a>
            </p>
          </div>

          <div class="ml-block">
            <h3>Données collectées</h3>
            <p>Ce site peut collecter les données suivantes :</p>
            <ul class="co-list">
              <li><strong>Formulaire de contact</strong> : nom, email, message (via Web3Forms). Ces données sont utilisées uniquement pour répondre à votre demande.</li>
              <li><strong>Données de navigation</strong> : adresse IP, type de navigateur, pages visitées, via les logs serveur de l'hébergeur (Vercel).</li>
            </ul>
          </div>

          <div class="ml-block">
            <h3>Finalité du traitement</h3>
            <p>Les données collectées servent exclusivement à :</p>
            <ul class="co-list">
              <li>Répondre aux demandes de contact</li>
              <li>Assurer le bon fonctionnement technique du site</li>
              <li>Améliorer l'expérience utilisateur</li>
            </ul>
          </div>

          <div class="ml-block">
            <h3>Partage des données</h3>
            <p>
              Vos données ne sont ni vendues, ni louées, ni partagées avec des tiers à des fins commerciales. Elles peuvent être transmises aux prestataires techniques suivants, dans le cadre strict du fonctionnement du site :
            </p>
            <ul class="co-list">
              <li><strong>Web3Forms</strong> — Traitement des formulaires de contact</li>
              <li><strong>Vercel</strong> — Hébergement du site</li>
            </ul>
          </div>

          <div class="ml-block">
            <h3>Cookies</h3>
            <p>
              Ce site n'utilise pas de cookies de suivi ni de cookies publicitaires. Seuls des cookies techniques strictement nécessaires au fonctionnement du site peuvent être utilisés.
            </p>
          </div>

          <div class="ml-block">
            <h3>Durée de conservation</h3>
            <p>
              Les données issues du formulaire de contact sont conservées le temps nécessaire au traitement de la demande, puis supprimées dans un délai raisonnable. Les logs serveur sont conservés selon la politique de l'hébergeur (Vercel).
            </p>
          </div>

          <div class="ml-block">
            <h3>Vos droits</h3>
            <p>
              Conformément à la LPD, vous disposez d'un droit d'accès, de rectification et de suppression de vos données personnelles. Pour exercer ces droits, contactez-moi à l'adresse <a href="mailto:contact@jonlabs.ch" class="ml-link">contact@jonlabs.ch</a>.
            </p>
          </div>

          <div class="ml-block">
            <h3>Modifications</h3>
            <p>
              Cette politique de confidentialité peut être mise à jour à tout moment. La date de dernière modification est indiquée ci-dessous.
            </p>
            <p class="ml-meta">
              Dernière mise à jour : 20 février 2026
            </p>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style is:global>
  /* ══ MENTIONS LÉGALES — styles .ml-* (colonne de lecture étroite, filets fins) ══ */

  /* Colonne de lecture étroite, alignée eyebrow/titre/corps */
  .ml-col { max-width: 68ch; }

  .co-root .ml-lead { margin-top: 16px; max-width: 60ch; line-height: 1.65; font-size: 1.05rem; }
  .ml-h2 { margin-top: 8px; font-size: clamp(1.5rem, 3.5vw, 2rem); }

  /* Fiche coordonnées (co-spec) — largeur dt un peu plus large pour libellés légaux */
  .ml-spec { margin-top: 24px; }
  .ml-spec .co-spec-row { grid-template-columns: 132px 1fr; }
  .co-root .ml-spec dd { line-height: 1.55; }
  .ml-spec dd strong { font-weight: 600; }

  /* Prose légale : blocs séparés par un filet fin, coins nets */
  .ml-prose { display: flex; flex-direction: column; margin-top: 28px; }
  .ml-block { display: flex; flex-direction: column; gap: 10px; padding-top: 24px; margin-top: 24px; border-top: 1px solid var(--line); }
  .ml-block:first-child { margin-top: 0; padding-top: 0; border-top: 0; }
  .ml-block h3 { font-size: 1.05rem; font-weight: 600; }
  .co-root .ml-block p { line-height: 1.65; color: var(--muted); }
  .ml-block p strong { color: var(--ink); font-weight: 600; }
  .co-root .ml-block .co-list { margin-top: 2px; }
  .ml-block .co-list li { line-height: 1.6; color: var(--muted); }
  .ml-block .co-list li strong { color: var(--ink); font-weight: 600; }

  .co-root .ml-intro { margin-top: 18px; max-width: 62ch; line-height: 1.65; color: var(--muted); }
  .ml-intro strong { color: var(--ink); font-weight: 600; }

  .ml-meta { font-size: 13px; color: var(--muted); }

  /* Liens : accent teal, underline propre (texte inline, coins nets) */
  .ml-link { color: var(--accent); text-decoration: underline; text-underline-offset: 3px; text-decoration-thickness: 1px; transition: color .18s ease-out; }
  .ml-link:hover { color: var(--ink); }

  @media (max-width: 640px) {
    .ml-spec .co-spec-row { grid-template-columns: 1fr; gap: 4px; }
  }
</style>
