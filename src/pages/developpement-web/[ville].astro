---
// Développement web [ville] — page programmatique (blueprint).
// Migrée du brutaliste vers le design system .co-* : sections cadrées, filets fins,
// crosshairs, accent teal unique, Inter Tight × Instrument Serif. Namespace scopé .dwv-*.
// Gabarit-or de référence : services/referencement-local.astro.
//
// HARD-PRESERVE :
//  - getStaticPaths() sur villesFrontalieres + type VilleData (data/villes-frontalieres),
//    props { ville }, tous les bindings dynamiques ville (nom, nomComplet, région,
//    distance, temps trajet, description, contexte, spécificités, publicCible,
//    exemplesProjets, FAQ) — rien en dur.
//  - Schema.org : getWebPageSchema / getBreadcrumbSchema / getFAQPageSchema, tableau
//    schemas + ordre identiques, injection ld+json via Layout.
//  - seoData dynamique par ville (pageTitle / pageDescription, logique de longueur).
//  - Maillage villes voisines (getVoisines) → mêmes hrefs /developpement-web/{slug}.
//  - Deep-links SEO internes (/services/*, /portfolio, /tarifs, /blog/*,
//    /developpeur-web-freelance-geneve, /contact, mailto).
//  - Prix exacts (CHF/EUR) et copie éditoriale.
import "../../styles/global.css";
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { Image } from "astro:assets";
import illuDevWeb from "../../assets/illustrations/developpement-web.webp";

import { getWebPageSchema, getBreadcrumbSchema, getFAQPageSchema } from "../../lib/seo";
import { SITE_URL, localBusinessData } from "../../data/schema";
import { villesFrontalieres, getVoisines, type VilleData } from "../../data/villes-frontalieres";

// ============================================
// STATIC PATHS — programmatic SEO
// ============================================
export async function getStaticPaths() {
  return villesFrontalieres.map(ville => ({
    params: { ville: ville.slug },
    props: { ville }
  }));
}

interface Props {
  ville: VilleData;
}

const { ville } = Astro.props;

// ============================================
// SEO META
// ============================================
const pageUrl = `${SITE_URL}/developpement-web/${ville.slug}`;
// Title : on adapte la longueur pour passer sous 60 chars sur les noms longs
const titleLong = `Développeur web ${ville.nom} — sites sur-mesure | Jon Labs`;
const pageTitle = titleLong.length <= 60
  ? titleLong
  : `Développeur web ${ville.nom} | Jon Labs`;
// Description : version compacte si nom de ville long pour rester sous 160 chars
const descLong = `Développement web sur mesure à ${ville.nom} (${ville.distanceGeneve} de Genève). Sites pro, refonte, MVP. Tarifs CHF/EUR transparents, freelance basé à Genève.`;
const pageDescription = descLong.length <= 158
  ? descLong
  : `Développeur web freelance pour ${ville.nom} (${ville.distanceGeneve} de Genève). Sites sur-mesure, refonte, MVP. Tarifs CHF/EUR. Basé à Genève.`;

// ============================================
// SCHEMA.ORG
// ============================================
const webPageSchema = getWebPageSchema({
  url: pageUrl,
  name: pageTitle,
  description: pageDescription
});

const breadcrumbSchema = getBreadcrumbSchema([
  { name: "Accueil", url: SITE_URL },
  { name: "Développement web", url: `${SITE_URL}/services` },
  { name: ville.nom, url: pageUrl }
]);

const faqSchema = getFAQPageSchema(ville.faqs);

const schemas = [webPageSchema, breadcrumbSchema, faqSchema, localBusinessData];

// ============================================
// MAILLAGE — villes voisines
// ============================================
const voisines = getVoisines(ville);

// ============================================
// SERVICES (5 cards génériques)
// ============================================
const services = [
  {
    icon: "ri-window-line",
    title: "Création de site web",
    description: `Site vitrine sur-mesure pour PME et indépendants de ${ville.nom}. Design unique, performance Google, livré en 3-4 semaines.`,
    price: "Dès CHF 1'490 / EUR 1'550",
    href: "/services/creation-site-web"
  },
  {
    icon: "ri-refresh-line",
    title: "Refonte de site web",
    description: "Modernisation d'un site existant. Refonte WordPress ou migration depuis WordPress, Wix ou Squarespace vers une stack rapide et maintenable.",
    price: "Dès CHF 2'490 / EUR 2'600",
    href: "/services/developpeur-wordpress"
  },
  {
    icon: "ri-rocket-line",
    title: "Développement MVP",
    description: "Prototype fonctionnel en 2-3 semaines pour tester ton idée auprès de vrais utilisateurs avant de t'engager plus loin.",
    price: "Dès CHF 4'500 / EUR 4'700",
    href: "/services/developpement-mvp"
  },
  {
    icon: "ri-tools-line",
    title: "Outils sur mesure",
    description: "Applications internes, tableaux de bord, portails clients. Pour automatiser ce qu'Excel ne sait plus faire seul.",
    price: "Sur devis",
    href: "/services/outils-sur-mesure"
  },
  {
    icon: "ri-map-pin-2-line",
    title: "Référencement local",
    description: `SEO local pour exister sur Google quand un habitant de ${ville.nom} ou un Genevois cherche ton métier.`,
    price: "Dès CHF 800/mois",
    href: "/services/referencement-local"
  }
];

// ============================================
// PRICING — version EUR/CHF
// ============================================
const pricingPlans = [
  {
    name: "Site vitrine",
    priceChf: "1'490",
    priceEur: "1'550",
    description: `Pour indépendants et artisans de ${ville.nom} qui veulent une présence en ligne propre.`,
    features: ["1 à 5 pages", "Design sur-mesure", "Responsive", "SEO de base", "Hébergement 1 an"],
    highlighted: false
  },
  {
    name: "Site sur-mesure",
    priceChf: "4'000",
    priceEur: "4'150",
    description: `Pour PME de ${ville.nom} avec contenu, blog, intégrations spécifiques.`,
    features: ["Pages illimitées", "CMS / blog", "SEO avancé", "Intégrations (Stripe, GMB...)", "Formation incluse"],
    highlighted: true
  },
  {
    name: "Application web",
    priceChf: "8'000",
    priceEur: "8'300",
    description: "Pour outils internes, MVP, plateformes avec authentification et données.",
    features: ["Backend custom", "Base de données", "Authentification", "API tiers", "Maintenance évolutive"],
    highlighted: false
  }
];

// ============================================
// ARTICLES BLOG (maillage)
// ============================================
const blogArticles = [
  {
    title: "Combien coûte vraiment un site web en Suisse en 2026 ?",
    description: "Fourchettes en CHF et EUR par profil de prestataire (freelance, agence, no-code) et par type de projet.",
    href: "/blog/prix-site-web-suisse-2026",
    icon: "ri-money-cny-circle-line"
  },
  {
    title: "Spécialiste dev web Suisse : comment bien choisir",
    description: "Les 7 critères pour différencier un bon développeur d'un copieur de templates en 2026.",
    href: "/blog/specialiste-developpement-web-suisse",
    icon: "ri-user-search-line"
  }
];
---

<Layout
  title={pageTitle}
  description={pageDescription}
  schemas={schemas}
>
  <Header />

  <main class="co-root">

    <!-- ══ HERO LOCAL ══ -->
    <section class="co-sec co-pad dwv-hero" style="padding:64px 40px 56px;">
      <div class="dwv-hero-inner">
        <div class="dwv-hero-badges" data-animate>
          <span class="co-badge">Disponible</span>
          <span class="co-badge"><i class="ri-map-pin-line"></i> {ville.nom} · {ville.distanceGeneve} de Genève</span>
        </div>

        <h1 class="dwv-hero-title" data-animate data-delay="0.1">
          Développeur web sur mesure à <span class="co-ser">{ville.nom}</span>
        </h1>

        <p class="dwv-hero-lead" data-animate data-delay="0.2">
          {ville.angleHero} Devis transparent en <strong>CHF ou EUR</strong>, freelance basé à <strong>Genève</strong>.
        </p>

        <div class="dwv-hero-btns" data-animate data-delay="0.3">
          <a href="/contact" class="co-btn"><i class="ri-mail-send-line"></i> Demander un devis</a>
          <a href="/portfolio" class="co-btn co-btn--ghost">Voir mes réalisations <i class="ri-arrow-right-line"></i></a>
        </div>

        <div class="dwv-hero-trust" data-animate data-delay="0.4">
          <span><i class="ri-time-line"></i> {ville.tempsTrajetGeneve}</span>
          <span><i class="ri-stack-line"></i> 50+ sites livrés</span>
          <span><i class="ri-currency-line"></i> Facturation CHF / EUR</span>
        </div>
      </div>
    </section>

    <!-- ══ 01 · CONTEXTE LOCAL ══ -->
    <section id="contexte" class="co-sec co-pad" style="padding:56px 40px;">
      <p class="co-eyebrow" data-animate>01 — Contexte local</p>
      <h2 style="margin-top:8px;" data-animate>
        Pourquoi un <span class="co-ser">développeur web</span> pour {ville.nom} ?
      </h2>
      <p class="co-mut" data-animate style="margin-top:10px;max-width:64ch;line-height:1.6;">
        {ville.description}
      </p>

      <!-- Contexte économique (encart cadré) -->
      <div class="dwv-context co-frame" data-animate>
        <span class="co-x tl"></span><span class="co-x tr"></span>
        <span class="co-x bl"></span><span class="co-x br"></span>
        <h3 class="dwv-context-title"><i class="ri-building-line"></i> Tissu économique de {ville.nomComplet}</h3>
        <p>{ville.contexteEconomique}</p>
      </div>

      <!-- Spécificités locales (cartes numérotées) -->
      <div class="dwv-grid dwv-grid--2" data-animate-stagger>
        {ville.specificites.map((item, idx) => (
          <div class="dwv-spec co-frame co-frame--reveal" data-animate-item>
            <span class="dwv-spec-num co-index">{String(idx + 1).padStart(2, '0')}</span>
            <p class="dwv-spec-text">{item}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- ══ 02 · SERVICES ══ -->
    <section id="services" class="co-sec co-pad" style="padding:56px 40px;">
      <p class="co-eyebrow" data-animate>02 — Services</p>
      <h2 style="margin-top:8px;" data-animate>Services adaptés au tissu de {ville.nom}</h2>
      <p class="co-mut" data-animate style="margin-top:10px;max-width:62ch;line-height:1.6;">
        Du <strong>créateur de site web {ville.nom}</strong> au développement d'outils internes — toute la chaîne, un seul interlocuteur.
      </p>

      <!-- Public cible -->
      <div class="dwv-audience" data-animate>
        <p class="co-eyebrow dwv-audience-label">À qui je m'adresse à {ville.nom}</p>
        <div class="dwv-chips">
          {ville.publicCible.map((p) => (
            <span class="co-badge">{p}</span>
          ))}
        </div>
      </div>

      <!-- Services grid -->
      <div class="dwv-grid dwv-grid--3" data-animate-stagger>
        {services.map((service) => (
          <a href={service.href} class="dwv-service co-frame co-frame--reveal" data-animate-item>
            <i class={`${service.icon} dwv-service-icon`} aria-hidden="true"></i>
            <h3 class="dwv-service-title">{service.title}</h3>
            <p class="dwv-service-text">{service.description}</p>
            <div class="dwv-service-foot">
              <span class="dwv-service-price">{service.price}</span>
              <i class="ri-arrow-right-line" aria-hidden="true"></i>
            </div>
          </a>
        ))}

        <!-- Card "Tous les services" -->
        <a href="/services" class="dwv-service dwv-service--all co-frame co-frame--reveal" data-animate-item>
          <i class="ri-arrow-right-up-line dwv-service-icon" aria-hidden="true"></i>
          <h3 class="dwv-service-title">Voir tous les services</h3>
          <p class="dwv-service-text">Automatisation, validation d'idée, intégrations…</p>
        </a>
      </div>

      <!-- Exemples de projets (encart cadré) -->
      <div class="dwv-examples co-frame" data-animate>
        <span class="co-x tl"></span><span class="co-x tr"></span>
        <span class="co-x bl"></span><span class="co-x br"></span>
        <h3 class="dwv-examples-title"><i class="ri-lightbulb-line"></i> Exemples de projets typiques à {ville.nom}</h3>
        <ul class="co-list">
          {ville.exemplesProjets.map((projet) => (
            <li>{projet}</li>
          ))}
        </ul>
      </div>
    </section>

    <!-- ══ 03 · TARIFS CHF / EUR ══ -->
    <section id="tarifs" class="co-sec co-pad" style="padding:56px 40px;">
      <p class="co-eyebrow" data-animate>03 — Tarifs</p>
      <h2 style="margin-top:8px;" data-animate>
        Tarifs en <span class="co-ser">CHF</span> et en <span class="co-ser">EUR</span>
      </h2>
      <p class="co-mut" data-animate style="margin-top:10px;max-width:60ch;line-height:1.6;">
        Trois fourchettes pour situer ton projet à {ville.nom}. Devis personnalisé après notre premier échange.
      </p>

      <div class="dwv-tiers" data-animate-stagger>
        {pricingPlans.map((plan) => (
          <div class={`dwv-tier ${plan.highlighted ? 'dwv-tier--reco' : ''}`} data-animate-item>
            {plan.highlighted && <span class="co-badge co-badge--solid dwv-tier-reco">Le plus demandé</span>}
            <h3 class="dwv-tier-name">{plan.name}</h3>
            <p class="dwv-tier-desc">{plan.description}</p>
            <div class="dwv-tier-price">
              <span class="dwv-tier-pricelabel">À partir de</span>
              <b>{plan.priceChf}<span class="dwv-tier-cur"> CHF</span></b>
              <span class="dwv-tier-eur">≈ {plan.priceEur} EUR</span>
            </div>
            <ul class="co-list co-list--check dwv-tier-features">
              {plan.features.map((feature) => (
                <li><i class="ri-check-line"></i><span>{feature}</span></li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <p class="dwv-tier-note co-mut" data-animate>
        <i class="ri-information-line"></i>
        Facturation possible en CHF (IBAN suisse) ou en EUR (virement SEPA). TVA française appliquée pour les sociétés assujetties.
      </p>

      <div class="dwv-tier-cta" data-animate>
        <a href="/tarifs" class="co-btn co-btn--ghost"><i class="ri-price-tag-3-line"></i> Voir tous les tarifs <i class="ri-arrow-right-line"></i></a>
      </div>
    </section>

    <!-- ══ 04 · FAQ VILLE-SPÉCIFIQUE ══ -->
    <section id="faq" class="co-sec co-pad" style="padding:56px 40px;">
      <div class="dwv-faq-grid">
        <!-- Illustration contextuelle (encadrée .co-frame) -->
        <div class="dwv-faq-media">
          <div class="dwv-illu co-frame" data-animate="scale">
            <span class="co-x tl"></span><span class="co-x tr"></span>
            <span class="co-x bl"></span><span class="co-x br"></span>
            <Image src={illuDevWeb} alt="" class="dwv-illu-img" aria-hidden="true" />
          </div>
        </div>

        <!-- Colonne FAQ -->
        <div>
          <p class="co-eyebrow" data-animate>04 — FAQ</p>
          <h2 style="margin-top:8px;" data-animate>Questions fréquentes ({ville.nom})</h2>
          <p class="co-mut" data-animate style="margin-top:10px;line-height:1.6;">
            Ce que les clients de {ville.nom} et du Genevois français me demandent en premier.
          </p>

          <div class="dwv-faq">
            {ville.faqs.map((faq, index) => (
              <details open={index === 0}>
                <summary>
                  {faq.question}
                  <i class="ri-arrow-down-s-line" aria-hidden="true"></i>
                </summary>
                <p class="dwv-faq-answer">{faq.answer}</p>
              </details>
            ))}
          </div>

          <p class="dwv-faq-more">
            Une autre question sur {ville.nom} ? <a href="/contact" class="dwv-inline">Écris-moi</a>, je réponds sous 24h.
          </p>
        </div>
      </div>
    </section>

    <!-- ══ 05 · AUTRES VILLES + PAGE PILIER ══ -->
    <section id="zones" class="co-sec co-pad" style="padding:56px 40px;">
      <p class="co-eyebrow" data-animate>05 — Zones</p>
      <h2 style="margin-top:8px;" data-animate>Autres zones d'intervention</h2>
      <p class="co-mut" data-animate style="margin-top:10px;max-width:64ch;line-height:1.6;">
        Je couvre l'ensemble du Genevois français et la <strong>Suisse romande</strong>. Voici les autres communes voisines de {ville.nom} où j'interviens régulièrement.
      </p>

      <!-- Villes voisines -->
      <div class="dwv-grid dwv-grid--3" data-animate-stagger>
        {voisines.map((v) => (
          <a href={`/developpement-web/${v.slug}`} class="dwv-voisine co-frame co-frame--reveal" data-animate-item>
            <div class="dwv-voisine-head">
              <i class="ri-map-pin-line dwv-voisine-icon" aria-hidden="true"></i>
              <span class="dwv-voisine-dist co-index">{v.distanceGeneve}</span>
            </div>
            <h3 class="dwv-voisine-name">{v.nom}</h3>
            <p class="dwv-voisine-pop">{v.populationLabel} hab.</p>
            <p class="dwv-voisine-text">
              Développement web pour {v.nom} — {v.publicCible[0]}, {v.publicCible[1]}.
            </p>
            <span class="dwv-voisine-link">Voir la page <i class="ri-arrow-right-line" aria-hidden="true"></i></span>
          </a>
        ))}
      </div>

      <!-- Page pilier Genève (bloc sombre) -->
      <div class="dwv-pilier" data-animate>
        <span class="co-x tl"></span><span class="co-x tr"></span>
        <span class="co-x bl"></span><span class="co-x br"></span>
        <span class="co-glow"></span>
        <div class="dwv-pilier-inner">
          <div class="dwv-pilier-copy">
            <span class="dwv-pilier-badge"><i class="ri-star-line"></i> Page pilier</span>
            <h3 class="dwv-pilier-title">Voir la page principale Genève</h3>
            <p class="dwv-pilier-lead">
              La page de référence pour le <strong>développement web Suisse</strong>, avec stack technique détaillée, comparaison freelance/agence, méthodologie et FAQ étendue.
            </p>
          </div>
          <a href="/developpeur-web-freelance-geneve" class="dwv-pilier-btn">
            Page Genève <i class="ri-arrow-right-line" aria-hidden="true"></i>
          </a>
        </div>
      </div>

      <!-- Liens secondaires -->
      <div class="dwv-links" data-animate>
        <a href="/services" class="dwv-link co-frame co-frame--reveal">
          <span class="dwv-link-label"><i class="ri-briefcase-line"></i> Tous les services</span>
          <i class="ri-arrow-right-line" aria-hidden="true"></i>
        </a>
        <a href="/tarifs" class="dwv-link co-frame co-frame--reveal">
          <span class="dwv-link-label"><i class="ri-price-tag-3-line"></i> Page tarifs</span>
          <i class="ri-arrow-right-line" aria-hidden="true"></i>
        </a>
        <a href="/portfolio" class="dwv-link co-frame co-frame--reveal">
          <span class="dwv-link-label"><i class="ri-stack-line"></i> Portfolio</span>
          <i class="ri-arrow-right-line" aria-hidden="true"></i>
        </a>
      </div>
    </section>

    <!-- ══ 06 · À LIRE ══ -->
    <section id="ressources" class="co-sec co-pad" style="padding:56px 40px;">
      <p class="co-eyebrow" data-animate>06 — Ressources</p>
      <h2 style="margin-top:8px;" data-animate>À lire avant de te décider</h2>
      <p class="co-mut" data-animate style="margin-top:10px;max-width:60ch;line-height:1.6;">
        Deux articles pour cadrer ton projet de <strong>création site web {ville.nom}</strong> avant même d'envoyer un mail.
      </p>

      <div class="dwv-grid dwv-grid--2" data-animate-stagger>
        {blogArticles.map((article) => (
          <a href={article.href} class="dwv-article co-frame co-frame--reveal" data-animate-item>
            <i class={`${article.icon} dwv-article-icon`} aria-hidden="true"></i>
            <h3 class="dwv-article-title">{article.title}</h3>
            <p class="dwv-article-text">{article.description}</p>
            <span class="dwv-article-link">Lire l'article <i class="ri-arrow-right-line" aria-hidden="true"></i></span>
          </a>
        ))}
      </div>
    </section>

    <!-- ══ CTA FINAL (primitive .co-cta sombre) ══ -->
    <section class="co-cta">
      <span class="co-x tl"></span><span class="co-x tr"></span>
      <span class="co-x bl"></span><span class="co-x br"></span>
      <div class="co-cta-inner">
        <p class="co-cta-eyebrow" data-animate>Prêt ?</p>
        <h2 class="co-cta-title" data-animate data-delay="0.1">
          Discutons de ton projet à <span class="co-ser">{ville.nom}</span>
        </h2>
        <p class="co-cta-lead" data-animate data-delay="0.2">
          Premier échange gratuit, sans engagement. Je viens si nécessaire à {ville.nom} ({ville.tempsTrajetGeneve} depuis Genève) ou on cale une visio. Réponse sous 24h.
        </p>
        <div class="co-cta-btns" data-animate data-delay="0.3">
          <a href="/contact" class="co-cta-btn"><i class="ri-mail-send-line"></i> Demander un devis</a>
          <a href="mailto:hello@jonlabs.ch" class="co-cta-btn co-cta-btn--ghost"><i class="ri-mail-line"></i> hello@jonlabs.ch</a>
        </div>
        <div class="co-cta-trust" data-animate data-delay="0.4">
          <span><i class="ri-time-line"></i> Réponse sous 24h</span>
          <span><i class="ri-calendar-line"></i> Lun-Ven, 9h-18h (CET)</span>
          <span><i class="ri-currency-line"></i> Facturation CHF ou EUR</span>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style is:global>
  /* ══ DÉVELOPPEMENT WEB [VILLE] — styles .dwv-* (namespace scopé, corps .co-root) ══ */

  /* ── Hero ── */
  .dwv-hero-inner { max-width: 760px; margin: 0 auto; text-align: center; display: flex; flex-direction: column; align-items: center; }
  .dwv-hero-badges { display: flex; flex-wrap: wrap; justify-content: center; gap: 10px; margin-bottom: 24px; }
  .dwv-hero-badges .co-badge i { font-size: 13px; color: var(--accent); }
  .dwv-hero-title { font-size: clamp(2.1rem, 5vw, 3.3rem); }
  .co-root .dwv-hero-lead { margin-top: 20px; max-width: 54ch; font-size: 1.075rem; line-height: 1.65; color: var(--muted); }
  .dwv-hero-lead strong { color: var(--ink); font-weight: 600; }
  .dwv-hero-btns { display: flex; flex-wrap: wrap; justify-content: center; gap: 12px; margin-top: 28px; }
  .dwv-hero-btns .co-btn i { transition: transform .18s ease-out; }
  .dwv-hero-btns .co-btn:hover i { transform: translateX(2px); }
  .dwv-hero-trust { display: flex; flex-wrap: wrap; justify-content: center; gap: 12px 26px; margin-top: 28px; font-size: 13.5px; color: var(--muted); }
