---
// Hub du silo géographique /developpement-web (blueprint .co-*, namespace .dw-*).
// Les 5 pages ville existaient sans parent : maillage latéral via getVoisines
// uniquement, et le breadcrumb /developpement-web pointait dans le vide.
// Source de vérité unique des villes : src/data/villes-frontalieres.ts — jamais
// de liste en dur ici (même pattern que GeoZonesStrip et portfolio-relations).
import '../../styles/global.css';
import Layout from '../../layouts/Layout.astro';
import AppHeader from '../../components/Header.astro';
import AppFooter from '../../components/Footer.astro';
import { villesFrontalieres } from '../../data/villes-frontalieres';
import { getCollectionPageSchema, getBreadcrumbSchema } from '../../lib/seo';
import { SITE_URL, personData, organizationData } from '../../data/schema';

const villes = [...villesFrontalieres].sort((a, b) => b.population - a.population);

const pageTitle = 'Développeur web dans le Genevois français';
const pageDescription =
  "Développeur web freelance basé à Genève, j'interviens dans les villes frontalières de Haute-Savoie : Annemasse, Gaillard, Ville-la-Grand, Saint-Julien et La Roche-sur-Foron.";
const pageUrl = `${SITE_URL}/developpement-web`;

const collectionSchema = getCollectionPageSchema({
  url: pageUrl,
  name: 'Développement web dans le Genevois français',
  description: pageDescription,
});

const breadcrumbSchema = getBreadcrumbSchema([
  { name: 'Accueil', url: SITE_URL },
  { name: 'Développement web', url: pageUrl },
]);

const schemas = [personData, organizationData, collectionSchema, breadcrumbSchema];
---

<Layout title={pageTitle} description={pageDescription} schemas={schemas}>
  <AppHeader />

  <main class="co-root">
    <!-- ══ HERO ══ -->
    <section class="co-sec co-pad dw-hero">
      <h1 class="dw-h1">
        Développeur web dans le <span class="co-ser">Genevois français</span>
      </h1>
      <p class="co-mut dw-lead">
        Basé à Genève, je travaille avec les commerces, PME et indépendants des villes
        frontalières de Haute-Savoie. Même exigence qu'à Genève, facturation adaptée à
        ta réalité locale.
      </p>
    </section>

    <!-- ══ VILLES ══ -->
    <section class="co-sec co-pad dw-sec">
      <p class="co-eyebrow">Zones d'intervention</p>
      <h2 class="dw-sec-title">Les villes où j'interviens</h2>
      <div class="dw-grid">
        {villes.map((ville) => (
          <a href={`/developpement-web/${ville.slug}`} class="dw-card co-frame co-frame--reveal">
            <div class="dw-card-icon"><i class="ri-map-pin-line"></i></div>
            <div class="dw-card-body">
              <h3 class="dw-card-title">{ville.nom}</h3>
              <p class="co-mut dw-card-desc">{ville.angleHero}</p>
              <div class="dw-card-meta">
                <span><i class="ri-road-map-line"></i> {ville.distanceGeneve} de Genève</span>
                <span><i class="ri-group-line"></i> {ville.populationLabel} hab.</span>
                <span class="dw-card-cta">Voir la page <i class="ri-arrow-right-line"></i></span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- ══ GENÈVE ══ -->
    <section class="co-sec co-pad dw-sec">
      <p class="co-eyebrow">Et à Genève</p>
      <h2 class="dw-sec-title">Tu es côté suisse ?</h2>
      <p class="co-mut dw-geneve-lead">
        La page dédiée au canton couvre les projets genevois : sites vitrines, applications
        métier et référencement local, avec des prix en CHF.
      </p>
      <ul class="dw-links">
        <li>
          <a href="/developpeur-web-freelance-geneve" class="dw-link">
            <i class="ri-briefcase-line"></i>
            <span>Développeur web freelance à Genève</span>
            <i class="ri-arrow-right-line dw-link-arrow"></i>
          </a>
        </li>
        <li>
          <a href="/services/creation-site-web" class="dw-link">
            <i class="ri-layout-line"></i>
            <span>Création de site web</span>
            <i class="ri-arrow-right-line dw-link-arrow"></i>
          </a>
        </li>
        <li>
          <a href="/services/referencement-local" class="dw-link">
            <i class="ri-search-line"></i>
            <span>Référencement local</span>
            <i class="ri-arrow-right-line dw-link-arrow"></i>
          </a>
        </li>
      </ul>
    </section>

    <!-- ══ CTA FINAL (primitive .co-cta) ══ -->
    <section class="co-cta">
      <span class="co-x tl"></span><span class="co-x tr"></span>
      <div class="co-cta-inner">
        <h2 class="co-cta-title">Ton projet est de <span class="co-ser">l'autre côté de la frontière ?</span></h2>
        <p class="co-cta-lead">
          Genève est à 15 minutes. On en parle 20 minutes et tu sauras si ça vaut le coup.
        </p>
        <div class="co-cta-btns">
          <a href="/contact" class="co-btn co-cta-btn"><i class="ri-calendar-check-line" aria-hidden="true"></i> Discuter de mon projet</a>
          <a href="/portfolio" class="co-btn co-cta-btn co-cta-btn--ghost"><i class="ri-image-line" aria-hidden="true"></i> Voir mes réalisations</a>
        </div>
      </div>
    </section>
  </main>

  <AppFooter />
</Layout>

<style is:global>
  /* ══ Hub développement web (silo géo) blueprint — .dw-* (dans .co-root) ══ */
  .dw-hero { padding: 64px 40px 48px; }
  .co-root .dw-h1 { font-size: clamp(2.2rem, 5.5vw, 3.6rem); line-height: 1.06; letter-spacing: -0.03em; margin-top: 14px; max-width: 20ch; }
  .co-root .dw-lead { margin-top: 18px; font-size: 1.1rem; line-height: 1.6; max-width: 60ch; }

  .dw-sec { padding: 48px 40px; }
  .dw-sec-title { font-size: clamp(1.5rem, 3vw, 2rem); line-height: 1.1; margin-top: var(--space-eyebrow); }
  .co-root .dw-geneve-lead { margin-top: 14px; font-size: 1rem; line-height: 1.6; max-width: 58ch; }

  /* Grille villes */
  .dw-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; margin-top: 28px; }
  .dw-card {
    position: relative; display: flex; gap: 20px; align-items: flex-start;
    padding: 28px; border: 1px solid var(--line-2); background: var(--surface);
    transition: box-shadow .18s ease-out;
  }
  .dw-card:hover { box-shadow: 0 8px 26px rgba(20,22,26,.08); }
  .dw-card-icon { flex: none; width: 46px; height: 46px; display: inline-flex; align-items: center; justify-content: center; border: 1px solid var(--line-2); font-size: 22px; color: var(--accent); }
  .dw-card-body { min-width: 0; }
  .dw-card-title { font-size: 1.3rem; line-height: 1.2; margin-bottom: 8px; }
  .co-root .dw-card-desc { font-size: 0.95rem; line-height: 1.55; margin-bottom: 16px; }
  .dw-card-meta { display: flex; flex-wrap: wrap; align-items: center; gap: 16px; font-size: 0.85rem; color: var(--muted); }
  .dw-card-meta > span { display: inline-flex; align-items: center; gap: 5px; }
  .dw-card-cta { color: var(--accent); font-weight: 600; }
  .dw-card-cta i { transition: transform .18s ease-out; }
  .dw-card:hover .dw-card-cta i { transform: translateX(4px); }

  /* Liens Genève */
  .dw-links { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; margin-top: 24px; }
  .dw-link {
    display: flex; align-items: center; gap: 12px; padding: 16px 18px;
    border: 1px solid var(--line-2); background: var(--surface); color: var(--ink);
    font-weight: 500; transition: box-shadow .18s ease-out, border-color .18s ease-out;
  }
  .dw-link:hover { border-color: var(--ink); box-shadow: 0 6px 22px rgba(20,22,26,.07); }
  .dw-link > i:first-child { color: var(--accent); font-size: 1.2rem; flex: none; }
  .dw-link span { flex: 1; line-height: 1.35; }
  .dw-link-arrow { color: var(--muted); flex: none; transition: transform .18s ease-out; }
  .dw-link:hover .dw-link-arrow { transform: translateX(3px); color: var(--accent); }

  @media (max-width: 900px) {
    .dw-grid { grid-template-columns: 1fr; }
    .dw-links { grid-template-columns: 1fr; }
  }
  @media (prefers-reduced-motion: reduce) {
    .dw-card-cta i, .dw-link, .dw-link-arrow { transition: none; }
  }
</style>
