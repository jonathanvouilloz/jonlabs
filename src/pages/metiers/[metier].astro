---
import "../../styles/global.css";
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

import { getWebPageSchema, getBreadcrumbSchema, getFAQPageSchema, getServiceItemSchema } from "../../lib/seo";
import { SITE_URL, localBusinessData } from "../../data/schema";
import { metiersIA, type MetierIAData } from "../../data/metiers-ia";

// ============================================
// STATIC PATHS — pages Métiers (silo IA)
// ============================================
export async function getStaticPaths() {
  return metiersIA.map(metier => ({
    params: { metier: metier.slug },
    props: { metier }
  }));
}

interface Props {
  metier: MetierIAData;
}

const { metier } = Astro.props;

// ============================================
// SEO META
// ============================================
const pageUrl = `${SITE_URL}/metiers/${metier.slug}`;
const pageTitle = metier.title;
const pageDescription = metier.metaDescription;

// ============================================
// SCHEMA.ORG
// ============================================
const webPageSchema = getWebPageSchema({
  url: pageUrl,
  name: pageTitle,
  description: pageDescription
});

const breadcrumbSchema = getBreadcrumbSchema([
  { name: "Accueil", url: SITE_URL },
  { name: "Consultant IA", url: `${SITE_URL}/consultant-ia` },
  { name: metier.metier, url: pageUrl }
]);

const faqSchema = getFAQPageSchema(metier.faqs);
const serviceSchema = getServiceItemSchema(`metiers/${metier.slug}`);

const schemas = [
  webPageSchema,
  breadcrumbSchema,
  faqSchema,
  ...(serviceSchema ? [serviceSchema] : []),
  localBusinessData
];

// ============================================
// Trust line ("a · b · c")
// ============================================
const preuvesHero = metier.preuveLocale.split('·').map((p) => p.trim()).filter(Boolean);

// Icônes cyclées pour les cartes cas d'usage
const casIcons = [
  "ri-robot-2-line",
  "ri-mail-settings-line",
  "ri-file-text-line",
  "ri-search-eye-line",
  "ri-customer-service-2-line",
  "ri-flow-chart",
  "ri-file-list-3-line",
  "ri-dashboard-3-line"
];

// ============================================
// MÉTHODE — commune à tous les métiers
// ============================================
const methode = [
  {
    step: "01",
    title: "Audit",
    description: "On regarde vos process réels et on repère les 2-3 tâches qui mangent le plus de temps. Pas de promesse en l'air : je vous dis franchement où l'IA aide et où elle n'apporte rien."
  },
  {
    step: "02",
    title: "Prototype",
    description: "Je conçois un agent ciblé sur une tâche précise et je l'intègre à vos outils. Un premier résultat en production en deux à trois semaines, pas un chantier de six mois."
  },
  {
    step: "03",
    title: "Garde-fous",
    description: "Validation humaine sur ce qui l'exige, cadrage des données (ce qui sort, ce qui reste chez vous), hébergement conforme. L'agent ne décide pas à votre place."
  },
  {
    step: "04",
    title: "Prise en main",
    description: "Je forme votre équipe à l'usage quotidien. L'objectif n'est jamais de vous rendre dépendant : c'est de vous donner un outil qui tourne et que vous pilotez."
  }
];

// ============================================
// SERVICES IA (maillage)
// ============================================
const servicesIA = [
  {
    icon: "ri-brain-line",
    title: "Consultant IA (hub)",
    description: "La page de référence sur le conseil IA pour PME romandes : méthode, types d'agents, conformité et tarifs.",
    href: "/consultant-ia"
  },
  {
    icon: "ri-loop-left-line",
    title: "Automatisation & agents IA",
    description: "Agents qui prennent en charge les tâches répétitives : tri d'e-mails, relances, préparation de documents, reporting.",
    href: "/services/automatisation"
  }
];
---

<Layout
  title={pageTitle}
  description={pageDescription}
  schemas={schemas}
>
  <Header />

  <!-- ============================================== -->
  <!-- HERO SECTORIEL -->
  <!-- ============================================== -->
  <section class="hero-section -mt-[120px] pt-[150px] pb-16 md:pt-[160px] md:pb-20 px-4 relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-0 -left-20 w-[500px] h-[500px] bg-[var(--blue)] opacity-20 blur-[120px] rounded-full"></div>
      <div class="absolute top-1/3 -right-20 w-[400px] h-[400px] bg-[var(--violet)] opacity-15 blur-[100px] rounded-full"></div>
      <div class="absolute bottom-0 left-1/3 w-[300px] h-[300px] bg-[var(--blue)] opacity-10 blur-[80px] rounded-full"></div>
    </div>

    <div class="max-w-4xl mx-auto relative z-10 text-center">
      <div class="flex flex-wrap justify-center gap-3 mb-8">
        <span class="inline-flex items-center gap-2 bg-white border-2 border-black px-3 py-1 text-xs font-mono shadow-[2px_2px_0px_rgba(0,0,0,1)]">
          <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
          Disponible
        </span>
        <span class="inline-flex items-center gap-2 bg-[var(--blue)] border-2 border-black px-3 py-1 text-xs font-mono shadow-[2px_2px_0px_rgba(0,0,0,1)]">
          <i class="ri-briefcase-4-line"></i>
          {metier.heroBadge}
        </span>
      </div>

      <h1 class="text-4xl md:text-6xl font-normal tracking-tight mb-6 leading-[1.08]">
        {metier.h1}
      </h1>

      <p class="text-lg md:text-2xl text-gray-700 mb-8 leading-relaxed max-w-3xl mx-auto">
        {metier.accroche}
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-10">
        <a
          href="/contact"
          class="bg-[var(--blue)] border-2 border-black px-6 py-4 text-lg font-bold shadow-[4px_4px_0px_rgba(0,0,0,1)] transition-all duration-200 hover:bg-[var(--yellow)] hover:shadow-[2px_2px_0px_rgba(0,0,0,1)] hover:translate-x-[2px] hover:translate-y-[2px] flex items-center justify-center gap-2"
        >
          <i class="ri-calendar-check-line"></i>
          Cadrer mon projet IA
        </a>
        <a
          href="/contact"
          class="bg-white border-2 border-black px-6 py-4 text-lg font-medium transition-all duration-200 hover:bg-gray-100 flex items-center justify-center gap-2"
        >
          Décrire mon besoin
          <i class="ri-arrow-right-line"></i>
        </a>
      </div>

      <div class="flex flex-wrap justify-center gap-x-6 gap-y-2 text-sm text-gray-600">
        {preuvesHero.map((p) => (
          <span class="flex items-center gap-2">
            <i class="ri-checkbox-circle-line text-[var(--blue)]"></i>
            {p}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================== -->
  <!-- CE QUI DEVRAIT REMONTER TOUT SEUL -->
  <!-- ============================================== -->
  <section class="py-20 md:py-28 px-4 bg-white border-y-2 border-black">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-12 md:mb-16">
        <span class="inline-flex items-center gap-2 text-xs font-mono uppercase tracking-[0.2em] text-gray-500 mb-4">
          <span class="w-8 h-px bg-gray-400"></span>
          le principe
          <span class="w-8 h-px bg-gray-400"></span>
        </span>
        <h2 class="text-3xl md:text-4xl font-normal tracking-tight mb-4">
          Ce qui devrait <strong>remonter tout seul</strong>
        </h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          L'idée n'est pas de tout automatiser, mais de faire en sorte que l'essentiel arrive à vous prêt à décider — au lieu d'aller le chercher.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {metier.fluxRemontent.map((flux, idx) => (
          <div class="bg-[var(--main-bg)] border-2 border-black p-6 shadow-[4px_4px_0px_rgba(0,0,0,0.3)] flex items-start gap-4">
            <div class="w-10 h-10 bg-[var(--blue)] border-2 border-black flex items-center justify-center flex-shrink-0 font-mono font-black text-sm">
              {String(idx + 1).padStart(2, '0')}
            </div>
            <p class="text-base text-gray-700 leading-relaxed pt-1">{flux}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================== -->
  <!-- PAINS OPÉRATIONNELS -->
  <!-- ============================================== -->
  <section class="py-20 md:py-28 px-4">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-12 md:mb-16">
        <span class="inline-flex items-center gap-2 text-xs font-mono uppercase tracking-[0.2em] text-gray-500 mb-4">
          <span class="w-8 h-px bg-gray-400"></span>
          ce qui coince
          <span class="w-8 h-px bg-gray-400"></span>
        </span>
        <h2 class="text-3xl md:text-4xl font-normal tracking-tight mb-4">
          Les <strong>blocages</strong> du métier
        </h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Si vous vous reconnaissez dans l'un de ces points, il y a probablement du temps à récupérer.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {metier.pains.map((pain) => (
          <div class="bg-white border-2 border-black p-5 shadow-[4px_4px_0px_rgba(0,0,0,0.3)] flex items-start gap-4">
            <div class="w-10 h-10 bg-[var(--blue)] border-2 border-black flex items-center justify-center flex-shrink-0">
              <i class="ri-alert-line text-lg"></i>
            </div>
            <p class="text-sm text-gray-700 leading-relaxed pt-1">{pain}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================== -->
  <!-- 8 CAS D'USAGE IA (le cœur) -->
  <!-- ============================================== -->
  <section class="py-20 md:py-28 px-4 bg-white border-y-2 border-black">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12 md:mb-16">
        <span class="inline-flex items-center gap-2 text-xs font-mono uppercase tracking-[0.2em] text-gray-500 mb-4">
          <span class="w-8 h-px bg-gray-400"></span>
          cas d'usage
          <span class="w-8 h-px bg-gray-400"></span>
        </span>
        <h2 class="text-3xl md:text-4xl font-normal tracking-tight mb-4">
          8 façons dont l'<strong>IA change le quotidien</strong>
        </h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Pas de démo de labo. Des agents branchés sur des tâches réelles du métier, avec la validation humaine là où elle compte.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {metier.casUsage.map((item, idx) => (
          <div class="group bg-[var(--main-bg)] border-2 border-black p-6 shadow-[4px_4px_0px_rgba(0,0,0,0.3)] transition-all duration-200 hover:translate-x-[-2px] hover:translate-y-[-2px] hover:shadow-[6px_6px_0px_rgba(0,0,0,0.3)] flex flex-col">
            <div class="w-12 h-12 bg-[var(--blue)] border-2 border-black flex items-center justify-center mb-4 group-hover:bg-[var(--yellow)] transition-colors">
              <i class={`${casIcons[idx % casIcons.length]} text-2xl`}></i>
            </div>
            <h3 class="text-lg font-bold mb-2">{item.titre}</h3>
            <p class="text-gray-600 text-sm leading-relaxed flex-grow">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================== -->
  <!-- PARCOURS MÉTIER -->
  <!-- ============================================== -->
  <section class="py-20 md:py-28 px-4">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-12 md:mb-16">
        <span class="inline-flex items-center gap-2 text-xs font-mono uppercase tracking-[0.2em] text-gray-500 mb-4">
          <span class="w-8 h-px bg-gray-400"></span>
          parcours
          <span class="w-8 h-px bg-gray-400"></span>
        </span>
        <h2 class="text-3xl md:text-4xl font-normal tracking-tight mb-4">
          {metier.parcoursLabel}
        </h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          À chaque étape, l'IA enlève du travail répétitif — pas la décision, qui reste la vôtre.
        </p>
      </div>

      <div class="space-y-4">
        {metier.parcours.map((etape, idx) => (
          <div class="bg-white border-2 border-black p-6 shadow-[4px_4px_0px_rgba(0,0,0,0.3)] flex items-start gap-5">
            <div class="w-12 h-12 bg-[var(--yellow)] border-2 border-black flex items-center justify-center flex-shrink-0 font-mono font-black">
              {String(idx + 1).padStart(2, '0')}
            </div>
            <div>
              <h3 class="text-lg font-bold mb-1">{etape.etape}</h3>
              <p class="text-gray-600 text-sm leading-relaxed">{etape.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================== -->
  <!-- OUTILS MÉTIER COMPATIBLES -->
  <!-- ============================================== -->
  <section class="py-20 md:py-28 px-4 bg-white border-y-2 border-black">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-12 md:mb-16">
        <span class="inline-flex items-center gap-2 text-xs font-mono uppercase tracking-[0.2em] text-gray-500 mb-4">
          <span class="w-8 h-px bg-gray-400"></span>
          outils
          <span class="w-8 h-px bg-gray-400"></span>
        </span>
        <h2 class="text-3xl md:text-4xl font-normal tracking-tight mb-4">
          On se <strong>branche sur vos outils</strong>
        </h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          L'idée n'est pas de tout remplacer, mais de brancher l'IA sur les logiciels que vous utilisez déjà.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {metier.outils.map((outil) => (
          <div class="bg-[var(--main-bg)] border-2 border-black p-5 shadow-[4px_4px_0px_rgba(0,0,0,0.3)] flex items-start gap-4">
            <div class="w-10 h-10 bg-white border-2 border-black flex items-center justify-center flex-shrink-0">
              <i class="ri-plug-line text-lg text-[var(--blue)]"></i>
            </div>
            <div>
              <h3 class="font-bold mb-1">{outil.nom}</h3>
              <p class="text-sm text-gray-600 leading-relaxed">{outil.usage}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================== -->
  <!-- MÉTHODE -->
  <!-- ============================================== -->
  <section class="py-20 md:py-28 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12 md:mb-16">
        <span class="inline-flex items-center gap-2 text-xs font-mono uppercase tracking-[0.2em] text-gray-500 mb-4">
          <span class="w-8 h-px bg-gray-400"></span>
          méthode
          <span class="w-8 h-px bg-gray-400"></span>
        </span>
        <h2 class="text-3xl md:text-4xl font-normal tracking-tight mb-4">
          Comment on <strong>travaille ensemble</strong>
        </h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Une méthode qui part de vos process réels et garde l'humain aux commandes.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {methode.map((m) => (
          <div class="bg-white border-2 border-black p-6 shadow-[4px_4px_0px_rgba(0,0,0,0.3)] flex flex-col">
            <div class="font-mono font-black text-3xl text-[var(--blue)] mb-3">{m.step}</div>
            <h3 class="text-lg font-bold mb-2">{m.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed flex-grow">{m.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================== -->
  <!-- POUR QUI / PAS POUR QUI -->
  <!-- ============================================== -->
  <section class="py-20 md:py-28 px-4 bg-white border-y-2 border-black">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-12 md:mb-16">
        <span class="inline-flex items-center gap-2 text-xs font-mono uppercase tracking-[0.2em] text-gray-500 mb-4">
          <span class="w-8 h-px bg-gray-400"></span>
          honnêteté
          <span class="w-8 h-px bg-gray-400"></span>
        </span>
        <h2 class="text-3xl md:text-4xl font-normal tracking-tight mb-4">
          Pour qui — et <strong>pas pour qui</strong>
        </h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Autant le dire tout de suite : l'IA n'est pas la réponse à tout. Voici où elle aide, et où elle n'a rien à faire.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-[var(--main-bg)] border-3 border-black p-6 md:p-8 shadow-[6px_6px_0px_rgba(0,0,0,1)]">
          <h3 class="font-bold text-lg mb-4 flex items-center gap-2">
            <span class="w-8 h-8 bg-[var(--blue)] border-2 border-black flex items-center justify-center">
              <i class="ri-check-line"></i>
            </span>
            Pour vous si…
          </h3>
          <ul class="space-y-3">
            {metier.pourQui.map((item) => (
              <li class="flex items-start gap-3 text-sm text-gray-700 leading-relaxed">
                <i class="ri-checkbox-circle-fill text-[var(--blue)] mt-0.5 flex-shrink-0"></i>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <div class="bg-[var(--main-bg)] border-3 border-black p-6 md:p-8 shadow-[6px_6px_0px_rgba(0,0,0,1)]">
          <h3 class="font-bold text-lg mb-4 flex items-center gap-2">
            <span class="w-8 h-8 bg-[var(--violet)] text-white border-2 border-black flex items-center justify-center">
              <i class="ri-close-line"></i>
            </span>
            Pas pour vous si…
          </h3>
          <ul class="space-y-3">
            {metier.pasPourQui.map((item) => (
              <li class="flex items-start gap-3 text-sm text-gray-700 leading-relaxed">
                <i class="ri-close-circle-fill text-[var(--violet)] mt-0.5 flex-shrink-0"></i>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================== -->
  <!-- FAQ MÉTIER -->
  <!-- ============================================== -->
  <section class="py-20 md:py-28 px-4">
    <div class="max-w-3xl mx-auto">
      <div class="text-center mb-12">
        <span class="inline-flex items-center gap-2 text-xs font-mono uppercase tracking-[0.2em] text-gray-500 mb-4">
          <span class="w-8 h-px bg-gray-400"></span>
          faq
          <span class="w-8 h-px bg-gray-400"></span>
        </span>
        <h2 class="text-3xl md:text-4xl font-normal tracking-tight mb-4">Questions fréquentes</h2>
        <p class="text-lg text-gray-600">
          Ce que les professionnels du métier me demandent avant de se lancer.
        </p>
      </div>

      <div class="faq-list space-y-4">
        {metier.faqs.map((faq, index) => (
          <div class="faq-item border-2 border-black bg-white shadow-[3px_3px_0px_rgba(0,0,0,0.3)]" data-faq-item>
            <button
              class="faq-trigger w-full flex items-center justify-between gap-4 p-5 text-left font-medium cursor-pointer transition-colors duration-200 hover:bg-[var(--blue)] hover:bg-opacity-10"
              aria-expanded="false"
              data-faq-trigger
            >
              <span class="flex items-start gap-3">
                <span class="font-mono text-sm text-gray-400 mt-0.5">{String(index + 1).padStart(2, '0')}</span>
                <span class="text-base md:text-lg">{faq.question}</span>
              </span>
              <span class="faq-icon w-8 h-8 border-2 border-black bg-[var(--main-bg)] flex items-center justify-center transition-transform duration-300 flex-shrink-0">
                <i class="ri-add-line text-lg"></i>
              </span>
            </button>
            <div class="faq-content overflow-hidden transition-all duration-300" style="max-height: 0;" data-faq-content>
              <div class="p-6 pt-2 pl-12">
                <p class="text-gray-600 leading-relaxed">{faq.answer}</p>
              </div>
            </div>
          </div>
        ))}
      </div>

      <p class="text-center mt-10 text-gray-500 text-sm">
        Une autre question ? <a href="/contact" class="text-[var(--blue)] font-medium hover:underline">Écrivez-moi</a>, je réponds sous 24h.
      </p>
    </div>
  </section>

  <!-- ============================================== -->
  <!-- PREUVES -->
  <!-- ============================================== -->
  <section class="py-20 md:py-28 px-4 bg-white border-y-2 border-black">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-12 md:mb-16">
        <span class="inline-flex items-center gap-2 text-xs font-mono uppercase tracking-[0.2em] text-gray-500 mb-4">
          <span class="w-8 h-px bg-gray-400"></span>
          preuves
          <span class="w-8 h-px bg-gray-400"></span>
        </span>
        <h2 class="text-3xl md:text-4xl font-normal tracking-tight mb-4">
          Pourquoi <strong>me faire confiance</strong>
        </h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Pas de storytelling : des faits vérifiables et un ancrage suisse réel.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-10">
        {metier.preuves.map((preuve) => (
          <div class="bg-[var(--main-bg)] border-2 border-black p-5 shadow-[4px_4px_0px_rgba(0,0,0,0.3)] flex items-start gap-4">
            <div class="w-10 h-10 bg-[var(--blue)] border-2 border-black flex items-center justify-center flex-shrink-0">
              <i class="ri-verified-badge-line text-lg"></i>
            </div>
            <p class="text-sm text-gray-700 leading-relaxed pt-1">{preuve}</p>
          </div>
        ))}
      </div>

      <div class="text-center">
        <a href="/portfolio" class="inline-flex items-center gap-2 text-[var(--blue)] font-medium hover:underline">
          Voir mes réalisations
          <i class="ri-arrow-right-line"></i>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================== -->
  <!-- MAILLAGE — HUB + SERVICES + ARTICLES -->
  <!-- ============================================== -->
  <section class="py-20 md:py-28 px-4">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-12 md:mb-16">
