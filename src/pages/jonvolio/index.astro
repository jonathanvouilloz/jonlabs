---
import JonvolioLayout from '../../layouts/JonvolioLayout.astro';
import { jonvolio } from '../../data/jonvolio';

const currentlyItems = [
  { title: 'Building tools', desc: 'for small businesses' },
  { title: 'AI-assisted', desc: 'development' },
  { title: 'Shipping', desc: 'side projects in public' },
];
---

<JonvolioLayout
  title="jonvolio"
  description="I build things on the internet. Indie hacker from Geneva, Switzerland."
>
  <!-- Hero Section -->
  <section class="home-hero">
    <div class="hero-content">
      <img
        src="/jonvolio/jonvolio.webp"
        alt="Jonathan Vouilloz"
        class="avatar-round"
      />
      <div class="hero-text">
        <h1>Hey, it's Jonathan Vouilloz!</h1>
        <p class="tagline">{jonvolio.tagline}</p>
        <p class="location">Geneva, Switzerland</p>
      </div>
    </div>
  </section>

  <!-- Currently Section -->
  <section class="currently-section">
    <span class="section-label">Currently</span>
    <div class="currently-cards">
      {currentlyItems.map(item => (
        <div class="currently-card">
          <span class="card-title">{item.title}</span>
          <span class="card-desc">{item.desc}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- Quick Links -->
  <section class="jonvolio-section">
    <div class="quick-links">
      <a href="/jonvolio/projects">Projects</a>
      <a href="/jonvolio/blog">Blog</a>
      <a href="/jonvolio/inspirations">Inspirations</a>
      <a href="/">Jon Labs (FR)</a>
    </div>
  </section>

  <!-- About snippet -->
  <section class="jonvolio-section">
    <p class="about-text">
      Developer and indie hacker based in Geneva. By day, I help businesses
      through <a href="/">Jon Labs</a>. By night, I build side projects
      and share what I learn along the way.
    </p>
  </section>
</JonvolioLayout>
