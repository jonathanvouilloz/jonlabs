---
import JonvolioLayout from '../../../layouts/JonvolioLayout.astro';
import { getCollection } from 'astro:content';

// Get all projects sorted by date (newest first)
const projects = await getCollection('jonvolio-projects');
const sortedProjects = projects.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

// Status labels (simple format)
const statusLabels = {
  live: '> live',
  wip: '> wip',
  archived: '> archived',
};

// 2026 Challenge: 24 apps (2 per month)
const liveProjects2026 = projects.filter(p => {
  const date = new Date(p.data.date);
  return p.data.status === 'live' && date.getFullYear() === 2026;
});

// Count projects per month (for 24 cubes - 2 per month)
const projectsPerMonth = Array(12).fill(0);
liveProjects2026.forEach(p => {
  const month = new Date(p.data.date).getMonth();
  projectsPerMonth[month]++;
});

// Generate 24 cubes (2 per month)
const cubes = [];
const currentMonth = new Date().getMonth();
for (let month = 0; month < 12; month++) {
  const count = projectsPerMonth[month];
  const isFuture = month > currentMonth;
  // First cube of the month
  cubes.push({
    filled: count >= 1,
    future: isFuture
  });
  // Second cube of the month
  cubes.push({
    filled: count >= 2,
    future: isFuture
  });
}

const totalShipped = liveProjects2026.length;

// Group projects by year
const projectsByYear = sortedProjects.reduce((acc, project) => {
  const year = new Date(project.data.date).getFullYear();
  if (!acc[year]) acc[year] = [];
  acc[year].push(project);
  return acc;
}, {} as Record<number, typeof sortedProjects>);

const years = Object.keys(projectsByYear).sort((a, b) => Number(b) - Number(a));
---

<JonvolioLayout
  title="Projects"
  description="Side projects, experiments, and shipped products. Here's what I'm building."
>
  <section class="jonvolio-hero">
    <h1>Projects</h1>
    <p class="tagline">Side projects, experiments, shipped products.</p>

    <div class="challenge-section">
      <p class="challenge-text">My goal is to ship at least 24 apps in 2026 (2 per month minimum).</p>
      <div class="challenge-grid">
        <span class="challenge-label">2026</span>
        <div class="month-squares">
          {cubes.map((cube, i) => (
            <div
              class={`month-square ${cube.filled ? 'filled' : ''} ${cube.future ? 'future' : ''}`}
              title={`App ${i + 1}/24`}
            />
          ))}
        </div>
        <span class="challenge-count">{totalShipped}/24</span>
      </div>
    </div>
  </section>

  <section class="py-8">
    {sortedProjects.length > 0 ? (
      <div class="projects-by-year">
        {years.map((year, yearIndex) => (
          <>
            {yearIndex > 0 && <hr class="year-divider" />}
            <div class="year-section">
              <span class="year-label">{year}</span>
              <div class="project-grid">
                {projectsByYear[Number(year)].map(project => (
                  <article class="project-card">
                    {project.data.thumbnail && (
                      <div class="thumbnail">
                        <img
                          src={project.data.thumbnail}
                          alt={project.data.title}
                          loading="lazy"
                        />
                      </div>
                    )}
                    <div class="project-meta">
                      <span class="project-status">
                        {statusLabels[project.data.status]}
                      </span>
                      <span class="project-date">
                        {new Date(project.data.date).toLocaleDateString('en', { month: 'short' })}
                      </span>
                    </div>
                    <h3>{project.data.title}</h3>
                    <p>{project.data.description}</p>
                    <div class="flex justify-between items-end mt-auto">
                      {project.data.stack.length > 0 ? (
                        <div class="stack">
                          {project.data.stack.map(tech => (
                            <span class="stack-badge">{tech}</span>
                          ))}
                        </div>
                      ) : <div></div>}
                      {project.data.url && (
                        <a href={project.data.url} target="_blank" rel="noopener" class="text-sm whitespace-nowrap">
                          See project &rarr;
                        </a>
                      )}
                    </div>
                  </article>
                ))}
              </div>
            </div>
          </>
        ))}
      </div>
    ) : (
      <div class="text-center py-12 text-muted">
        <p>Projects coming soon...</p>
        <p class="text-sm mt-2">Check back later or follow me on <a href="https://twitter.com/jonvolio" target="_blank" rel="noopener">Twitter</a> for updates.</p>
      </div>
    )}
  </section>
</JonvolioLayout>
