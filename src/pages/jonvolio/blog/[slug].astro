---
import JonvolioLayout from '../../../layouts/JonvolioLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('jonvolio-blog', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<JonvolioLayout
  title={post.data.title}
  description={post.data.description}
  ogType="article"
  article={{
    publishedTime: post.data.pubDate,
    author: 'Jon Vouilloz',
    tags: post.data.tags,
  }}
>
  <article class="py-8">
    <!-- Header -->
    <header class="mb-8">
      <p class="text-muted text-sm mono mb-2">{formatDate(post.data.pubDate)}</p>
      <h1 class="text-2xl font-semibold mb-4">{post.data.title}</h1>
      {post.data.tags.length > 0 && (
        <div class="flex flex-wrap gap-2">
          {post.data.tags.map(tag => (
            <span class="stack-badge">{tag}</span>
          ))}
        </div>
      )}
    </header>

    <!-- Content -->
    <div class="prose">
      <Content />
    </div>

    <!-- Footer -->
    <footer class="mt-12 pt-8 border-t border-[var(--jv-border-muted)]">
      <a href="/jonvolio/blog" class="text-[var(--jv-accent)] hover:underline">
        &larr; Back to blog
      </a>
    </footer>
  </article>
</JonvolioLayout>

<script>
  // Add copy buttons to all code blocks
  document.querySelectorAll('.prose pre').forEach((pre) => {
    // Create wrapper
    const wrapper = document.createElement('div');
    wrapper.className = 'code-block-wrapper';
    pre.parentNode?.insertBefore(wrapper, pre);
    wrapper.appendChild(pre);

    // Create copy button
    const btn = document.createElement('button');
    btn.className = 'copy-btn';
    btn.setAttribute('aria-label', 'Copy code');
    btn.innerHTML = `
      <svg class="copy-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
        <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
      </svg>
      <svg class="check-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="20 6 9 17 4 12"></polyline>
      </svg>
      <span class="tooltip">Copy</span>
    `;
    wrapper.appendChild(btn);

    // Handle click
    btn.addEventListener('click', async () => {
      const code = pre.querySelector('code')?.textContent || pre.textContent || '';
      await navigator.clipboard.writeText(code);

      btn.classList.add('copied');
      btn.querySelector('.tooltip')!.textContent = 'Copied!';

      setTimeout(() => {
        btn.classList.remove('copied');
        btn.querySelector('.tooltip')!.textContent = 'Copy';
      }, 2000);
    });
  });
</script>

<style>
  /* Prose styling for blog content */
  .prose :global(h2) {
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .prose :global(h3) {
    font-size: 1.125rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .prose :global(p) {
    margin-bottom: 1rem;
    line-height: 1.75;
  }

  /* Lists */
  .prose :global(ul),
  .prose :global(ol) {
    margin-bottom: 1.25rem;
    padding-left: 0;
    list-style: none;
  }

  .prose :global(ul ul),
  .prose :global(ol ol),
  .prose :global(ul ol),
  .prose :global(ol ul) {
    margin-top: 0.5rem;
    margin-bottom: 0.5rem;
    padding-left: 1.25rem;
  }

  .prose :global(li) {
    position: relative;
    padding-left: 1.5rem;
    margin-bottom: 0.5rem;
    line-height: 1.7;
  }

  .prose :global(ul > li)::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.7em;
    width: 6px;
    height: 6px;
    background: var(--jv-accent);
    border-radius: 50%;
  }

  .prose :global(ul ul > li)::before {
    background: transparent;
    border: 1.5px solid var(--jv-accent);
  }

  .prose :global(ol) {
    counter-reset: list-counter;
  }

  .prose :global(ol > li) {
    counter-increment: list-counter;
  }

  .prose :global(ol > li)::before {
    content: counter(list-counter) ".";
    position: absolute;
    left: 0;
    font-weight: 600;
    color: var(--jv-accent);
    font-size: 0.875em;
  }

  .prose :global(li strong) {
    color: var(--jv-text);
  }

  /* Tables */
  .prose :global(table) {
    width: 100%;
    margin: 1.5rem 0;
    border-collapse: collapse;
    font-size: 0.9rem;
    overflow: hidden;
    border-radius: 8px;
    border: 1px solid var(--jv-border-muted);
  }

  .prose :global(thead) {
    background: var(--jv-code-bg);
  }

  .prose :global(th) {
    padding: 0.75rem 1rem;
    text-align: left;
    font-weight: 600;
    color: var(--jv-text);
    border-bottom: 2px solid var(--jv-border-muted);
  }

  .prose :global(td) {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--jv-border-muted);
    color: var(--jv-text-muted);
  }

  .prose :global(tr:last-child td) {
    border-bottom: none;
  }

  .prose :global(tbody tr:hover) {
    background: var(--jv-code-bg);
  }

  .prose :global(td code),
  .prose :global(th code) {
    font-size: 0.85em;
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--jv-border);
    padding-left: 1rem;
    color: var(--jv-text-muted);
    font-style: italic;
    margin: 1rem 0;
  }

  .prose :global(pre) {
    background: var(--jv-code-bg);
    border-radius: 6px;
    padding: 1rem;
    overflow-x: auto;
    font-size: 0.875rem;
    margin: 1rem 0;
  }

  .prose :global(code:not(pre code)) {
    background: var(--jv-code-bg);
    padding: 0.125rem 0.375rem;
    border-radius: 4px;
    font-size: 0.875em;
  }

  .prose :global(a) {
    color: var(--jv-accent);
    text-decoration: underline;
  }

  .prose :global(a:hover) {
    color: var(--jv-accent-hover);
  }

  .prose :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 6px;
    margin: 1.5rem 0;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--jv-border-muted);
    margin: 2rem 0;
  }

  /* Code block copy button */
  .prose :global(.code-block-wrapper) {
    position: relative;
  }

  .prose :global(.copy-btn) {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    padding: 0.375rem;
    background: var(--jv-bg);
    border: 1px solid var(--jv-border-muted);
    border-radius: 4px;
    color: var(--jv-text-muted);
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.2s, background 0.2s, color 0.2s;
  }

  .prose :global(.code-block-wrapper:hover .copy-btn) {
    opacity: 1;
  }

  .prose :global(.copy-btn:hover) {
    background: var(--jv-border-muted);
    color: var(--jv-text);
  }

  .prose :global(.copy-btn .copy-icon) {
    display: block;
  }

  .prose :global(.copy-btn .check-icon) {
    display: none;
  }

  .prose :global(.copy-btn.copied .copy-icon) {
    display: none;
  }

  .prose :global(.copy-btn.copied .check-icon) {
    display: block;
    color: #22c55e;
  }

  .prose :global(.copy-btn .tooltip) {
    position: absolute;
    bottom: calc(100% + 0.5rem);
    left: 50%;
    transform: translateX(-50%);
    padding: 0.25rem 0.5rem;
    background: var(--jv-text);
    color: var(--jv-bg);
    font-size: 0.75rem;
    border-radius: 4px;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s;
  }

  .prose :global(.copy-btn .tooltip::after) {
    content: '';
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border: 4px solid transparent;
    border-top-color: var(--jv-text);
  }

  .prose :global(.copy-btn:hover .tooltip),
  .prose :global(.copy-btn.copied .tooltip) {
    opacity: 1;
  }

  /* Expert Quote Cards */
  .prose :global(.expert-card) {
    border: 1px solid var(--jv-border);
    border-radius: 8px;
    padding: 1.5rem;
    margin: 1.5rem 0;
    background: var(--jv-bg-secondary);
    transition: border-color 0.2s ease;
  }

  .prose :global(.expert-card:hover) {
    border-color: var(--jv-accent);
  }

  .prose :global(.expert-header) {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--jv-border-muted);
  }

  .prose :global(.expert-name) {
    font-weight: 600;
    font-size: 1rem;
    color: var(--jv-text);
  }

  .prose :global(.expert-title) {
    font-size: 0.8rem;
    color: var(--jv-text-muted);
    font-family: var(--font-mono);
  }

  .prose :global(.expert-content blockquote) {
    border-left: 3px solid var(--jv-accent);
    margin: 0.75rem 0;
  }

  .prose :global(.expert-source) {
    display: block;
    text-align: right;
    font-size: 0.8rem;
    margin-top: 1rem;
    color: var(--jv-text-muted);
  }

  .prose :global(.expert-source:hover) {
    color: var(--jv-accent);
  }
</style>
