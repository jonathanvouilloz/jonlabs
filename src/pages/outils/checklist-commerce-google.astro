<script>
    // PDF Form submission — HARD-PRESERVE (câblage Web3Forms inchangé, id #pdf-form)
    const pdfForm = document.getElementById('pdf-form') as HTMLFormElement;

    pdfForm?.addEventListener('submit', async (e) => {
        e.preventDefault();

        const submitBtn = pdfForm.querySelector('button[type="submit"]') as HTMLButtonElement;

        // Loading state
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<i class="ri-loader-4-line"></i> Envoi en cours...';

        try {
            const formData = new FormData(pdfForm);
            const response = await fetch('https://api.web3forms.com/submit', {
                method: 'POST',
                body: formData
            });

            const result = await response.json();

            if (result.success) {
                // Redirect to thank you page with PDF access
                window.location.href = '/merci-checklist';
            } else {
                alert('Erreur lors de l\'envoi. Réessaye ou écris-moi directement à contact@jonlabs.ch');
                submitBtn.innerHTML = '<i class="ri-download-line"></i> Recevoir le PDF';
                submitBtn.disabled = false;
            }
        } catch (error) {
            alert('Erreur de connexion. Réessaye.');
            submitBtn.innerHTML = '<i class="ri-download-line"></i> Recevoir le PDF';
            submitBtn.disabled = false;
        }
    });
</script>
