</Layout>

<style>
    .intro-bar {
        background: #0a0a0f;
    }

    .intro-bar::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image:
            linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
        background-size: 50px 50px;
        pointer-events: none;
    }

    .score-bar {
        background: white;
    }

    .checklist-card {
        transition: all 0.15s ease;
    }

    .checklist-card:hover {
        box-shadow: 4px 4px 0px rgba(0,0,0,0.12);
    }

    .palier-block {
        transition: all 0.25s ease;
    }

    section[id] {
        scroll-margin-top: 80px;
    }
</style>

<script>
    // Score calculation
    const checkboxes = document.querySelectorAll<HTMLInputElement>('.score-checkbox');
    const scoreCount = document.getElementById('score-count');
    const scoreBar = document.getElementById('score-bar') as HTMLElement;
    const scoreLabel = document.getElementById('score-label');
    const diagnosticScoreDisplays = document.querySelectorAll<HTMLElement>('.diagnostic-score-display');

    const palierInitial = document.getElementById('palier-initial');
    const palier0 = document.getElementById('palier-0');
    const palier1 = document.getElementById('palier-1');
    const palier2 = document.getElementById('palier-2');

    function updateScore() {
        const checked = Array.from(checkboxes).filter(cb => cb.checked).length;
        const pct = (checked / 15) * 100;

        if (scoreCount) scoreCount.textContent = String(checked);
        if (scoreBar) scoreBar.style.width = `${pct}%`;

        diagnosticScoreDisplays.forEach(el => el.textContent = String(checked));

        // Color the bar
        if (scoreBar) {
            if (checked <= 5) {
                scoreBar.style.background = '#4ade80';
            } else if (checked <= 10) {
                scoreBar.style.background = 'var(--yellow)';
            } else {
                scoreBar.style.background = '#ef4444';
            }
        }

        // Update label
        if (scoreLabel) {
            if (checked === 0) {
                scoreLabel.textContent = 'Commence le diagnostic';
                scoreLabel.className = 'text-sm font-medium text-gray-500 hidden sm:block';
            } else if (checked <= 5) {
                scoreLabel.textContent = 'Site réveillé';
                scoreLabel.className = 'text-sm font-medium text-green-600 hidden sm:block';
            } else if (checked <= 10) {
                scoreLabel.textContent = 'Site en sommeil';
                scoreLabel.className = 'text-sm font-medium text-yellow-600 hidden sm:block';
            } else {
                scoreLabel.textContent = 'Site mort clinique';
                scoreLabel.className = 'text-sm font-medium text-red-600 hidden sm:block';
            }
        }

        // Show/hide diagnostic paliers
        if (palierInitial) palierInitial.classList.toggle('hidden', checked > 0);
        if (palier0) palier0.classList.toggle('hidden', !(checked >= 0 && checked <= 5 && checked > 0));
        if (palier1) palier1.classList.toggle('hidden', !(checked >= 6 && checked <= 10));
        if (palier2) palier2.classList.toggle('hidden', !(checked >= 11));
    }

    checkboxes.forEach(checkbox => {
        checkbox.addEventListener('change', updateScore);
    });

    // PDF Form submission
    const pdfForm = document.getElementById('pdf-form') as HTMLFormElement;

    pdfForm?.addEventListener('submit', async (e) => {
        e.preventDefault();

        const submitBtn = pdfForm.querySelector('button[type="submit"]') as HTMLButtonElement;
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<i class="ri-loader-4-line animate-spin"></i> Envoi en cours...';

        try {
            const formData = new FormData(pdfForm);
            const response = await fetch('https://api.web3forms.com/submit', {
                method: 'POST',
                body: formData
            });

            const result = await response.json();

            if (result.success) {
                window.location.href = '/merci-checklist-15-signes';
            } else {
                alert('Erreur lors de l\'envoi. Réessaye ou écris-moi directement à contact@jonlabs.ch');
                submitBtn.innerHTML = '<i class="ri-download-line"></i> Recevoir le PDF →';
                submitBtn.disabled = false;
            }
        } catch (error) {
            alert('Erreur de connexion. Réessaye.');
            submitBtn.innerHTML = '<i class="ri-download-line"></i> Recevoir le PDF →';
            submitBtn.disabled = false;
        }
    });
</script>
