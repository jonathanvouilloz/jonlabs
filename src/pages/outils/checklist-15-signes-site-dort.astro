---
// Checklist « 15 signes que ton site dort » — landing lead-magnet (blueprint).
// Migrée du brutaliste vers le design system .co-* : sections cadrées, filets fins,
// crosshairs, colonne capée, coins nets, accent teal unique, Inter Tight ×
// Instrument Serif. Namespace scopé .c15-*. Gabarit-or : services/referencement-local.astro.
//
// HARD-PRESERVE :
//  - Formulaire Web3Forms (#pdf-form) INTACT : action/endpoint, method, access_key
//    (3f64c7a1-46b9-4524-8e78-47524896d467), hidden subject/from_name, honeypot
//    botcheck, name="email", bouton submit + le <script> de submit (fetch + redirect
//    vers /merci-checklist-15-signes). Seul le STYLE change, jamais le câblage.
//  - Script de score interactif : ids/classes conservés (.score-checkbox,
//    #score-count, #score-bar, #score-label, .diagnostic-score-display,
//    #palier-initial, #palier-0/1/2, classe hidden togglée).
//  - Schema.org : getWebPageSchema + getBreadcrumbSchema, tableau schemas, injection
//    Layout schemas — data + ordre. seoData exact. global.css gardé. Copie FR préservée.
//    Deep-links internes (/outils, /blog/*, /services/*) intacts.
//
// Déviation assumée : la barre de score sticky brutaliste devient un panneau non
// sticky (`.co-root` a `overflow:hidden`, qui casse position:sticky). Feedback live
// conservé + rappel du score dans la section diagnostic.

import '../../styles/global.css';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

// Schema.org
import { SITE_URL } from '../../data/schema';
import { getWebPageSchema, getBreadcrumbSchema } from '../../lib/seo';

const seoData = {
    title: "Checklist 15 signes que ton site dort | Diagnostic gratuit | Jon Labs",
    description: "15 questions oui/non, 4 minutes, score sur 15. Diagnostic honnête de ton site web : visible, actif ou mort clinique ? Télécharge le PDF."
};

const webPageSchema = getWebPageSchema({
    url: `${SITE_URL}/outils/checklist-15-signes-site-dort`,
    name: seoData.title,
    description: seoData.description
});
const breadcrumb = getBreadcrumbSchema([
    { name: "Accueil", url: SITE_URL },
    { name: "Outils", url: `${SITE_URL}/outils` },
    { name: "Checklist 15 signes que ton site dort", url: `${SITE_URL}/outils/checklist-15-signes-site-dort` }
]);
const schemas = [webPageSchema, breadcrumb];

const categories = [
    {
        id: "visibilite",
        title: "Visibilité Google",
        range: "Signes 1 à 3",
        icon: "ri-search-eye-line",
        items: [
            { num: 1, text: "Tu n'as jamais ouvert Google Search Console (ou tu ne sais pas ce que c'est)." },
            { num: 2, text: "Tu tapes le nom exact de ton activité plus ta ville sur Google, et tu n'apparais pas en page 1." },
            { num: 3, text: "Ta fiche Google Business n'a pas bougé depuis plus de 6 mois (ou tu n'en as pas)." }
        ]
    },
    {
        id: "contenu",
        title: "Contenu",
        range: "Signes 4 à 6",
        icon: "ri-article-line",
        items: [
            { num: 4, text: "Ton dernier article ou ta dernière actualité date de plus de 6 mois (ou tu n'as jamais rien publié)." },
            { num: 5, text: "Tes pages services font moins de 300 mots et se ressemblent toutes." },
            { num: 6, text: "Tu n'as aucun blog, aucune ressource, aucune FAQ publique." }
        ]
    },
    {
        id: "technique",
        title: "Technique",
        range: "Signes 7 à 9",
        icon: "ri-code-s-slash-line",
        items: [
            { num: 7, text: "Ton site n'est pas en HTTPS." },
            { num: 8, text: "Tu ouvres ton site sur ton téléphone et c'est illisible." },
            { num: 9, text: "Ton site met plus de 3 secondes à s'afficher sur une 4G moyenne." }
        ]
    },
    {
        id: "conversion",
        title: "Conversion",
        range: "Signes 10 à 12",
        icon: "ri-cursor-line",
        items: [
            { num: 10, text: "Aucun call-to-action clair au-dessus de la ligne de flottaison." },
            { num: 11, text: "Ton formulaire de contact, tu ne sais même pas s'il fonctionne." },
            { num: 12, text: "Tu n'as aucun outil de suivi (Analytics, Plausible, Fathom...)." }
        ]
    },
    {
        id: "autorite",
        title: "Autorité et E-E-A-T",
        range: "Signes 13 à 15",
        icon: "ri-shield-check-line",
        items: [
            { num: 13, text: "Aucune page « À propos » réelle avec photo et histoire." },
            { num: 14, text: "Aucun avis client visible sur le site." },
            { num: 15, text: "Aucun auteur identifié sur tes pages ou tes articles." }
        ]
    }
];
---

<Layout
    title={seoData.title}
    description={seoData.description}
    schemas={schemas}
>
    <Header />

    <main class="co-root">

        <!-- ══ HERO ══ -->
        <section class="co-sec co-pad co-hero c15-hero" style="padding:64px 40px 48px;">
            <nav class="c15-crumb" aria-label="Fil d'Ariane">
                <a href="/">Accueil</a>
                <span aria-hidden="true">/</span>
                <a href="/outils">Outils</a>
                <span aria-hidden="true">/</span>
                <span class="co-mut">Checklist 15 signes</span>
            </nav>

            <h1 class="c15-hero-title" data-animate data-delay="0.1">
                15 signes que <span class="co-ser">ton site dort</span>
            </h1>

            <p class="c15-hero-lead" data-animate data-delay="0.2">
                15 questions fermées, oui ou non, 4 minutes montre en main.
                <strong>Coche, additionne, lis ton diagnostic.</strong>
            </p>

            <div class="c15-hero-btns" data-animate data-delay="0.3">
                <a href="#signe-1" class="co-btn"><i class="ri-play-line"></i> Commencer le diagnostic</a>
                <a href="#telecharger" class="co-btn co-btn--ghost"><i class="ri-download-line"></i> Télécharger le PDF</a>
            </div>

            <div class="c15-hero-context co-frame" data-animate data-delay="0.4">
                <span class="co-x tl"></span><span class="co-x tr"></span>
                <span class="co-x bl"></span><span class="co-x br"></span>
                <i class="ri-article-line" aria-hidden="true"></i>
                <p>
                    Tu n'as pas lu l'article complet ?
                    <a href="/blog/15-signes-site-web-dort" class="c15-inline">Commence par là <i class="ri-arrow-right-line"></i></a>
                </p>
            </div>
        </section>

        <!-- ══ MÉTRIQUES + SCORE LIVE ══ -->
        <section class="co-sec co-pad" style="padding:48px 40px;">
            <p class="co-eyebrow">Le diagnostic en chiffres</p>

            <div class="c15-metrics" data-animate-stagger>
                <div class="c15-stat co-frame co-frame--reveal" data-animate-item>
                    <div class="c15-stat-value">15</div>
                    <div class="c15-stat-label">signes à vérifier</div>
                </div>
                <div class="c15-stat co-frame co-frame--reveal" data-animate-item>
                    <div class="c15-stat-value">4 min</div>
                    <div class="c15-stat-label">montre en main</div>
                </div>
                <div class="c15-stat co-frame co-frame--reveal" data-animate-item>
                    <div class="c15-stat-value">0 CHF</div>
                    <div class="c15-stat-label">100 % gratuit</div>
                </div>
            </div>

            <div class="c15-trust" data-animate>
                <span><i class="ri-check-line"></i> Score calculé en direct</span>
                <span><i class="ri-check-line"></i> Diagnostic personnalisé</span>
                <span><i class="ri-check-line"></i> PDF imprimable</span>
            </div>

            <!-- Panneau score (live, alimenté par le script — non sticky, cf. note frontmatter) -->
            <div class="c15-score co-frame" data-animate>
                <span class="co-x tl"></span><span class="co-x tr"></span>
                <span class="co-x bl"></span><span class="co-x br"></span>
                <div class="c15-score-head">
                    <span class="co-eyebrow">Score</span>
                    <span class="c15-score-num"><span id="score-count">0</span><span class="co-mut">/15</span></span>
                </div>
                <div class="c15-score-track">
                    <div id="score-bar" class="c15-score-fill" style="width: 0%"></div>
                </div>
                <div id="score-label" class="c15-score-status">Commence le diagnostic</div>
            </div>
        </section>

        <!-- ══ CATÉGORIES ══ -->
        {categories.map((cat, catIndex) => (
            <section
                id={`signe-${cat.items[0].num}`}
                class="co-sec co-pad c15-cat"
                style="padding:52px 40px;"
            >
                <div class="c15-cat-head" data-animate>
                    <span class="c15-cat-index co-index">0{catIndex + 1}</span>
                    <i class={`${cat.icon} c15-cat-icon`} aria-hidden="true"></i>
                    <div>
                        <span class="co-eyebrow">{cat.range}</span>
                        <h2 class="c15-cat-title">{cat.title}</h2>
                    </div>
                </div>

                <div class="c15-items" data-animate-stagger>
                    {cat.items.map((item) => (
                        <label class="c15-item co-frame co-frame--reveal" data-animate-item>
                            <input
                                type="checkbox"
                                class="score-checkbox c15-check"
                                id={`signe-check-${item.num}`}
                                aria-label={`Signe ${item.num}`}
                            />
                            <span class="c15-item-num co-index">#{item.num}</span>
                            <span class="c15-item-text">{item.text}</span>
                        </label>
                    ))}
                </div>
            </section>
        ))}

        <!-- ══ DIAGNOSTIC ══ -->
        <section id="diagnostic" class="co-sec co-pad" style="padding:56px 40px;">
            <p class="co-eyebrow">Résultat</p>
            <h2 style="margin-top:8px;">Ton <span class="co-ser">diagnostic</span></h2>
            <p class="co-mut" style="margin-top:10px;">
                Score actuel : <strong class="c15-diag-score"><span class="diagnostic-score-display">0</span>/15</strong>
            </p>

            <!-- Palier 0-5 : Site réveillé -->
            <div id="palier-0" class="c15-palier c15-palier--ok palier-block co-frame hidden">
                <span class="co-x tl"></span><span class="co-x tr"></span>
                <span class="co-x bl"></span><span class="co-x br"></span>
                <div class="c15-palier-head">
                    <i class="ri-sun-line c15-palier-icon" aria-hidden="true"></i>
                    <div class="c15-palier-titlerow">
                        <h3>Site réveillé</h3>
                        <span class="c15-palier-tag">0-5 signes</span>
                    </div>
                </div>
                <div class="c15-palier-body">
                    <p>
                        Tu fais déjà beaucoup de choses bien. Les signes cochés sont des optimisations, pas des fondations manquantes. Pas besoin de tout refaire : un article de plus par trimestre, une page À propos enrichie, quelques avis clients captés.
                    </p>
                    <p class="c15-palier-note">
                        Risque principal : la complaisance. Un site qui fonctionne aujourd'hui peut dormir dans 18 mois si tu le laisses tranquille. Relis cette checklist tous les 6 mois.
                    </p>
                </div>
            </div>

            <!-- Palier 6-10 : Site en sommeil -->
            <div id="palier-1" class="c15-palier c15-palier--warn palier-block co-frame hidden">
                <span class="co-x tl"></span><span class="co-x tr"></span>
                <span class="co-x bl"></span><span class="co-x br"></span>
                <div class="c15-palier-head">
                    <i class="ri-moon-line c15-palier-icon" aria-hidden="true"></i>
                    <div class="c15-palier-titlerow">
                        <h3>Site en sommeil</h3>
                        <span class="c15-palier-tag">6-10 signes</span>
                    </div>
                </div>
                <div class="c15-palier-body">
                    <p>
                        C'est la zone la plus fréquente. Le site existe, il a été bien pensé au départ, mais personne ne l'a touché depuis la mise en ligne. Tu as probablement un bon produit et un site qui sous-performe de 50 à 70 %.
                    </p>
                    <p class="c15-palier-note">
                        Bonne nouvelle : ça se réveille. Il te faut un plan de 30 jours ciblé sur les signes cochés.
                    </p>
                    <a href="/blog/0a30joursgooglevisible" class="co-btn c15-palier-btn">
                        <i class="ri-arrow-right-line"></i> Plan 30 jours étape par étape
                    </a>
                </div>
            </div>

            <!-- Palier 11-15 : Site mort clinique -->
            <div id="palier-2" class="c15-palier c15-palier--bad palier-block co-frame hidden">
                <span class="co-x tl"></span><span class="co-x tr"></span>
                <span class="co-x bl"></span><span class="co-x br"></span>
                <div class="c15-palier-head">
                    <i class="ri-alarm-warning-line c15-palier-icon" aria-hidden="true"></i>
                    <div class="c15-palier-titlerow">
                        <h3>Site mort clinique</h3>
                        <span class="c15-palier-tag">11-15 signes</span>
                    </div>
                </div>
                <div class="c15-palier-body">
                    <p>
                        À 11 ou plus, tu paies l'hébergement d'un site qui travaille contre toi. Chaque semaine qui passe, un prospect qui aurait dû t'appeler appelle quelqu'un d'autre.
                    </p>
                    <p class="c15-palier-note">
                        Si tu veux mettre un chiffre dessus avant de décider, le calculateur de coût d'un site dormant te donne une estimation en 60 secondes.
                    </p>
                    <div class="c15-palier-btns">
                        <a href="/services/refonte-site-web" class="co-btn c15-palier-btn">
                            <i class="ri-arrow-right-line"></i> Regarder ensemble ton site
                        </a>
                        <a href="/blog/cout-site-web-dormant-calculateur" class="co-btn co-btn--ghost">
                            Calculer ton coût dormant
                        </a>
                    </div>
                </div>
            </div>

            <!-- État initial : pas encore commencé -->
            <div id="palier-initial" class="c15-palier-initial">
                <i class="ri-checkbox-blank-circle-line" aria-hidden="true"></i>
                <p class="co-mut">Coche les signes ci-dessus pour voir ton diagnostic apparaître ici.</p>
            </div>
        </section>

        <!-- ══ TÉLÉCHARGEMENT PDF + FORMULAIRE (Web3Forms — HARD-PRESERVE câblage) ══ -->
        <section id="telecharger" class="co-sec co-pad" style="padding:56px 40px 64px;">
            <div class="c15-dl-grid">
                <!-- Visuel -->
                <div class="c15-dl-visual" data-animate="scale">
                    <div class="c15-mock co-frame">
                        <span class="co-x tl"></span><span class="co-x tr"></span>
                        <span class="co-x bl"></span><span class="co-x br"></span>
                        <div class="c15-mock-icon"><i class="ri-file-list-3-line" aria-hidden="true"></i></div>
                        <p class="c15-mock-title">Checklist PDF</p>
                        <p class="c15-mock-sub">15 signes que ton site dort</p>
                        <div class="c15-mock-lines">
                            {[1,2,3,4,5].map(() => (
                                <div class="c15-mock-line">
                                    <span class="c15-mock-box"></span>
                                    <span class="c15-mock-bar"></span>
                                </div>
                            ))}
                            <p class="c15-mock-more">+ 10 autres signes</p>
                        </div>
                    </div>
                </div>

                <!-- Contenu + formulaire -->
                <div class="c15-dl-content" data-animate>
                    <p class="co-eyebrow"><i class="ri-file-pdf-line"></i> Téléchargement gratuit</p>
                    <h2 style="margin-top:10px;">Télécharge la checklist en <span class="co-ser">PDF</span></h2>
                    <p class="co-mut" style="margin-top:10px;line-height:1.6;">
                        Imprime-la, remplis-la au stylo, partage-la à un associé ou glisse-la dans un dossier client.
                    </p>

                    <div class="c15-bonus co-frame">
                        <p class="c15-bonus-title">Dans la version PDF :</p>
                        <ul class="co-list co-list--check">
                            <li><i class="ri-check-line"></i><span>Les 15 signes groupés par catégorie avec cases à cocher</span></li>
                            <li><i class="ri-check-line"></i><span>Tableau récap des 3 paliers de diagnostic</span></li>
                            <li><i class="ri-check-line"></i><span>Plan d'action par palier (0-5 / 6-10 / 11-15)</span></li>
                            <li><i class="ri-check-line"></i><span><strong>Bonus :</strong> Liens vers les ressources utiles pour chaque signe</span></li>
                        </ul>
                    </div>

                    <!-- Form — HARD-PRESERVE : action, access_key, name=, botcheck, script -->
                    <form
                        action="https://api.web3forms.com/submit"
                        method="POST"
                        class="c15-form"
                        id="pdf-form"
                    >
                        <input type="hidden" name="access_key" value="3f64c7a1-46b9-4524-8e78-47524896d467">
                        <input type="hidden" name="subject" value="Téléchargement Checklist 15 Signes Site Dort">
                        <input type="hidden" name="from_name" value="Jon Labs - Checklist 15 Signes PDF">
                        <input type="checkbox" name="botcheck" class="hidden" style="display: none;">

                        <div class="c15-field">
                            <label for="c15-email" class="c15-label"><span class="co-index">01</span> Ton email</label>
                            <input
                                type="email"
                                id="c15-email"
                                name="email"
                                placeholder="vous@exemple.ch"
                                required
                                class="c15-input"
                            />
                        </div>

                        <button type="submit" class="co-btn c15-submit">
                            <i class="ri-download-line"></i> Recevoir le PDF →
                        </button>

                        <p class="c15-form-note">
                            Pas de spam. Juste la checklist, et de temps en temps des conseils pratiques.
                        </p>
                    </form>
                </div>
            </div>
        </section>

        <!-- ══ CTA (ancien composant CTA remplacé par la primitive .co-cta inline — bouton clair sur ink) ══ -->
        <section class="co-cta">
            <span class="co-x tl"></span><span class="co-x tr"></span>
            <span class="co-x bl"></span><span class="co-x br"></span>
            <div class="co-cta-inner">
                <p class="co-cta-eyebrow">Option accompagnée</p>
                <h2 class="co-cta-title">Tu préfères un regard <span class="co-ser">extérieur ?</span></h2>
                <p class="co-cta-lead">
                    Cette checklist diagnostique l'état. Si ton score est élevé et que tu veux aller vite, je peux regarder ton site avec toi, chiffres en main, et te dire ce qui saigne le plus.
                </p>
                <div class="co-cta-btns">
                    <a href="/services/refonte-site-web" class="co-btn co-cta-btn">
                        <i class="ri-search-eye-line"></i> Demander un audit
                    </a>
                </div>
                <p class="c15-cta-sub">Score au-dessus de 10 et tu n'as pas envie de tout refaire seul ? On commence par là.</p>
            </div>
        </section>

        <!-- ══ RETOUR ARTICLE ══ -->
        <section class="co-sec co-pad c15-back" style="padding:28px 40px;">
            <a href="/blog/15-signes-site-web-dort" class="c15-back-link">
                <i class="ri-arrow-left-line"></i> Retour à l'article complet
            </a>
            <p class="co-mut c15-back-sign"><strong>Jon Labs</strong> — Genève</p>
        </section>

    </main>

    <Footer />
</Layout>

<style is:global>
    /* ══ CHECKLIST 15 SIGNES — styles .c15-* (namespace scopé, corps .co-root) ══ */

    /* Sévérité diagnostic (data-driven, pas accent décoratif) */
    .co-root { --c15-ok: #16a34a; --c15-warn: #d97706; --c15-bad: #dc2626; }

    /* ── Liens inline ── */
    .c15-inline { color: var(--accent); text-decoration: underline; text-underline-offset: 2px; font-weight: 500; display: inline-flex; align-items: center; gap: 5px; }
    .c15-inline:hover { color: var(--ink); }
    .c15-inline i { transition: transform .18s ease-out; }
    .c15-inline:hover i { transform: translateX(3px); }

    /* ── Hero ── */
    .c15-crumb { display: flex; flex-wrap: wrap; align-items: center; gap: 8px; font-size: 13px; color: var(--muted); }
    .c15-crumb a { color: var(--muted); transition: color .18s ease-out; }
    .c15-crumb a:hover { color: var(--accent); }
    .c15-hero-title { font-size: clamp(2.1rem, 5.4vw, 3.4rem); margin-top: 18px; }
    .co-root .c15-hero-lead { margin-top: 18px; max-width: 54ch; font-size: 1.1rem; line-height: 1.65; color: var(--muted); }
    .c15-hero-lead strong { color: var(--ink); font-weight: 600; }
    .c15-hero-btns { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 28px; }
    .c15-hero-btns .co-btn i { transition: transform .18s ease-out; }
    .c15-hero-btns .co-btn:hover i { transform: translateY(1px); }
    .c15-hero-context { position: relative; display: inline-flex; align-items: center; gap: 10px; margin-top: 28px; padding: 14px 20px; background: var(--surface); border: 1px solid var(--line-2); }
    .c15-hero-context i { color: var(--accent); font-size: 18px; flex: none; }
    .co-root .c15-hero-context p { font-size: 14px; color: var(--muted); }

    /* ── Métriques ── */
    .c15-metrics { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 24px; }
    .c15-stat { position: relative; display: flex; flex-direction: column; align-items: center; text-align: center; gap: 6px; padding: 26px 16px; background: var(--surface); border: 1px solid var(--line-2); transition: transform .18s ease-out; }
    .c15-stat:hover { transform: translateY(-2px); }
    .c15-stat-value { font-size: 1.9rem; font-weight: 700; letter-spacing: -0.03em; line-height: 1; }
    .c15-stat-label { font-size: 12.5px; color: var(--muted); }
    .c15-trust { display: flex; flex-wrap: wrap; gap: 12px 26px; margin-top: 20px; font-size: 13.5px; color: var(--muted); }
    .c15-trust span { display: inline-flex; align-items: center; gap: 6px; }
    .c15-trust i { color: var(--accent); font-size: 15px; }

    /* ── Panneau score (live) ── */
    .c15-score { position: relative; margin-top: 28px; padding: 22px 26px; background: var(--surface); border: 1px solid var(--line-2); }
    .c15-score-head { display: flex; align-items: baseline; justify-content: space-between; gap: 16px; }
    .c15-score-num { font-size: 1.5rem; font-weight: 700; letter-spacing: -0.02em; font-variant-numeric: tabular-nums; }
    .c15-score-track { margin-top: 14px; height: 6px; background: var(--bg); border: 1px solid var(--line); overflow: hidden; }
    .c15-score-fill { height: 100%; background: var(--accent); transition: width .3s ease-out; }
    .co-root .c15-score-status { margin-top: 12px; font-size: 13.5px; font-weight: 600; color: var(--muted); }

    /* ── Catégories ── */
    .c15-cat-head { display: flex; align-items: center; gap: 16px; }
    .c15-cat-index { font-size: 20px; font-weight: 700; }
    .c15-cat-icon { font-size: 26px; color: var(--accent); flex: none; }
    .c15-cat-title { font-size: clamp(1.4rem, 3vw, 1.75rem); }
    .c15-cat-head .co-eyebrow { display: block; }

    .c15-items { display: flex; flex-direction: column; gap: 12px; margin-top: 28px; }
    .c15-item {
        position: relative; display: flex; align-items: flex-start; gap: 16px;
        padding: 18px 20px; background: var(--surface); border: 1px solid var(--line-2);
        cursor: pointer; transition: box-shadow .18s ease-out, transform .18s ease-out;
    }
    .c15-item:hover { transform: translateY(-1px); box-shadow: 0 6px 18px rgba(20,22,26,.06); }
    .c15-check {
        appearance: none; -webkit-appearance: none; flex: none; position: relative;
        width: 22px; height: 22px; margin: 0; margin-top: 1px; cursor: pointer;
        background: var(--bg); border: 1px solid var(--line-2);
        transition: background .16s ease-out, border-color .16s ease-out;
    }
    .c15-check:hover { border-color: var(--accent); }
    .c15-check:focus-visible { outline: none; box-shadow: 0 0 0 3px rgba(0,168,125,.2); }
    .c15-check:checked { background: var(--accent); border-color: var(--accent); }
    .c15-check:checked::after {
        content: ""; position: absolute; left: 7px; top: 3px; width: 6px; height: 11px;
        border: solid #fff; border-width: 0 2px 2px 0; transform: rotate(45deg);
    }
    .c15-item-num { font-size: 12px; font-weight: 700; flex: none; margin-top: 3px; }
    .co-root .c15-item-text { font-size: 15px; line-height: 1.5; color: var(--ink); }
    .c15-check:checked ~ .c15-item-text { color: var(--muted); }

    /* ── Diagnostic ── */
    .c15-diag-score { color: var(--ink); }
    .c15-palier { position: relative; margin-top: 18px; padding: 28px 30px; background: var(--surface); border: 1px solid var(--line-2); }
    .c15-palier-head { display: flex; align-items: center; gap: 16px; }
    .c15-palier-icon { font-size: 26px; flex: none; color: var(--sev, var(--accent)); }
    .c15-palier-titlerow { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
    .c15-palier-titlerow h3 { font-size: 1.25rem; }
    .c15-palier-tag { font-size: 11px; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; padding: 3px 10px; color: var(--sev, var(--accent)); border: 1px solid var(--sev, var(--line-2)); border-radius: 999px; }
    .c15-palier-body { margin-top: 16px; }
    .co-root .c15-palier-body p { font-size: 14.5px; line-height: 1.6; color: var(--muted); }
    .co-root .c15-palier-note { margin-top: 12px; font-size: 13.5px; }
    .c15-palier-btn { margin-top: 18px; }
    .c15-palier-btn i { transition: transform .18s ease-out; }
    .c15-palier-btn:hover i { transform: translateX(3px); }
    .c15-palier-btns { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 18px; }
    .c15-palier-btns .c15-palier-btn { margin-top: 0; }
    .c15-palier--ok { --sev: var(--c15-ok); }
    .c15-palier--warn { --sev: var(--c15-warn); }
    .c15-palier--bad { --sev: var(--c15-bad); }

    .c15-palier-initial { display: flex; flex-direction: column; align-items: center; text-align: center; gap: 10px; margin-top: 18px; padding: 34px 30px; border: 1px dashed var(--line-2); }
    .c15-palier-initial i { font-size: 32px; color: var(--line-2); }

    /* ── Téléchargement PDF ── */
    .c15-dl-grid { display: grid; grid-template-columns: 0.9fr 1.1fr; gap: 44px; align-items: center; }
    .c15-dl-visual { display: flex; justify-content: center; }
    .c15-mock { position: relative; width: 100%; max-width: 320px; padding: 32px 28px; text-align: center; background: var(--surface); border: 1px solid var(--line-2); }
    .c15-mock-icon { display: inline-flex; align-items: center; justify-content: center; width: 56px; height: 56px; margin: 0 auto 16px; background: var(--bg); border: 1px solid var(--line-2); }
    .c15-mock-icon i { font-size: 26px; color: var(--accent); }
    .c15-mock-title { font-size: 1.05rem; font-weight: 700; }
    .co-root .c15-mock-sub { margin-top: 4px; font-size: 13px; color: var(--muted); }
    .c15-mock-lines { margin-top: 18px; display: flex; flex-direction: column; gap: 10px; text-align: left; }
    .c15-mock-line { display: flex; align-items: center; gap: 10px; }
    .c15-mock-box { flex: none; width: 15px; height: 15px; border: 1px solid var(--line-2); }
    .c15-mock-bar { flex: 1; height: 7px; background: var(--line); }
    .co-root .c15-mock-more { margin-top: 6px; text-align: center; font-size: 12px; color: var(--muted); }

    .c15-dl-content .co-eyebrow { display: inline-flex; align-items: center; gap: 7px; }
    .c15-dl-content .co-eyebrow i { color: var(--accent); font-size: 14px; }
    .c15-bonus { position: relative; margin-top: 22px; padding: 22px 24px; background: var(--surface); border: 1px solid var(--line-2); }
    .c15-bonus-title { font-size: 14px; font-weight: 700; margin-bottom: 14px; }
    .c15-bonus .co-list li { font-size: 14px; line-height: 1.5; }
    .c15-bonus strong { color: var(--ink); font-weight: 600; }

    /* ── Formulaire (Web3Forms restylé, câblage préservé) ── */
    .c15-form { margin-top: 24px; display: flex; flex-direction: column; gap: 14px; }
    .c15-field { display: flex; flex-direction: column; gap: 8px; }
    .c15-label { display: flex; align-items: baseline; gap: 8px; font-size: 13px; font-weight: 600; color: var(--ink); }
    .c15-label .co-index { font-size: 11px; }
    .c15-input {
        width: 100%; font-family: "Inter Tight", ui-sans-serif, sans-serif; font-size: 15px; color: var(--ink);
        background: var(--bg); border: 1px solid var(--line-2); padding: 13px 15px;
        transition: border-color .18s ease-out, box-shadow .18s ease-out;
    }
    .c15-input::placeholder { color: var(--muted); opacity: .7; }
    .c15-input:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 3px rgba(0,168,125,.15); }
    .c15-submit { width: 100%; justify-content: center; padding: 14px 20px; font-size: 16px; }
    .c15-submit .ri-loader-4-line { animation: c15Spin 1s linear infinite; }
    @keyframes c15Spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
    .co-root .c15-form-note { text-align: center; font-size: 12px; color: var(--muted); }

    /* ── CTA sous-texte ── */
    .co-root .c15-cta-sub { margin-top: 6px; font-size: 13px; color: rgba(255,255,255,0.6); max-width: 46ch; line-height: 1.55; }

    /* ── Retour article ── */
    .c15-back { display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 14px; }
    .c15-back-link { display: inline-flex; align-items: center; gap: 8px; font-size: 14px; font-weight: 500; color: var(--muted); transition: color .18s ease-out; }
    .c15-back-link:hover { color: var(--accent); }
    .c15-back-link i { transition: transform .18s ease-out; }
    .c15-back-link:hover i { transform: translateX(-3px); }
    .co-root .c15-back-sign { font-size: 13px; }
    .c15-back-sign strong { color: var(--ink); }

    /* ── Anchor scroll offset ── */
    .co-root section[id] { scroll-margin-top: 100px; }

    /* ── Responsive ── */
    @media (max-width: 860px) {
        .c15-dl-grid { grid-template-columns: 1fr; gap: 32px; }
        .c15-dl-visual { order: 2; }
    }
    @media (max-width: 640px) {
        .c15-metrics { grid-template-columns: 1fr; }
        .c15-cat-head { flex-wrap: wrap; gap: 12px; }
    }
    @media (prefers-reduced-motion: reduce) {
        .c15-stat, .c15-item, .c15-check, .c15-score-fill, .c15-inline i, .c15-hero-btns .co-btn i, .c15-palier-btn i, .c15-back-link i { transition: none; }
        .c15-submit .ri-loader-4-line { animation: none; }
    }
</style>

<script>
    // Score calculation
    const checkboxes = document.querySelectorAll<HTMLInputElement>('.score-checkbox');
    const scoreCount = document.getElementById('score-count');
    const scoreBar = document.getElementById('score-bar') as HTMLElement;
    const scoreLabel = document.getElementById('score-label');
    const diagnosticScoreDisplays = document.querySelectorAll<HTMLElement>('.diagnostic-score-display');

    const palierInitial = document.getElementById('palier-initial');
    const palier0 = document.getElementById('palier-0');
    const palier1 = document.getElementById('palier-1');
    const palier2 = document.getElementById('palier-2');

    function updateScore() {
        const checked = Array.from(checkboxes).filter(cb => cb.checked).length;
        const pct = (checked / 15) * 100;

        if (scoreCount) scoreCount.textContent = String(checked);
        if (scoreBar) scoreBar.style.width = `${pct}%`;

        diagnosticScoreDisplays.forEach(el => el.textContent = String(checked));

        // Color the bar
        if (scoreBar) {
            if (checked <= 5) {
                scoreBar.style.background = '#16a34a';
            } else if (checked <= 10) {
                scoreBar.style.background = '#d97706';
            } else {
                scoreBar.style.background = '#dc2626';
            }
        }

        // Update label
        if (scoreLabel) {
            if (checked === 0) {
                scoreLabel.textContent = 'Commence le diagnostic';
                scoreLabel.style.color = 'var(--muted)';
            } else if (checked <= 5) {
                scoreLabel.textContent = 'Site réveillé';
                scoreLabel.style.color = '#16a34a';
            } else if (checked <= 10) {
                scoreLabel.textContent = 'Site en sommeil';
                scoreLabel.style.color = '#d97706';
            } else {
                scoreLabel.textContent = 'Site mort clinique';
                scoreLabel.style.color = '#dc2626';
            }
        }

        // Show/hide diagnostic paliers
        if (palierInitial) palierInitial.classList.toggle('hidden', checked > 0);
        if (palier0) palier0.classList.toggle('hidden', !(checked >= 0 && checked <= 5 && checked > 0));
        if (palier1) palier1.classList.toggle('hidden', !(checked >= 6 && checked <= 10));
        if (palier2) palier2.classList.toggle('hidden', !(checked >= 11));
    }

    checkboxes.forEach(checkbox => {
        checkbox.addEventListener('change', updateScore);
    });

    // PDF Form submission
    const pdfForm = document.getElementById('pdf-form') as HTMLFormElement;

    pdfForm?.addEventListener('submit', async (e) => {
        e.preventDefault();

        const submitBtn = pdfForm.querySelector('button[type="submit"]') as HTMLButtonElement;
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<i class="ri-loader-4-line"></i> Envoi en cours...';

        try {
            const formData = new FormData(pdfForm);
            const response = await fetch('https://api.web3forms.com/submit', {
                method: 'POST',
                body: formData
            });

            const result = await response.json();

            if (result.success) {
                window.location.href = '/merci-checklist-15-signes';
            } else {
                alert('Erreur lors de l\'envoi. Réessaye ou écris-moi directement à contact@jonlabs.ch');
                submitBtn.innerHTML = '<i class="ri-download-line"></i> Recevoir le PDF →';
                submitBtn.disabled = false;
            }
        } catch (error) {
            alert('Erreur de connexion. Réessaye.');
            submitBtn.innerHTML = '<i class="ri-download-line"></i> Recevoir le PDF →';
            submitBtn.disabled = false;
        }
    });
</script>
