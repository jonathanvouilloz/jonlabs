---
import '../../styles/global.css';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CTASection from '../../components/CTASection.astro';

// Schema.org
import { SITE_URL } from '../../data/schema';
import { getWebPageSchema, getBreadcrumbSchema } from '../../lib/seo';

const seoData = {
    title: "Checklist 15 signes que ton site dort | Diagnostic gratuit | Jon Labs",
    description: "15 questions oui/non, 4 minutes, score sur 15. Diagnostic honnête de ton site web : visible, actif ou mort clinique ? Télécharge le PDF."
};

const webPageSchema = getWebPageSchema({
    url: `${SITE_URL}/outils/checklist-15-signes-site-dort`,
    name: seoData.title,
    description: seoData.description
});
const breadcrumb = getBreadcrumbSchema([
    { name: "Accueil", url: SITE_URL },
    { name: "Outils", url: `${SITE_URL}/outils` },
    { name: "Checklist 15 signes que ton site dort", url: `${SITE_URL}/outils/checklist-15-signes-site-dort` }
]);
const schemas = [webPageSchema, breadcrumb];

const categories = [
    {
        id: "visibilite",
        title: "Visibilité Google",
        range: "Signes 1 à 3",
        accent: "blue",
        accentVar: "var(--blue)",
        items: [
            { num: 1, text: "Tu n'as jamais ouvert Google Search Console (ou tu ne sais pas ce que c'est)." },
            { num: 2, text: "Tu tapes le nom exact de ton activité plus ta ville sur Google, et tu n'apparais pas en page 1." },
            { num: 3, text: "Ta fiche Google Business n'a pas bougé depuis plus de 6 mois (ou tu n'en as pas)." }
        ]
    },
    {
        id: "contenu",
        title: "Contenu",
        range: "Signes 4 à 6",
        accent: "yellow",
        accentVar: "var(--yellow)",
        items: [
            { num: 4, text: "Ton dernier article ou ta dernière actualité date de plus de 6 mois (ou tu n'as jamais rien publié)." },
            { num: 5, text: "Tes pages services font moins de 300 mots et se ressemblent toutes." },
            { num: 6, text: "Tu n'as aucun blog, aucune ressource, aucune FAQ publique." }
        ]
    },
    {
        id: "technique",
        title: "Technique",
        range: "Signes 7 à 9",
        accent: "violet",
        accentVar: "var(--violet)",
        items: [
            { num: 7, text: "Ton site n'est pas en HTTPS." },
            { num: 8, text: "Tu ouvres ton site sur ton téléphone et c'est illisible." },
            { num: 9, text: "Ton site met plus de 3 secondes à s'afficher sur une 4G moyenne." }
        ]
    },
    {
        id: "conversion",
        title: "Conversion",
        range: "Signes 10 à 12",
        accent: "blue",
        accentVar: "var(--blue)",
        items: [
            { num: 10, text: "Aucun call-to-action clair au-dessus de la ligne de flottaison." },
            { num: 11, text: "Ton formulaire de contact, tu ne sais même pas s'il fonctionne." },
            { num: 12, text: "Tu n'as aucun outil de suivi (Analytics, Plausible, Fathom...)." }
        ]
    },
    {
        id: "autorite",
        title: "Autorité et E-E-A-T",
        range: "Signes 13 à 15",
        accent: "yellow",
        accentVar: "var(--yellow)",
        items: [
            { num: 13, text: "Aucune page « À propos » réelle avec photo et histoire." },
            { num: 14, text: "Aucun avis client visible sur le site." },
            { num: 15, text: "Aucun auteur identifié sur tes pages ou tes articles." }
        ]
    }
];
---

<Layout
    title={seoData.title}
    description={seoData.description}
    schemas={schemas}
>
    <Header />

    <!-- HERO SECTION -->
    <section class="hero-section pt-32 pb-16 md:pt-40 md:pb-20 px-4 relative overflow-hidden">
        <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
            <div class="absolute top-0 -left-20 w-[500px] h-[500px] bg-[var(--blue)] opacity-15 blur-[120px] rounded-full"></div>
            <div class="absolute bottom-0 right-0 w-[400px] h-[400px] bg-[var(--violet)] opacity-10 blur-[100px] rounded-full"></div>
        </div>

        <div class="max-w-4xl mx-auto relative z-10">
            <div class="text-center">
                <!-- Breadcrumb -->
                <div class="flex items-center justify-center gap-2 text-sm text-gray-500 mb-6">
                    <a href="/" class="hover:text-[var(--blue)]">Accueil</a>
                    <span>/</span>
                    <a href="/outils" class="hover:text-[var(--blue)]">Outils</a>
                    <span>/</span>
                    <span class="text-[var(--text)]">Checklist 15 signes</span>
                </div>

                <!-- Badge -->
                <span class="inline-flex items-center gap-2 bg-[var(--blue)] border-2 border-black px-4 py-1 text-sm font-medium mb-6">
                    <i class="ri-checkbox-circle-line text-black"></i>
                    Outil gratuit
                </span>

                <h1 class="text-3xl md:text-4xl lg:text-5xl font-normal tracking-tight mb-6">
                    15 signes que<br/>
                    <span class="relative inline-block">
                        <span class="absolute bg-[var(--yellow)] w-full h-[40%] left-0 bottom-1 -z-1"></span>
                        <span class="relative z-10">ton site dort</span>
                    </span>
                </h1>

                <p class="text-lg md:text-xl text-gray-600 mb-8 leading-relaxed max-w-2xl mx-auto">
                    15 questions fermées, oui ou non, 4 minutes montre en main.<br/>
                    <strong class="text-[var(--text)]">Coche, additionne, lis ton diagnostic.</strong>
                </p>

                <!-- CTAs -->
                <div class="flex flex-col sm:flex-row gap-4 justify-center mb-12">
                    <a
                        href="#signe-1"
                        class="
                            bg-[var(--blue)]
                            border-2 border-black
                            px-6 py-4
                            text-lg font-medium
                            shadow-[4px_4px_0px_rgba(0,0,0,1)]
                            transition-all duration-200
                            hover:bg-[var(--yellow)]
                            hover:shadow-[2px_2px_0px_rgba(0,0,0,1)]
                            hover:translate-x-[2px] hover:translate-y-[2px]
                            flex items-center justify-center gap-2
                        "
                    >
                        <i class="ri-play-line"></i>
                        Commencer le diagnostic
                    </a>
                    <a
                        href="#telecharger"
                        class="
                            bg-white
                            border-2 border-black
                            px-6 py-4
                            text-lg font-medium
                            transition-all duration-200
                            hover:bg-gray-100
                            flex items-center justify-center gap-2
                        "
                    >
                        <i class="ri-download-line"></i>
                        Télécharger le PDF
                    </a>
                </div>

                <!-- Context link -->
                <div class="mt-4 p-4 bg-white border-2 border-black inline-block">
                    <p class="text-sm text-gray-600">
                        <i class="ri-article-line mr-2 text-[var(--blue)]"></i>
                        Tu n'as pas lu l'article complet ?
                        <a href="/blog/15-signes-site-web-dort" class="text-[var(--blue)] font-medium hover:underline">
                            Commence par là →
                        </a>
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- INTRO BAR -->
    <section class="intro-bar relative py-8 px-4 text-white overflow-hidden">
        <div class="max-w-4xl mx-auto relative z-10">
            <div class="flex flex-col items-center gap-6">
                <div class="flex flex-wrap justify-center items-center gap-x-8 gap-y-3 text-base md:text-lg">
                    <span class="flex items-center gap-2">
                        <span class="w-8 h-8 bg-[var(--blue)] bg-opacity-20 border border-[var(--blue)] border-opacity-50 flex items-center justify-center text-sm font-mono font-bold">15</span>
                        <span class="text-white/80">signes</span>
                    </span>
                    <span class="text-white/20 text-2xl hidden sm:inline">·</span>
                    <span class="flex items-center gap-2">
                        <span class="font-bold text-white">4 minutes</span>
                        <span class="text-white/60">montre en main</span>
                    </span>
                    <span class="text-white/20 text-2xl hidden sm:inline">·</span>
                    <span class="flex items-center gap-2">
                        <span class="font-bold text-[var(--blue)]">0 CHF</span>
                        <span class="text-white/60">100% gratuit</span>
                    </span>
                </div>
                <div class="flex flex-wrap justify-center gap-6 text-sm">
                    <span class="flex items-center gap-2 text-white/70">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-[var(--blue)]">
                            <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
                            <path d="M22 4L12 14.01l-3-3"/>
                        </svg>
                        Score calculé en direct
                    </span>
                    <span class="flex items-center gap-2 text-white/70">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-[var(--blue)]">
                            <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
                            <path d="M22 4L12 14.01l-3-3"/>
                        </svg>
                        Diagnostic personnalisé
                    </span>
                    <span class="flex items-center gap-2 text-white/70">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-[var(--blue)]">
                            <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
                            <path d="M22 4L12 14.01l-3-3"/>
                        </svg>
                        PDF imprimable
                    </span>
                </div>
            </div>
        </div>
    </section>

    <!-- SCORE STICKY BAR -->
    <div class="score-bar sticky top-0 z-40 bg-white border-b-2 border-black py-3 px-4 shadow-sm">
        <div class="max-w-4xl mx-auto flex items-center justify-between gap-4">
            <div class="flex items-center gap-3">
                <span class="text-sm font-mono text-gray-500 hidden sm:inline">Score :</span>
                <span class="text-xl font-bold font-mono"><span id="score-count">0</span><span class="text-gray-400">/15</span></span>
            </div>
            <div class="flex-1 max-w-xs">
                <div class="h-3 bg-gray-100 border border-gray-300 rounded-none overflow-hidden">
                    <div id="score-bar" class="h-full bg-[var(--blue)] transition-all duration-300" style="width: 0%"></div>
                </div>
            </div>
            <div id="score-label" class="text-sm font-medium text-gray-500 hidden sm:block">Commence le diagnostic</div>
        </div>
    </div>

    <!-- CATEGORIES -->
    {categories.map((cat, catIndex) => (
        <section
            id={`signe-${cat.items[0].num}`}
            class={`py-16 md:py-20 px-4 ${catIndex % 2 === 0 ? 'bg-white border-b-2 border-black' : 'border-b-2 border-black'}`}
        >
            <div class="max-w-4xl mx-auto">
                <!-- Category header -->
                <div class="flex items-start gap-4 mb-8">
                    <div
                        class="w-16 h-16 border-3 border-black flex items-center justify-center flex-shrink-0 shadow-[4px_4px_0px_rgba(0,0,0,1)]"
                        style={`background: ${cat.accentVar}`}
                    >
                        <i class="ri-bar-chart-horizontal-line text-black text-2xl"></i>
                    </div>
                    <div>
                        <span class="text-sm font-mono text-gray-500 uppercase tracking-wider">{cat.range}</span>
                        <h2 class="text-2xl md:text-3xl font-bold">{cat.title}</h2>
                    </div>
                </div>

                <!-- Items -->
                <div class="space-y-4">
                    {cat.items.map((item) => (
                        <div class="checklist-card bg-[var(--main-bg)] border-2 border-black p-5">
                            <div class="flex items-start gap-4">
                                <!-- Checkbox -->
                                <div class="checkbox-wrapper mt-0.5 flex-shrink-0">
                                    <input
                                        type="checkbox"
                                        class="peer sr-only score-checkbox"
                                        id={`signe-check-${item.num}`}
                                    />
                                    <label
                                        for={`signe-check-${item.num}`}
                                        class="w-6 h-6 border-2 border-black bg-white flex items-center justify-center cursor-pointer transition-all peer-checked:bg-[var(--blue)]"
                                    >
                                        <i class="ri-check-line text-white opacity-0 peer-checked:opacity-100 transition-opacity text-sm"></i>
                                    </label>
                                </div>
                                <!-- Content -->
                                <div class="flex-1">
                                    <div class="flex items-baseline gap-2 mb-1">
                                        <span class="text-xs font-mono font-bold text-gray-400">#{item.num}</span>
                                        <p class="text-gray-800 font-medium leading-snug">{item.text}</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    ))}
                </div>
            </div>
        </section>
    ))}

    <!-- DIAGNOSTIC SECTION -->
    <section id="diagnostic" class="py-16 md:py-20 px-4 bg-white border-b-2 border-black">
        <div class="max-w-4xl mx-auto">
            <div class="text-center mb-10">
                <h2 class="text-2xl md:text-3xl font-bold mb-2">Ton diagnostic</h2>
                <p class="text-gray-600">Score actuel : <strong><span class="diagnostic-score-display">0</span>/15</strong></p>
            </div>

            <!-- Palier 0-5 : Site réveillé -->
            <div id="palier-0" class="palier-block border-2 border-black p-6 mb-4 hidden">
                <div class="flex items-start gap-4">
                    <div class="w-14 h-14 bg-green-400 border-2 border-black flex items-center justify-center flex-shrink-0 flex-shrink-0">
                        <i class="ri-sun-line text-black text-2xl"></i>
                    </div>
                    <div class="flex-1">
                        <div class="flex items-center gap-3 mb-2">
                            <h3 class="text-xl font-bold">Site réveillé</h3>
                            <span class="text-xs font-mono bg-green-100 text-green-700 border border-green-300 px-2 py-0.5">0-5 signes</span>
                        </div>
                        <p class="text-gray-700 leading-relaxed">
                            Tu fais déjà beaucoup de choses bien. Les signes cochés sont des optimisations, pas des fondations manquantes. Pas besoin de tout refaire : un article de plus par trimestre, une page À propos enrichie, quelques avis clients captés.
                        </p>
                        <p class="text-gray-600 text-sm mt-3">
                            Risque principal : la complaisance. Un site qui fonctionne aujourd'hui peut dormir dans 18 mois si tu le laisses tranquille. Relis cette checklist tous les 6 mois.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Palier 6-10 : Site en sommeil -->
            <div id="palier-1" class="palier-block border-2 border-black p-6 mb-4 hidden">
                <div class="flex items-start gap-4">
                    <div class="w-14 h-14 bg-[var(--yellow)] border-2 border-black flex items-center justify-center flex-shrink-0">
                        <i class="ri-moon-line text-black text-2xl"></i>
                    </div>
                    <div class="flex-1">
                        <div class="flex items-center gap-3 mb-2">
                            <h3 class="text-xl font-bold">Site en sommeil</h3>
                            <span class="text-xs font-mono bg-yellow-100 text-yellow-700 border border-yellow-300 px-2 py-0.5">6-10 signes</span>
                        </div>
                        <p class="text-gray-700 leading-relaxed">
                            C'est la zone la plus fréquente. Le site existe, il a été bien pensé au départ, mais personne ne l'a touché depuis la mise en ligne. Tu as probablement un bon produit et un site qui sous-performe de 50 à 70 %.
                        </p>
                        <p class="text-gray-600 text-sm mt-3 mb-4">
                            Bonne nouvelle : ça se réveille. Il te faut un plan de 30 jours ciblé sur les signes cochés.
                        </p>
                        <a
                            href="/blog/0a30joursgooglevisible"
                            class="inline-flex items-center gap-2 bg-[var(--yellow)] border-2 border-black px-4 py-2 text-sm font-bold shadow-[3px_3px_0px_rgba(0,0,0,1)] transition-all hover:shadow-[1px_1px_0px_rgba(0,0,0,1)] hover:translate-x-[2px] hover:translate-y-[2px]"
                        >
                            <i class="ri-arrow-right-line"></i>
                            Plan 30 jours étape par étape
                        </a>
                    </div>
                </div>
            </div>

            <!-- Palier 11-15 : Site mort clinique -->
            <div id="palier-2" class="palier-block border-2 border-red-500 p-6 mb-4 hidden">
                <div class="flex items-start gap-4">
                    <div class="w-14 h-14 bg-red-500 border-2 border-black flex items-center justify-center flex-shrink-0">
                        <i class="ri-alarm-warning-line text-white text-2xl"></i>
                    </div>
                    <div class="flex-1">
                        <div class="flex items-center gap-3 mb-2">
                            <h3 class="text-xl font-bold">Site mort clinique</h3>
                            <span class="text-xs font-mono bg-red-100 text-red-700 border border-red-300 px-2 py-0.5">11-15 signes</span>
                        </div>
                        <p class="text-gray-700 leading-relaxed">
                            À 11 ou plus, tu paies l'hébergement d'un site qui travaille contre toi. Chaque semaine qui passe, un prospect qui aurait dû t'appeler appelle quelqu'un d'autre.
                        </p>
                        <p class="text-gray-600 text-sm mt-3 mb-4">
                            Si tu veux mettre un chiffre dessus avant de décider, le calculateur de coût d'un site dormant te donne une estimation en 60 secondes.
                        </p>
                        <div class="flex flex-wrap gap-3">
                            <a
                                href="/services/refonte-site-web"
                                class="inline-flex items-center gap-2 bg-red-500 text-white border-2 border-black px-4 py-2 text-sm font-bold shadow-[3px_3px_0px_rgba(0,0,0,1)] transition-all hover:shadow-[1px_1px_0px_rgba(0,0,0,1)] hover:translate-x-[2px] hover:translate-y-[2px]"
                            >
                                <i class="ri-arrow-right-line"></i>
                                Regarder ensemble ton site
                            </a>
                            <a
                                href="/blog/cout-site-web-dormant-calculateur"
                                class="inline-flex items-center gap-2 bg-white border-2 border-black px-4 py-2 text-sm font-medium transition-all hover:bg-gray-100"
                            >
                                Calculer ton coût dormant
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- État initial : pas encore commencé -->
            <div id="palier-initial" class="border-2 border-dashed border-gray-300 p-6 text-center">
                <i class="ri-checkbox-blank-circle-line text-4xl text-gray-300 mb-3 block"></i>
                <p class="text-gray-500">Coche les signes ci-dessus pour voir ton diagnostic apparaître ici.</p>
            </div>
        </div>
    </section>

    <!-- PDF DOWNLOAD SECTION -->
    <section id="telecharger" class="py-16 md:py-24 px-4">
        <div class="max-w-4xl mx-auto">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
                <!-- Left: Visual -->
                <div class="order-2 md:order-1">
                    <div class="bg-white border-3 border-black shadow-[6px_6px_0px_rgba(0,0,0,1)] p-8 -rotate-2 hover:rotate-0 transition-transform duration-300">
                        <div class="text-center">
                            <div class="w-16 h-16 bg-[var(--blue)] border-2 border-black flex items-center justify-center mx-auto mb-4">
                                <i class="ri-file-list-3-line text-3xl text-black"></i>
                            </div>
                            <p class="font-bold text-lg mb-2">Checklist PDF</p>
                            <p class="text-sm text-gray-500 mb-4">15 signes que ton site dort</p>
                            <div class="space-y-2 text-left">
                                {[1,2,3,4,5].map(() => (
                                    <div class="flex items-center gap-2">
                                        <div class="w-4 h-4 border border-gray-400 flex-shrink-0"></div>
                                        <div class="h-2 bg-gray-200 rounded flex-1"></div>
                                    </div>
                                ))}
                                <div class="text-xs text-gray-400 text-center mt-3">+ 10 autres signes</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Right: Content + Form -->
                <div class="order-1 md:order-2">
                    <span class="inline-flex items-center gap-2 text-sm font-mono uppercase tracking-wider text-gray-500 mb-4">
                        <i class="ri-file-pdf-line text-red-500"></i>
                        Téléchargement gratuit
                    </span>
                    <h2 class="text-2xl md:text-3xl font-bold mb-4">Télécharge la checklist en PDF</h2>
                    <p class="text-gray-600 mb-6">
                        Imprime-la, remplis-la au stylo, partage-la à un associé ou glisse-la dans un dossier client.
                    </p>

                    <!-- Bonus list -->
                    <div class="bg-white border-2 border-black p-4 mb-6">
                        <p class="font-bold text-sm mb-3">Dans la version PDF :</p>
                        <ul class="space-y-2 text-sm text-gray-600">
                            <li class="flex items-start gap-2">
                                <i class="ri-check-line text-[var(--blue)] mt-0.5"></i>
                                Les 15 signes groupés par catégorie avec cases à cocher
                            </li>
                            <li class="flex items-start gap-2">
                                <i class="ri-check-line text-[var(--blue)] mt-0.5"></i>
                                Tableau récap des 3 paliers de diagnostic
                            </li>
                            <li class="flex items-start gap-2">
                                <i class="ri-check-line text-[var(--blue)] mt-0.5"></i>
                                Plan d'action par palier (0-5 / 6-10 / 11-15)
                            </li>
                            <li class="flex items-start gap-2">
                                <i class="ri-check-line text-[var(--violet)] mt-0.5"></i>
                                <strong>Bonus :</strong> Liens vers les ressources utiles pour chaque signe
                            </li>
                        </ul>
                    </div>

                    <!-- Form -->
                    <form
                        action="https://api.web3forms.com/submit"
                        method="POST"
                        class="space-y-4"
                        id="pdf-form"
                    >
                        <input type="hidden" name="access_key" value="3f64c7a1-46b9-4524-8e78-47524896d467">
                        <input type="hidden" name="subject" value="Téléchargement Checklist 15 Signes Site Dort">
                        <input type="hidden" name="from_name" value="Jon Labs - Checklist 15 Signes PDF">
                        <input type="checkbox" name="botcheck" class="hidden" style="display: none;">

                        <div>
                            <input
                                type="email"
                                name="email"
                                placeholder="Ton email"
                                required
                                class="w-full px-4 py-3 border-2 border-black bg-white text-lg placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-[var(--blue)] focus:ring-offset-2 transition-all"
                            />
                        </div>

                        <button
                            type="submit"
                            class="
                                w-full
                                bg-[var(--blue)]
                                border-2 border-black
                                px-6 py-4
                                text-lg font-bold
                                shadow-[4px_4px_0px_rgba(0,0,0,1)]
                                transition-all duration-200
                                hover:bg-[var(--yellow)]
                                hover:shadow-[2px_2px_0px_rgba(0,0,0,1)]
                                hover:translate-x-[2px] hover:translate-y-[2px]
                                flex items-center justify-center gap-2
                            "
                        >
                            <i class="ri-download-line"></i>
                            Recevoir le PDF →
                        </button>

                        <p class="text-xs text-gray-500 text-center">
                            Pas de spam. Juste la checklist, et de temps en temps des conseils pratiques.
                        </p>
                    </form>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <CTASection
        title="Tu préfères un regard extérieur ?"
        description="Cette checklist diagnostique l'état. Si ton score est élevé et que tu veux aller vite, je peux regarder ton site avec toi, chiffres en main, et te dire ce qui saigne le plus."
        buttonText="Demander un audit"
        buttonLink="/services/refonte-site-web"
        buttonIcon="ri-search-eye-line"
        subtext="Score au-dessus de 10 et tu n'as pas envie de tout refaire seul ? On commence par là."
        variant="light"
        badge="Option accompagnée"
    />

    <!-- BACK TO ARTICLE -->
    <section class="py-8 px-4 bg-white border-t-2 border-black">
        <div class="max-w-4xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
            <a
                href="/blog/15-signes-site-web-dort"
                class="flex items-center gap-2 text-gray-600 hover:text-[var(--blue)] transition-colors"
            >
                <i class="ri-arrow-left-line"></i>
                Retour à l'article complet
