---
// PDF version — print-optimized, noindex
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex, nofollow">
  <title>Checklist 15 signes que ton site dort - PDF | Jon Labs</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    @page {
      size: A4;
      margin: 1cm;
    }

    html, body {
      font-family: 'Segoe UI', Arial, Helvetica, sans-serif;
      font-size: 9pt;
      line-height: 1.35;
      color: #1a1a1a;
      background: white;
    }

    @media print {
      body {
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
      }
      .no-print {
        display: none !important;
      }
      .page-break {
        page-break-before: always;
      }
    }

    .pdf-container {
      max-width: 210mm;
      margin: 0 auto;
      padding: 0.3cm;
    }

    .pdf-header {
      text-align: center;
      padding-bottom: 10px;
      margin-bottom: 14px;
      border-bottom: 2px solid #000;
    }

    .pdf-title {
      font-size: 17pt;
      font-weight: 700;
      margin-bottom: 2px;
      letter-spacing: -0.5px;
    }

    .pdf-subtitle {
      font-size: 10pt;
      color: #444;
      margin-bottom: 6px;
    }

    .pdf-meta {
      font-size: 8pt;
      color: #666;
    }

    /* Intro block */
    .intro-block {
      background: #f9f9f9;
      border: 1px solid #ddd;
      padding: 8px 10px;
      margin-bottom: 12px;
      font-size: 8.5pt;
      color: #444;
    }

    /* Category sections */
    .category-section {
      margin-bottom: 12px;
    }

    .category-header {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 6px;
      padding-bottom: 4px;
      border-bottom: 1.5px solid #000;
    }

    .category-number {
      background: #000;
      color: white;
      width: 20px;
      height: 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      font-size: 9pt;
      flex-shrink: 0;
    }

    .category-title {
      font-size: 11pt;
      font-weight: 700;
    }

    .category-range {
      font-size: 8pt;
      color: #666;
      font-style: italic;
      margin-left: auto;
    }

    .checklist-items {
      padding-left: 4px;
    }

    .checklist-item {
      display: flex;
      align-items: flex-start;
      gap: 7px;
      margin-bottom: 4px;
      font-size: 8.5pt;
    }

    .checkbox {
      width: 11px;
      height: 11px;
      border: 1.5px solid #000;
      flex-shrink: 0;
      margin-top: 1px;
    }

    .item-num {
      font-size: 7.5pt;
      font-weight: 700;
      color: #999;
      min-width: 16px;
      flex-shrink: 0;
    }

    .item-text {
      color: #333;
      line-height: 1.3;
    }

    /* Score table */
    .score-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 8.5pt;
      margin-bottom: 12px;
    }

    .score-table th,
    .score-table td {
      border: 1px solid #ccc;
      padding: 5px 8px;
      text-align: left;
    }

    .score-table th {
      background: #f0f0f0;
      font-weight: 700;
    }

    .score-table .score-good { background: #f0fdf4; }
    .score-table .score-warn { background: #fefce8; }
    .score-table .score-bad  { background: #fef2f2; }

    /* Action plan */
    .action-box {
      border: 1px solid #ddd;
      padding: 8px;
      margin-bottom: 8px;
      font-size: 8pt;
    }

    .action-box-title {
      font-weight: 700;
      font-size: 9pt;
      margin-bottom: 4px;
    }

    /* Footer */
    .pdf-footer {
      margin-top: 16px;
      padding-top: 8px;
      border-top: 1px solid #ccc;
      text-align: center;
      font-size: 8pt;
      color: #666;
    }

    .pdf-footer a {
      color: #000;
      font-weight: 600;
    }

    .two-cols {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
    }

    /* Print button */
    .print-btn {
      position: fixed;
      top: 20px;
      right: 20px;
      background: #000;
      color: white;
      border: none;
      padding: 12px 24px;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      z-index: 100;
    }

    .print-btn:hover {
      background: #333;
    }

    @media print {
      .print-btn {
        display: none;
      }
    }

    .score-box {
      border: 2px solid #000;
      padding: 6px 10px;
      display: inline-block;
      margin-bottom: 10px;
      font-size: 10pt;
    }

    .score-fill {
      display: inline-block;
      width: 14px;
      height: 14px;
      border: 1.5px solid #000;
      vertical-align: middle;
      margin-right: 2px;
    }
  </style>
</head>
<body>
  <button class="print-btn no-print" id="download-btn">
    Télécharger PDF
  </button>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
  <script>
    document.getElementById('download-btn').addEventListener('click', function() {
      const element = document.querySelector('.pdf-container');
      const btn = this;
      btn.textContent = 'Génération...';
      btn.disabled = true;

      const opt = {
        margin: 0,
        filename: 'Checklist-15-signes-site-dort-JonLabs.pdf',
        image: { type: 'jpeg', quality: 0.98 },
        html2canvas: { scale: 2, useCORS: true },
        jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' }
      };

      html2pdf().set(opt).from(element).save().then(() => {
        btn.textContent = 'Télécharger PDF';
        btn.disabled = false;
      });
    });
  </script>

  <div class="pdf-container">
    <!-- Header -->
    <header class="pdf-header">
      <h1 class="pdf-title">Checklist : 15 signes que ton site dort</h1>
      <p class="pdf-subtitle">Diagnostic honnête — 15 questions oui/non, score sur 15, 3 paliers</p>
      <p class="pdf-meta">jonlabs.ch | contact@jonlabs.ch</p>
    </header>

    <!-- Intro -->
    <div class="intro-block">
      <strong>Mode d'emploi :</strong> Pour chaque question, coche la case si c'est « oui ». Compte tes coches à la fin et lis ton diagnostic en bas de page. Sois honnête — tu te mens, tu gaspilles ton temps.
    </div>

    <!-- Score box to fill -->
    <div style="margin-bottom: 12px;">
      <strong style="font-size: 9pt;">Mon score : </strong>
      <span class="score-box">_____ / 15</span>
    </div>

    <div class="two-cols">
      <!-- LEFT COLUMN -->
      <div>
        <!-- Visibilité Google -->
        <div class="category-section">
          <div class="category-header">
            <span class="category-number">1</span>
            <span class="category-title">Visibilité Google</span>
            <span class="category-range">Signes 1 à 3</span>
          </div>
          <div class="checklist-items">
            <div class="checklist-item">
              <span class="checkbox"></span>
              <span class="item-num">#1</span>
              <span class="item-text">Tu n'as jamais ouvert Google Search Console (ou tu ne sais pas ce que c'est).</span>
            </div>
            <div class="checklist-item">
              <span class="checkbox"></span>
              <span class="item-num">#2</span>
              <span class="item-text">Tu tapes le nom exact de ton activité + ta ville sur Google, et tu n'apparais pas en page 1.</span>
            </div>
            <div class="checklist-item">
              <span class="checkbox"></span>
              <span class="item-num">#3</span>
              <span class="item-text">Ta fiche Google Business n'a pas bougé depuis plus de 6 mois (ou tu n'en as pas).</span>
            </div>
          </div>
        </div>

        <!-- Contenu -->
        <div class="category-section">
          <div class="category-header">
            <span class="category-number">2</span>
            <span class="category-title">Contenu</span>
            <span class="category-range">Signes 4 à 6</span>
          </div>
          <div class="checklist-items">
            <div class="checklist-item">
              <span class="checkbox"></span>
              <span class="item-num">#4</span>
              <span class="item-text">Ton dernier article ou ta dernière actualité date de plus de 6 mois (ou tu n'as jamais rien publié).</span>
            </div>
            <div class="checklist-item">
              <span class="checkbox"></span>
              <span class="item-num">#5</span>
              <span class="item-text">Tes pages services font moins de 300 mots et se ressemblent toutes.</span>
            </div>
            <div class="checklist-item">
              <span class="checkbox"></span>
              <span class="item-num">#6</span>
              <span class="item-text">Tu n'as aucun blog, aucune ressource, aucune FAQ publique.</span>
            </div>
          </div>
        </div>

        <!-- Technique -->
        <div class="category-section">
          <div class="category-header">
            <span class="category-number">3</span>
            <span class="category-title">Technique</span>
            <span class="category-range">Signes 7 à 9</span>
          </div>
          <div class="checklist-items">
            <div class="checklist-item">
              <span class="checkbox"></span>
              <span class="item-num">#7</span>
              <span class="item-text">Ton site n'est pas en HTTPS.</span>
            </div>
            <div class="checklist-item">
              <span class="checkbox"></span>
              <span class="item-num">#8</span>
              <span class="item-text">Tu ouvres ton site sur ton téléphone et c'est illisible.</span>
            </div>
            <div class="checklist-item">
              <span class="checkbox"></span>
              <span class="item-num">#9</span>
              <span class="item-text">Ton site met plus de 3 secondes à s'afficher sur une 4G moyenne.</span>
            </div>
          </div>
        </div>
      </div>

      <!-- RIGHT COLUMN -->
      <div>
        <!-- Conversion -->
        <div class="category-section">
          <div class="category-header">
            <span class="category-number">4</span>
            <span class="category-title">Conversion</span>
            <span class="category-range">Signes 10 à 12</span>
          </div>
          <div class="checklist-items">
            <div class="checklist-item">
              <span class="checkbox"></span>
              <span class="item-num">#10</span>
              <span class="item-text">Aucun call-to-action clair au-dessus de la ligne de flottaison.</span>
            </div>
            <div class="checklist-item">
              <span class="checkbox"></span>
              <span class="item-num">#11</span>
              <span class="item-text">Ton formulaire de contact, tu ne sais même pas s'il fonctionne.</span>
            </div>
            <div class="checklist-item">
              <span class="checkbox"></span>
              <span class="item-num">#12</span>
              <span class="item-text">Tu n'as aucun outil de suivi (Analytics, Plausible, Fathom...).</span>
            </div>
          </div>
        </div>

        <!-- Autorité E-E-A-T -->
        <div class="category-section">
          <div class="category-header">
            <span class="category-number">5</span>
            <span class="category-title">Autorité et E-E-A-T</span>
            <span class="category-range">Signes 13 à 15</span>
          </div>
          <div class="checklist-items">
            <div class="checklist-item">
              <span class="checkbox"></span>
              <span class="item-num">#13</span>
              <span class="item-text">Aucune page « À propos » réelle avec photo et histoire.</span>
            </div>
            <div class="checklist-item">
              <span class="checkbox"></span>
              <span class="item-num">#14</span>
              <span class="item-text">Aucun avis client visible sur le site.</span>
            </div>
            <div class="checklist-item">
              <span class="checkbox"></span>
              <span class="item-num">#15</span>
              <span class="item-text">Aucun auteur identifié sur tes pages ou tes articles.</span>
            </div>
          </div>
        </div>

        <!-- Zone notes -->
        <div style="margin-top: 8px; border: 1px dashed #ccc; padding: 8px;">
          <div style="font-size: 8pt; font-weight: 700; margin-bottom: 6px;">Notes :</div>
          <div style="height: 60px;"></div>
        </div>
      </div>
    </div>

    <!-- Diagnostic table -->
    <div style="margin-top: 8px;">
      <div style="font-size: 10pt; font-weight: 700; margin-bottom: 6px; border-bottom: 1.5px solid #000; padding-bottom: 4px;">Ton diagnostic</div>
      <table class="score-table">
        <thead>
          <tr>
            <th>Score</th>
            <th>Diagnostic</th>
            <th>Ce que ça veut dire</th>
          </tr>
        </thead>
        <tbody>
          <tr class="score-good">
            <td><strong>0-5</strong></td>
            <td><strong>Site réveillé</strong></td>
            <td>Optimisations à la marge — continue à surveiller tous les 6 mois</td>
          </tr>
          <tr class="score-warn">
            <td><strong>6-10</strong></td>
            <td><strong>Site en sommeil</strong></td>
            <td>Potentiel gros gaspillé — plan 30 jours sur les signes cochés</td>
          </tr>
          <tr class="score-bad">
            <td><strong>11-15</strong></td>
            <td><strong>Site mort clinique</strong></td>
            <td>Tu perds des clients chaque semaine — agir maintenant</td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- Action plans -->
    <div class="two-cols" style="margin-top: 10px;">
      <div class="action-box">
        <div class="action-box-title">Score 6-10 : Plan 30 jours</div>
        <div style="color: #444; line-height: 1.5;">
          Sem. 1 : technique (HTTPS, mobile, vitesse)<br>
          Sem. 2 : Search Console + Google Business<br>
          Sem. 3 : premier article publié<br>
          Sem. 4 : CTA visibles + formulaire testé
        </div>
        <div style="font-size: 7.5pt; color: #666; margin-top: 4px;">Détail : jonlabs.ch/blog/0a30joursgooglevisible</div>
      </div>
      <div class="action-box">
        <div class="action-box-title">Score 11-15 : Deux options</div>
        <div style="color: #444; line-height: 1.5;">
          <strong>Tu as du temps :</strong> attaque signe par signe — commence par 7, 8, 9, 10, 11.<br>
          <strong>Tu n'as pas le temps :</strong> externalise. À ce niveau, chaque semaine coûte un client.
        </div>
        <div style="font-size: 7.5pt; color: #666; margin-top: 4px;">Audit : jonlabs.ch/services/refonte-site-web</div>
      </div>
    </div>

    <!-- Footer -->
    <footer class="pdf-footer">
      <p><strong>Jon Labs</strong> — Genève, Suisse</p>
      <p><a href="https://www.jonlabs.ch">jonlabs.ch</a> | contact@jonlabs.ch</p>
      <p style="margin-top: 6px; font-size: 7pt;">
        Score élevé ? <a href="https://www.jonlabs.ch/services/refonte-site-web">Demande un audit personnalisé</a> — je regarde ton site avec toi, chiffres en main.
      </p>
    </footer>
  </div>
</body>
</html>
