---
// Hub des outils gratuits — page blueprint.
// Migrée du brutaliste vers le design system .co-* : section cadrée, filets fins,
// crosshairs, colonne capée, coins nets. Accent teal unique, Inter Tight ×
// Instrument Serif. Namespace scopé .ou-*. Réf canonique : services/referencement-local.astro.
//
// HARD-PRESERVE : Schema.org (getCollectionPageSchema → outilsSchema → schemas,
// injecté via Layout schemas={schemas}), seoData title/description exacts, tous les
// liens /outils/* et la copie éditoriale FR. Import global.css gardé.

import '../../styles/global.css';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

// Schema.org
import { SITE_URL } from '../../data/schema';
import { getCollectionPageSchema } from '../../lib/seo';

const seoData = {
    title: "Outils Gratuits pour Entrepreneurs",
    description: "Checklists, guides pratiques et templates gratuits pour commerçants et entrepreneurs. Boostez votre visibilité en ligne étape par étape."
};

const outils = [
    {
        title: "Checklist : Commerce visible sur Google",
        description: "Plan d'action en 4 semaines pour rendre votre commerce visible sur Google. Google Business, site one-page, avis clients.",
        link: "/outils/checklist-commerce-google",
        badge: "Gratuit",
        icon: "ri-checkbox-circle-line"
    },
    {
        title: "Checklist : 15 signes que ton site dort",
        description: "15 questions oui/non, score calculé en direct. Diagnostic honnête pour savoir si ton site travaille encore pour toi.",
        link: "/outils/checklist-15-signes-site-dort",
        badge: "Gratuit",
        icon: "ri-sleep-line"
    },
    {
        title: "Reddit Dashboard",
        description: "Outil local pour scraper les discussions Reddit sur un mot-clé, sans API ni compte. Récupère la vraie parole des gens pour nourrir tes prompts SEO.",
        link: "/outils/reddit-dashboard",
        badge: "Gratuit",
        icon: "ri-reddit-line"
    }
];

// Schema.org data
const outilsSchema = getCollectionPageSchema({
    url: `${SITE_URL}/outils`,
    name: seoData.title,
    description: seoData.description
});

const schemas = [outilsSchema];
---

<Layout
    title={seoData.title}
    description={seoData.description}
    schemas={schemas}
>
    <Header />

    <main class="co-root">

        <!-- ══ RESSOURCES · Hub outils ══ -->
        <section class="co-sec co-pad" style="padding:72px 40px 64px;">
            <h1 class="ou-title" data-animate data-delay="0.1">
                Des outils <span class="co-ser">gratuits</span> pour développer votre présence en ligne
            </h1>
            <p class="ou-lead co-mut" data-animate data-delay="0.2">
                Des ressources pratiques pour t'aider à développer ta présence en ligne, sans jargon.
            </p>

            <div class="ou-list" data-animate-stagger>
                {outils.map((outil) => (
                    <a href={outil.link} class="ou-card co-frame co-frame--reveal" data-animate-item>
                        <div class="ou-card-icon">
                            <i class={outil.icon} aria-hidden="true"></i>
                        </div>
                        <div class="ou-card-body">
                            <div class="ou-card-head">
                                <h2 class="ou-card-title">{outil.title}</h2>
                                <span class="co-badge">{outil.badge}</span>
                            </div>
                            <p class="ou-card-text">{outil.description}</p>
                        </div>
                        <i class="ri-arrow-right-line ou-card-arrow" aria-hidden="true"></i>
                    </a>
                ))}
            </div>

            <p class="ou-note co-mut" data-animate>
                <i class="ri-more-line" aria-hidden="true"></i> D'autres outils arrivent bientôt.
            </p>
        </section>

    </main>

    <Footer />
</Layout>

<style is:global>
    /* ══ OUTILS (hub) — styles .ou-* (namespace scopé, corps .co-root) ══ */

    .ou-title { font-size: clamp(2rem, 4.6vw, 3rem); max-width: 20ch; }
    .co-root .ou-lead { margin-top: 16px; max-width: 54ch; font-size: 1.075rem; line-height: 1.6; }

    /* ── Liste des outils (cartes-liens filet, coins nets, crosshairs au survol) ── */
    .ou-list { display: flex; flex-direction: column; gap: 16px; margin-top: 40px; }
    .ou-card {
        position: relative;
        display: flex; align-items: flex-start; gap: 20px; padding: 24px;
        background: var(--surface); border: 1px solid var(--line-2);
        transition: transform .18s ease-out, box-shadow .18s ease-out;
    }
    .ou-card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(20,22,26,.07); }
    .ou-card-icon {
        flex: none; display: flex; align-items: center; justify-content: center;
        width: 52px; height: 52px; background: var(--bg); border: 1px solid var(--line-2);
    }
    .ou-card-icon i { font-size: 24px; color: var(--muted); transition: color .18s ease-out; }
    .ou-card:hover .ou-card-icon i { color: var(--accent); }
    .ou-card-body { flex: 1; min-width: 0; }
    .ou-card-head { display: flex; align-items: center; flex-wrap: wrap; gap: 12px; }
    .ou-card-title { font-size: 1.2rem; transition: color .18s ease-out; }
    .ou-card:hover .ou-card-title { color: var(--accent); }
    .co-root .ou-card-text { margin-top: 8px; font-size: 14.5px; line-height: 1.55; color: var(--muted); }
    .ou-card-arrow {
        flex: none; align-self: center; font-size: 22px; color: var(--muted);
        transition: color .18s ease-out, transform .18s ease-out;
    }
    .ou-card:hover .ou-card-arrow { color: var(--accent); transform: translateX(3px); }

    /* ── Note bas de section ── */
    .co-root .ou-note {
        margin-top: 32px; font-size: 13.5px; display: inline-flex; align-items: center; gap: 6px;
    }
    .ou-note i { color: var(--accent); font-size: 16px; }

    /* ── Responsive ── */
    @media (max-width: 640px) {
        .ou-card { flex-wrap: wrap; gap: 16px; }
        .ou-card-arrow { display: none; }
    }
    @media (prefers-reduced-motion: reduce) {
        .ou-card, .ou-card-icon i, .ou-card-title, .ou-card-arrow { transition: none; }
    }
</style>
