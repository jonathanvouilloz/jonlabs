        width: 100%; font-family: "Inter Tight", ui-sans-serif, sans-serif; font-size: 15px; color: var(--ink);
        background: var(--bg); border: 1px solid var(--line-2); padding: var(--pad-chip);
        transition: border-color .18s ease-out, box-shadow .18s ease-out;
    }
    .ig-input::placeholder, .ig-textarea::placeholder { color: var(--muted); opacity: .7; }
    .ig-input:focus, .ig-select:focus, .ig-textarea:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 3px rgba(0,168,125,.15); }
