    /* ── Formulaire (Web3Forms restylé, câblage préservé) ── */
    .ig-form { position: relative; margin-top: var(--space-block); padding: 34px; background: var(--surface); border: 1px solid var(--line-2); }
    .ig-form-title { font-size: 1.25rem; text-align: left; margin-bottom: 22px; }
    .ig-form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
    .ig-field { display: flex; flex-direction: column; gap: 8px; }
