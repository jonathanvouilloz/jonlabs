<style is:global>
    /* ══ GESTION FICHE GOOGLE — styles .gm-* (namespace scopé, corps .co-root) ══ */

    /* ── Hero ── */
    .gm-hero-grid { display: grid; grid-template-columns: 1.05fr 0.95fr; gap: 48px; align-items: center; }
    .gm-hero-title { font-size: clamp(2.1rem, 4.6vw, 3.2rem); }
    .co-root .gm-hero-lead { margin-top: 18px; max-width: 52ch; font-size: 1.075rem; line-height: 1.65; color: var(--muted); }
    .gm-hero-lead strong { color: var(--ink); font-weight: 600; }
    .gm-hero-btns { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 28px; }
    .gm-hero-btns .co-btn i { transition: transform .18s ease-out; }
    .gm-hero-btns .co-btn:hover i { transform: translateY(2px); }
    .co-root .gm-hero-loc { margin-top: 22px; font-size: 13.5px; display: inline-flex; align-items: center; gap: 6px; }
    .gm-hero-loc i { color: var(--accent); }

    /* GMB card mockup */
    .gm-hero-media { position: relative; }
    .gm-mock { position: relative; background: var(--surface); border: 1px solid var(--line-2); }
    .gm-mock-bar { display: flex; align-items: center; gap: 8px; padding: 11px 14px; border-bottom: 1px solid var(--line); background: var(--bg); }
    .gm-mock-dot { width: 9px; height: 9px; border-radius: 999px; background: var(--line-2); flex: none; }
    .gm-mock-url { flex: 1; text-align: center; font-size: 12px; color: var(--muted); font-variant-numeric: tabular-nums; }
    .gm-mock-body { padding: 22px 24px; display: flex; flex-direction: column; gap: 16px; }
    .gm-mock-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; }
    .gm-mock-name { font-size: 1.15rem; }
    .co-root .gm-mock-cat { margin-top: 2px; font-size: 13px; color: var(--muted); }
    .gm-mock-status { display: inline-flex; align-items: center; gap: 6px; font-size: 12px; font-weight: 600; color: var(--accent); border: 1px solid var(--accent); padding: 4px 9px; white-space: nowrap; }
    .gm-mock-live { width: 7px; height: 7px; border-radius: 999px; background: var(--accent); flex: none; }
    .gm-mock-rating { display: flex; align-items: center; gap: 7px; font-size: 14px; }
    .gm-mock-stars { color: var(--accent); display: inline-flex; gap: 1px; font-size: 15px; }
    .gm-mock-rating b { font-weight: 600; }
    .gm-mock-count { color: var(--muted); font-size: 13px; }
    .gm-mock-info { display: flex; flex-direction: column; gap: 9px; }
    .gm-mock-row { display: flex; align-items: center; gap: 10px; font-size: 13.5px; color: var(--ink); }
    .gm-mock-row i { color: var(--muted); font-size: 16px; flex: none; }
    .gm-mock-actions { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; padding-top: 14px; border-top: 1px solid var(--line); }
    .gm-mock-act { display: flex; flex-direction: column; align-items: center; gap: 5px; font-size: 12px; font-weight: 500; color: var(--accent); text-align: center; }
    .gm-mock-act i { font-size: 18px; }
    .gm-badge { position: absolute; z-index: 4; background: var(--surface); border: 1px solid var(--line-2); padding: 8px 12px; font-size: 12px; font-weight: 600; }
    .gm-badge--stat { top: -16px; left: -14px; display: flex; flex-direction: column; line-height: 1.1; }
    .gm-badge--stat b { color: var(--accent); font-size: 15px; font-variant-numeric: tabular-nums; }
    .gm-badge--stat span { color: var(--muted); font-size: 10px; text-transform: uppercase; letter-spacing: 0.08em; }
    .gm-badge--tag { bottom: -16px; right: -14px; background: var(--accent); border-color: var(--accent); color: #fff; }

    /* ── Cartes génériques (problèmes / piliers / ressources) ── */
    .gm-grid { display: grid; gap: 16px; margin-top: 32px; }
    .gm-grid--2 { grid-template-columns: repeat(2, 1fr); }
    .gm-grid--3 { grid-template-columns: repeat(3, 1fr); }
    .gm-card {
        position: relative; display: flex; flex-direction: column; gap: 10px; padding: 24px;
        background: var(--surface); border: 1px solid var(--line-2);
        transition: box-shadow .18s ease-out, transform .18s ease-out;
