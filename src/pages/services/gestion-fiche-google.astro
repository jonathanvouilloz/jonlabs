    /* ── Cadrage (pour qui / pas pour qui) ── */
    .gm-fit-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; margin-top: 32px; align-items: start; }
    .gm-fit { position: relative; padding: 30px 28px; background: var(--surface); border: 1px solid var(--line-2); }
    .gm-fit-title { font-size: 1.15rem; display: flex; align-items: center; gap: 9px; margin-bottom: 18px; }
    .gm-fit-title i { color: var(--accent); font-size: 22px; }
