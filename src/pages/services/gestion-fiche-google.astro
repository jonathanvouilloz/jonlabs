    .gm-fit-list { gap: 11px; }
    .gm-fit-list li { font-size: 14.5px; line-height: 1.45; }
    .gm-fit-list--not { display: flex; flex-direction: column; gap: 11px; list-style: none; }
    .gm-fit-list--not li { display: flex; align-items: flex-start; gap: 10px; font-size: 14.5px; line-height: 1.45; color: var(--muted); }
    .gm-fit-list--not li i { color: var(--muted); font-size: 17px; flex: none; margin-top: 1px; }
    .co-root .gm-fit-foot { margin-top: 18px; padding-top: 16px; border-top: 1px solid var(--line); font-size: 13px; font-style: italic; line-height: 1.5; color: var(--muted); }

    /* ── Méthode : cartes semaines ── */
    .gm-weeks { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 32px; align-items: start; }
    .gm-week { position: relative; display: flex; flex-direction: column; gap: 14px; padding: 26px 24px; background: var(--surface); border: 1px solid var(--line-2); }
    .gm-week-head { display: flex; align-items: center; gap: 12px; }
    .gm-week-title { font-size: 1.15rem; }
    .gm-week-tasks { gap: 9px; }
    .gm-week-tasks li { font-size: 14px; line-height: 1.45; }
    .gm-week-deliver { margin-top: auto; padding-top: 16px; border-top: 1px solid var(--line); display: flex; flex-direction: column; gap: 6px; }
    .gm-week-deliver-label { font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--muted); }
    .gm-week-deliver-val { font-size: 13px; font-weight: 500; color: var(--ink); border-left: 2px solid var(--accent); padding-left: 10px; line-height: 1.4; }

    /* ── Encart différenciateurs ── */
    .gm-diff { position: relative; margin-top: 32px; padding: 36px; background: var(--surface); border: 1px solid var(--line-2); }
    .gm-diff-title { text-align: center; font-size: 1.25rem; }
    .gm-diff-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 28px; margin-top: 28px; }
