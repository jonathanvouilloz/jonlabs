---
// Gestion de fiche Google Business Profile — sous-page service (blueprint).
// Migrée du brutaliste vers le design system .co-* : sections cadrées, filets fins,
// accent teal unique, Inter Tight × Instrument Serif. Suit le gabarit-or
// /services/creation-site-web.astro (namespace scopé .gm-*).
//
// HARD-PRESERVE : Schema.org (serviceSchemas/breadcrumb/FAQ + ordre), câblage
// Web3Forms (#gmb-form, access_key + hidden inputs, tous les name=, honeypot, JS submit
// + validation situation), prix exacts (CHF 590 setup / CHF 300 mensuel), tous les
// liens SEO internes (cluster blog GMB, /services/referencement-local).

import '../../styles/global.css';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

// Schema.org
import { serviceSchemas, SITE_URL } from '../../data/schema';
import { getBreadcrumbSchema, getFAQPageSchema } from '../../lib/seo';

const seoData = {
    title: "Gestion de fiche Google Business à Genève | Jonlabs",
    description: "Gérez votre fiche Google Business à Genève : optimisation, posts, avis. Forfait tout inclus CHF 300/mois, sans engagement. 📩 Devis gratuit"
};

const breadcrumb = getBreadcrumbSchema([
    { name: "Accueil", url: SITE_URL },
    { name: "Services", url: `${SITE_URL}/services` },
    { name: "Gestion de fiche Google", url: `${SITE_URL}/services/gestion-fiche-google` }
]);
const schemas: any[] = [serviceSchemas["gestion-fiche-google"], breadcrumb];

const painPoints = [
    {
        icon: "ri-eye-off-line",
        title: "Invisible sur Google Maps",
        description: "Vos clients vous cherchent et tombent sur vos concurrents. Le pack local Google capte 32% des clics — vous n'y êtes pas."
    },
    {
        icon: "ri-time-line",
        title: "Pas le temps de poster",
        description: "Vous savez qu'il faut publier régulièrement sur votre fiche, mais entre vos clients et votre activité, ça passe en dernier. Tous les mois."
    },
    {
        icon: "ri-message-3-line",
        title: "Avis qui dorment sans réponse",
        description: "20% du ranking pack local vient des avis. Les vôtres s'accumulent depuis 6 mois sans une réponse — Google et les clients voient la même chose."
    },
    {
        icon: "ri-error-warning-line",
        title: "Fiche suspendue ou bloquée",
        description: "Du jour au lendemain, votre fiche disparaît. Réclamation refusée, formulaire opaque, support Google injoignable. Vous saignez du chiffre d'affaires."
    },
    {
        icon: "ri-image-line",
        title: "Description bâclée, photos floues",
        description: "Catégorie principale mal choisie, 3 photos pixelisées de 2018, description copiée d'un site web. Tout ce qui plombe le ranking sans que vous le sachiez."
    },
    {
        icon: "ri-question-line",
        title: "Vous gérez à l'aveugle",
        description: "Aucun reporting, aucun chiffre. Vous ne savez ni si ça marche, ni ce qui marche. Juste l'impression que « ça pourrait être mieux »."
    }
];

const piliers = [
    {
        icon: "ri-store-2-line",
        title: "Setup & vérification",
        description: "Création de A à Z, ou récupération si la fiche existe sans accès. Vérification (carte postale, vidéo, téléphone), désuspension si nécessaire.",
        items: ["Création / récupération / vérification", "Désuspension fiche bloquée", "Migration multi-établissements"]
    },
    {
        icon: "ri-tools-line",
        title: "Optimisation complète",
        description: "Le travail de fond qui détermine 80% du ranking. Catégorie principale, description 750 caractères, photos, attributs, services, horaires, schema LocalBusiness sur le site.",
        items: ["Catégorie + description optimisées KW", "Photos (hero, intérieur, équipe)", "Schema LocalBusiness sur votre site"]
    },
    {
        icon: "ri-edit-2-line",
        title: "Posts hebdomadaires",
        description: "1-2 posts par semaine rédigés à votre voix : nouveautés, offres, événements. Premier 100 caractères critiques, CTA tracking UTM, photo cohérente avec votre marque.",
        items: ["1-2 posts/semaine sans copier-coller", "Tracking UTM sur les CTA", "Cohérence visuelle marque"]
    },
    {
        icon: "ri-chat-smile-2-line",
        title: "Gestion des avis",
        description: "Système de collecte (lien court + QR code + relance post-prestation) et réponses signature business sur tous les avis, positifs comme négatifs. Sans copier-coller.",
        items: ["Lien avis + QR code à afficher", "Réponses illimitées (positifs + négatifs)", "Signalement avis injuste"]
    }
];

const methodSteps = [
    {
        week: "Semaine 1",
        title: "Audit & Setup",
        tasks: [
            "Audit fiche actuelle (catégorie, NAP, attributs)",
            "Optimisation complète (description 750c, photos, services)",
            "Schema LocalBusiness sur votre site"
        ],
        deliverable: "Fiche propre + cohérence GBP ↔ site"
    },
    {
        week: "Semaine 2",
        title: "Système d'avis",
        tasks: [
            "Lien GMB court + QR code à afficher",
            "Modèle SMS / email post-prestation",
            "Réponses aux avis existants en attente"
        ],
        deliverable: "Système collecte + tous les avis traités"
    },
    {
        week: "Mois 1+",
        title: "Cadence récurrente",
        tasks: [
            "1-2 posts par semaine (rédaction + publication)",
            "Réponses avis sous 48h",
            "Suivi positions + reporting mensuel"
        ],
        deliverable: "Reporting mensuel + ajustements"
    }
];

const differentiators = [
    {
        icon: "ri-quill-pen-line",
        title: "Voice authentique",
        description: "Posts et réponses écrits à votre ton. Pas de phrases qui sentent l'IA générique ou le copier-coller d'agence."
    },
    {
        icon: "ri-link",
        title: "GBP ↔ site cohérent",
        description: "NAP identique, schema LocalBusiness sur votre site, citations alignées. Google voit un signal cohérent au lieu de bruit."
    },
    {
        icon: "ri-bar-chart-2-line",
        title: "Reporting sans jargon",
        description: "Itinéraires demandés, appels reçus, demandes site. Les chiffres qui comptent — pas un PDF de 30 pages que vous ne lirez jamais."
    },
    {
        icon: "ri-user-line",
        title: "Un interlocuteur",
        description: "Moi (Jon) du début à la fin. Pas un junior que vous formez à votre métier tous les 3 mois."
    }
];

const forQui = [
    { type: "for", icon: "ri-checkbox-circle-line", text: "Commerce physique avec adresse (boutique, restaurant, salon)" },
    { type: "for", icon: "ri-checkbox-circle-line", text: "Profession libérale (cabinet médical, paramédical, juridique)" },
    { type: "for", icon: "ri-checkbox-circle-line", text: "Artisan zone de service (paysagiste, plombier, électricien)" },
    { type: "for", icon: "ri-checkbox-circle-line", text: "PME B2C avec dimension locale forte" },
    { type: "not", icon: "ri-close-circle-line", text: "Pure player web sans dimension locale" },
    { type: "not", icon: "ri-close-circle-line", text: "E-commerce sans store physique ni zone de service" },
    { type: "not", icon: "ri-close-circle-line", text: "Activité B2B nationale sans clientèle locale" }
];

const inclusions = [
    "1-2 posts hebdomadaires rédigés à votre voix",
    "Réponses illimitées sur tous les avis (positifs + négatifs)",
    "Photos mensuelles (vous fournissez, j'optimise et publie)",
    "Suivi positions sur 5-10 mots-clés locaux",
    "Reporting mensuel chiffré (itinéraires, appels, demandes)",
    "Signalement avis injustes",
    "Ajustements catégorie / attributs / services au fil de l'eau",
    "Mensuel résiliable, 1 mois de préavis"
];

const setupInclusions = [
    "Audit complet fiche actuelle",
    "Création / récupération / vérification",
    "Optimisation complète (catégorie, description 750c, photos, attributs, services, horaires)",
    "Schema LocalBusiness sur votre site",
    "Système d'avis (lien court + QR code)",
    "Réponses aux avis existants en attente"
];

const faqs = [
    {
        question: "Combien de temps avant de voir des résultats ?",
        answer: "Pour une fiche existante mal optimisée, les premiers effets se voient en 30-60 jours sur les itinéraires demandés et les appels. Pour une fiche neuve à créer, compte 60-90 jours pour entrer dans le pack local sur votre commune. Le SEO local n'est pas instantané, mais c'est plus rapide que le SEO classique."
    },
    {
        question: "Pourquoi pas Google Ads à la place ?",
        answer: "Ads et fiche optimisée ne couvrent pas la même intention. Ads = vous payez à chaque clic, dès que vous coupez le budget plus rien. Fiche optimisée = présence organique permanente, qui se renforce avec le temps. Les deux sont compatibles, mais commencer par la fiche est presque toujours plus rentable pour une PME locale."
    },
    {
        question: "Vous gérez ma fiche ou je garde la main ?",
        answer: "Vous gardez 100% le contrôle. Je suis ajouté comme manager sur votre Business Profile, vous restez propriétaire. À tout moment vous pouvez consulter ce que je publie, voir les réponses aux avis, et révoquer mes accès si vous arrêtez le forfait."
    },
    {
        question: "Que se passe-t-il si ma fiche est suspendue ?",
        answer: "Première chose : on diagnostique pourquoi (les 7 causes typiques sont documentées). Ensuite réclamation auprès de Google avec dossier complet (preuves activité, photos local, factures). Si elle est validée, retour rapide. Si elle est refusée, on passe par les recours forum produit. Je l'ai déjà fait, ça prend 2-4 semaines en général.",
        linkText: "Lire le guide complet →",
        linkUrl: "/blog/fiche-google-my-business-suspendue-recours"
    },
    {
        question: "Vous écrivez vraiment les réponses aux avis ?",
        answer: "Oui, chaque réponse est rédigée à la main pour matcher l'avis spécifique. Pas de templates copier-coller (Google et les clients voient la différence). Vous validez les 3-5 premières pour caler le ton, ensuite je suis autonome avec un brief de voix."
    },
    {
        question: "Et si j'ai plusieurs établissements ?",
        answer: "Le forfait à CHF 300/mois couvre 1 fiche. Pour 2-5 établissements, on passe à un forfait multi-locations dégressif. Pour 6+, on bascule sur Google Business Profile API pour automatiser une partie (devis sur mesure)."
    },
    {
        question: "Vous travaillez avec quels secteurs ?",
        answer: "Tous les secteurs avec une dimension locale forte : restaurants, salons de coiffure, cabinets médicaux et paramédicaux, artisans (paysagistes, plombiers, électriciens), commerces, écoles, associations. Pas de niches secret — la mécanique GMB est universelle, ce qui change c'est le ton et les types de posts adaptés."
    },
    {
        question: "Faut-il signer un engagement long ?",
        answer: "Non. Le mensuel est résiliable avec 1 mois de préavis. Je ne crois pas aux engagements 12 mois fermes — si le travail est sérieux, vous n'aurez pas envie de partir. Si vous partez, j'ai mal fait mon job."
    },
    {
        question: "Ça inclut le SEO local complet ou juste la fiche ?",
        answer: "Juste la fiche et son écosystème direct (posts, avis, photos, schema sur votre site, NAP cohérent). Pour du SEO local complet (contenu blog, citations annuaires, netlinking, optimisation site), c'est un autre service.",
        linkText: "Voir le service Référencement local →",
        linkUrl: "/services/referencement-local"
    },
    {
        question: "Comment se passe le premier contact ?",
        answer: "Vous remplissez le formulaire avec l'URL de votre fiche actuelle (ou indiquez si vous n'en avez pas). Je vous réponds sous 24-48h avec un mini-audit gratuit : ce qui est en place, ce qui manque, le potentiel. Ensuite on planifie un appel de 15 min pour caler le démarrage."
    }
];
schemas.push(getFAQPageSchema(faqs));

const zones = [
    { name: "Genève", type: "primary", icon: "ri-map-pin-fill" },
    { name: "Vaud", type: "secondary", icon: "ri-map-pin-line" },
    { name: "Valais", type: "secondary", icon: "ri-map-pin-line" },
    { name: "Toute Suisse romande + francophonie distante", type: "tertiary", icon: "ri-global-line" }
];

const localAdvantages = [
    { icon: "ri-bar-chart-line", title: "Connaissance des annuaires CH", description: "search.ch, local.ch, twixtel — citations cohérentes avec votre fiche." },
    { icon: "ri-search-line", title: "Pack local Genève / Vaud", description: "Spécialisation marché romand : concurrence, saisonnalité, requêtes typiques." },
    { icon: "ri-time-line", title: "Même fuseau horaire", description: "Réponses dans la journée, en français, sans décalage." },
    { icon: "ri-shield-check-line", title: "Conformité LPD", description: "Vos données et celles de vos clients restent en Suisse." }
];

const trustItems = [
    { icon: "ri-file-search-line", text: "Audit gratuit sous 24-48h" },
    { icon: "ri-handshake-line", text: "Sans engagement long" },
    { icon: "ri-eye-2-line", text: "Reporting mensuel transparent" }
];

// Cluster GMB — maillage interne vers le contenu éditorial du cluster fiche Google
const clusterGroups = [
    {
        label: "Créer & optimiser",
        icon: "ri-add-circle-line",
        articles: [
            { title: "Apparaître sur Google Maps quand on débute", href: "/blog/comment-apparaitre-google-maps-pme-debutant" },
            { title: "Créer ta fiche étape par étape", href: "/blog/creer-fiche-google-my-business-etape-par-etape" },
            { title: "Choisir la bonne catégorie GBP", href: "/blog/choisir-categorie-google-business-profile" },
            { title: "Optimiser ta fiche : la checklist 25 points", href: "/blog/optimiser-fiche-google-my-business-checklist-2026" },
            { title: "Entrer dans le top 3 de Google Maps", href: "/blog/entrer-top-3-google-maps" }
        ]
    },
    {
        label: "Avis & animation",
        icon: "ri-star-line",
        articles: [
            { title: "Obtenir plus d'avis Google", href: "/blog/obtenir-plus-avis-google" },
            { title: "Répondre à tes avis (modèles 2026)", href: "/blog/repondre-avis-google-modeles-2026" },
            { title: "Collecter des avis avec un QR code", href: "/blog/qr-code-avis-google-collecte-pme" },
            { title: "Publier des Google Posts qui convertissent", href: "/blog/google-post-business-profile-conversion" }
        ]
    },
    {
        label: "Incident",
        icon: "ri-error-warning-line",
        articles: [
            { title: "Fiche suspendue : les recours", href: "/blog/fiche-google-my-business-suspendue-recours" }
        ]
    }
];
---

<Layout title={seoData.title} description={seoData.description} schemas={schemas}>
    <Header />

    <main class="co-root">

        <!-- ══ HERO ══ -->
        <section class="co-sec co-pad co-hero gm-hero" style="padding:64px 40px 56px;">
            <div class="gm-hero-grid">
                <div class="gm-hero-copy">
                    <h1 class="gm-hero-title" data-animate data-delay="0.1">
                        Gestion de fiche Google <span class="co-ser">My Business.</span>
                    </h1>
                    <p class="gm-hero-lead" data-animate data-delay="0.2">
                        Votre fiche Google, gérée comme un actif. Création, optimisation, posts hebdomadaires,
                        gestion des avis. <strong>Vous gardez la main, je m'occupe du reste.</strong>
                    </p>
                    <div class="gm-hero-btns" data-animate data-delay="0.3">
                        <a href="#contact" class="co-btn"><i class="ri-search-eye-line"></i> Audit gratuit de ma fiche</a>
                        <a href="#prix" class="co-btn co-btn--ghost">Voir le forfait <i class="ri-arrow-down-line"></i></a>
                    </div>
                    <p class="gm-hero-loc co-mut" data-animate data-delay="0.4">
                        <i class="ri-map-pin-fill"></i> Basé à Genève · Service francophonie complète
                    </p>
                </div>

                <div class="gm-hero-media" data-animate="scale" data-delay="0.3">
                    <div class="gm-mock co-frame">
                        <span class="co-x tl"></span><span class="co-x tr"></span>
                        <span class="co-x bl"></span><span class="co-x br"></span>
                        <div class="gm-mock-bar">
                            <span class="gm-mock-dot"></span>
                            <span class="gm-mock-dot"></span>
                            <span class="gm-mock-dot"></span>
                            <span class="gm-mock-url">google.com/maps</span>
                        </div>
                        <div class="gm-mock-body">
                            <div class="gm-mock-head">
                                <div>
                                    <h3 class="gm-mock-name">Votre commerce</h3>
                                    <p class="gm-mock-cat">Votre catégorie · Genève</p>
                                </div>
                                <span class="gm-mock-status"><span class="gm-mock-live"></span> Ouvert</span>
                            </div>
                            <div class="gm-mock-rating">
                                <span class="gm-mock-stars">
                                    <i class="ri-star-fill"></i><i class="ri-star-fill"></i><i class="ri-star-fill"></i><i class="ri-star-fill"></i><i class="ri-star-fill"></i>
                                </span>
                                <b>4.9</b><span class="gm-mock-count">· 127 avis</span>
                            </div>
                            <div class="gm-mock-info">
                                <div class="gm-mock-row"><i class="ri-map-pin-line"></i><span>Rue du Marché 1, 1204 Genève</span></div>
                                <div class="gm-mock-row"><i class="ri-time-line"></i><span>Ouvre 9:00 · Ferme 19:00</span></div>
                                <div class="gm-mock-row"><i class="ri-phone-line"></i><span>+41 22 123 45 67</span></div>
                            </div>
                            <div class="gm-mock-actions">
                                <span class="gm-mock-act"><i class="ri-direction-line"></i> Itinéraire</span>
                                <span class="gm-mock-act"><i class="ri-phone-line"></i> Appeler</span>
                                <span class="gm-mock-act"><i class="ri-global-line"></i> Site web</span>
                            </div>
                        </div>
                    </div>
                    <div class="gm-badge gm-badge--stat"><b>+520%</b><span>itinéraires</span></div>
                    <div class="gm-badge gm-badge--tag">Pack local</div>
                </div>
            </div>
        </section>

        <!-- ══ 01 · PROBLÈMES ══ -->
        <section id="problemes" class="co-sec co-pad" style="padding:56px 40px;">
            <p class="co-eyebrow">01 — Problèmes</p>
            <h2 style="margin-top:8px;">Votre fiche vous fait <span class="co-ser">perdre des clients ?</span></h2>
            <p class="co-mut" style="margin-top:10px;max-width:56ch;line-height:1.6;">
                Vous êtes au bon endroit si vous vous reconnaissez dans l'une de ces situations.
            </p>

            <div class="gm-grid gm-grid--3" data-animate-stagger>
                {painPoints.map((point) => (
                    <div class="gm-card co-frame co-frame--reveal" data-animate-item>
                        <i class={`${point.icon} gm-card-icon`} aria-hidden="true"></i>
                        <h3 class="gm-card-title">{point.title}</h3>
                        <p class="gm-card-text">{point.description}</p>
                    </div>
                ))}
            </div>

            <div class="gm-note gm-note--accent" data-animate>
                <i class="ri-lightbulb-line"></i>
                <p><strong>Bonne nouvelle :</strong> tout ça est réparable. Et plus rapidement qu'une refonte de site.</p>
            </div>

            <div class="gm-note" data-animate>
                <p>
                    <strong>Pas sûr du potentiel de votre fiche ?</strong> Le
                    <a href="/services/referencement-local" class="gm-inline">guide référencement local Genève</a>
                    explique comment Google classe les fiches en 2026, et pourquoi 80% du ranking se joue dans 3 paramètres souvent négligés.
                </p>
            </div>
        </section>

        <!-- ══ 02 · CADRAGE (pour qui / pas pour qui) ══ -->
        <section id="pour-qui" class="co-sec co-pad" style="padding:56px 40px;">
            <p class="co-eyebrow">02 — Cadrage</p>
            <h2 style="margin-top:8px;">Pour qui c'est <span class="co-ser">utile</span> (et pour qui non)</h2>
            <p class="co-mut" style="margin-top:10px;max-width:62ch;line-height:1.6;">
                Une fiche Google n'a de sens que si votre clientèle vous cherche localement. Sans dimension locale, c'est de l'argent jeté.
            </p>

            <div class="gm-fit-grid" data-animate-stagger>
                <div class="gm-fit co-frame" data-animate-item>
                    <span class="co-x tl"></span><span class="co-x tr"></span>
                    <span class="co-x bl"></span><span class="co-x br"></span>
                    <h3 class="gm-fit-title"><i class="ri-checkbox-circle-line"></i> Pour vous si vous êtes...</h3>
                    <ul class="co-list co-list--check gm-fit-list">
                        {forQui.filter((i) => i.type === 'for').map((item) => (
                            <li><i class="ri-check-line"></i><span>{item.text}</span></li>
                        ))}
                    </ul>
                </div>

                <div class="gm-fit co-frame" data-animate-item>
                    <span class="co-x tl"></span><span class="co-x tr"></span>
                    <span class="co-x bl"></span><span class="co-x br"></span>
                    <h3 class="gm-fit-title gm-fit-title--muted"><i class="ri-close-circle-line"></i> Pas pour vous si...</h3>
                    <ul class="gm-fit-list gm-fit-list--not">
                        {forQui.filter((i) => i.type === 'not').map((item) => (
                            <li><i class="ri-close-line"></i><span>{item.text}</span></li>
                        ))}
                    </ul>
                    <p class="gm-fit-foot">
                        Dans ces cas, mieux vaut investir ailleurs : SEO classique, contenu, partenariats sectoriels.
                    </p>
                </div>
            </div>
        </section>

        <!-- ══ 03 · PÉRIMÈTRE (4 piliers) ══ -->
        <section id="ce-que-je-fais" class="co-sec co-pad" style="padding:56px 40px;">
            <p class="co-eyebrow">03 — Périmètre</p>
            <h2 style="margin-top:8px;">Concrètement, ce que je fais sur <span class="co-ser">votre fiche</span></h2>

            <div class="gm-grid gm-grid--2" data-animate-stagger>
                {piliers.map((pilier, index) => (
                    <div class="gm-card co-frame co-frame--reveal" data-animate-item>
                        <div class="gm-card-head">
                            <i class={`${pilier.icon} gm-card-icon`} aria-hidden="true"></i>
                            <span class="co-index">0{index + 1}</span>
                        </div>
                        <h3 class="gm-card-title">{pilier.title}</h3>
                        <p class="gm-card-text">{pilier.description}</p>
                        <ul class="co-list co-list--check gm-card-items">
                            {pilier.items.map((item) => (
                                <li><i class="ri-check-line"></i><span>{item}</span></li>
                            ))}
                        </ul>
                    </div>
                ))}
            </div>
        </section>

        <!-- ══ 04 · MÉTHODE ══ -->
        <section id="methode" class="co-sec co-pad" style="padding:56px 40px;">
            <p class="co-eyebrow">04 — Méthode</p>
            <h2 style="margin-top:8px;">Le setup d'abord, la <span class="co-ser">cadence</span> ensuite</h2>
            <p class="co-mut" style="margin-top:10px;max-width:58ch;line-height:1.6;">
                Un socle propre en deux semaines, puis une cadence récurrente qui transforme la fiche en actif.
            </p>

            <div class="gm-weeks" data-animate-stagger>
                {methodSteps.map((step, index) => (
                    <div class="gm-week co-frame" data-animate-item>
                        <div class="gm-week-head">
                            <span class="co-index">0{index + 1}</span>
                            <span class="co-badge">{step.week}</span>
                        </div>
                        <h3 class="gm-week-title">{step.title}</h3>
