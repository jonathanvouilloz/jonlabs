                        </div>
                        <ul class="co-list co-list--check wf-tier-features">
                            {plan.features.map((feature) => (
                                <li><i class="ri-check-line"></i><span>{feature}</span></li>
                            ))}
                        </ul>
                        <p class="wf-tier-ideal"><strong>Idéal pour :</strong> {plan.ideal}</p>
                    </div>
                ))}
            </div>

            <div class="wf-pricenote co-frame" data-animate>
                <span class="co-x tl"></span><span class="co-x tr"></span>
                <span class="co-x bl"></span><span class="co-x br"></span>
                <h3 class="wf-pricenote-title"><i class="ri-information-line"></i> Bon à savoir</h3>
                <div class="wf-pricenote-grid">
                    <ul class="co-list">
                        <li>L'abonnement Webflow (CHF 15-40/mois) remplace hébergement et maintenance</li>
                        <li>Le prix dépend du nombre de pages et des intégrations</li>
                    </ul>
                    <ul class="co-list">
                        <li>Refonte d'un site Webflow existant : audit d'abord, devis ferme ensuite</li>
                        <li>Paiement en 2-3 fois possible selon le montant</li>
                    </ul>
                </div>
                <p class="wf-note-inline">
                    <strong>Pas sûr de la formule ?</strong> On en discute ensemble. Premier échange gratuit et sans
                    engagement. Voir aussi <a href="/tarifs" class="wf-inline">mes tarifs détaillés</a>.
                </p>
                <p class="wf-note-inline">
                    <strong>À lire avant de vous décider :</strong>
                    <a href="/blog/prix-site-web-suisse-2026" class="wf-inline">Combien coûte vraiment un site web en Suisse en 2026 ?</a>
                    — un guide transparent des fourchettes en CHF, par profil de prestataire.
                </p>
            </div>
        </section>

        <!-- ══ 06 · FAQ (accordéon natif <details>, zéro JS) ══ -->
        <section id="faq" class="co-sec co-pad" style="padding:56px 40px;">
            <p class="co-eyebrow">06 — FAQ</p>
            <h2 style="margin-top:8px;">Questions fréquentes</h2>

            <div class="wf-faq" style="margin-top:32px;">
                {faqs.map((faq, index) => (
                    <details open={index === 0}>
                        <summary>
                            {faq.question}
                            <i class="ri-arrow-down-s-line" aria-hidden="true"></i>
                        </summary>
                        <p class="wf-faq-answer">{faq.answer}</p>
                    </details>
                ))}
            </div>

            <p class="co-mut" style="margin-top:24px;text-align:center;">
                Une autre question ? <a href="#contact" class="wf-inline">Contactez-moi directement</a>, je réponds sous 24h.
            </p>
        </section>

        <!-- ══ 07 · LOCAL (SEO géo) ══ -->
        <section id="local" class="co-sec co-pad" style="padding:56px 40px;">
            <p class="co-eyebrow">07 — Local</p>
            <h2 style="margin-top:8px;">Un freelance Webflow en <span class="co-ser">Suisse romande</span>, ça change quoi ?</h2>

            <div class="wf-local-grid">
                <div data-animate="fade-left">
                    <h3 class="wf-local-h3">La plupart des freelances Webflow francophones sont en France. Travailler avec quelqu'un d'ici, c'est :</h3>
                    <div class="wf-local-adv">
                        {localAdvantages.map((adv) => (
                            <div class="wf-local-item co-frame">
                                <i class={`${adv.icon} wf-local-icon`} aria-hidden="true"></i>
                                <div>
                                    <h4 class="wf-local-name">{adv.title}</h4>
                                    <p class="wf-local-desc">{adv.description}</p>
                                </div>
                            </div>
                        ))}
                    </div>
                </div>

                <div data-animate="fade-left" data-delay="0.1">
                    <h3 class="wf-local-h3">Zones couvertes</h3>
                    <div class="wf-zones">
                        {zones.map((zone) => (
                            <div class={`wf-zone ${zone.type === 'primary' ? 'wf-zone--primary' : ''}`}>
                                <i class={zone.icon}></i>
                                <span>
                                    <strong>{zone.name}</strong>
                                    {zone.type === 'primary' && <span class="co-mut"> (basé sur place)</span>}
                                </span>
                            </div>
                        ))}
                    </div>
                    <p class="co-mut" style="margin-top:16px;font-size:13.5px;">
                        <i class="ri-information-line"></i> Les échanges se font en personne ou en visio selon vos préférences.
                    </p>
                </div>
            </div>
        </section>

        <!-- ══ 08 · CONTACT (formulaire Web3Forms — HARD-PRESERVE câblage) ══ -->
        <section id="contact" class="co-sec co-pad" style="padding:64px 40px;">
            <p class="co-eyebrow">08 — Contact</p>
            <h2 style="margin-top:8px;">Prêt à lancer votre projet <span class="co-ser">Webflow ?</span></h2>
            <p class="co-mut" style="margin-top:10px;max-width:62ch;line-height:1.6;">
