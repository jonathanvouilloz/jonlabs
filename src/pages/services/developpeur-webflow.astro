---
import '../../styles/global.css';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

// Import image hero (réutiliser temporairement refonte-1.webp)
import webflowHero from '../../assets/services/refonte-1.webp';

// Import background components
import BackgroundGlitchGrid from '../../components/backgrounds/BackgroundGlitchGrid.astro';
import BackgroundProgressFlow from '../../components/backgrounds/BackgroundProgressFlow.astro';
import BackgroundCircuitBoard from '../../components/backgrounds/BackgroundCircuitBoard.astro';
import BackgroundQuestionMarks from '../../components/backgrounds/BackgroundQuestionMarks.astro';
import BackgroundMapContours from '../../components/backgrounds/BackgroundMapContours.astro';

// Schema.org
import { serviceSchemas, SITE_URL } from '../../data/schema';
import { getBreadcrumbSchema, getFAQPageSchema } from '../../lib/seo';

// SEO Data
const seoData = {
    title: "Développeur Webflow freelance en Suisse romande | Jon Labs",
    description: "Création, refonte et e-commerce Webflow pour PME romandes. Tarifs transparents en CHF, SEO intégré. Discutons de votre projet."
};

// Schema.org data
const breadcrumb = getBreadcrumbSchema([
    { name: "Accueil", url: SITE_URL },
    { name: "Services", url: `${SITE_URL}/services` },
    { name: "Développeur Webflow", url: `${SITE_URL}/services/developpeur-webflow` }
]);
const schemas: any[] = [serviceSchemas["developpeur-webflow"], breadcrumb];

// Pain points data (4 items)
const painPoints = [
    {
        icon: "ri-money-dollar-circle-line",
        title: "Des devis d'agence hors budget",
        description: "Vous avez demandé des devis pour un site Webflow et les agences vous annoncent des montants à cinq chiffres, avec trois interlocuteurs et des délais flous."
    },
    {
        icon: "ri-question-line",
        title: "Un site Webflow que personne ne maîtrise",
        description: "Votre prestataire a livré le site puis a disparu. Vous avez les accès, mais vous n'osez toucher à rien de peur de tout casser."
    },
    {
        icon: "ri-file-copy-line",
        title: "Un template qui ne vous ressemble pas",
        description: "Vous avez acheté un template Webflow, mais le résultat fait générique. Votre site ressemble à celui de centaines d'autres entreprises."
    },
    {
        icon: "ri-shopping-cart-line",
        title: "Bloqué sur la vente en ligne",
        description: "Vous voulez vendre vos produits ou services en ligne, mais vous ne savez pas si Webflow suffit pour votre boutique — et personne ne vous donne de réponse claire."
    }
];

// Offres (3 cards)
const offers = [
    {
        icon: "ri-add-box-line",
        title: "Création de site Webflow",
        description: "Un site Webflow sur-mesure, construit depuis vos maquettes Figma ou de zéro. Structure propre (style Client-First), animations sobres, CMS configuré pour que vous publiiez vous-même.",
        idealFor: "Indépendants et PME qui veulent un site élégant et gérable en autonomie"
    },
    {
        icon: "ri-refresh-line",
        title: "Refonte de site Webflow existant",
        description: "Votre site Webflow plafonne : structure brouillonne, pages lentes, SEO inexistant. Je reprends le projet, je nettoie, je restructure et je remets les performances à niveau.",
        idealFor: "Sites Webflow hérités d'un autre prestataire ou montés en interne"
    },
    {
        icon: "ri-plug-line",
        title: "Intégrations & automatisations",
        description: "Webflow ne vit pas seul : formulaires connectés à votre CRM, contenus synchronisés via l'API, automatisations Make ou n8n. Votre site devient un vrai outil de travail.",
        idealFor: "Entreprises qui veulent connecter leur site à leurs outils métier"
    }
];

// E-commerce : quand ça marche / quand ça coince
const ecomWorks = [
    "Catalogue simple : moins de 100 produits, peu de variantes",
    "Vente de services, formations ou produits digitaux",
    "Marché suisse ou zone unique (TVA et livraison simples)",
    "Priorité au design : une boutique qui ressemble à votre marque",
    "Paiement par carte via Stripe, sans usine à gaz"
];
const ecomLimits = [
    "Gros catalogue avec variantes complexes (tailles × couleurs × stocks)",
    "Multi-devises ou règles de TVA internationales",
    "Logistique avancée : multi-entrepôts, click & collect, abonnements",
    "Besoin de TWINT ou de moyens de paiement suisses spécifiques",
    "Marketplace ou fonctionnalités sur-mesure côté serveur"
];

// Methodology steps (5 étapes)
const methodSteps = [
    {
        step: "1",
        title: "Échange",
        description: "Je discute avec vous de votre activité et de votre projet. Première question honnête : est-ce que Webflow est le bon outil pour ce que vous voulez faire ? Si non, je vous le dis.",
        duration: "30-45 min (gratuit, sans engagement)"
    },
    {
        step: "2",
        title: "Structure & maquette",
        description: "Je définis l'architecture des pages et le design — depuis vos maquettes Figma si vous en avez, sinon je les crée. Vous validez avant que je construise quoi que ce soit.",
        duration: "3-5 jours"
    },
    {
        step: "3",
        title: "Build Webflow",
        description: "Je construis le site avec une structure de classes propre et un CMS bien pensé. Pas de bricolage : un projet Webflow que n'importe quel professionnel pourra reprendre après moi.",
        duration: "1-2 semaines"
    },
    {
        step: "4",
        title: "SEO & performance",
        description: "Balises, maillage interne, données structurées, images optimisées, temps de chargement. Votre site Webflow est prêt à remonter sur Google, pas juste joli.",
        duration: "2-3 jours"
    },
    {
        step: "5",
        title: "Formation & autonomie",
        description: "Je vous forme à l'éditeur Webflow : textes, images, articles, produits. Vous gérez votre contenu vous-même, sans repasser par moi pour chaque virgule.",
        duration: "1 session + support"
    }
];

// Differentiators : freelance vs agence
const differentiators = [
    {
        icon: "ri-user-voice-line",
        title: "Un seul interlocuteur",
        description: "vous parlez à celui qui construit, pas à un chef de projet"
    },
    {
        icon: "ri-price-tag-3-line",
        title: "Tarifs en CHF affichés",
        description: "des fourchettes claires, pas de devis surprise"
    },
    {
        icon: "ri-map-pin-line",
        title: "Basé à Genève",
        description: "même fuseau, même marché, café possible"
    },
    {
        icon: "ri-scales-3-line",
        title: "Conseil honnête",
        description: "si Webflow n'est pas adapté, je vous le dis et je propose mieux"
    }
];

// Pricing plans (alignés sur /tarifs)
const pricingPlans = [
    {
        name: "Site Webflow essentiel",
        price: "1'490",
        priceLabel: "À partir de",
        features: [
            "1 à 5 pages sur-mesure",
            "Responsive (mobile + desktop)",
            "SEO de base : balises, structure, vitesse",
            "Formulaire de contact connecté",
            "Formation à l'éditeur Webflow"
        ],
        ideal: "Indépendants et consultants qui veulent une présence pro, gérable en autonomie.",
        highlighted: false
    },
    {
        name: "Site Webflow + CMS",
        price: "2'490",
        priceLabel: "À partir de",
        features: [
            "Tout ce qui est inclus dans Essentiel",
            "CMS configuré : blog, portfolio, fiches",
            "SEO avancé + données structurées",
            "Animations et interactions sur-mesure",
            "Intégrations (CRM, newsletter, Make/n8n)"
        ],
        ideal: "PME et marques qui publient du contenu et veulent un site qui travaille pour elles.",
        highlighted: true
    },
    {
        name: "E-commerce & projets complexes",
        price: "Sur devis",
        priceLabel: "",
        features: [
            "Boutique Webflow Ecommerce",
            "Paiement sécurisé via Stripe",
            "Ou alternative sur-mesure si Webflow ne suffit pas",
            "Intégrations logistique et facturation"
        ],
        ideal: "Commerçants et créateurs qui veulent vendre en ligne — on valide d'abord la faisabilité ensemble.",
        highlighted: false
    }
];

// FAQs (10 questions)
const faqs = [
    {
        question: "Webflow ou WordPress : que choisir en 2026 ?",
        answer: "Webflow si vous voulez un site visuel, rapide, hébergé et sécurisé sans plugins à maintenir. WordPress si vous avez besoin d'un blog très actif, de plugins métier spécifiques ou d'un budget plus serré au départ. Je travaille avec les deux — je vous oriente selon votre projet, pas selon mes préférences."
    },
    {
        question: "Combien coûte un site Webflow en Suisse ?",
        answer: "Comptez à partir de CHF 1'490 pour un site essentiel de 1 à 5 pages, à partir de CHF 2'490 avec un CMS (blog, portfolio), et sur devis pour l'e-commerce. S'y ajoute l'abonnement Webflow (environ CHF 15-40/mois selon le plan), qui remplace l'hébergement et la maintenance technique."
    },
    {
        question: "Webflow peut-il gérer un e-commerce ?",
        answer: "Oui, pour une boutique simple : moins de 100 produits, paiement Stripe, marché suisse. Au-delà — variantes complexes, multi-devises, TWINT, logistique avancée — Webflow Ecommerce montre ses limites. Dans ce cas je vous propose une alternative (intégration ou solution sur-mesure) plutôt que de forcer l'outil."
    },
    {
        question: "Combien de temps pour créer un site Webflow ?",
        answer: "Entre 2 et 4 semaines pour un site vitrine, selon le nombre de pages et la complexité du design. Un e-commerce demande 4 à 6 semaines. Si vous avez une échéance serrée, on en parle dès le premier échange."
    },
    {
        question: "Puis-je modifier mon site moi-même après la livraison ?",
        answer: "Oui, c'est tout l'intérêt de Webflow. L'éditeur vous permet de changer textes, images, articles et produits sans toucher au design. Je vous forme à la livraison, et vous repartez autonome. Pour les évolutions structurelles, je reste disponible."
    },
    {
        question: "Webflow est-il bon pour le référencement Google ?",
        answer: "Techniquement, oui : code propre, pages rapides, balises et redirections gérables finement. Mais l'outil ne fait pas tout — c'est la structure, le contenu et le maillage qui font le référencement. C'est précisément ce que j'intègre dans chaque projet, référencement local compris."
    },
    {
        question: "Freelance ou agence Webflow : quelle différence ?",
        answer: "Avec une agence, vous payez aussi les couches de gestion de projet et les allers-retours internes. Avec moi, vous parlez directement à celui qui construit votre site. Résultat : décisions plus rapides, budget plus contenu, et un interlocuteur qui connaît chaque recoin du projet."
    },
    {
        question: "Que se passe-t-il si Webflow ne convient pas à mon projet ?",
        answer: "Je vous le dis dès le premier échange, et je vous propose l'alternative adaptée : un site sur-mesure (Astro, Next.js) pour la performance et les besoins techniques, ou WordPress si votre projet le justifie. Mon métier est de livrer le bon outil, pas de vendre Webflow à tout prix."
    },
    {
        question: "Travaillez-vous uniquement sur Genève ?",
        answer: "Je suis basé à Genève et je travaille avec des clients dans toute la Suisse romande — Vaud, Valais, Neuchâtel, Fribourg. Les échanges se font en personne ou en visio selon vos préférences."
    },
    {
        question: "Reprenez-vous des sites Webflow existants ?",
        answer: "Oui, c'est une demande fréquente : un site monté par un prestataire parti ou construit en interne, qui plafonne. Je commence par un audit du projet (structure, performance, SEO), puis je vous propose un plan de refonte clair avec un budget ferme."
    }
];
schemas.push(getFAQPageSchema(faqs));

// Local zones
const zones = [
    { name: "Genève", type: "primary", icon: "ri-map-pin-fill" },
    { name: "Vaud", type: "secondary", icon: "ri-map-pin-line" },
    { name: "Valais", type: "secondary", icon: "ri-map-pin-line" },
    { name: "Neuchâtel", type: "secondary", icon: "ri-map-pin-line" },
    { name: "Fribourg", type: "secondary", icon: "ri-map-pin-line" },
    { name: "Toute Suisse romande", type: "tertiary", icon: "ri-global-line" }
];

// Project type options for form
const projectTypes = [
    { value: "creation-webflow", label: "Création de site Webflow" },
    { value: "refonte-webflow", label: "Refonte d'un site Webflow existant" },
    { value: "ecommerce-webflow", label: "E-commerce" },
    { value: "ne-sait-pas", label: "Je ne sais pas encore" }
];

// Budget options for form
const budgetOptions = [
    { value: "moins-1500", label: "< 1'500 CHF" },
    { value: "1500-3000", label: "1'500 - 3'000 CHF" },
    { value: "3000-6000", label: "3'000 - 6'000 CHF" },
    { value: "plus-6000", label: "> 6'000 CHF" },
    { value: "ne-sait-pas", label: "Je ne sais pas" }
];
---

<Layout
    title={seoData.title}
    description={seoData.description}
    schemas={schemas}
>
    <Header />

    <!-- ============================================== -->
    <!-- HERO SECTION -->
    <!-- ============================================== -->
    <section class="hero-section -mt-[120px] pt-[150px] pb-16 md:pt-[160px] md:pb-20 px-4 relative overflow-hidden">
        <!-- Gradient mesh background -->
        <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
            <div class="absolute top-0 -left-20 w-[500px] h-[500px] bg-[var(--blue)] opacity-20 blur-[120px] rounded-full"></div>
            <div class="absolute top-1/3 -right-20 w-[400px] h-[400px] bg-[var(--violet)] opacity-15 blur-[100px] rounded-full"></div>
            <div class="absolute bottom-0 left-1/3 w-[300px] h-[300px] bg-[var(--blue)] opacity-10 blur-[80px] rounded-full"></div>
        </div>

        <div class="max-w-4xl mx-auto relative z-10">
            <!-- Centered text content -->
            <div class="text-center">
                <!-- H1 SEO discret -->
                <h1 class="seo-h1 mb-8 mt-8">Développeur Webflow freelance à Genève</h1>

                <!-- Main title -->
                <p class="text-3xl md:text-4xl lg:text-5xl font-normal tracking-tight mb-6" data-animate="fade-up">
                    Un site Webflow qui tourne,<br/>
                    <span class="relative inline-block">
                        <span class="relative z-10">et que vous gérez vous-même</span>
                    </span>
                </p>

                <!-- Description -->
                <p class="text-lg md:text-xl text-gray-600 mb-8 leading-relaxed max-w-2xl mx-auto" data-animate="fade-up" data-delay="0.1">
                    Création, refonte ou boutique en ligne :<br class="hidden md:block"/>
                    <strong class="text-[var(--text)]">un développeur Webflow basé à Genève</strong>, qui construit proprement<br class="hidden md:block"/>
                    et vous dit honnêtement si Webflow est le bon choix pour votre projet.
                </p>

                <!-- CTAs centered -->
                <div class="flex flex-col sm:flex-row gap-4 justify-center mb-16 md:mb-20" data-animate="fade-up" data-delay="0.2">
                    <a
                        href="#contact"
                        class="
                            bg-[var(--blue)]
                            border-2 border-black
                            px-6 py-4
                            text-lg font-medium
                            shadow-[4px_4px_0px_rgba(0,0,0,1)]
                            transition-all duration-200
                            hover:bg-[var(--yellow)]
                            hover:shadow-[2px_2px_0px_rgba(0,0,0,1)]
                            hover:translate-x-[2px] hover:translate-y-[2px]
                            flex items-center justify-center gap-2
                        "
                    >
                        <i class="ri-chat-3-line"></i>
                        Discuter de mon projet
                    </a>
                    <a
                        href="#ecommerce"
                        class="
                            bg-white
                            border-2 border-black
                            px-6 py-4
                            text-lg font-medium
                            transition-all duration-200
                            hover:bg-gray-100
                            flex items-center justify-center gap-2
                        "
                    >
                        E-commerce sur Webflow ?
                        <i class="ri-arrow-down-line"></i>
                    </a>
                </div>
            </div>

            <!-- Browser mockup centered -->
            <div class="w-full mx-auto relative" data-animate="scale" data-delay="0.3">
                <div class="bg-white border-3 border-black shadow-[8px_8px_0px_rgba(0,0,0,1)] relative">
                    <!-- Browser bar -->
                    <div class="flex items-center gap-2 p-3 border-b-2 border-black bg-gray-50">
                        <div class="flex gap-1.5">
                            <div class="w-3 h-3 rounded-full bg-red-400 border border-black"></div>
                            <div class="w-3 h-3 rounded-full bg-yellow-400 border border-black"></div>
                            <div class="w-3 h-3 rounded-full bg-green-400 border border-black"></div>
                        </div>
                        <div class="flex-1 bg-white border border-black px-3 py-1 text-xs text-gray-400 font-mono text-center">
                            votresite.webflow.io
                        </div>
                    </div>
                    <!-- Screenshot -->
                    <img
                        src={webflowHero.src}
                        alt="Exemple de site Webflow sur-mesure créé par un développeur freelance"
                        class="w-full h-auto"
                    />
                </div>
                <!-- Score badge -->
                <div class="absolute -top-4 -left-4 bg-white border-2 border-black px-3 py-2 shadow-[3px_3px_0px_rgba(0,0,0,1)] -rotate-6">
                    <span class="font-mono text-sm font-bold text-[var(--blue)]">90+</span>
                    <span class="text-xs text-gray-500 block">Google</span>
                </div>
                <!-- Speed badge -->
                <div class="absolute -bottom-4 -right-4 bg-[var(--blue)] border-2 border-black px-4 py-2 shadow-[3px_3px_0px_rgba(0,0,0,1)] rotate-3">
                    <span class="font-bold text-sm">2-4 sem.</span>
                </div>
            </div>

            <!-- Location badge centered -->
            <div class="flex items-center justify-center gap-2 text-sm text-gray-500 mt-12">
                <i class="ri-map-pin-fill text-[var(--blue)]"></i>
                <span>Basé à Genève | Service en Suisse romande</span>
            </div>
        </div>
    </section>

    <!-- PAIN POINTS SECTION -->
    <section id="problemes" class="py-20 md:py-28 px-4 bg-white border-y-2 border-black relative overflow-hidden">
        <BackgroundGlitchGrid />
        <div class="max-w-5xl mx-auto relative z-10">
            <!-- Section header -->
            <div class="text-center mb-12 md:mb-16" data-animate="fade-up">
                <span class="inline-flex items-center gap-2 text-xs font-mono uppercase tracking-[0.2em] text-gray-500 mb-4">
                    <span class="w-8 h-px bg-gray-400"></span>
                    problèmes
                    <span class="w-8 h-px bg-gray-400"></span>
                </span>
                <h2 class="text-3xl md:text-4xl font-normal tracking-tight mb-4">
                    <span class="relative inline-block">
                        <span class="absolute bg-red-200 w-full h-[40%] left-0 bottom-1 -z-1"></span>
                        Vous vous reconnaissez ?
                    </span>
                </h2>
                <p class="text-lg text-gray-600">Ce sont les situations typiques des clients qui cherchent un freelance Webflow.</p>
            </div>

            <!-- Pain points grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6 mb-12" data-animate-stagger>
                {painPoints.map((point) => (
                    <div class="pain-card bg-[var(--main-bg)] border-2 border-black p-6 relative transition-all duration-200 hover:-translate-y-1 hover:shadow-[4px_4px_0px_rgba(0,0,0,0.2)]" data-animate-item>
                        <!-- Red X icon -->
                        <div class="w-10 h-10 bg-red-100 border-2 border-red-300 flex items-center justify-center mb-4">
                            <i class="ri-close-line text-red-500 text-xl"></i>
                        </div>
                        <h3 class="text-lg font-bold mb-2">{point.title}</h3>
                        <p class="text-gray-600 text-sm leading-relaxed">{point.description}</p>
                    </div>
                ))}
            </div>

            <!-- Good news callout -->
            <div class="bg-[var(--blue)] bg-opacity-10 border-2 border-[var(--blue)] p-6 md:p-8 text-center" data-animate="fade-up">
                <p class="text-lg md:text-xl font-medium">
                    <i class="ri-lightbulb-line text-[var(--blue)] mr-2"></i>
                    <strong>La bonne nouvelle ?</strong> Webflow bien construit, c'est un site rapide, élégant, et que vous éditez vous-même — sans dépendre de personne.
                </p>
            </div>
        </div>
    </section>

    <!-- OFFERS SECTION -->
    <section id="offres" class="py-20 md:py-28 px-4 relative overflow-hidden">
        <BackgroundCircuitBoard animated={true} />
        <div class="max-w-5xl mx-auto relative z-10">
            <!-- Section header -->
            <div class="text-center mb-12 md:mb-16" data-animate="fade-up">
                <span class="inline-flex items-center gap-2 text-xs font-mono uppercase tracking-[0.2em] text-gray-500 mb-4">
                    <span class="w-8 h-px bg-gray-400"></span>
                    prestations
                    <span class="w-8 h-px bg-gray-400"></span>
                </span>
                <h2 class="text-3xl md:text-4xl font-normal tracking-tight mb-4">
                    Ce que je fais sur Webflow
                </h2>
                <p class="text-lg text-gray-600 max-w-2xl mx-auto">
                    Trois types de missions, un même standard : <strong>un projet Webflow propre</strong>, documenté, que n'importe quel professionnel pourrait reprendre.
                </p>
            </div>

            <!-- Offer cards -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6 mb-12" data-animate-stagger="scale">
                {offers.map((offer) => (
                    <div class="tech-card bg-white border-2 border-black p-6 transition-all duration-200 hover:shadow-[4px_4px_0px_rgba(0,0,0,0.2)]" data-animate-item>
                        <i class={`${offer.icon} text-3xl text-[var(--violet)] mb-4 block`}></i>
                        <h3 class="text-xl font-bold mb-2">{offer.title}</h3>
                        <p class="text-sm text-gray-600 mb-3">{offer.description}</p>
                        <p class="text-xs text-[var(--blue)] font-medium">
                            <i class="ri-user-star-line mr-1"></i>
                            {offer.idealFor}
                        </p>
                    </div>
                ))}
            </div>

            <!-- Reassurance note -->
            <div class="bg-white border-2 border-black p-6 text-center" data-animate="fade-up">
                <p class="text-gray-600">
                    <i class="ri-information-line text-[var(--blue)] mr-2"></i>
                    <strong>Et le référencement ?</strong> Intégré dans chaque mission — structure, balises, vitesse, <a href="/services/referencement-local" class="text-[var(--blue)] font-medium hover:underline">référencement local</a> compris. Un site Webflow invisible sur Google ne sert à rien.
                </p>
            </div>
        </div>
    </section>

    <!-- E-COMMERCE SECTION -->
    <section id="ecommerce" class="py-20 md:py-28 px-4 bg-white border-y-2 border-black">
        <div class="max-w-5xl mx-auto">
            <!-- Section header -->
            <div class="text-center mb-12 md:mb-16" data-animate="fade-up">
                <span class="inline-flex items-center gap-2 text-xs font-mono uppercase tracking-[0.2em] text-gray-500 mb-4">
                    <span class="w-8 h-px bg-gray-400"></span>
                    vente en ligne
                    <span class="w-8 h-px bg-gray-400"></span>
                </span>
                <h2 class="text-3xl md:text-4xl font-normal tracking-tight mb-4">
                    E-commerce Webflow : ce qui marche, ce qui coince
                </h2>
                <p class="text-lg text-gray-600 max-w-2xl mx-auto">
                    On me demande souvent de créer une <strong>boutique en ligne sur Webflow</strong>. Réponse honnête : ça dépend de votre catalogue. Voici la grille de décision que j'utilise.
                </p>
            </div>

            <!-- Two columns -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8 mb-12">
                <!-- Works -->
