                n'est pas le bon outil pour vous.
            </p>

            <form class="wf-form co-frame" id="webflow-form" data-animate>
                <span class="co-x tl"></span><span class="co-x tr"></span>
                <span class="co-x bl"></span><span class="co-x br"></span>

                <!-- Hidden fields for Web3Forms (HARD-PRESERVE) -->
                <input type="hidden" name="access_key" value="3f64c7a1-46b9-4524-8e78-47524896d467">
                <input type="hidden" name="subject" value="Demande développeur Webflow - Jon Labs">
                <input type="hidden" name="from_name" value="Jon Labs - Développeur Webflow">
                <input type="checkbox" name="botcheck" class="wf-honeypot" style="display: none;">

                <h3 class="wf-form-title">Parlons de votre projet Webflow</h3>

                <div class="wf-form-grid">
                    <div class="wf-field">
                        <label for="name" class="wf-label"><span class="co-index">01</span> Nom / Prénom <span class="wf-req">*</span></label>
                        <input type="text" id="name" name="name" required placeholder="Jean Dupont" class="wf-input" />
                    </div>

                    <div class="wf-field">
                        <label for="email" class="wf-label"><span class="co-index">02</span> Email <span class="wf-req">*</span></label>
                        <input type="email" id="email" name="email" required placeholder="vous@exemple.ch" class="wf-input" />
                    </div>

                    <div class="wf-field">
                        <label for="phone" class="wf-label"><span class="co-index">03</span> Téléphone (optionnel)</label>
                        <input type="tel" id="phone" name="phone" placeholder="+41 79 123 45 67" class="wf-input" />
                    </div>

                    <div class="wf-field">
                        <label for="project-type" class="wf-label"><span class="co-index">04</span> Type de projet <span class="wf-req">*</span></label>
                        <div class="wf-select-wrap">
                            <select id="project-type" name="project_type" required class="wf-select">
                                <option value="" disabled selected>Choisir...</option>
                                {projectTypes.map((type) => (<option value={type.value}>{type.label}</option>))}
                            </select>
                            <i class="ri-arrow-down-s-line wf-select-caret" aria-hidden="true"></i>
                        </div>
                    </div>

                    <div class="wf-field wf-field--full">
                        <label for="message" class="wf-label"><span class="co-index">05</span> Votre message <span class="wf-req">*</span></label>
                        <textarea id="message" name="message" rows="4" required placeholder="Décrivez brièvement votre activité et votre projet Webflow..." class="wf-textarea"></textarea>
                    </div>

                    <div class="wf-field">
                        <label for="budget" class="wf-label"><span class="co-index">06</span> Budget approximatif</label>
                        <div class="wf-select-wrap">
                            <select id="budget" name="budget" class="wf-select">
                                <option value="" disabled selected>Choisir...</option>
                                {budgetOptions.map((option) => (<option value={option.value}>{option.label}</option>))}
                            </select>
                            <i class="ri-arrow-down-s-line wf-select-caret" aria-hidden="true"></i>
                        </div>
                    </div>

                    <div class="wf-field">
                        <label for="source" class="wf-label"><span class="co-index">07</span> Comment m'avez-vous trouvé ? (optionnel)</label>
                        <input type="text" id="source" name="source" placeholder="Google, recommandation, LinkedIn..." class="wf-input" />
                    </div>

                    <div class="wf-field wf-field--full">
                        <label class="wf-consent">
                            <input type="checkbox" name="consent" required class="wf-checkbox" />
                            <span>Vos données sont utilisées uniquement pour répondre à votre demande. Pas de spam, promis. <span class="wf-req">*</span></span>
                        </label>
                    </div>

                    <div class="wf-field wf-field--full">
                        <button type="submit" class="co-btn submit-btn wf-submit">
                            <span>Envoyer ma demande</span>
                            <i class="ri-send-plane-line"></i>
                        </button>
                    </div>
                </div>
            </form>

            <div class="wf-form-after" data-animate>
                <div class="wf-trust">
                    <span><i class="ri-time-line"></i> Réponse sous 24h</span>
                    <span><i class="ri-gift-line"></i> Premier échange gratuit</span>
                    <span><i class="ri-file-list-3-line"></i> Devis clair</span>
                </div>
                <div class="wf-alt">
                    <p class="co-mut">Vous préférez réserver un créneau directement ?</p>
                    <a href="https://cal.com/jonathan-vouilloz/appel-de-bienvenue" target="_blank" rel="noopener noreferrer" class="wf-inline"><i class="ri-calendar-line"></i> Prendre rendez-vous sur Cal.com</a>
                </div>
                <div class="wf-alt">
                    <p class="co-mut">Besoin d'une réponse rapide ?</p>
                    <a href="mailto:contact@jonlabs.ch" class="wf-inline">contact@jonlabs.ch</a>
                </div>
                <p class="wf-note-inline" style="text-align:center;">
                    <strong>Webflow n'est pas adapté à votre projet ?</strong> Je développe aussi des sites
                    <a href="/services/creation-site-web" class="wf-inline">sur-mesure</a> et je reprends des sites
                    <a href="/services/developpeur-wordpress" class="wf-inline">WordPress</a>. Pour un exemple concret,
                    voyez mon étude de cas <a href="/portfolio/barber-concept" class="wf-inline">Barber Concept</a>
                    ou l'ensemble de mes <a href="/portfolio" class="wf-inline">réalisations</a>.
                </p>
            </div>
        </section>

    </main>

    <Footer />
</Layout>

<style is:global>
    /* ══ DÉVELOPPEUR WEBFLOW — styles .wf-* (namespace scopé, corps .co-root) ══ */

    /* ── Hero ── */
    .wf-hero-grid { display: grid; grid-template-columns: 1.05fr 0.95fr; gap: 48px; align-items: center; }
    .wf-hero-title { font-size: clamp(2.2rem, 5vw, 3.4rem); }
    .co-root .wf-hero-lead { margin-top: 18px; max-width: 52ch; font-size: 1.075rem; line-height: 1.65; color: var(--muted); }
    .wf-hero-lead strong { color: var(--ink); font-weight: 600; }
    .wf-hero-btns { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 28px; }
    .wf-hero-btns .co-btn i { transition: transform .18s ease-out; }
    .wf-hero-btns .co-btn:hover i { transform: translateY(2px); }
    .co-root .wf-hero-loc { margin-top: 22px; font-size: 13.5px; display: inline-flex; align-items: center; gap: 6px; }
    .wf-hero-loc i { color: var(--accent); }

    /* browser mockup */
    .wf-hero-media { position: relative; }
    .wf-browser { position: relative; background: var(--surface); border: 1px solid var(--line-2); }
    .wf-browser-bar { display: flex; align-items: center; gap: 8px; padding: 11px 14px; border-bottom: 1px solid var(--line); background: var(--bg); }
    .wf-browser-dot { width: 9px; height: 9px; border-radius: 999px; background: var(--line-2); flex: none; }
    .wf-browser-url { flex: 1; text-align: center; font-size: 12px; color: var(--muted); font-variant-numeric: tabular-nums; }
    .wf-browser-img { display: block; width: 100%; height: auto; }
    .wf-badge { position: absolute; z-index: 4; background: var(--surface); border: 1px solid var(--line-2); padding: 8px 12px; font-size: 12px; font-weight: 600; }
    .wf-badge--score { top: -16px; left: -14px; display: flex; flex-direction: column; line-height: 1.1; }
    .wf-badge--score b { color: var(--accent); font-size: 15px; }
    .wf-badge--score span { color: var(--muted); font-size: 10px; text-transform: uppercase; letter-spacing: 0.08em; }
    .wf-badge--speed { bottom: -16px; right: -14px; background: var(--accent); border-color: var(--accent); color: #fff; }

    /* ── Cartes génériques (problèmes / prestations) ── */
    .wf-grid { display: grid; gap: 16px; margin-top: 32px; }
    .wf-grid--2 { grid-template-columns: repeat(2, 1fr); }
    .wf-grid--3 { grid-template-columns: repeat(3, 1fr); }
    .wf-card {
        position: relative; display: flex; flex-direction: column; gap: 10px; padding: 24px;
        background: var(--surface); border: 1px solid var(--line-2);
        transition: box-shadow .18s ease-out, transform .18s ease-out;
    }
    .wf-card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(20,22,26,.07); }
    .wf-card-icon { font-size: 24px; color: var(--accent); line-height: 1; }
    .wf-card-title { font-size: 1.1rem; }
    .wf-card-text { font-size: 14px; line-height: 1.55; color: var(--muted); }
    .wf-card-tag { margin-top: auto; padding-top: 4px; font-size: 12.5px; font-weight: 600; color: var(--accent); display: inline-flex; align-items: center; gap: 5px; }

    /* ── Notes / callouts ── */
    .wf-note { display: flex; align-items: flex-start; gap: 12px; margin-top: 20px; padding: 18px 22px; border: 1px solid var(--line-2); background: var(--surface); }
    .wf-note i { color: var(--accent); font-size: 20px; flex: none; margin-top: 1px; }
    .co-root .wf-note p { font-size: 14.5px; line-height: 1.6; color: var(--muted); }
    .wf-note--accent { border-color: var(--accent); background: rgba(0,168,125,0.05); }
    .wf-note-inline { margin-top: 14px !important; font-size: 14px; line-height: 1.6; color: var(--muted); }
    .wf-inline { color: var(--accent); text-decoration: underline; text-underline-offset: 2px; font-weight: 500; }
    .wf-inline:hover { color: var(--ink); }
    .wf-note strong, .wf-note-inline strong { color: var(--ink); font-weight: 600; }

    /* ── E-commerce : deux colonnes marche / coince ── */
    .wf-ecom { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 32px; align-items: start; }
    .wf-ecom-card { position: relative; padding: 28px; background: var(--surface); border: 1px solid var(--line-2); }
    .wf-ecom-head { display: flex; align-items: center; gap: 12px; margin-bottom: 18px; }
    .wf-ecom-head i { font-size: 22px; flex: none; }
    .wf-ecom-head--ok i { color: var(--accent); }
    .wf-ecom-head--limit i { color: var(--muted); }
    .wf-ecom-title { font-size: 1.15rem; }
    .wf-ecom-list li { font-size: 14px; line-height: 1.5; }
    .wf-cross { display: flex; flex-direction: column; gap: 10px; padding: 0; list-style: none; }
    .wf-cross li { display: flex; gap: 9px; color: var(--muted); }
    .wf-cross li i { color: var(--muted); font-size: 15px; flex: none; margin-top: 1px; }

    /* ── Étapes méthode ── */
    .wf-steps { display: flex; flex-direction: column; margin-top: 32px; border-top: 1px solid var(--line); }
    .wf-step { display: grid; grid-template-columns: 56px 1fr; gap: 20px; padding: 22px 0; border-bottom: 1px solid var(--line); }
    .wf-step-num { font-size: 20px; font-weight: 600; }
    .wf-step-title { font-size: 1.15rem; }
    .co-root .wf-step-text { margin-top: 6px; font-size: 14.5px; line-height: 1.55; color: var(--muted); max-width: 68ch; }
    .co-root .wf-step-dur { margin-top: 10px; font-size: 13px; color: var(--muted); display: inline-flex; align-items: center; gap: 6px; }
    .wf-step-dur i { color: var(--accent); }

    /* ── Encart différenciateurs ── */
    .wf-diff { position: relative; margin-top: 32px; padding: 36px; background: var(--surface); border: 1px solid var(--line-2); }
    .wf-diff-title { text-align: center; font-size: 1.25rem; }
    .wf-diff-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 28px; margin-top: 28px; }
    .wf-diff-item { text-align: center; }
    .wf-diff-icon { font-size: 26px; color: var(--accent); }
    .wf-diff-name { margin-top: 10px; font-size: 15px; font-weight: 600; }
    .co-root .wf-diff-desc { margin-top: 4px; font-size: 13px; line-height: 1.45; color: var(--muted); }

    /* ── Tarifs ── */
    .wf-tiers { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; align-items: start; margin-top: 36px; }
    .wf-tier { position: relative; display: flex; flex-direction: column; gap: 18px; padding: 30px 26px; background: var(--surface); border: 1px solid var(--line-2); }
    .wf-tier--reco { border-color: var(--accent); box-shadow: 0 0 0 1px var(--accent); }
    .wf-tier-reco { position: absolute; top: -12px; left: 26px; z-index: 4; }
    .wf-tier-name { font-size: 1.15rem; }
    .wf-tier-price { display: flex; align-items: baseline; gap: 6px; flex-wrap: wrap; }
    .wf-tier-pricelabel { font-size: 13px; color: var(--muted); width: 100%; }
    .wf-tier-price b { font-size: 2.3rem; font-weight: 700; letter-spacing: -0.03em; line-height: 1; }
    .wf-tier-cur { font-size: 15px; color: var(--muted); font-weight: 500; }
    .wf-tier-features { gap: 10px; }
    .wf-tier-features li { font-size: 14px; line-height: 1.45; }
    .co-root .wf-tier-ideal { margin-top: auto; padding-top: 16px; border-top: 1px solid var(--line); font-size: 13px; line-height: 1.5; color: var(--muted); }
    .wf-tier-ideal strong { color: var(--ink); }

    .wf-pricenote { position: relative; margin-top: 28px; padding: 30px 32px; background: var(--surface); border: 1px solid var(--line-2); }
    .wf-pricenote-title { font-size: 1.1rem; display: inline-flex; align-items: center; gap: 8px; }
    .wf-pricenote-title i { color: var(--accent); }
    .wf-pricenote-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px 40px; margin-top: 18px; }
    .wf-pricenote-grid li { font-size: 14px; }

    /* ── FAQ (accordéon natif <details> — smooth via ::details-content, zéro JS) ── */
    .wf-faq { border-top: 1px solid var(--line); }
    .wf-faq details { border-bottom: 1px solid var(--line); }
    .wf-faq summary {
        list-style: none; cursor: pointer; padding: 20px 0;
        display: flex; justify-content: space-between; align-items: center; gap: 20px;
        font-size: 1.1rem; font-weight: 600; letter-spacing: -0.01em; color: var(--ink);
    }
    .wf-faq summary::-webkit-details-marker { display: none; }
    .wf-faq summary i { transition: transform .2s ease-out; color: var(--muted); font-size: 22px; flex: none; }
    .wf-faq details[open] summary i { transform: rotate(180deg); }
    .co-root .wf-faq-answer { padding: 0 0 22px; color: var(--muted); line-height: 1.6; max-width: 68ch; }
    .wf-faq details::details-content {
        block-size: 0; overflow: hidden;
        transition: block-size .28s ease-out, content-visibility .28s ease-out allow-discrete;
    }
    .wf-faq details[open]::details-content { block-size: auto; }

    /* ── Local ── */
    .wf-local-grid { display: grid; grid-template-columns: 1.15fr 0.85fr; gap: 40px; margin-top: 32px; }
    .wf-local-h3 { font-size: 1.15rem; margin-bottom: 18px; line-height: 1.3; }
    .wf-local-adv { display: flex; flex-direction: column; gap: 12px; }
    .wf-local-item { position: relative; display: flex; align-items: flex-start; gap: 14px; padding: 18px; background: var(--surface); border: 1px solid var(--line-2); }
    .wf-local-icon { font-size: 22px; color: var(--accent); flex: none; margin-top: 2px; }
    .wf-local-name { font-size: 15px; font-weight: 600; }
    .co-root .wf-local-desc { margin-top: 3px; font-size: 13.5px; line-height: 1.5; color: var(--muted); }
    .wf-zones { display: flex; flex-direction: column; gap: 10px; }
    .wf-zone { display: flex; align-items: center; gap: 12px; padding: 14px 16px; background: var(--surface); border: 1px solid var(--line-2); font-size: 14px; }
    .wf-zone i { color: var(--muted); font-size: 18px; }
    .wf-zone--primary { border-color: var(--accent); background: rgba(0,168,125,0.05); }
    .wf-zone--primary i { color: var(--accent); }

    /* ── Formulaire (Web3Forms restylé, câblage préservé) ── */
    .wf-form { position: relative; margin-top: 32px; padding: 34px; background: var(--surface); border: 1px solid var(--line-2); }
    .wf-form-title { font-size: 1.25rem; text-align: left; margin-bottom: 22px; }
    .wf-form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
    .wf-field { display: flex; flex-direction: column; gap: 8px; }
    .wf-field--full { grid-column: 1 / -1; }
    .wf-label { display: flex; align-items: baseline; gap: 8px; font-size: 13px; font-weight: 600; color: var(--ink); }
    .wf-label .co-index { font-size: 11px; }
    .wf-req { color: var(--accent); }
    .wf-input, .wf-select, .wf-textarea {
        width: 100%; font-family: "Inter Tight", ui-sans-serif, sans-serif; font-size: 15px; color: var(--ink);
        background: var(--bg); border: 1px solid var(--line-2); padding: 12px 14px;
        transition: border-color .18s ease-out, box-shadow .18s ease-out;
    }
    .wf-input::placeholder, .wf-textarea::placeholder { color: var(--muted); opacity: .7; }
    .wf-input:focus, .wf-select:focus, .wf-textarea:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 3px rgba(0,168,125,.15); }
    .wf-textarea { resize: vertical; min-height: 120px; line-height: 1.5; }
    .wf-select-wrap { position: relative; }
    .wf-select { appearance: none; -webkit-appearance: none; cursor: pointer; padding-right: 40px; }
    .wf-select-caret { position: absolute; right: 14px; top: 50%; transform: translateY(-50%); font-size: 18px; color: var(--muted); pointer-events: none; }
    .wf-consent { display: flex; align-items: flex-start; gap: 10px; font-size: 13px; line-height: 1.5; color: var(--muted); cursor: pointer; }
    .wf-consent:hover { color: var(--ink); }
    .wf-checkbox { margin-top: 2px; width: 16px; height: 16px; flex: none; accent-color: var(--accent); cursor: pointer; }
    .wf-submit { width: 100%; justify-content: center; padding: 14px 20px; font-size: 16px; }
    .submit-btn.loading { pointer-events: none; opacity: 0.7; }
    .submit-btn.loading i { animation: wfSpin 1s linear infinite; }
    @keyframes wfSpin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }

    /* ── Après-formulaire ── */
    .wf-form-after { margin-top: 28px; display: flex; flex-direction: column; gap: 18px; align-items: center; text-align: center; }
    .wf-trust { display: flex; flex-wrap: wrap; justify-content: center; gap: 24px; font-size: 13.5px; color: var(--muted); }
