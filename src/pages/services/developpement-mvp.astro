---
// Développement sur mesure & MVP — sous-page service (blueprint).
// Migrée du brutaliste vers le design system .co-* : sections cadrées, filets fins,
// accent teal unique, Inter Tight × Instrument Serif. Namespace scopé .mv-*.
//
// Pas de formulaire embarqué : cette page CTA vers Cal.com / /contact (restylés
// en .co-cta / .co-btn). HARD-PRESERVE : Schema.org (serviceSchemas/breadcrumb/FAQ),
// liens SEO internes (/portfolio/wisp, /portfolio, /about, /contact,
// /services/validation-idee), lien Cal.com, copywriting réel.

import '../../styles/global.css';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

// Image hero (illustration MVP)
import imgHero from '../../assets/services/mvp-hero.webp';

// Schema.org
import { serviceSchemas, SITE_URL } from '../../data/schema';
import { getFAQPageSchema } from '../../lib/seo';
import { getBreadcrumbSchema } from '../../lib/seo';

// SEO Data
const seoData = {
    title: "Développement sur mesure & MVP à Genève",
    description: "Développeur freelance à Genève : MVP, applications et logiciels sur mesure pour PME et startups romandes. De l'idée au produit livré. 📩 Devis gratuit"
};

// Schema.org data
const breadcrumb = getBreadcrumbSchema([
    { name: "Accueil", url: SITE_URL },
    { name: "Services", url: `${SITE_URL}/services` },
    { name: "Développement MVP", url: `${SITE_URL}/services/developpement-mvp` }
]);
const schemas: any[] = [serviceSchemas["developpement-mvp"], breadcrumb];

// Pain points data
const painPoints = [
    {
        title: "Le pitch dans 3 semaines",
        description: "Tu as décroché un rendez-vous avec un investisseur — FONGIT, Business Angel romand, ou fonds d'amorçage suisse. Ton \"produit\", pour l'instant, c'est un PowerPoint et beaucoup de promesses. Montrer quelque chose de concret changerait tout."
    },
    {
        title: "L'idée qui tourne en boucle",
        description: "Ça fait des semaines que tu y penses. Tu as noté des trucs, fait des schémas, peut-être même commencé à coder un bout. Mais tu n'arrives pas à sortir quelque chose de montrable. Le perfectionnisme te paralyse."
    },
    {
        title: "Le doute qui s'installe",
        description: "Est-ce que les gens vont vraiment vouloir ça ? Est-ce que ça résout un vrai problème ? Tu pourrais passer encore 3 mois à te poser la question... ou construire un truc minimal et avoir ta réponse en 3 semaines."
    },
    {
        title: "Le process interne à tester",
        description: "Tu bosses dans une PME romande et tu as une idée pour améliorer un process. Mais convaincre ta direction avec un doc Word, c'est mission impossible. Il te faudrait un proto fonctionnel pour montrer concrètement ce que ça donnerait."
    }
];

// Method steps
const methodSteps = [
    {
        step: "1",
        title: "Cadrage",
        description: "On se pose ensemble — autour d'un café à Genève ou en visio — et on identifie LA fonctionnalité qui compte. Pas les 47 features de ta roadmap idéale. Juste celle qui prouve ta valeur. C'est souvent la partie la plus difficile : couper dans le gras.",
        duration: "1-2h appel + échanges async"
    },
    {
        step: "2",
        title: "Construction",
        description: "Je développe avec des technologies modernes et robustes — application web, application mobile (iOS / Android) ou PWA selon ton projet. Tu n'as pas besoin de comprendre le code. On avance par itérations courtes : je te montre, tu me dis ce qui va ou pas, on ajuste. Pas de surprise à la livraison.",
        duration: "1-2 semaines"
    },
    {
        step: "3",
        title: "Livraison",
        description: "Tu repars avec un prototype fonctionnel que tu peux montrer, tester, utiliser. Pas une maquette cliquable — un truc qui marche vraiment. Je te fournis aussi une documentation claire pour que tu puisses continuer sans moi.",
        duration: "Démo + passation quelques heures"
    }
];

// Differentiators
const differentiators = [
    {
        icon: "ri-timer-line",
        text: "Pas de tunnel de 6 mois : prototype en main en 2-3 semaines max"
    },
    {
        icon: "ri-user-line",
        text: "Un seul interlocuteur : tu parles à celui qui code, pas à un chef de projet"
    },
    {
        icon: "ri-shield-check-line",
        text: "Qualité suisse, flexibilité freelance : réactivité et rigueur, sans les coûts d'une agence"
    },
    {
        icon: "ri-door-open-line",
        text: "Pas de dépendance forcée : tu repars avec quelque chose d'utilisable et documenté"
    }
];

// Results
const results = [
    {
        title: "Un prototype fonctionnel",
        description: "Pas une maquette Figma, pas un PowerPoint animé. Un truc qui tourne, que tu peux montrer en live à tes investisseurs ou tes premiers utilisateurs."
    },
    {
        title: "Focus sur l'essentiel",
        description: "LA fonctionnalité qui démontre ta valeur. Le reste viendra après, si ça vaut le coup."
    },
    {
        title: "De quoi convaincre",
        description: "Investisseurs suisses, partenaires, direction, premiers clients — montrer vaut mille mots."
    },
    {
        title: "Une base solide pour la suite",
        description: "Si tu décides de continuer, le code est propre et documenté. Pas de dette technique cachée. Tu peux itérer dessus ou le confier à une équipe plus tard."
    },
    {
        title: "Ta réponse",
        description: "Le marché veut ça ou pas ? En 2-3 semaines, tu es fixé. Plus de doutes qui traînent pendant des mois."
    }
];

// Price factors
const priceFactors = [
    "La complexité de la fonctionnalité clé",
    "Le niveau de finition nécessaire (proto interne vs démo investisseurs)",
    "Le délai souhaité"
];

// FAQs
const faqs = [
    {
        question: "C'est quoi la différence entre un MVP et un produit fini ?",
        answer: "Un MVP, c'est le strict minimum pour prouver que ton concept fonctionne. On coupe tout ce qui n'est pas essentiel — pas de cahier des charges de 50 pages, pas de développement sur mesure de chaque feature. Un produit fini, c'est après — quand tu sais que ça vaut le coup d'investir plus."
    },
    {
        question: "2-3 semaines, c'est vraiment possible ?",
        answer: "Pour un proto ciblé sur une fonctionnalité clé, oui. Si tu veux une app complète avec 15 features, non. C'est justement l'intérêt du MVP : aller vite en se concentrant sur l'essentiel."
    },
    {
        question: "Et si je veux continuer après le MVP ?",
        answer: "Soit on continue ensemble pour développer la vraie V1, soit tu repars avec une base propre et documentée pour bosser avec quelqu'un d'autre. Pas de lock-in, pas de code \"otage\"."
    },
    {
        question: "Je n'y connais rien en technique, c'est un problème ?",
        answer: "Zéro. Je m'occupe de la partie technique, toi tu me dis ce que tu veux accomplir. On parle business et problèmes à résoudre, pas lignes de code. Si tu veux préparer la conversation, voici un guide sur ce que je t'aide à rédiger : le cahier des charges d'app métier (jonlabs.ch/blog/cahier-des-charges-application-metier)."
    },
    {
        question: "Et si le MVP montre que mon idée ne marche pas ?",
        answer: "C'est une victoire. Tu as ta réponse en quelques semaines au lieu de la découvrir après 6 mois de travail. Mieux vaut un \"non\" rapide qu'un \"non\" après avoir tout investi."
    },
    {
        question: "Tu peux m'aider à définir ce que devrait être le MVP ?",
        answer: "Oui, c'est même une grosse partie du travail. Savoir quoi couper est souvent plus dur que savoir quoi construire."
    },
    {
        question: "Pourquoi travailler avec un freelance à Genève plutôt qu'une agence ou un dev offshore ?",
        answer: "Trois raisons principales. La proximité : on peut se voir, on parle la même langue, on comprend le contexte suisse. La réactivité : pas de décalage horaire, pas de chef de projet intermédiaire, tu parles directement à celui qui code. La confiance : tes données restent en Suisse, conformes à la nLPD, et tu sais exactement qui travaille sur ton projet."
    }
];
schemas.push(getFAQPageSchema(faqs));

// Local zones
const zones = [
    { name: "Genève", type: "primary", icon: "ri-map-pin-fill" },
    { name: "Lausanne", type: "secondary", icon: "ri-map-pin-line" },
    { name: "Vaud", type: "secondary", icon: "ri-map-pin-line" },
    { name: "Toute Suisse romande", type: "tertiary", icon: "ri-global-line" }
];
---

<Layout title={seoData.title} description={seoData.description} schemas={schemas}>
    <Header />

    <main class="co-root">

        <!-- ══ HERO ══ -->
        <section class="co-sec co-pad co-hero mv-hero" style="padding:64px var(--sec-pad-x) var(--sec-pad-y);">
            <div class="mv-hero-grid">
                <div class="mv-hero-copy">
                    <h1 class="mv-hero-title" data-animate data-delay="0.1">
                        Ton prototype fonctionnel en <span class="co-ser">2-3 semaines.</span>
                    </h1>
                    <p class="mv-hero-lead" data-animate data-delay="0.2">
                        <strong>Arrête de construire dans ton coin pendant 6 mois.</strong> Tu as une idée,
                        un concept à tester, un pitch à préparer. Tu n'as pas besoin d'une app complète —
                        tu as besoin d'un <strong>partenaire technique en Suisse romande</strong> pour sortir
                        un truc qui marche, maintenant.
                    </p>
                    <div class="mv-hero-btns" data-animate data-delay="0.3">
                        <a href="https://cal.com/jonathan-vouilloz/appel-de-bienvenue" target="_blank" rel="noopener noreferrer" class="co-btn"><i class="ri-rocket-line"></i> Discuter de mon projet</a>
                        <a href="#methode" class="co-btn co-btn--ghost">Voir comment ça fonctionne <i class="ri-arrow-down-line"></i></a>
                    </div>
                    <p class="mv-hero-loc co-mut" data-animate data-delay="0.4">
                        <i class="ri-map-pin-fill"></i> Basé à Genève · Service en Suisse romande
                    </p>
                </div>

                <div class="mv-hero-media" data-animate="scale" data-delay="0.3">
                    <div class="mv-media-frame co-frame">
                        <span class="co-x tl"></span><span class="co-x tr"></span>
                        <span class="co-x bl"></span><span class="co-x br"></span>
                        <img src={imgHero.src} alt="Illustration de la construction d'un MVP : modules assemblés en un produit fonctionnel livrable" loading="eager" class="mv-media-img" />
                    </div>
                    <div class="mv-badge mv-badge--focus">
                        <b>1</b><span>fonctionnalité clé</span>
                    </div>
                    <div class="mv-badge mv-badge--speed">2-3 sem.</div>
                </div>
            </div>
        </section>

        <!-- ══ 01 · SITUATIONS ══ -->
        <section id="problemes" class="co-sec co-pad" style="padding:var(--sec-pad-y) var(--sec-pad-x);">
            <p class="co-eyebrow">01 — Situations</p>
            <h2 style="margin-top:var(--space-eyebrow);">Tu te <span class="co-ser">reconnais ?</span></h2>
            <p class="co-mut" style="margin-top:var(--space-title-lead);max-width:56ch;line-height:1.6;">
                Ces situations où le temps joue contre toi.
            </p>

            <div class="mv-grid mv-grid--2" data-animate-stagger>
                {painPoints.map((point, i) => (
                    <div class="mv-card co-frame co-frame--reveal" data-animate-item>
                        <i class={`${["ri-presentation-line","ri-loop-left-line","ri-question-line","ri-flow-chart"][i]} mv-card-icon`} aria-hidden="true"></i>
                        <h3 class="mv-card-title">{point.title}</h3>
                        <p class="mv-card-text">{point.description}</p>
                    </div>
                ))}
            </div>

            <figure class="mv-story co-frame" data-animate>
                <span class="co-x tl"></span><span class="co-x tr"></span>
                <span class="co-x bl"></span><span class="co-x br"></span>
                <p class="mv-story-lead">J'ai vécu exactement ça.</p>
                <div class="mv-body">
                    <p>On a passé un mois entier à développer un produit « parfait » — une plateforme de vente de contenu digital. L'UX était nickel, trois clics et c'était en ligne. Le problème ? <strong>On a découvert que le marché s'en foutait après avoir tout construit.</strong></p>
                    <p>Un mois de dev, des nuits blanches, un produit qui n'existe plus aujourd'hui.</p>
                </div>
                <blockquote class="mv-story-highlight">
                    Si j'avais sorti un proto moche mais fonctionnel en une semaine, j'aurais eu ma réponse sans y laisser des plumes.
                </blockquote>
            </figure>
        </section>

        <!-- ══ 02 · MÉTHODE ══ -->
        <section id="methode" class="co-sec co-pad" style="padding:var(--sec-pad-y) var(--sec-pad-x);">
            <p class="co-eyebrow">02 — Méthode</p>
            <h2 style="margin-top:var(--space-eyebrow);">Comment ça se passe ?</h2>
            <p class="co-mut" style="margin-top:var(--space-title-lead);max-width:60ch;line-height:1.6;">
                Pas de tunnel de développement. Tu vois ce qui se passe à chaque étape.
            </p>

            <div class="mv-steps" data-animate-stagger>
                {methodSteps.map((step, index) => (
                    <div class="mv-step" data-animate-item>
                        <span class="mv-step-num co-index">0{index + 1}</span>
                        <div class="mv-step-body">
                            <h3 class="mv-step-title">{step.title}</h3>
                            <p class="mv-step-text">{step.description}</p>
                            <p class="mv-step-dur"><i class="ri-time-line"></i> {step.duration}</p>
                        </div>
                    </div>
                ))}
            </div>

            <div class="mv-diff co-frame" data-animate>
                <span class="co-x tl"></span><span class="co-x tr"></span>
                <span class="co-x bl"></span><span class="co-x br"></span>
                <h3 class="mv-diff-title">Ce qui change avec Jon Labs</h3>
                <div class="mv-diff-grid">
                    {differentiators.map((diff) => (
                        <div class="mv-diff-item">
                            <i class={`${diff.icon} mv-diff-icon`} aria-hidden="true"></i>
                            <p class="mv-diff-text">{diff.text}</p>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <!-- ══ 03 · RÉSULTATS ══ -->
        <section id="resultats" class="co-sec co-pad" style="padding:var(--sec-pad-y) var(--sec-pad-x);">
            <p class="co-eyebrow">03 — Résultats</p>
            <h2 style="margin-top:var(--space-eyebrow);">Ce que tu <span class="co-ser">obtiens.</span></h2>

            <div class="mv-grid mv-grid--3" data-animate-stagger>
                {results.map((result, i) => (
                    <div class="mv-card co-frame co-frame--reveal" data-animate-item>
                        <i class={`${["ri-rocket-line","ri-focus-3-line","ri-presentation-line","ri-stack-line","ri-checkbox-circle-line"][i]} mv-card-icon`} aria-hidden="true"></i>
                        <h3 class="mv-card-title">{result.title}</h3>
                        <p class="mv-card-text">{result.description}</p>
                    </div>
                ))}
            </div>

            <div class="mv-note" data-animate>
                <i class="ri-briefcase-line"></i>
                <p>
                    <strong>Un exemple ?</strong> Découvre
                    <a href="/portfolio/wisp" class="mv-inline">Wisp</a>,
                    un MVP d'app d'écriture que j'ai construit en SvelteKit, ou l'ensemble de mes
                    <a href="/portfolio" class="mv-inline">réalisations</a>.
                </p>
            </div>
        </section>

        <!-- ══ 04 · INVESTISSEMENT ══ -->
        <section id="prix" class="co-sec co-pad" style="padding:var(--sec-pad-y) var(--sec-pad-x);">
            <p class="co-eyebrow">04 — Investissement</p>
            <h2 style="margin-top:var(--space-eyebrow);">Un devis <span class="co-ser">clair.</span></h2>
            <p class="co-mut" style="margin-top:var(--space-title-lead);max-width:60ch;line-height:1.6;">
                Chaque MVP est différent. Un proto pour tester une idée en interne, ce n'est pas la même
                chose qu'un démonstrateur pour lever des fonds.
            </p>

            <div class="mv-pricenote co-frame" data-animate>
                <span class="co-x tl"></span><span class="co-x tr"></span>
                <span class="co-x bl"></span><span class="co-x br"></span>
                <p class="mv-pricenote-lead">On en discute, je te fais un devis clair avec un périmètre précis.</p>
                <p class="mv-pricenote-sub co-mut">Pas de surprise en cours de route.</p>

                <div class="mv-pricenote-factors">
                    <h3 class="mv-pricenote-title"><i class="ri-information-line"></i> Ce qui influence le prix</h3>
                    <ul class="co-list">
                        {priceFactors.map((factor) => (<li>{factor}</li>))}
                    </ul>
                </div>

                <div class="mv-price-cta">
                    <a href="https://cal.com/jonathan-vouilloz/appel-de-bienvenue" target="_blank" rel="noopener noreferrer" class="co-btn">
                        <i class="ri-file-list-3-line"></i> Demander un devis
                    </a>
                </div>
            </div>
        </section>

        <!-- ══ 05 · FAQ (accordéon natif <details>, zéro JS) ══ -->
        <section id="faq" class="co-sec co-pad" style="padding:var(--sec-pad-y) var(--sec-pad-x);">
            <p class="co-eyebrow">05 — FAQ</p>
            <h2 style="margin-top:var(--space-eyebrow);">Questions fréquentes</h2>

            <div class="mv-faq" style="margin-top:var(--space-block);">
                {faqs.map((faq, index) => (
                    <details open={index === 0}>
                        <summary>
                            {faq.question}
                            <i class="ri-arrow-down-s-line" aria-hidden="true"></i>
                        </summary>
                        <p class="mv-faq-answer">{faq.answer}</p>
                    </details>
                ))}
            </div>

            <p class="co-mut" style="margin-top:24px;text-align:center;">
                Autre question ? <a href="/contact" class="mv-inline">Contacte-moi directement</a>, je réponds sous 24h.
            </p>
        </section>

        <!-- ══ 06 · À PROPOS ══ -->
        <section id="about" class="co-sec co-pad" style="padding:var(--sec-pad-y) var(--sec-pad-x);">
            <p class="co-eyebrow">06 — À propos</p>
            <h2 style="margin-top:var(--space-eyebrow);">Qui est derrière <span class="co-ser">Jon Labs ?</span></h2>

            <div class="mv-about co-frame" data-animate>
                <span class="co-x tl"></span><span class="co-x tr"></span>
                <span class="co-x bl"></span><span class="co-x br"></span>
                <div class="mv-body">
                    <p>Je suis <strong>Jonathan</strong>, développeur et créateur de solutions digitales basé à Genève.</p>
                    <p>Je ne suis pas une agence avec 15 commerciaux et des juniors qui font le travail. Je suis <strong>ton partenaire technique direct</strong> — celui qui va coder ton MVP, répondre à tes questions, et t'aider à trancher quand il faut faire des choix.</p>
                    <p>Mon approche : <strong>action plutôt que perfection</strong>. Mieux vaut un proto imparfait entre les mains qu'une idée parfaite qui reste dans ta tête.</p>
                    <p>J'ai accompagné des entrepreneurs romands, des startups en phase d'amorçage et des PME suisses qui avaient besoin de tester vite avant d'investir gros.</p>
                </div>
                <a href="/about" class="mv-about-link">
                    <i class="ri-user-line"></i> En savoir plus sur mon parcours <i class="ri-arrow-right-line"></i>
                </a>
            </div>
        </section>

        <!-- ══ 07 · LOCAL ══ -->
        <section id="local" class="co-sec co-pad" style="padding:var(--sec-pad-y) var(--sec-pad-x);">
            <p class="co-eyebrow">07 — Local</p>
            <h2 style="margin-top:var(--space-eyebrow);">Basé à <span class="co-ser">Genève</span>, disponible partout en Suisse romande</h2>

            <div class="mv-local-grid">
                <div class="mv-local-copy mv-body" data-animate="fade-left">
                    <p>Le développement de MVP se fait généralement à distance — les échanges, le suivi, les démos, tout peut se faire en visio. C'est souvent plus efficace.</p>
                    <p>Mais si tu préfères un échange en personne pour le cadrage initial ou les points d'étape, je suis disponible sur Genève et ses environs.</p>
                    <p>Je connais le contexte suisse romand — les attentes des investisseurs locaux, la nLPD pour la protection des données, les habitudes des utilisateurs d'ici.</p>
                </div>

                <div data-animate="fade-left" data-delay="0.1">
                    <h3 class="mv-local-h3">Zones couvertes</h3>
                    <div class="mv-zones">
                        {zones.map((zone) => (
                            <div class={`mv-zone ${zone.type === 'primary' ? 'mv-zone--primary' : ''}`}>
                                <i class={zone.icon}></i>
                                <span>
                                    <strong>{zone.name}</strong>
                                    {zone.type === 'primary' && <span class="co-mut"> (basé sur place)</span>}
                                </span>
                            </div>
                        ))}
                    </div>
                    <p class="co-mut" style="margin-top:16px;font-size:13.5px;">
                        <i class="ri-information-line"></i> Les échanges se font en personne ou en visio selon tes préférences.
                    </p>
                </div>
            </div>
        </section>

        <!-- ══ 08 · CTA FINAL (primitive .co-cta) ══ -->
        <section class="co-cta">
            <span class="co-x tl"></span><span class="co-x tr"></span>
            <span class="co-x bl"></span><span class="co-x br"></span>
            <div class="co-cta-inner">
                <h2 class="co-cta-title">Arrête de <span class="co-ser">tourner en rond.</span></h2>
                <p class="co-cta-lead">
                    En 30 minutes, on regarde ton projet ensemble et je te dis honnêtement si un MVP fait
                    sens — et ce qu'il faudrait pour le sortir.
                </p>
                <div class="co-cta-btns">
                    <a href="https://cal.com/jonathan-vouilloz/appel-de-bienvenue" target="_blank" rel="noopener noreferrer" class="co-btn co-cta-btn"><i class="ri-calendar-line"></i> Réserver un appel découverte</a>
                    <a href="/services/validation-idee" class="co-btn co-btn--ghost co-cta-btn co-cta-btn--ghost"><i class="ri-flask-line"></i> Valider mon idée d'abord</a>
                </div>
                <div class="co-cta-trust">
                    <span><i class="ri-time-line"></i> Réponse sous 24 h</span>
                    <span><i class="ri-phone-line"></i> Premier appel gratuit</span>
                    <span><i class="ri-map-pin-line"></i> Basé à Genève</span>
                </div>
            </div>
        </section>

    </main>

    <Footer />
</Layout>

<style is:global>
    /* ══ DÉVELOPPEMENT MVP — styles .mv-* (namespace scopé, corps .co-root) ══ */

    /* ── Corps rédactionnel réutilisable (story / about / local) ── */
    .mv-body { display: flex; flex-direction: column; gap: 14px; }
    .co-root .mv-body p { font-size: 14.5px; line-height: 1.65; color: var(--muted); }
    .mv-body strong { color: var(--ink); font-weight: 600; }

    /* ── Hero ── */
    .mv-hero-grid { display: grid; grid-template-columns: 1.05fr 0.95fr; gap: 48px; align-items: center; }
    .mv-hero-title { font-size: clamp(2.2rem, 5vw, 3.4rem); }
    .co-root .mv-hero-lead { margin-top: 18px; max-width: 54ch; font-size: 1.075rem; line-height: 1.65; color: var(--muted); }
    .mv-hero-lead strong { color: var(--ink); font-weight: 600; }
