<style is:global>
    /* ══ AUTOMATISATION DE TÂCHES — styles .au-* (namespace scopé, corps .co-root) ══ */

    /* ── Hero ── */
    .au-hero-grid { display: grid; grid-template-columns: 1.05fr 0.95fr; gap: 48px; align-items: center; }
    .au-hero-title { font-size: clamp(2.2rem, 5vw, 3.4rem); }
    .co-root .au-hero-lead { margin-top: 18px; max-width: 52ch; font-size: 1.075rem; line-height: 1.65; color: var(--muted); }
    .au-hero-lead strong { color: var(--ink); font-weight: 600; }
    .au-hero-btns { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 28px; }
    .au-hero-btns .co-btn i { transition: transform .18s ease-out; }
    .au-hero-btns .co-btn:hover i { transform: translateY(2px); }
    .co-root .au-hero-loc { margin-top: 22px; font-size: 13.5px; display: inline-flex; align-items: center; gap: 6px; }
    .au-hero-loc i { color: var(--accent); }

    /* ── Media (illustration cadrée) ── */
    .au-hero-media { position: relative; }
    .au-shot { position: relative; background: var(--surface); border: 1px solid var(--line-2); padding: 14px; }
    .au-shot-img { display: block; width: 100%; height: auto; }
    .au-badge-float { position: absolute; bottom: -16px; right: -14px; z-index: 4; background: var(--accent); border: 1px solid var(--accent); color: #fff; padding: 8px 14px; font-size: 13px; font-weight: 600; }
    .au-method-media { margin-top: 32px; max-width: 760px; }

    /* ── Cartes génériques (problèmes / résultats / tech / secteurs) ── */
    .au-grid { display: grid; gap: 16px; margin-top: 32px; }
    .au-grid--2 { grid-template-columns: repeat(2, 1fr); }
    .au-grid--3 { grid-template-columns: repeat(3, 1fr); }
    .au-card {
        position: relative; display: flex; flex-direction: column; gap: 10px; padding: 24px;
        background: var(--surface); border: 1px solid var(--line-2);
        transition: box-shadow .18s ease-out, transform .18s ease-out;
    }
    .au-card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(20,22,26,.07); }
    .au-card-icon { font-size: 24px; color: var(--accent); line-height: 1; }
    .au-card-title { font-size: 1.1rem; display: flex; align-items: center; gap: 8px; }
    .au-inline-icon { color: var(--accent); font-size: 20px; flex: none; }
    .au-card-text { font-size: 14px; line-height: 1.55; color: var(--muted); }
    .co-root .au-card-extra { margin-top: 2px; font-size: 13.5px; font-style: italic; color: var(--muted); }

    /* ── Notes / callouts ── */
    .au-note { display: flex; align-items: flex-start; gap: 12px; margin-top: 20px; padding: 18px 22px; border: 1px solid var(--line-2); background: var(--surface); }
    .au-note > i { color: var(--accent); font-size: 20px; flex: none; margin-top: 1px; }
    .au-note-stack { display: flex; flex-direction: column; gap: 8px; }
    .co-root .au-note p { font-size: 14.5px; line-height: 1.6; color: var(--muted); }
    .au-note--accent { border-color: var(--accent); background: rgba(0,168,125,0.05); }
    .au-note-inline { margin-top: 14px !important; font-size: 14px; line-height: 1.6; color: var(--muted); }
    .au-inline { color: var(--accent); text-decoration: underline; text-underline-offset: 2px; font-weight: 500; }
    .au-inline:hover { color: var(--ink); }
    .au-note strong, .au-note-inline strong { color: var(--ink); font-weight: 600; }

    /* ── Étapes méthode ── */
    .au-steps { display: flex; flex-direction: column; margin-top: 32px; border-top: 1px solid var(--line); }
    .au-step { display: grid; grid-template-columns: 56px 1fr; gap: 20px; padding: 22px 0; border-bottom: 1px solid var(--line); }
    .au-step-num { font-size: 20px; font-weight: 600; }
    .au-step-title { font-size: 1.15rem; }
    .co-root .au-step-text { margin-top: 6px; font-size: 14.5px; line-height: 1.55; color: var(--muted); max-width: 68ch; }
