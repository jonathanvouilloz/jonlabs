    .co-root .au-cmp-concl { margin-top: 22px; padding-top: 18px; border-top: 1px solid var(--line); font-size: 14px; line-height: 1.6; color: var(--muted); text-align: center; }
    .au-cmp-concl strong { color: var(--ink); }

    /* ── Stats / figures ── */
    .au-stats { position: relative; margin-top: 28px; padding: 30px 32px; background: var(--surface); border: 1px solid var(--line-2); }
    .au-stats-title { font-size: 1.1rem; display: inline-flex; align-items: center; gap: 8px; }
    .au-stats-title i { color: var(--accent); }
