</style>

<script>
    // Form submission — HARD-PRESERVE (câblage Web3Forms inchangé, id automatisation-form)
    const form = document.getElementById('automatisation-form') as HTMLFormElement;
    const submitBtn = form?.querySelector('.submit-btn') as HTMLButtonElement;

    form?.addEventListener('submit', async (e) => {
        e.preventDefault();

        if (!submitBtn) return;

        submitBtn.classList.add('loading');
        submitBtn.disabled = true;
        const originalContent = submitBtn.innerHTML;
        submitBtn.innerHTML = '<span>Envoi en cours...</span><i class="ri-loader-4-line"></i>';

        try {
            const formData = new FormData(form);
            const response = await fetch('https://api.web3forms.com/submit', {
                method: 'POST',
                body: formData
            });

            const data = await response.json();

            if (data.success) {
                submitBtn.innerHTML = '<span>Message envoyé !</span><i class="ri-check-line"></i>';
                submitBtn.classList.remove('loading');
                setTimeout(() => {
                    form.reset();
                    submitBtn.innerHTML = originalContent;
                    submitBtn.disabled = false;
                }, 3000);
            } else {
                throw new Error('Erreur lors de l\'envoi');
            }
        } catch (error) {
            submitBtn.innerHTML = '<span>Erreur, réessayez</span><i class="ri-error-warning-line"></i>';
            submitBtn.classList.remove('loading');
            submitBtn.disabled = false;
            setTimeout(() => {
                submitBtn.innerHTML = originalContent;
            }, 3000);
        }
    });
</script>
