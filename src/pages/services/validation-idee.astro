---
// Validation d'idée / test de concept — sous-page service (blueprint).
// Migrée du brutaliste vers le design system .co-* : sections cadrées, filets fins,
// accent teal unique, Inter Tight × Instrument Serif. Namespace .vi-*.
//
// PARTICULARITÉ : cette page N'A PAS de formulaire Web3Forms. Elle CTA vers
// cal.com (appel découverte) et /contact (devis). CTA final = primitive .co-cta.
//
// HARD-PRESERVE : Schema.org (serviceSchemas/breadcrumb/FAQ + ordre), robots noindex,
// prix exacts (750 – 1'500 CHF · 150 – 200 CHF · 2 semaines · dès 750 CHF), liens
// internes (/blog/valide-idee-business-suisse, /contact, cal.com), copywriting réel.

import '../../styles/global.css';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

// Schema.org
import { serviceSchemas, SITE_URL } from '../../data/schema';
import { getBreadcrumbSchema, getFAQPageSchema } from '../../lib/seo';

// SEO Data
const seoData = {
    title: "Test de concept et validation d'idée | Jon Labs Genève",
    description: "Vérifiez que votre idée intéresse le marché avant d'investir. Landing page + campagne ciblée + analyse. Réponse en 2 semaines. Basé à Genève."
};

// Schema.org data
const breadcrumb = getBreadcrumbSchema([
    { name: "Accueil", url: SITE_URL },
    { name: "Services", url: `${SITE_URL}/services` },
    { name: "Validation d'idée", url: `${SITE_URL}/services/validation-idee` }
]);
const schemas: any[] = [serviceSchemas["validation-idee"], breadcrumb];

// Pain points data
const painPoints = [
    {
        icon: "ri-time-line",
        title: "\"J'ai investi 3 mois sur un projet... que personne ne voulait.\"",
        description: "L'histoire classique : on construit dans son coin, on peaufine, on lance — et le marché s'en fiche. Le problème n'est pas l'exécution. C'est l'absence de validation."
    },
    {
        icon: "ri-emotion-normal-line",
        title: "\"Je ne sais pas si mon idée plaît vraiment ou si mes proches sont juste polis.\"",
        description: "Les retours de l'entourage sont biaisés par nature. Seuls des inconnus qui n'ont aucune raison de vous faire plaisir peuvent donner une réponse honnête."
    },
    {
        icon: "ri-hourglass-line",
        title: "\"On n'a pas le temps en interne de monter un test propre.\"",
        description: "Configurer une landing page, paramétrer une campagne pub, analyser les résultats... Ça demande des compétences spécifiques et du temps que vous n'avez pas."
    },
    {
        icon: "ri-scales-3-line",
        title: "\"Créer une Sàrl pour tester ? Trop risqué.\"",
        description: "20'000 CHF de capital, des frais de notaire, des mois de paperasse — pour découvrir ensuite que le marché n'existe pas. Il y a une autre façon de faire."
    }
];

// Method phases
const methodPhases = [
    {
        phase: "1",
        title: "Le signal faible",
        description: "On commence avec une landing page minimaliste — un \"coming soon\" bien présenté. On lance une première campagne ciblée. L'objectif : vérifier que le sujet attire l'attention. Si personne ne clique, inutile d'aller plus loin. Vous avez votre réponse."
    },
    {
        phase: "2",
        title: "L'intérêt confirmé",
        description: "Si la phase 1 fonctionne, on étoffe la page avec votre proposition de valeur et un formulaire d'inscription. On affine le ciblage avec des audiences similaires (lookalike). L'objectif : voir si des gens veulent en savoir plus, pas juste cliquer par curiosité."
    },
    {
        phase: "3",
        title: "L'intention d'achat",
        description: "Si la phase 2 confirme l'intérêt, on construit une landing complète avec un appel à l'action engageant — pré-commande, réservation, demande de devis. C'est le test ultime : est-ce que des inconnus sont prêts à passer à l'action ?"
    }
];

// Process steps
const processSteps = [
    {
        step: "1",
        title: "Échange initial",
        description: "On clarifie votre idée, votre cible, et ce que \"succès\" signifie pour vous. Je vous dis honnêtement si le test fait sens — ou s'il vaut mieux affiner le concept d'abord.",
        duration: "30 min (gratuit)"
    },
    {
        step: "2",
        title: "Création de la landing page",
        description: "Pas un template générique. Du copywriting stratégique pensé pour votre offre, un design soigné, une page optimisée pour la conversion. Le wording compte autant que le visuel.",
        duration: "3-5 jours"
    },
    {
        step: "3",
        title: "Configuration de la campagne",
        description: "Ciblage précis sur Meta Ads (Facebook/Instagram). On définit ensemble les audiences pertinentes, le budget est maîtrisé, et on peut cibler géographiquement si votre offre est locale.",
        duration: "1-2 jours"
    },
    {
        step: "4",
        title: "Analyse et rapport",
        description: "Données concrètes : visiteurs, taux de clic, inscriptions ou conversions. Pas des opinions — des chiffres. Plus un appel de debrief pour interpréter ensemble ce que ça signifie pour votre projet.",
        duration: "À la fin du test"
    }
];

// Differentiators
const differentiators = [
    { icon: "ri-edit-line", title: "Copywriting qui convertit", description: "Pas juste une \"jolie page\" : du wording pensé pour convertir." },
    { icon: "ri-stack-line", title: "Méthode itérative", description: "On teste par étapes, pas tout d'un coup." },
    { icon: "ri-key-line", title: "La page vous appartient", description: "Vous repartez avec la landing page — elle est à vous." },
    { icon: "ri-timer-line", title: "Réponse en 2 semaines", description: "Une réponse du marché en 2 semaines, pas 2 mois." }
];

// Results
const results = [
    {
        icon: "ri-window-line",
        title: "Une landing page professionnelle",
        description: "Wording précis, design soigné, hébergée et fonctionnelle. Elle vous appartient après le test."
    },
    {
        icon: "ri-megaphone-line",
        title: "Une campagne Meta Ads configurée",
        description: "Ciblage affiné, budget optimisé, audiences testées. Vous gardez le contrôle sur les dépenses."
    },
    {
        icon: "ri-bar-chart-box-line",
        title: "Un rapport avec métriques concrètes",
        description: "Visiteurs, clics, taux de conversion — des chiffres, pas des opinions."
    },
    {
        icon: "ri-phone-line",
        title: "Un appel de debrief",
        description: "On analyse ensemble ce que les données signifient. Faut-il pivoter ? Continuer ? Affiner le message ?"
    },
    {
        icon: "ri-checkbox-circle-line",
        title: "Une réponse claire en 2 semaines",
        description: "Ça mord, ou pas. Vous savez si vous devez continuer à investir."
    }
];

// Pricing
const pricing = {
    prestation: "750 – 1'500 CHF",
    budget_pub: "150 – 200 CHF",
    delai: "2 semaines"
};

// FAQs
const faqs = [
    {
        question: "Quel budget pub faut-il prévoir ?",
        answer: "Entre 150 et 200 CHF suffisent généralement pour un premier test significatif. Ce budget est payé directement à Meta (Facebook/Instagram), pas à moi. C'est vous qui contrôlez les dépenses, et on peut ajuster en cours de route."
    },
    {
        question: "Que se passe-t-il si le test est négatif ?",
        answer: "C'est une bonne nouvelle, pas une mauvaise. Vous venez d'économiser des semaines — voire des mois — de travail sur une idée qui n'aurait pas fonctionné. On peut discuter ensemble de comment pivoter ou affiner le concept. Parfois, c'est juste le message qui ne passait pas, pas l'idée elle-même."
    },
    {
        question: "La landing page m'appartient-elle après le test ?",
        answer: "Oui. Elle reste à vous. Vous pouvez continuer à l'utiliser, la modifier, ou la faire évoluer vers un vrai site si le test est positif. Pas de dépendance, pas d'abonnement caché."
    },
    {
        question: "Je n'ai pas encore de structure juridique, c'est un problème ?",
        answer: "Non. En Suisse, vous pouvez facturer jusqu'à 100'000 CHF par an en Raison Individuelle sans même créer de Sàrl. Le test de concept sert justement à valider AVANT d'investir dans une structure.",
        linkText: "En savoir plus sur la validation sans créer de Sàrl",
        linkUrl: "/blog/valide-idee-business-suisse"
    },
    {
        question: "Quels types d'idées peut-on tester ?",
        answer: "Pratiquement tout : un nouveau service, un produit physique ou digital, une formation, une app, un SaaS, une offre de consulting... Si ça peut s'expliquer sur une page et intéresser une audience ciblable sur les réseaux sociaux, on peut tester."
    },
    {
        question: "Comment je sais si mon idée est \"testable\" ?",
        answer: "On en discute lors du premier échange. Si votre idée est trop floue, si le marché est impossible à cibler précisément, ou si le test n'apporterait pas de réponse claire, je vous le dirai — et je vous aiderai à affiner avant de dépenser quoi que ce soit."
    },
    {
        question: "Pourquoi Meta Ads et pas Google Ads ?",
        answer: "Meta Ads permet de cibler des gens qui ne cherchent pas encore activement votre solution — c'est idéal pour tester une idée nouvelle. Google Ads fonctionne mieux quand les gens savent déjà ce qu'ils cherchent. Pour la validation de concept, Meta est généralement plus pertinent. Mais si votre offre répond à une recherche claire, on peut combiner les deux."
    },
    {
        question: "Et si le test est positif, vous pouvez développer la suite ?",
        answer: "Oui. Si votre idée est validée et que vous voulez passer à un vrai site ou une application, on peut en discuter. Mais ce n'est pas une obligation — le test est un service autonome, vous êtes libre de continuer avec qui vous voulez."
    }
];
schemas.push(getFAQPageSchema(faqs));

// Local zones
const zones = [
    { name: "Genève", type: "primary", icon: "ri-map-pin-fill" },
    { name: "Lausanne", type: "secondary", icon: "ri-map-pin-line" },
    { name: "Vaud", type: "secondary", icon: "ri-map-pin-line" },
    { name: "Toute la Suisse romande", type: "tertiary", icon: "ri-global-line" }
];
---

<Layout
    title={seoData.title}
    description={seoData.description}
    schemas={schemas}
    robots="noindex, follow"
>
    <Header />

    <main class="co-root">

        <!-- ══ HERO ══ -->
        <section class="co-sec co-pad co-hero vi-hero" style="padding:64px 40px 56px;">
            <div class="vi-hero-grid">
                <div class="vi-hero-copy">
                    <h1 class="vi-hero-title" data-animate data-delay="0.1">
                        Votre idée vaut-elle le coup ? Réponse en <span class="co-ser">2 semaines.</span>
                    </h1>
                    <p class="vi-hero-lead" data-animate data-delay="0.2">
                        Avant d'investir des mois de développement, vérifiez que des gens sont prêts à payer.
                        <strong>Une landing page stratégique, une campagne ciblée, des chiffres concrets.</strong>
                    </p>
                    <div class="vi-hero-btns" data-animate data-delay="0.3">
                        <a href="https://cal.com/jonathan-vouilloz/appel-de-bienvenue" target="_blank" rel="noopener noreferrer" class="co-btn"><i class="ri-rocket-line"></i> Tester mon idée</a>
                        <a href="#methode" class="co-btn co-btn--ghost">Voir comment ça fonctionne <i class="ri-arrow-down-line"></i></a>
                    </div>
                    <p class="vi-hero-loc co-mut" data-animate data-delay="0.4">
                        <i class="ri-map-pin-fill"></i> Basé à Genève · Service en Suisse romande
                    </p>
                </div>

                <div class="vi-hero-media" data-animate="scale" data-delay="0.3">
                    <div class="vi-flow co-frame">
                        <span class="co-x tl"></span><span class="co-x tr"></span>
                        <span class="co-x bl"></span><span class="co-x br"></span>
                        <div class="vi-flow-node">
                            <i class="ri-lightbulb-line" aria-hidden="true"></i>
                            <span>Votre idée</span>
                        </div>
                        <i class="ri-arrow-right-line vi-flow-arrow" aria-hidden="true"></i>
                        <div class="vi-flow-node">
                            <i class="ri-flask-line" aria-hidden="true"></i>
                            <span>Test marché</span>
                        </div>
                        <i class="ri-arrow-right-line vi-flow-arrow" aria-hidden="true"></i>
                        <div class="vi-flow-node">
                            <i class="ri-check-double-line" aria-hidden="true"></i>
                            <span>Réponse claire</span>
                        </div>
                    </div>
                    <div class="vi-badge vi-badge--delai"><b>2 sem.</b><span>Réponse</span></div>
                    <div class="vi-badge vi-badge--prix">dès 750 CHF</div>
                </div>
            </div>
        </section>

        <!-- ══ 01 · PROBLÈMES ══ -->
        <section id="problemes" class="co-sec co-pad" style="padding:56px 40px;">
            <p class="co-eyebrow">01 — Problèmes</p>
            <h2 style="margin-top:8px;">Vous vous <span class="co-ser">reconnaissez ?</span></h2>
            <p class="co-mut" style="margin-top:10px;max-width:56ch;line-height:1.6;">
                Ces situations sont plus courantes qu'on ne le croit.
            </p>

            <div class="vi-grid vi-grid--2" data-animate-stagger>
                {painPoints.map((point) => (
                    <div class="vi-card co-frame co-frame--reveal" data-animate-item>
                        <i class={`${point.icon} vi-card-icon`} aria-hidden="true"></i>
                        <h3 class="vi-card-title">{point.title}</h3>
                        <p class="vi-card-text">{point.description}</p>
                    </div>
                ))}
            </div>

            <div class="vi-note vi-note--accent" data-animate>
                <i class="ri-lightbulb-line"></i>
                <p><strong>La bonne nouvelle :</strong> vous pouvez avoir une réponse du marché avant d'investir sérieusement.</p>
            </div>
        </section>

        <!-- ══ 02 · MÉTHODE ══ -->
        <section id="methode" class="co-sec co-pad" style="padding:56px 40px;">
            <p class="co-eyebrow">02 — Méthode</p>
            <h2 style="margin-top:8px;">Comment ça se passe ?</h2>
            <p class="co-mut" style="margin-top:10px;max-width:60ch;line-height:1.6;">
                Une approche itérative qui minimise le risque et maximise l'apprentissage.
            </p>

            <!-- 3 phases -->
            <h3 class="vi-sub" style="margin-top:36px;">La méthode en 3 phases</h3>
            <p class="co-mut" style="margin-top:8px;max-width:64ch;line-height:1.6;">
                La plupart des prestataires vous livrent une landing page et vous souhaitent bonne chance.
                Ici, je procède par étapes — chaque phase nous apprend quelque chose avant de passer à la suivante.
            </p>

            <div class="vi-grid vi-grid--3" data-animate-stagger>
                {methodPhases.map((phase) => (
                    <div class="vi-card vi-card--phase co-frame co-frame--reveal" data-animate-item>
                        <span class="co-badge co-badge--solid">Phase {phase.phase}</span>
                        <h4 class="vi-card-title">{phase.title}</h4>
                        <p class="vi-card-text">{phase.description}</p>
                    </div>
                ))}
            </div>

            <div class="vi-note" data-animate>
                <i class="ri-information-line"></i>
                <p><strong>Pourquoi cette méthode ?</strong> À chaque phase, on affine le ciblage et le message. Si ça ne mord pas en phase 1, inutile de construire une landing complète. Vous économisez du temps et de l'argent. Et si ça fonctionne, vous avez des données solides pour continuer en confiance.</p>
            </div>

            <!-- Processus concret -->
            <h3 class="vi-sub" style="margin-top:44px;">Le processus concret</h3>
            <div class="vi-steps" data-animate-stagger>
                {processSteps.map((step, index) => (
                    <div class="vi-step" data-animate-item>
                        <span class="vi-step-num co-index">0{index + 1}</span>
                        <div class="vi-step-body">
                            <h4 class="vi-step-title">{step.title}</h4>
                            <p class="vi-step-text">{step.description}</p>
                            <p class="vi-step-dur"><i class="ri-time-line"></i> {step.duration}</p>
                        </div>
                    </div>
                ))}
            </div>

            <!-- Différenciateurs -->
            <div class="vi-diff co-frame" data-animate>
                <span class="co-x tl"></span><span class="co-x tr"></span>
                <span class="co-x bl"></span><span class="co-x br"></span>
                <h3 class="vi-diff-title">Ce qui change avec Jon Labs</h3>
                <div class="vi-diff-grid">
                    {differentiators.map((diff) => (
                        <div class="vi-diff-item">
                            <i class={`${diff.icon} vi-diff-icon`} aria-hidden="true"></i>
                            <h4 class="vi-diff-name">{diff.title}</h4>
                            <p class="vi-diff-desc">{diff.description}</p>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <!-- ══ 03 · RÉSULTATS ══ -->
        <section id="resultats" class="co-sec co-pad" style="padding:56px 40px;">
            <p class="co-eyebrow">03 — Résultats</p>
            <h2 style="margin-top:8px;">Ce que vous <span class="co-ser">obtenez.</span></h2>

            <div class="vi-grid vi-grid--3" data-animate-stagger>
                {results.map((result) => (
                    <div class="vi-card co-frame co-frame--reveal" data-animate-item>
                        <i class={`${result.icon} vi-card-icon`} aria-hidden="true"></i>
                        <h3 class="vi-card-title">{result.title}</h3>
                        <p class="vi-card-text">{result.description}</p>
                    </div>
                ))}
            </div>
        </section>

        <!-- ══ 04 · HISTOIRE (pourquoi ce service) ══ -->
        <section id="histoire" class="co-sec co-pad" style="padding:56px 40px;">
            <p class="co-eyebrow">04 — Pourquoi ce service</p>
            <h2 style="margin-top:8px;">Pourquoi je propose ce service</h2>

            <div class="vi-story co-frame" data-animate>
                <span class="co-x tl"></span><span class="co-x tr"></span>
                <span class="co-x bl"></span><span class="co-x br"></span>
                <div class="vi-story-body">
                    <p class="vi-story-lead">J'ai fait l'erreur que vous voulez éviter.</p>
                    <p>Avec un associé, on a passé un mois entier à développer une plateforme de vente de contenu digital. Le concept : permettre à n'importe qui de vendre du contenu instantanément. Tu uploades ton fichier, tu choisis ton prix, tu partages le lien. Le destinataire paie, il accède au contenu.</p>
                    <p>L'UX était nickel. Le produit était "parfait".</p>
                    <p><strong>Sauf qu'on n'avait jamais vérifié que quelqu'un voulait payer pour ça.</strong></p>
                    <p>Quand on a enfin montré le produit au monde, le marché s'en fichait. Les gens qu'on ciblait avaient déjà leurs solutions. Le problème qu'on résolvait n'était pas assez douloureux pour qu'ils changent leurs habitudes.</p>
                    <p>Un mois de travail. Des nuits blanches. Un produit qui n'existe plus aujourd'hui.</p>
                    <blockquote class="vi-story-quote">
                        Si on avait fait une landing page en 2 jours et dépensé 200 CHF de pub, on aurait su en une semaine que l'idée ne tenait pas.
                    </blockquote>
                    <p>C'est pour ça que je propose ce service. Pour vous éviter cette erreur.</p>
                </div>
                <p class="vi-note-inline vi-story-link">
                    <a href="/blog/valide-idee-business-suisse" class="vi-inline">
                        <i class="ri-article-line"></i> Lire l'histoire complète et la méthode du smoke test <i class="ri-arrow-right-line"></i>
                    </a>
                </p>
            </div>
        </section>

        <!-- ══ 05 · PRIX ══ -->
        <section id="prix" class="co-sec co-pad" style="padding:56px 40px;">
            <p class="co-eyebrow">05 — Investissement</p>
            <h2 style="margin-top:8px;">Un test qui coûte moins cher qu'un mois de <span class="co-ser">développement raté.</span></h2>

            <div class="vi-price co-frame" data-animate>
                <span class="co-x tl"></span><span class="co-x tr"></span>
                <span class="co-x bl"></span><span class="co-x br"></span>
                <div class="vi-price-grid">
                    <div class="vi-price-item">
                        <span class="vi-price-label">Prestation complète</span>
                        <b class="vi-price-value">{pricing.prestation}</b>
                    </div>
                    <div class="vi-price-item">
                        <span class="vi-price-label">Budget pub recommandé</span>
                        <b class="vi-price-value">{pricing.budget_pub}</b>
                        <span class="vi-price-sub">(payé directement à Meta)</span>
                    </div>
                    <div class="vi-price-item">
                        <span class="vi-price-label">Délai</span>
                        <b class="vi-price-value">{pricing.delai}</b>
                    </div>
                </div>
            </div>

            <div class="vi-pricenote co-frame" data-animate>
                <span class="co-x tl"></span><span class="co-x tr"></span>
                <span class="co-x bl"></span><span class="co-x br"></span>
                <h3 class="vi-pricenote-title"><i class="ri-information-line"></i> Ce qui influence le prix</h3>
                <ul class="co-list vi-pricenote-list">
                    <li>La complexité de l'offre à présenter</li>
                    <li>Le nombre de variantes à tester</li>
                    <li>Le niveau de design requis</li>
                </ul>
                <p class="vi-note-inline"><i class="ri-bank-card-line"></i> <strong>Paiement échelonné possible</strong> — on en discute selon votre situation.</p>
            </div>

            <div class="vi-price-cta" data-animate>
                <p class="co-mut" style="max-width:60ch;line-height:1.6;">
                    Premier échange gratuit et sans engagement. On parle de votre idée, je vous dis honnêtement si ce service fait sens pour vous.
                </p>
                <a href="/contact" class="co-btn"><i class="ri-file-list-3-line"></i> Demander un devis personnalisé</a>
            </div>
        </section>

        <!-- ══ 06 · FAQ (accordéon natif <details>, zéro JS) ══ -->
        <section id="faq" class="co-sec co-pad" style="padding:56px 40px;">
            <p class="co-eyebrow">06 — FAQ</p>
            <h2 style="margin-top:8px;">Questions fréquentes</h2>

            <div class="vi-faq" style="margin-top:32px;">
                {faqs.map((faq, index) => (
                    <details open={index === 0}>
                        <summary>
                            {faq.question}
                            <i class="ri-arrow-down-s-line" aria-hidden="true"></i>
                        </summary>
                        <p class="vi-faq-answer">
                            {faq.answer}
                            {faq.linkUrl && (
                                <><br /><a href={faq.linkUrl} class="vi-inline">{faq.linkText} <i class="ri-arrow-right-line"></i></a></>
                            )}
                        </p>
                    </details>
                ))}
            </div>

            <p class="co-mut" style="margin-top:24px;text-align:center;">
                Autre question ? <a href="/contact" class="vi-inline">Contactez-moi directement</a>, je réponds sous 24h.
            </p>
        </section>

        <!-- ══ 07 · LOCAL ══ -->
        <section id="local" class="co-sec co-pad" style="padding:56px 40px;">
            <p class="co-eyebrow">07 — Local</p>
            <h2 style="margin-top:8px;">Basé à <span class="co-ser">Genève</span>, disponible partout en Suisse romande</h2>

            <div class="vi-local-grid">
                <div class="vi-local-copy" data-animate="fade-left">
                    <p>Le test de concept se fait entièrement à distance — l'échange initial, le suivi, le debrief, tout peut se faire en visio. C'est souvent plus efficace.</p>
                    <p>Mais si vous préférez un échange en personne pour le kickoff ou le debrief, je suis disponible sur Genève et ses environs.</p>
