    }
    .rf-card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(20,22,26,.07); }
    .rf-card-icon { font-size: 24px; color: var(--accent); line-height: 1; }
    .rf-card-title { font-size: 1.1rem; }
    .rf-card-text { font-size: 14px; line-height: 1.55; color: var(--muted); }
    .rf-card--tech { text-align: center; align-items: center; gap: 8px; }
    .co-root .rf-card-eyebrow { font-size: 12.5px; color: var(--muted); }
    .rf-card-tag { margin-top: auto; padding-top: 4px; font-size: 12.5px; font-weight: 600; color: var(--accent); display: inline-flex; align-items: center; gap: 5px; }

    /* ── Notes / callouts ── */
    .rf-note { display: flex; align-items: flex-start; gap: 12px; margin-top: 20px; padding: 18px 22px; border: 1px solid var(--line-2); background: var(--surface); }
    .rf-note i { color: var(--accent); font-size: 20px; flex: none; margin-top: 1px; }
