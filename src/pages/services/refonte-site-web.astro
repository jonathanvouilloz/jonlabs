    .rf-hero-btns { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 28px; }
    .rf-hero-btns .co-btn i { transition: transform .18s ease-out; }
    .rf-hero-btns .co-btn:hover i { transform: translateX(2px); }
    .co-root .rf-hero-loc { margin-top: 22px; font-size: 13.5px; display: inline-flex; align-items: center; gap: 6px; }
    .rf-hero-loc i { color: var(--accent); }

    /* browser mockup */
    .rf-hero-media { position: relative; }
    .rf-browser { position: relative; background: var(--surface); border: 1px solid var(--line-2); }
    .rf-browser-bar { display: flex; align-items: center; gap: 8px; padding: 11px 14px; border-bottom: 1px solid var(--line); background: var(--bg); }
    .rf-browser-dot { width: 9px; height: 9px; border-radius: 999px; background: var(--line-2); flex: none; }
    .rf-browser-url { flex: 1; text-align: center; font-size: 12px; color: var(--muted); font-variant-numeric: tabular-nums; }
    .rf-browser-img { display: block; width: 100%; height: auto; }
    .rf-badge { position: absolute; z-index: 4; background: var(--surface); border: 1px solid var(--line-2); padding: 8px 12px; font-size: 12px; font-weight: 600; }
    .rf-badge--score { top: -16px; left: -14px; display: flex; flex-direction: column; line-height: 1.1; }
    .rf-badge--score b { color: var(--accent); font-size: 15px; }
    .rf-badge--score span { color: var(--muted); font-size: 10px; text-transform: uppercase; letter-spacing: 0.08em; }
    .rf-badge--speed { bottom: -16px; right: -14px; background: var(--accent); border-color: var(--accent); color: #fff; }

    /* ── Cartes génériques (problèmes / tech) ── */
    .rf-grid { display: grid; gap: 16px; margin-top: 32px; }
    .rf-grid--2 { grid-template-columns: repeat(2, 1fr); }
    .rf-grid--3 { grid-template-columns: repeat(3, 1fr); }
    .rf-card {
        position: relative; display: flex; flex-direction: column; gap: 10px; padding: 24px;
        background: var(--surface); border: 1px solid var(--line-2);
