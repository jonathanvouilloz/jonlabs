    @keyframes rfSpin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }

    /* ── Après-formulaire ── */
    .rf-form-after { margin-top: 28px; display: flex; flex-direction: column; gap: 18px; align-items: center; text-align: center; }
    .rf-trust { display: flex; flex-wrap: wrap; justify-content: center; gap: 24px; font-size: 13.5px; color: var(--muted); }
