    .rf-price-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; align-items: start; margin-top: 36px; }
    .rf-pricecard { position: relative; padding: 30px 28px; background: var(--surface); border: 1px solid var(--line-2); }
