    .rf-local-name { font-size: 15px; font-weight: 600; }
    .co-root .rf-local-desc { margin-top: 3px; font-size: 13.5px; line-height: 1.5; color: var(--muted); }
    .rf-zones { display: flex; flex-direction: column; gap: 10px; }
    .rf-zone { display: flex; align-items: center; gap: 12px; padding: 14px 16px; background: var(--surface); border: 1px solid var(--line-2); font-size: 14px; }
    .rf-zone i { color: var(--muted); font-size: 18px; flex: none; }
    .rf-zone--primary { border-color: var(--accent); background: rgba(0,168,125,0.05); }
    .rf-zone--primary i { color: var(--accent); }

    /* ── Ressources ── */
    .rf-res { position: relative; padding: 24px; background: var(--surface); border: 1px solid var(--line-2); }
    .rf-res-head { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; }
    .rf-res-icon { font-size: 22px; color: var(--accent); flex: none; }
    .rf-res-label { font-size: 1.05rem; }
    .rf-res-list { display: flex; flex-direction: column; gap: 8px; }
    .rf-res-link { display: flex; align-items: flex-start; gap: 8px; font-size: 14px; color: var(--muted); transition: color .18s ease-out; }
    .rf-res-link i { color: var(--accent); margin-top: 2px; transition: transform .18s ease-out; }
    .rf-res-link:hover { color: var(--ink); }
    .rf-res-link:hover i { transform: translateX(3px); }

    /* ── Options (avant formulaire) ── */
    .rf-options { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 32px; }
    .rf-option { position: relative; display: flex; flex-direction: column; gap: 8px; padding: 24px; text-align: center; align-items: center; background: var(--surface); border: 1px solid var(--line-2); }
    .rf-option-icon { font-size: 26px; color: var(--accent); }
    .rf-option-title { font-size: 1.1rem; }
    .rf-option-text { font-size: 14px; line-height: 1.55; color: var(--muted); }

    /* ── Formulaire (Web3Forms restylé, câblage préservé) ── */
    .rf-form { position: relative; margin-top: 24px; padding: 34px; background: var(--surface); border: 1px solid var(--line-2); }
    .rf-form-title { font-size: 1.25rem; text-align: center; margin-bottom: 6px; }
    .rf-form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 24px; }
    .rf-field { display: flex; flex-direction: column; gap: 8px; }
    .rf-field--full { grid-column: 1 / -1; }
    .rf-label { display: flex; align-items: baseline; gap: 8px; font-size: 13px; font-weight: 600; color: var(--ink); }
    .rf-label .co-index { font-size: 11px; }
    .rf-req { color: var(--accent); }
    .rf-input, .rf-textarea {
        width: 100%; font-family: "Inter Tight", ui-sans-serif, sans-serif; font-size: 15px; color: var(--ink);
        background: var(--bg); border: 1px solid var(--line-2); padding: 12px 14px;
        transition: border-color .18s ease-out, box-shadow .18s ease-out;
    }
    .rf-input::placeholder, .rf-textarea::placeholder { color: var(--muted); opacity: .7; }
    .rf-input:focus, .rf-textarea:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 3px rgba(0,168,125,.15); }
