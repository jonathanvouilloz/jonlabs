</Layout>

<style is:global>
    /* ══ REFONTE SITE WEB — styles .rf-* (namespace scopé, corps .co-root) ══ */

    /* ── Hero ── */
    .rf-hero-grid { display: grid; grid-template-columns: 1.05fr 0.95fr; gap: 48px; align-items: center; }
    .rf-hero-title { font-size: clamp(2.2rem, 5vw, 3.4rem); }
