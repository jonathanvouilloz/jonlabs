---
import '../../styles/global.css';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

// Import background components
import BackgroundGlitchGrid from '../../components/backgrounds/BackgroundGlitchGrid.astro';
import BackgroundProgressFlow from '../../components/backgrounds/BackgroundProgressFlow.astro';
import BackgroundCircuitBoard from '../../components/backgrounds/BackgroundCircuitBoard.astro';
import BackgroundQuestionMarks from '../../components/backgrounds/BackgroundQuestionMarks.astro';
import BackgroundMapContours from '../../components/backgrounds/BackgroundMapContours.astro';

// Schema.org
import { serviceSchemas, SITE_URL } from '../../data/schema';
import { getBreadcrumbSchema, getFAQPageSchema } from '../../lib/seo';

// SEO Data
const seoData = {
    title: "Référencement local SEO à Genève | Jon Labs",
    description: "Passez de invisible à #1 sur Google. Stratégie SEO local pour PME à Genève et Suisse romande. Cas réel : position #1 en 5 mois. Audit gratuit."
};

// Schema.org data
const breadcrumb = getBreadcrumbSchema([
    { name: "Accueil", url: SITE_URL },
    { name: "Services", url: `${SITE_URL}/services` },
    { name: "Référencement local SEO", url: `${SITE_URL}/services/referencement-local` }
]);
const schemas: any[] = [serviceSchemas["referencement-local"], breadcrumb];

// Pain points data (4 items)
const painPoints = [
    {
        icon: "ri-eye-off-line",
        title: "Invisible sur Google",
        description: "Vos concurrents apparaissent en premier quand quelqu'un cherche votre métier à Genève. Vous, vous êtes en page 3 — autant dire nulle part."
    },
    {
        icon: "ri-money-dollar-circle-line",
        title: "Budget pub qui explose",
        description: "Google Ads vous coûte de plus en plus cher, et dès que vous coupez le budget, plus rien. Vous êtes dépendant sans vraiment voir le retour."
    },
    {
        icon: "ri-question-line",
        title: "Le SEO fait peur",
        description: "Backlinks, maillage interne, Core Web Vitals... Le jargon est incompréhensible. Et à qui faire confiance quand tout le monde promet la lune ?"
    },
    {
        icon: "ri-time-line",
        title: "Pas de temps à y consacrer",
        description: "Vous savez que c'est important, mais entre vos clients et votre activité, le référencement passe toujours en dernier. C'est pas votre métier."
    }
];

// Case study stats
const caseStudyStats = [
    { value: "#1", label: "Position Google", icon: "ri-trophy-line" },
    { value: "20.4k", label: "Impressions", icon: "ri-eye-line" },
    { value: "485", label: "Clics organiques", icon: "ri-cursor-line" },
    { value: "2.4%", label: "CTR moyen", icon: "ri-percent-line" },
    { value: "100/100", label: "Score SEO", icon: "ri-speed-line" },
    { value: "1", label: "Client signé via le site", icon: "ri-user-add-line" }
];

// Methodology steps (4 phases)
const methodSteps = [
    {
        step: "1",
        title: "Audit & Analyse de marché",
        description: "J'analyse votre marché, vos concurrents et les mots-clés que vos clients tapent vraiment. On identifie les opportunités de niche où vous pouvez percer rapidement.",
        duration: "1 semaine"
    },
    {
        step: "2",
        title: "Architecture & Contenu",
        description: "Je structure votre site pour que Google comprenne exactement ce que vous faites et où vous le faites. Pages optimisées, contenu localisé, maillage interne stratégique.",
        duration: "2-3 semaines"
    },
    {
        step: "3",
        title: "Optimisation technique",
        description: "Lighthouse 90+, mobile-first, Schema.org, vitesse de chargement. Tout ce que Google adore, sans que vous ayez à comprendre le jargon technique.",
        duration: "1 semaine"
    },
    {
        step: "4",
        title: "Lancement & Suivi",
        description: "Indexation, Google Business Profile optimisé, rapports mensuels clairs. Vous voyez exactement d'où viennent vos visiteurs et ce qu'ils font.",
        duration: "Continu"
    }
];

// Differentiators
const differentiators = [
    {
        icon: "ri-tools-line",
        title: "Outils gratuits",
        description: "pas de frais d'abonnement cachés, on utilise les outils de Google"
    },
    {
        icon: "ri-bar-chart-box-line",
        title: "Résultats mesurables",
        description: "rapports Google Search Console, pas des métriques inventées"
    },
    {
        icon: "ri-map-pin-line",
        title: "Focus local",
        description: "stratégie pensée pour le marché suisse romand"
    },
    {
        icon: "ri-shield-check-line",
        title: "Transparence totale",
        description: "vous voyez exactement ce qui est fait, pas de boîte noire"
    }
];

// Results (6 items)
const results = [
    {
        icon: "ri-map-pin-2-line",
        title: "Visibilité Google Maps & Search",
        description: "Vos clients vous trouvent quand ils cherchent votre métier dans votre zone. Google Maps, résultats locaux, pack local — vous y êtes."
    },
    {
        icon: "ri-article-line",
        title: "Contenu optimisé qui attire",
        description: "Des pages qui répondent aux vraies questions de vos clients. Pas du contenu générique, du contenu local qui convertit."
    },
    {
        icon: "ri-store-2-line",
        title: "Fiche Google Business optimisée",
        description: "Votre fiche Google complète, à jour, avec les bonnes catégories et les bons mots-clés. Les avis clients bien mis en valeur."
    },
    {
        icon: "ri-line-chart-line",
        title: "Rapports mensuels clairs",
        description: "Positions, impressions, clics, d'où viennent vos visiteurs. Des chiffres réels, pas du jargon. Vous comprenez exactement ce qui se passe."
    },
    {
        icon: "ri-speed-line",
        title: "Site technique impeccable",
        description: "Score Lighthouse 90+, mobile-first, temps de chargement éclair. Les fondations techniques qui font que Google vous fait confiance."
    },
    {
        icon: "ri-route-line",
        title: "Stratégie long terme",
        description: "Pas un coup de peinture SEO. Une stratégie qui construit votre autorité locale mois après mois, avec des résultats durables."
    }
];

// Pricing plans (SEO)
const pricingPlans = [
    {
        name: "Présence",
        price: "1'490",
        priceLabel: "À partir de",
        features: [
            "Audit SEO complet",
            "Optimisation technique du site",
            "Fiche Google Business Profile",
            "Référencement local de base",
            "1 rapport de positionnement"
        ],
        ideal: "Indépendants et petites structures qui veulent poser les bases d'une visibilité locale.",
        highlighted: false
    },
    {
        name: "Visibilité",
        price: "2'490",
        priceLabel: "À partir de",
        features: [
            "Tout ce qui est inclus dans Présence",
            "Stratégie de contenu localisé",
            "Optimisation avancée (Schema.org)",
            "Suivi mensuel des positions",
            "Rapports Google Search Console",
            "Recommandations d'amélioration continues"
        ],
        ideal: "PME qui veulent dominer les résultats locaux et générer des leads via Google.",
        highlighted: true
    },
    {
        name: "Autorité",
        price: "Sur devis",
        priceLabel: "",
        features: [
            "Tout ce qui est inclus dans Visibilité",
            "Stratégie de contenu avancée",
            "Accompagnement SEO mensuel",
            "Veille concurrentielle",
            "Multi-localités si nécessaire"
        ],
        ideal: "Entreprises ambitieuses qui veulent devenir LA référence dans leur secteur en Suisse romande.",
        highlighted: false
    }
];

// SEO approaches
const seoApproaches = [
    {
        icon: "ri-search-eye-line",
        name: "Audit SEO",
        description: "Diagnostic complet de votre visibilité actuelle + plan d'action priorisé. Vous savez exactement où vous en êtes et quoi faire.",
        idealFor: "Comprendre votre situation avant de vous engager"
    },
    {
        icon: "ri-layout-line",
        name: "SEO + Site web",
        description: "Création ou refonte de site avec le SEO intégré dès le jour 1. L'approche la plus efficace : on ne rattrape pas, on part bien.",
        idealFor: "Nouveau site ou refonte nécessaire"
    },
    {
        icon: "ri-refresh-line",
        name: "Accompagnement SEO",
        description: "Suivi mensuel continu : optimisations, contenu, rapports. Le SEO, c'est un marathon, pas un sprint.",
        idealFor: "Site existant, résultats dans la durée"
    }
];

// FAQs (10 questions E-E-A-T)
const faqs = [
    {
        question: "Combien de temps pour voir des résultats ?",
        answer: "En général, les premières améliorations sont visibles en 2-3 mois. Les résultats solides (positions stables, trafic régulier) arrivent entre 4 et 6 mois. Dans le cas de Léo Lécureux, la position #1 a été atteinte en 5 mois dans une niche juridique très concurrentielle. Le SEO est un investissement sur le moyen terme — mais une fois en place, les résultats sont durables."
    },
    {
        question: "Est-ce que ça fonctionne pour mon secteur ?",
        answer: "Le SEO local fonctionne pour tout business qui sert des clients dans une zone géographique : artisans, cabinets, restaurants, commerces, thérapeutes, coachs... Si des gens cherchent votre métier + votre ville sur Google (et ils le font), le SEO local peut vous apporter des clients."
    },
    {
        question: "Quelle différence entre SEO et Google Ads ?",
        answer: "Google Ads, c'est de la pub : vous payez pour chaque clic, et quand vous coupez le budget, vous disparaissez. Le SEO, c'est du référencement naturel : une fois bien positionné, vous restez visible sans payer par clic. L'idéal, c'est souvent de combiner les deux au début, puis de réduire la pub à mesure que le SEO prend le relais."
    },
    {
        question: "J'ai déjà un site, vous pouvez l'optimiser ?",
        answer: "Oui, absolument. Je commence par un audit complet pour identifier les points d'amélioration : technique, contenu, structure. Ensuite, je vous propose un plan d'action priorisé. Parfois quelques ajustements suffisent, parfois une refonte partielle est plus efficace — on en discute ensemble."
    },
    {
        question: "Quels outils utilisez-vous ?",
        answer: "Principalement les outils gratuits de Google : Search Console, Analytics, PageSpeed Insights, Google Business Profile. Pas d'abonnement coûteux à des outils tiers dont vous seriez dépendant. Vous avez accès à tous vos données directement."
    },
    {
        question: "Comment mesurez-vous les résultats ?",
        answer: "Avec des données réelles de Google Search Console : positions sur vos mots-clés cibles, nombre d'impressions, clics, taux de clics (CTR). Pas des métriques inventées ou des scores propriétaires. Vous pouvez vérifier vous-même dans votre compte Google."
    },
    {
        question: "Garantissez-vous la première position ?",
        answer: "Non, et méfiez-vous de quiconque le fait. Google change ses algorithmes régulièrement, et personne ne peut garantir une position précise. Ce que je garantis : une méthodologie éprouvée, des optimisations concrètes, et des rapports transparents. Le cas Lécureux (#1 en 5 mois) montre ce qui est possible, mais chaque marché est différent."
    },
    {
        question: "Pourquoi pas une agence SEO classique ?",
        answer: "Les agences SEO facturent souvent des contrats 12 mois minimum, utilisent des outils coûteux dont vous payez l'abonnement, et sous-traitent le travail technique. Chez moi : un interlocuteur unique qui code ET optimise, des outils gratuits, pas de contrat longue durée, et une connaissance réelle du marché suisse romand."
    },
    {
        question: "C'est quoi le SEO local exactement ?",
        answer: "Le SEO local, c'est l'ensemble des techniques pour apparaître quand quelqu'un cherche un service près de chez lui : « plombier Genève », « avocat divorce Lausanne », « coach sportif Carouge ». Ça inclut votre fiche Google Business, vos avis clients, votre site web optimisé pour votre zone, et les annuaires locaux pertinents. Bonus : un bon SEO local vous rend aussi visible sur les IA comme ChatGPT — j'explique tout dans mon guide sur la visibilité ChatGPT à Genève."
    },
    {
        question: "Est-ce que je peux le faire moi-même ?",
        answer: "Oui, en partie. Les bases (fiche Google Business, contenu de qualité, site rapide) sont faisables seul. La partie technique (Schema.org, audit de crawl, architecture de pages) et la stratégie (analyse concurrentielle, mots-clés de niche) demandent plus d'expertise. Mon audit SEO peut vous donner un plan d'action que vous exécutez vous-même si vous préférez."
    }
];
schemas.push(getFAQPageSchema(faqs));

// Local advantages
const localAdvantages = [
    {
        icon: "ri-user-voice-line",
        title: "Des échanges facilités",
        description: "On peut se voir en personne si besoin. Un café pour discuter du projet, un atelier pour affiner les détails."
    },
    {
        icon: "ri-bar-chart-line",
        title: "La même réalité business",
        description: "Je connais le marché suisse, les attentes des clients locaux, les spécificités légales (LPD, facturation)."
    },
    {
        icon: "ri-time-line",
        title: "Réactivité",
        description: "Même fuseau horaire, même rythme. Une question urgente ? Vous avez une réponse dans la journée."
    },
    {
        icon: "ri-group-line",
        title: "Un réseau local",
        description: "Besoin d'un photographe professionnel ? D'un rédacteur ? Je peux vous recommander des personnes de confiance dans la région."
    }
];

// Local zones
const zones = [
    { name: "Genève", type: "primary", icon: "ri-map-pin-fill" },
    { name: "Vaud", type: "secondary", icon: "ri-map-pin-line" },
    { name: "Valais", type: "secondary", icon: "ri-map-pin-line" },
    { name: "Neuchâtel", type: "secondary", icon: "ri-map-pin-line" },
    { name: "Fribourg", type: "secondary", icon: "ri-map-pin-line" },
    { name: "Toute Suisse romande", type: "tertiary", icon: "ri-global-line" }
];

// Project type options for form
const projectTypes = [
    { value: "audit-seo", label: "Audit SEO" },
    { value: "seo-nouveau-site", label: "SEO + nouveau site" },
    { value: "optimiser-existant", label: "Optimiser mon site existant" },
    { value: "accompagnement-mensuel", label: "Accompagnement mensuel" },
    { value: "ne-sait-pas", label: "Je ne sais pas encore" }
];

// Budget options for form
const budgetOptions = [
    { value: "moins-1500", label: "< 1'500 CHF" },
    { value: "1500-2500", label: "1'500 - 2'500 CHF" },
    { value: "2500-5000", label: "2'500 - 5'000 CHF" },
    { value: "plus-5000", label: "> 5'000 CHF" },
    { value: "ne-sait-pas", label: "Je ne sais pas" }
];
---

<Layout
    title={seoData.title}
    description={seoData.description}
    schemas={schemas}
>
    <Header />

    <!-- ============================================== -->
    <!-- HERO SECTION -->
    <!-- ============================================== -->
    <section class="hero-section -mt-[120px] pt-[150px] pb-16 md:pt-[160px] md:pb-20 px-4 relative overflow-hidden">
        <!-- Gradient mesh background -->
        <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
            <div class="absolute top-0 -left-20 w-[500px] h-[500px] bg-[var(--blue)] opacity-20 blur-[120px] rounded-full"></div>
            <div class="absolute top-1/3 -right-20 w-[400px] h-[400px] bg-[var(--violet)] opacity-15 blur-[100px] rounded-full"></div>
            <div class="absolute bottom-0 left-1/3 w-[300px] h-[300px] bg-[var(--blue)] opacity-10 blur-[80px] rounded-full"></div>
        </div>

        <div class="max-w-4xl mx-auto relative z-10">
            <!-- Centered text content -->
            <div class="text-center">
                <!-- H1 SEO discret -->
                <h1 class="seo-h1 mb-8 mt-8">Référencement local SEO à Genève</h1>

                <!-- Main title -->
                <p class="text-3xl md:text-4xl lg:text-5xl font-normal tracking-tight mb-6" data-animate="fade-up">
                    Vos clients vous cherchent sur Google.<br/>
                    <span class="relative inline-block">
                        <span class="relative z-10">Est-ce qu'ils vous trouvent ?</span>
                    </span>
                </p>

                <!-- Description -->
                <p class="text-lg md:text-xl text-gray-600 mb-8 leading-relaxed max-w-2xl mx-auto" data-animate="fade-up" data-delay="0.1">
                    <strong class="text-[var(--text)]">46% des recherches Google sont locales.</strong><br class="hidden md:block"/>
                    Si vous n'êtes pas visible, vos concurrents récupèrent vos clients.<br class="hidden md:block"/>
                    Cas prouvé : <strong class="text-[var(--blue)]">position #1 en 5 mois</strong> dans une niche concurrentielle.
                </p>

                <!-- CTAs centered -->
                <div class="flex flex-col sm:flex-row gap-4 justify-center mb-16 md:mb-20" data-animate="fade-up" data-delay="0.2">
                    <a
                        href="#contact"
                        class="
                            bg-[var(--blue)]
                            border-2 border-black
                            px-6 py-4
                            text-lg font-medium
                            shadow-[4px_4px_0px_rgba(0,0,0,1)]
                            transition-all duration-200
                            hover:bg-[var(--yellow)]
                            hover:shadow-[2px_2px_0px_rgba(0,0,0,1)]
                            hover:translate-x-[2px] hover:translate-y-[2px]
                            flex items-center justify-center gap-2
                        "
                    >
                        <i class="ri-search-eye-line"></i>
                        Obtenir mon audit gratuit
                    </a>
                    <a
                        href="#etude-de-cas"
                        class="
                            bg-white
                            border-2 border-black
                            px-6 py-4
                            text-lg font-medium
                            transition-all duration-200
                            hover:bg-gray-100
                            flex items-center justify-center gap-2
                        "
                    >
                        Voir un cas concret
                        <i class="ri-arrow-down-line"></i>
                    </a>
                </div>
            </div>

            <!-- Google result mockup -->
            <div class="w-full max-w-2xl mx-auto relative" data-animate="scale" data-delay="0.3">
                <div class="bg-white border-3 border-black shadow-[8px_8px_0px_rgba(0,0,0,1)] relative p-6 md:p-8">
                    <!-- Browser bar -->
                    <div class="flex items-center gap-2 p-3 border-2 border-black bg-gray-50 mb-6 -mt-2">
                        <div class="flex gap-1.5">
                            <div class="w-3 h-3 rounded-full bg-red-400 border border-black"></div>
                            <div class="w-3 h-3 rounded-full bg-yellow-400 border border-black"></div>
                            <div class="w-3 h-3 rounded-full bg-green-400 border border-black"></div>
                        </div>
                        <div class="flex-1 bg-white border border-black px-3 py-1 text-xs text-gray-400 font-mono text-center">
                            google.ch/search?q=avocat+divorce+genève
                        </div>
                    </div>

                    <!-- Fake Google result -->
                    <div class="space-y-4">
                        <div class="bg-[var(--blue)] bg-opacity-10 border-2 border-[var(--blue)] p-4">
                            <div class="text-xs text-green-700 font-mono mb-1">www.leo-lecureux.ch</div>
                            <div class="text-lg font-bold text-blue-800 mb-1">Léo Lécureux — Avocat spécialisé divorce à Genève</div>
                            <div class="text-sm text-gray-600">Cabinet d'avocat spécialisé en droit du divorce et de la famille à Genève. Consultation personnalisée...</div>
                        </div>
                        <div class="p-4 opacity-40">
                            <div class="text-xs text-green-700 font-mono mb-1">www.concurrent-2.ch</div>
                            <div class="text-lg font-bold text-blue-800 mb-1">Autre cabinet — Avocat à Genève</div>
                            <div class="text-sm text-gray-600">Résultat concurrent en position 2...</div>
                        </div>
                    </div>
                </div>
                <!-- #1 badge -->
                <div class="absolute -top-4 -left-4 bg-[var(--yellow)] border-2 border-black px-3 py-2 shadow-[3px_3px_0px_rgba(0,0,0,1)] -rotate-6">
                    <span class="font-mono text-sm font-bold">#1</span>
                    <span class="text-xs text-gray-700 block">Google</span>
                </div>
                <!-- Duration badge -->
                <div class="absolute -bottom-4 -right-4 bg-[var(--blue)] border-2 border-black px-4 py-2 shadow-[3px_3px_0px_rgba(0,0,0,1)] rotate-3">
                    <span class="font-bold text-sm">5 mois</span>
                </div>
            </div>

            <!-- Location badge centered -->
            <div class="flex items-center justify-center gap-2 text-sm text-gray-500 mt-12">
                <i class="ri-map-pin-fill text-[var(--blue)]"></i>
                <span>Basé à Genève · SEO Suisse romande</span>
            </div>
        </div>
    </section>

    <!-- ============================================== -->
    <!-- PAIN POINTS SECTION -->
    <!-- ============================================== -->
    <section id="problemes" class="py-20 md:py-28 px-4 bg-white border-y-2 border-black relative overflow-hidden">
        <BackgroundGlitchGrid />
        <div class="max-w-5xl mx-auto relative z-10">
            <!-- Section header -->
            <div class="text-center mb-12 md:mb-16" data-animate="fade-up">
                <span class="inline-flex items-center gap-2 text-xs font-mono uppercase tracking-[0.2em] text-gray-500 mb-4">
                    <span class="w-8 h-px bg-gray-400"></span>
                    problèmes
                    <span class="w-8 h-px bg-gray-400"></span>
                </span>
                <h2 class="text-3xl md:text-4xl font-normal mb-4">
                    <span class="relative inline-block">
                        <span class="absolute bg-red-200 w-full h-[40%] left-0 bottom-1 -z-1"></span>
                        Vous vous reconnaissez ?
                    </span>
                </h2>
                <p class="text-lg text-gray-600">Les problèmes que rencontrent la majorité des PME suisses avec leur visibilité en ligne.</p>
            </div>

            <!-- Pain points grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6 mb-12" data-animate-stagger>
                {painPoints.map((point) => (
                    <div class="pain-card bg-[var(--main-bg)] border-2 border-black p-6 relative transition-all duration-200 hover:-translate-y-1 hover:shadow-[4px_4px_0px_rgba(0,0,0,0.2)]" data-animate-item>
                        <!-- Red X icon -->
                        <div class="w-10 h-10 bg-red-100 border-2 border-red-300 flex items-center justify-center mb-4">
                            <i class="ri-close-line text-red-500 text-xl"></i>
                        </div>
                        <h3 class="text-lg font-bold mb-2">{point.title}</h3>
                        <p class="text-gray-600 text-sm leading-relaxed">{point.description}</p>
                    </div>
                ))}
            </div>

            <!-- Good news callout -->
            <div class="bg-[var(--blue)] bg-opacity-10 border-2 border-[var(--blue)] p-6 md:p-8 text-center" data-animate="fade-up">
                <p class="text-lg md:text-xl font-medium">
                    <i class="ri-lightbulb-line text-[var(--blue)] mr-2"></i>
                    <strong>La bonne nouvelle ?</strong> Pas besoin d'un gros budget ni d'être expert en SEO. Il faut juste la bonne méthode et quelqu'un qui sait ce qu'il fait.
                </p>
            </div>
        </div>
    </section>

    <!-- ============================================== -->
    <!-- ÉTUDE DE CAS LÉCUREUX -->
    <!-- ============================================== -->
    <section id="etude-de-cas" class="py-20 md:py-28 px-4 relative overflow-hidden">
        <div class="max-w-5xl mx-auto relative z-10">
            <!-- Section header -->
            <div class="text-center mb-12 md:mb-16" data-animate="fade-up">
                <span class="inline-flex items-center gap-2 text-xs font-mono uppercase tracking-[0.2em] text-gray-500 mb-4">
                    <span class="w-8 h-px bg-gray-400"></span>
                    cas réel
                    <span class="w-8 h-px bg-gray-400"></span>
                </span>
                <h2 class="text-3xl md:text-4xl font-normal mb-4">
                    De <span class="line-through text-gray-400">invisible</span> à <span class="text-[var(--blue)]">#1 sur Google</span> en 5 mois
                </h2>
                <p class="text-lg text-gray-600 max-w-2xl mx-auto">
                    Léo Lécureux, avocat spécialisé divorce à Genève. Niche juridique ultra-concurrentielle (800+ cabinets). Zéro présence en ligne au départ.
                </p>
            </div>

            <!-- Stats grid -->
