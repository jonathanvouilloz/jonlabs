---
import '../../styles/global.css';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

// Import background components
import BackgroundGlitchGrid from '../../components/backgrounds/BackgroundGlitchGrid.astro';
import BackgroundProgressFlow from '../../components/backgrounds/BackgroundProgressFlow.astro';
import BackgroundCircuitBoard from '../../components/backgrounds/BackgroundCircuitBoard.astro';
import BackgroundQuestionMarks from '../../components/backgrounds/BackgroundQuestionMarks.astro';
import BackgroundMapContours from '../../components/backgrounds/BackgroundMapContours.astro';

// Import images
import heroImage from '../../assets/services/automatisation-hero.png';
import balanceImage from '../../assets/services/balance-temps-argent.png';
import puzzleImage from '../../assets/services/puzzle-connexion.png';

// Schema.org
import { SITE_URL } from '../../data/schema';
import { getServiceItemSchema, getBreadcrumbSchema, getFAQPageSchema } from '../../lib/seo';

// SEO Data
const seoData = {
    title: "Formation IA pour équipes en Suisse romande | Jon Labs",
    description: "Formation IA sur-mesure pour les équipes de PME romandes : cadrage des usages, outils, garde-fous nLPD. Présentiel Genève ou distanciel, dès CHF 1'200."
};

// Schema.org data
const breadcrumb = getBreadcrumbSchema([
    { name: "Accueil", url: SITE_URL },
    { name: "Services", url: `${SITE_URL}/services` },
    { name: "Formation IA équipe", url: `${SITE_URL}/services/formation-ia-equipe` }
]);
const schemas: any[] = [getServiceItemSchema("formation-ia-equipe"), breadcrumb];

// Pain points (4 items)
const painPoints = [
    {
        icon: "ri-bank-card-line",
        title: "\"On paie des outils IA que personne n'utilise\"",
        description: "ChatGPT, Copilot, un abonnement par-ci, une licence par-là. Les factures tombent chaque mois, mais dans les faits, deux ou trois curieux testent et le reste de l'équipe n'y touche pas. Vous payez pour une adoption qui n'a jamais eu lieu."
    },
    {
        icon: "ri-emotion-unhappy-line",
        title: "\"Mon équipe se méfie de l'IA\"",
        description: "Peur de mal faire, peur d'être remplacé, impression que c'est réservé aux geeks. Sans un cadre rassurant et des cas concrets, la curiosité reste bloquée par la méfiance. Et un outil qu'on n'ose pas utiliser ne sert à rien."
    },
    {
        icon: "ri-shield-cross-line",
        title: "\"Chacun bricole dans son coin\"",
        description: "Des données clients copiées-collées dans ChatGPT, des prompts partagés sous le manteau, des usages improvisés sans aucun contrôle. Ça avance, mais n'importe comment — et parfois avec des informations sensibles qui n'auraient jamais dû sortir."
    },
    {
        icon: "ri-question-line",
        title: "\"On n'a ni cadre ni bonnes pratiques\"",
        description: "Personne ne sait ce qu'on a le droit de mettre dans une IA, ce qui est fiable, ce qui ne l'est pas. Pas de règles, pas de repères, pas de playbook. Résultat : l'IA reste un sujet flou que tout le monde évite d'aborder sérieusement."
    }
];

// Method steps / programme (4 items)
const methodSteps = [
    {
        step: "1",
        title: "Audit des usages réels",
        description: "Avant de parler d'IA, on regarde votre quotidien. Quelles tâches vous prennent du temps, où sont les répétitions, ce que votre équipe fait déjà (ou aimerait faire). Je repère les cas où l'IA gagne vraiment du temps — pas les gadgets.",
        duration: "1-2 heures en amont"
    },
    {
        step: "2",
        title: "Atelier pratique sur VOS cas",
        description: "Pas de slides génériques ni de théorie fumeuse. On ouvre vos vrais outils, vos vrais dossiers, et on construit ensemble des usages qui tiennent la route. Chaque personne repart avec des prompts et des réflexes qui marchent sur son métier.",
        duration: "½ journée à 2 jours"
    },
    {
        step: "3",
        title: "Garde-fous & nLPD",
        description: "Ce qu'on met dans une IA, ce qu'on n'y met jamais. Données clients, dossiers RH, informations confidentielles : on pose des règles simples et compréhensibles, alignées sur la nLPD suisse. Votre équipe utilise l'IA sans exposer votre entreprise.",
        duration: "Inclus dans l'atelier"
    },
    {
        step: "4",
        title: "Autonomie : playbook + suivi",
        description: "Vous repartez avec un playbook interne : les usages validés, les prompts qui marchent, les règles à respecter. Et je reste disponible après la formation pour répondre aux questions et ajuster au fur et à mesure que les usages s'installent.",
        duration: "Après la session"
    }
];

// Differentiators
const differentiators = [
    {
        icon: "ri-briefcase-4-line",
        title: "Sur VOS cas, pas de théorie",
        description: "On travaille sur vos outils et vos tâches réelles. Votre équipe repart avec des usages concrets, pas des concepts."
    },
    {
        icon: "ri-shield-check-line",
        title: "Angle nLPD maîtrisé",
        description: "Données suisses, conformité nLPD, confidentialité : le cadre légal fait partie de la formation, pas d'un vague disclaimer."
    },
    {
        icon: "ri-terminal-box-line",
        title: "Un formateur qui construit",
        description: "Je conçois aussi les agents IA que je déploie chez mes clients. Vous formez avec quelqu'un qui met les mains dans le cambouis, pas un consultant slides."
    }
];

// Results (6 items)
const results = [
    {
        icon: "ri-team-line",
        title: "Une équipe qui utilise l'IA au quotidien",
        description: "L'IA passe du gadget testé une fois à un réflexe de travail, intégré dans les tâches de chacun"
    },
    {
        icon: "ri-timer-flash-line",
        title: "Un gain de temps mesurable",
        description: "Comptes rendus, réponses clients, rédaction : des heures récupérées chaque semaine sur des tâches répétitives"
    },
    {
        icon: "ri-shield-check-line",
        title: "Des usages conformes",
        description: "Chacun sait ce qu'il peut mettre (ou pas) dans une IA. Fini les données sensibles copiées-collées n'importe où"
    },
    {
        icon: "ri-book-open-line",
        title: "Un playbook interne",
        description: "Les usages validés, les prompts qui marchent et les règles maison, réunis dans un document que l'équipe garde"
    },
    {
        icon: "ri-emotion-happy-line",
        title: "La fin de la peur de l'outil",
        description: "L'IA n'est plus un sujet anxiogène réservé à quelques-uns, mais un outil que toute l'équipe s'approprie"
    },
    {
        icon: "ri-wallet-3-line",
        title: "Des abonnements rentabilisés",
        description: "Les licences IA que vous payez déjà sont enfin utilisées, au lieu de dormir dans un tableau de dépenses"
    }
];

// Concrete example
const concreteExample = {
    title: "Une PME de 12 personnes qui payait dans le vide",
    before: "Une PME romande payait ChatGPT, Copilot et deux autres abonnements IA. Dans les faits : deux ou trois curieux qui testaient de temps en temps, le reste de l'équipe qui n'y touchait pas. Des factures mensuelles pour zéro résultat concret.",
    after: "Après la formation, chaque pôle a 2-3 usages ancrés dans son quotidien — comptes rendus de réunion, réponses clients, rédaction d'offres — avec des règles claires sur ce qu'on met (ou pas) dans une IA.",
    result: "Plusieurs heures récupérées chaque semaine, des abonnements enfin rentabilisés, et une équipe qui n'a plus peur de l'outil."
};

// Formats & modalités (replaces "outils" section)
const formats = [
    {
        name: "Présentiel à Genève",
        description: "Je me déplace dans vos locaux. Rien ne remplace un atelier en salle, avec vos écrans, vos dossiers et toute l'équipe autour de la table.",
        icon: "ri-map-pin-2-line"
    },
    {
        name: "Distanciel (visio)",
        description: "Pour les équipes réparties ou à distance : même contenu, même approche pratique, en visioconférence. Partout en Suisse romande.",
        icon: "ri-vidicon-line"
    },
    {
        name: "Atelier découverte (½ journée)",
        description: "Un premier format court pour lever les blocages, montrer 3-4 usages concrets et donner envie. Idéal pour tester avant d'aller plus loin.",
        icon: "ri-compass-3-line"
    },
    {
        name: "Programme sur 1 à 2 jours",
        description: "Pour ancrer durablement les usages : audit, atelier approfondi par pôle, garde-fous nLPD et playbook interne. Le format qui change vraiment la donne.",
        icon: "ri-calendar-2-line"
    }
];

// Pricing factors
const pricingFactors = [
    "La taille de votre équipe",
    "La durée (½ journée à 2 jours)",
    "Le format (présentiel ou distanciel)",
    "Le niveau de personnalisation des cas"
];

// Pricing inclusions
const pricingInclusions = [
    "Audit préalable des usages",
    "Atelier pratique sur vos cas",
    "Garde-fous & cadre nLPD",
    "Playbook interne remis à l'équipe",
    "Suivi post-formation"
];

// FAQs (6 items)
const faqs = [
    {
        question: "La formation se fait en présentiel ou à distance ?",
        answer: "Les deux. Je me déplace en présentiel à Genève et dans toute la Suisse romande, ou j'anime la formation en distanciel par visioconférence pour les équipes réparties. Le contenu et l'approche pratique restent les mêmes — on choisit le format le plus adapté à votre organisation."
    },
    {
        question: "Combien de temps dure une formation ?",
        answer: "De la demi-journée découverte à un programme sur deux jours. Une demi-journée suffit pour lever les blocages et installer quelques usages. Pour ancrer durablement l'IA dans plusieurs pôles, avec audit et playbook, on part plutôt sur un à deux jours. On cale la durée ensemble selon vos objectifs."
    },
    {
        question: "Combien ça coûte ?",
        answer: "À partir de CHF 1'200 la session. Le prix final dépend de la taille de l'équipe, de la durée et du format (présentiel ou distanciel). Je vous envoie un devis clair après un premier échange gratuit — pas de surprise, pas de coût caché."
    },
    {
        question: "Mon équipe n'y connaît rien, c'est un problème ?",
        answer: "Pas du tout. Aucun niveau technique n'est requis. La formation part de zéro et s'appuie sur des cas concrets de votre métier. L'objectif, c'est justement de rendre l'IA accessible à tout le monde — y compris à ceux qui s'en méfient ou qui pensent que ce n'est pas pour eux."
    },
    {
        question: "C'est une formation catalogue ou sur-mesure ?",
        answer: "Entièrement sur-mesure. Je ne déroule pas des slides génériques : je construis la formation autour de vos outils, vos tâches et vos cas réels. C'est ce qui fait la différence entre une équipe qui a « vu une démo IA » et une équipe qui utilise vraiment l'IA au quotidien."
    },
    {
        question: "Et après la formation, on est livrés à nous-mêmes ?",
        answer: "Non. Vous repartez avec un playbook interne (usages validés, prompts qui marchent, règles nLPD) et je reste disponible pour répondre aux questions et ajuster à mesure que les usages s'installent. La formation est un point de départ, pas un one-shot qu'on oublie la semaine d'après."
    }
];
schemas.push(getFAQPageSchema(faqs));

// Local zones
const zones = [
    { name: "Genève", type: "primary", icon: "ri-map-pin-fill" },
    { name: "Vaud", type: "secondary", icon: "ri-map-pin-line" },
    { name: "Valais", type: "secondary", icon: "ri-map-pin-line" },
    { name: "Neuchâtel", type: "secondary", icon: "ri-map-pin-line" },
    { name: "Fribourg", type: "secondary", icon: "ri-map-pin-line" },
    { name: "Toute Suisse romande", type: "tertiary", icon: "ri-global-line" }
];

// Session type options for form
const sessionTypes = [
    { value: "atelier-decouverte", label: "Atelier découverte (½ journée)" },
    { value: "formation-equipe", label: "Formation équipe (1-2 jours)" },
    { value: "garde-fous-nlpd", label: "Garde-fous & nLPD" },
    { value: "autre", label: "Autre / Je ne sais pas" }
];
---

<Layout
    title={seoData.title}
    description={seoData.description}
    schemas={schemas}
    robots="index, follow"
>
    <Header />

    <!-- ============================================== -->
    <!-- HERO SECTION -->
    <!-- ============================================== -->
    <section class="hero-section -mt-[120px] pt-[150px] pb-16 md:pt-[160px] md:pb-20 px-4 relative overflow-hidden">
        <!-- Gradient mesh background -->
        <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
            <div class="absolute top-0 -left-20 w-[500px] h-[500px] bg-[var(--blue)] opacity-20 blur-[120px] rounded-full"></div>
            <div class="absolute top-1/3 -right-20 w-[400px] h-[400px] bg-[var(--violet)] opacity-15 blur-[100px] rounded-full"></div>
            <div class="absolute bottom-0 left-1/3 w-[300px] h-[300px] bg-[var(--blue)] opacity-10 blur-[80px] rounded-full"></div>
        </div>

        <div class="max-w-4xl mx-auto relative z-10">
            <!-- Text content centered -->
            <div class="text-center">
                <!-- H1 SEO discret -->
                <h1 class="seo-h1 mb-6 mt-8 text-center">Formation IA pour équipes de PME à Genève et en Suisse romande</h1>

                <!-- Main title -->
                <p class="text-3xl md:text-4xl lg:text-5xl font-normal tracking-tight mb-6" data-animate="fade-up">
                    Formation IA pour<br/>
                    <span class="relative inline-block">
                        <span class="absolute bg-[var(--accent)] w-full h-[40%] left-0 bottom-1 -z-1"></span>
                        <span class="relative z-10">vos équipes.</span>
                    </span>
                </p>

                <!-- Description -->
                <p class="text-lg md:text-xl text-gray-600 mb-8 leading-relaxed max-w-2xl mx-auto" data-animate="fade-up" data-delay="0.1">
                    Vos équipes ont accès à l'IA, mais ne savent pas quoi en faire concrètement. On transforme la curiosité en usages qui font gagner du temps — sur vos vrais outils, avec les bons garde-fous.<br class="hidden md:block"/>
                    <strong class="text-[var(--text)]">Fini les abonnements IA payés que personne n'utilise.</strong>
                </p>

                <!-- CTAs -->
                <div class="flex flex-col sm:flex-row gap-4 justify-center mb-12 md:mb-16" data-animate="fade-up" data-delay="0.2">
                    <a
                        href="/contact"
                        class="
                            bg-[var(--blue)]
                            border-2 border-black
                            px-6 py-4
                            text-lg font-medium
                            shadow-[4px_4px_0px_rgba(0,0,0,1)]
                            transition-all duration-200
                            hover:bg-[var(--yellow)]
                            hover:shadow-[2px_2px_0px_rgba(0,0,0,1)]
                            hover:translate-x-[2px] hover:translate-y-[2px]
                            flex items-center justify-center gap-2
                        "
                    >
                        <i class="ri-chat-3-line"></i>
                        Discuter d'une formation
                    </a>
                    <a
                        href="#programme"
                        class="
                            bg-white
                            border-2 border-black
                            px-6 py-4
                            text-lg font-medium
                            transition-all duration-200
                            hover:bg-gray-100
                            flex items-center justify-center gap-2
                        "
                    >
                        Voir le programme
                        <i class="ri-arrow-down-line"></i>
                    </a>
                </div>
            </div>

            <!-- Hero illustration centered below -->
            <div class="max-w-2xl mx-auto" data-animate="scale" data-delay="0.3">
                <div class="bg-white border-3 border-black shadow-[8px_8px_0px_rgba(0,0,0,1)] p-4 relative">
                    <img
                        src={heroImage.src}
                        alt="Illustration d'une formation IA pour une équipe de PME en Suisse romande"
                        class="w-full h-auto"
                    />
                    <!-- Corner boxes -->
                    <div class="absolute -top-1.5 -left-1.5 w-3 h-3 bg-[var(--blue)] border-2 border-black"></div>
                    <div class="absolute -top-1.5 -right-1.5 w-3 h-3 bg-[var(--violet)] border-2 border-black"></div>
                    <div class="absolute -bottom-1.5 -left-1.5 w-3 h-3 bg-[var(--violet)] border-2 border-black"></div>
                    <div class="absolute -bottom-1.5 -right-1.5 w-3 h-3 bg-[var(--blue)] border-2 border-black"></div>
                </div>
            </div>

            <!-- Location badge -->
            <div class="flex items-center justify-center gap-2 text-sm text-gray-500 mt-12">
                <i class="ri-map-pin-fill text-[var(--blue)]"></i>
                <span>Présentiel à Genève | Distanciel en Suisse romande</span>
            </div>
        </div>
    </section>

    <!-- ============================================== -->
    <!-- CONTEXTE SUISSE SECTION -->
    <!-- ============================================== -->
    <section id="contexte" class="py-20 md:py-28 px-4 bg-white border-y-2 border-black">
        <div class="max-w-5xl mx-auto">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12 items-center">
                <!-- Text content -->
                <div data-animate="fade-right">
                    <span class="inline-flex items-center gap-2 text-xs font-mono uppercase tracking-[0.2em] text-gray-500 mb-4">
                        <span class="w-8 h-px bg-gray-400"></span>
                        contexte
                        <span class="w-8 h-px bg-gray-400"></span>
                    </span>
                    <h2 class="text-3xl md:text-4xl font-normal mb-6">
                        L'IA ne manque pas à vos équipes. <span class="text-[var(--blue)]">Le mode d'emploi, si.</span>
                    </h2>
                    <div class="space-y-4 text-gray-600 leading-relaxed">
                        <p>
                            En Suisse romande, la plupart des PME ont déjà mis un pied dans l'IA : un abonnement ChatGPT, une licence Copilot, quelques outils testés ici ou là. L'accès n'est pas le problème.
                        </p>
                        <p>
                            Le problème, c'est l'écart entre <strong class="text-[var(--text)]">avoir accès à l'IA</strong> et <strong class="text-[var(--text)]">savoir quoi en faire au quotidien</strong>. Sans cadre ni prise en main, l'outil reste un gadget que deux ou trois personnes testent, pendant que le reste de l'équipe attend.
                        </p>
                        <div class="bg-red-50 border-2 border-red-200 p-4 my-6">
                            <p class="text-lg font-medium text-red-800">
                                Un abonnement IA <span class="bg-red-200 px-1">payé mais pas utilisé</span>, c'est de l'argent qui part chaque mois — et un gain de temps <span class="bg-red-200 px-1 font-bold">jamais encaissé</span>.
                            </p>
                            <p class="text-sm text-red-600 mt-2">Le vrai coût n'est pas l'abonnement. C'est le temps qu'on continue de perdre à côté.</p>
                        </div>
                        <p>
                            Une bonne formation ne parle pas d'IA en général. Elle part de <strong class="text-[var(--text)]">vos tâches réelles</strong> et transforme la curiosité en usages concrets, adoptés par toute l'équipe — avec les garde-fous qui protègent vos données.
                        </p>
                    </div>
                </div>

                <!-- Illustration -->
                <div class="relative" data-animate="fade-left">
                    <img
                        src={balanceImage.src}
                        alt="Illustration du temps gagné par une équipe formée à l'IA en Suisse romande"
                        class="w-full h-auto max-w-md mx-auto"
                    />
                </div>
            </div>
        </div>
    </section>

    <!-- ============================================== -->
    <!-- PAIN POINTS SECTION -->
    <!-- ============================================== -->
    <section id="problemes" class="py-20 md:py-28 px-4 relative overflow-hidden">
        <BackgroundGlitchGrid color="rgba(239, 68, 68, 0.5)" opacity={0.12} />
        <div class="max-w-5xl mx-auto relative z-10">
            <!-- Section header -->
            <div class="text-center mb-12 md:mb-16" data-animate="fade-up">
                <span class="inline-flex items-center gap-2 text-xs font-mono uppercase tracking-[0.2em] text-gray-500 mb-4">
                    <span class="w-8 h-px bg-gray-400"></span>
                    problèmes
                    <span class="w-8 h-px bg-gray-400"></span>
                </span>
                <h2 class="text-3xl md:text-4xl font-normal mb-4">
                    <span class="relative inline-block">
                        <span class="absolute bg-red-200 w-full h-[40%] left-0 bottom-1 -z-1"></span>
                        Ça vous parle ?
                    </span>
                </h2>
                <p class="text-lg text-gray-600">Vous n'êtes pas seul. La plupart des équipes de PME romandes bloquent au même endroit avec l'IA.</p>
            </div>

            <!-- Pain points grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6 mb-12" data-animate-stagger>
                {painPoints.map((point) => (
                    <div class="pain-card bg-white border-2 border-black p-6 relative transition-all duration-200 hover:-translate-y-1 hover:shadow-[4px_4px_0px_rgba(0,0,0,0.2)]" data-animate-item>
                        <!-- Red X icon -->
                        <div class="w-10 h-10 bg-red-100 border-2 border-red-300 flex items-center justify-center mb-4">
                            <i class="ri-close-line text-red-500 text-xl"></i>
                        </div>
                        <h3 class="text-lg font-bold mb-2">{point.title}</h3>
                        <p class="text-gray-600 text-sm leading-relaxed">{point.description}</p>
                    </div>
                ))}
            </div>

            <!-- Transition callout -->
            <div class="bg-[var(--blue)] bg-opacity-10 border-2 border-[var(--blue)] p-6 md:p-8 text-center" data-animate="fade-up">
                <p class="text-lg md:text-xl font-medium">
                    <i class="ri-lightbulb-line text-[var(--blue)] mr-2"></i>
                    <strong>Le problème n'est pas l'IA.</strong> C'est qu'on l'a mise entre les mains de vos équipes sans mode d'emploi ni cadre. Et ça, ça se forme.
                </p>
            </div>
        </div>
    </section>

    <!-- ============================================== -->
    <!-- PROGRAMME / METHODOLOGY SECTION -->
    <!-- ============================================== -->
    <section id="programme" class="py-20 md:py-28 px-4 bg-white border-y-2 border-black relative overflow-hidden">
        <BackgroundProgressFlow />
        <div class="max-w-5xl mx-auto relative z-10">
            <!-- Section header -->
            <div class="text-center mb-12 md:mb-16" data-animate="fade-up">
                <span class="inline-flex items-center gap-2 text-xs font-mono uppercase tracking-[0.2em] text-gray-500 mb-4">
                    <span class="w-8 h-px bg-gray-400"></span>
                    programme
                    <span class="w-8 h-px bg-gray-400"></span>
                </span>
                <h2 class="text-3xl md:text-4xl font-normal mb-4">
                    Comment se passe la formation ?
                </h2>
                <p class="text-lg text-gray-600 max-w-2xl mx-auto">
                    Quatre étapes, un objectif : une équipe autonome qui utilise l'IA sans risque.
                </p>
            </div>

            <!-- Method steps grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12" data-animate-stagger>
                {methodSteps.map((step, index) => (
                    <div class="bg-[var(--main-bg)] border-2 border-black p-6 shadow-[4px_4px_0px_rgba(0,0,0,0.15)] relative" data-animate-item>
                        <!-- Number badge -->
                        <div class="flex items-center gap-3 mb-4">
                            <span class="w-10 h-10 bg-[var(--blue)] border-2 border-black flex items-center justify-center font-mono font-bold text-sm">
                                0{index + 1}
                            </span>
                        </div>
                        <h3 class="text-xl font-bold mb-3">{step.title}</h3>
                        <p class="text-gray-600 text-sm leading-relaxed mb-4">{step.description}</p>
                        <!-- Duration -->
                        <div class="flex items-center gap-2 text-sm text-gray-500">
                            <i class="ri-time-line"></i>
                            <span>{step.duration}</span>
                        </div>
                    </div>
                ))}
            </div>

            <!-- Differentiators box -->
