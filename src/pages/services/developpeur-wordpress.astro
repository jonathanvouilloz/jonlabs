            </div>
        </section>

    </main>

    <Footer />
</Layout>

<style is:global>
    /* ══ FREELANCE WORDPRESS — styles .wp-* (namespace scopé, corps .co-root) ══ */

    /* ── Hero (centré) ── */
    .wp-hero-inner { max-width: 900px; margin: 0 auto; display: flex; flex-direction: column; align-items: center; text-align: center; }
    .wp-hero-title { font-size: clamp(2.2rem, 5vw, 3.4rem); }
    .co-root .wp-hero-lead { margin-top: 18px; max-width: 62ch; font-size: 1.075rem; line-height: 1.65; color: var(--muted); }
    .wp-hero-lead strong { color: var(--ink); font-weight: 600; }
    .wp-hero-btns { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 28px; justify-content: center; }
    .wp-hero-btns .co-btn i { transition: transform .18s ease-out; }
    .wp-hero-btns .co-btn:hover i { transform: translateY(2px); }
    .co-root .wp-hero-loc { margin-top: 40px; font-size: 13.5px; display: inline-flex; align-items: center; gap: 6px; }
    .wp-hero-loc i { color: var(--accent); }

    /* browser mockup */
    .wp-hero-media { position: relative; width: 100%; max-width: 660px; margin: 56px auto 0; }
    .wp-browser { position: relative; background: var(--surface); border: 1px solid var(--line-2); }
    .wp-browser-bar { display: flex; align-items: center; gap: 8px; padding: 11px 14px; border-bottom: 1px solid var(--line); background: var(--bg); }
    .wp-browser-dot { width: 9px; height: 9px; border-radius: 999px; background: var(--line-2); flex: none; }
    .wp-browser-url { flex: 1; text-align: center; font-size: 12px; color: var(--muted); font-variant-numeric: tabular-nums; }
    .wp-browser-img { display: block; width: 100%; height: auto; }
    .wp-badge { position: absolute; z-index: 4; background: var(--surface); border: 1px solid var(--line-2); padding: 8px 12px; font-size: 12px; font-weight: 600; }
    .wp-badge--score { top: -16px; left: -14px; display: flex; flex-direction: column; line-height: 1.1; }
    .wp-badge--score b { color: var(--accent); font-size: 15px; }
    .wp-badge--score span { color: var(--muted); font-size: 10px; text-transform: uppercase; letter-spacing: 0.08em; }
    .wp-badge--speed { bottom: -16px; right: -14px; background: var(--accent); border-color: var(--accent); color: #fff; }

    /* ── Cartes génériques (problèmes) ── */
    .wp-grid { display: grid; gap: 16px; margin-top: 32px; }
    .wp-grid--2 { grid-template-columns: repeat(2, 1fr); }
    .wp-card {
        position: relative; display: flex; flex-direction: column; gap: 10px; padding: 24px;
        background: var(--surface); border: 1px solid var(--line-2);
        transition: box-shadow .18s ease-out, transform .18s ease-out;
    }
    .wp-card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(20,22,26,.07); }
    .wp-card-icon { font-size: 24px; color: var(--accent); line-height: 1; }
    .wp-card-title { font-size: 1.1rem; }
    .wp-card-text { font-size: 14px; line-height: 1.55; color: var(--muted); }

    /* ── Notes / callouts ── */
    .wp-note { display: flex; align-items: flex-start; gap: 12px; margin-top: 20px; padding: 18px 22px; border: 1px solid var(--line-2); background: var(--surface); }
    .wp-note i { color: var(--accent); font-size: 20px; flex: none; margin-top: 1px; }
    .co-root .wp-note p { font-size: 14.5px; line-height: 1.6; color: var(--muted); }
    .wp-note--accent { border-color: var(--accent); background: rgba(0,168,125,0.05); }
    .wp-note-inline { margin-top: 14px !important; font-size: 14px; line-height: 1.6; color: var(--muted); }
    .wp-inline { color: var(--accent); text-decoration: underline; text-underline-offset: 2px; font-weight: 500; }
    .wp-inline:hover { color: var(--ink); }
    .wp-note strong, .wp-note-inline strong { color: var(--ink); font-weight: 600; }

    /* ── Prestations (3 trajectoires) ── */
    .wp-intents { display: flex; flex-direction: column; gap: 20px; margin-top: 36px; }
    .wp-intent { position: relative; display: grid; grid-template-columns: 1fr 1fr; gap: 36px; padding: 32px; background: var(--surface); border: 1px solid var(--line-2); }
    .wp-intent-head { display: flex; flex-direction: column; gap: 12px; }
