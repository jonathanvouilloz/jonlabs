---
import '../../styles/global.css';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

// Import image hero (réutiliser temporairement refonte-1.webp)
import wordpressHero from '../../assets/services/refonte-1.webp';

// Import background components
import BackgroundGlitchGrid from '../../components/backgrounds/BackgroundGlitchGrid.astro';
import BackgroundProgressFlow from '../../components/backgrounds/BackgroundProgressFlow.astro';
import BackgroundCircuitBoard from '../../components/backgrounds/BackgroundCircuitBoard.astro';
import BackgroundQuestionMarks from '../../components/backgrounds/BackgroundQuestionMarks.astro';
import BackgroundMapContours from '../../components/backgrounds/BackgroundMapContours.astro';

// Schema.org
import { serviceSchemas, SITE_URL } from '../../data/schema';
import { getBreadcrumbSchema, getFAQPageSchema } from '../../lib/seo';

// SEO Data
const seoData = {
    title: "Freelance WordPress à Genève — création, refonte | Jon Labs",
    description: "Votre site WordPress rame ou date ? Création, refonte et migration vers du moderne. Freelance à Genève, tarifs CHF clairs. Audit gratuit."
};

// Schema.org data
const breadcrumb = getBreadcrumbSchema([
    { name: "Accueil", url: SITE_URL },
    { name: "Services", url: `${SITE_URL}/services` },
    { name: "Freelance WordPress", url: `${SITE_URL}/services/developpeur-wordpress` }
]);
const schemas: any[] = [serviceSchemas["developpeur-wordpress"], breadcrumb];

// Pain points data (4 items)
const painPoints = [
    {
        icon: "ri-speed-line",
        title: "Un site WordPress qui rame",
        description: "Votre site met 6 secondes à charger. Vos visiteurs partent avant d'avoir vu votre offre, et Google vous pénalise pour la lenteur."
    },
    {
        icon: "ri-user-unfollow-line",
        title: "Un prestataire qui ne répond plus",
        description: "Le site a été fait il y a des années par quelqu'un d'injoignable. Vous payez encore une maintenance sans savoir pour quoi exactement."
    },
    {
        icon: "ri-stack-line",
        title: "Des plugins entassés",
        description: "30 plugins installés au fil du temps, des mises à jour qui font peur, des alertes de sécurité ignorées. Personne n'ose toucher au site."
    },
    {
        icon: "ri-money-dollar-circle-line",
        title: "Des coûts qui s'accumulent",
        description: "Hébergement, licences de plugins, thème premium, maintenance, dépannages... Le site coûte chaque mois sans rien rapporter de mesurable."
    }
];

// 3 intents : création / refonte / migration
const intents = [
    {
        id: "creation",
        icon: "ri-add-box-line",
        title: "Création de site WordPress",
        intro: "WordPress reste un bon choix quand le projet le justifie : blog actif, édition fréquente par vos équipes, fonctionnalités métier disponibles en plugin. Je le construis proprement dès le départ.",
        features: [
            "Thème léger sur-mesure — pas de page builder usine à gaz",
            "Seulement les plugins nécessaires, maintenus et reconnus",
            "Performance et référencement natifs dès la mise en ligne",
            "Interface d'édition simple, adaptée à votre équipe",
            "Formation incluse pour publier en autonomie"
        ]
    },
    {
        id: "refonte",
        icon: "ri-refresh-line",
        title: "Refonte de site WordPress lent ou vieilli",
        intro: "C'est le cas le plus fréquent : un site WordPress qui a 5-10 ans, lent, au design daté, gonflé de plugins. Quand la base est saine, pas besoin de tout jeter — on refait bien.",
        features: [
            "Audit complet d'abord : vitesse, sécurité, structure, SEO",
            "Nettoyage des plugins et de la base de données",
            "Thème refait : design actuel, mobile impeccable",
            "Référencement préservé : URLs, contenus, positions Google",
            "Devis ferme après l'audit — pas de chantier sans fin"
        ]
    },
    {
        id: "migration",
        icon: "ri-arrow-right-up-line",
        title: "Migration WordPress vers une stack moderne",
        intro: "Quand WordPress n'est plus le bon outil — site vitrine sans blog actif, coûts récurrents injustifiés, failles de sécurité à répétition — je migre votre site vers une stack moderne (Astro, Next.js). C'est ma spécialité.",
        features: [
            "Contenu intégralement repris : pages, articles, images",
            "Redirections 301 systématiques — votre référencement est conservé",
            "Fini les mises à jour de plugins et les alertes de sécurité",
            "Coûts d'hébergement quasi nuls, vitesse multipliée",
            "Site éditable via une interface simple, sans WordPress"
        ]
    }
];

// Methodology steps (4 étapes)
const methodSteps = [
    {
        step: "1",
        title: "Audit gratuit",
        description: "J'analyse votre site WordPress existant (ou votre projet) : vitesse, sécurité, structure, référencement. Vous recevez un diagnostic clair et la recommandation honnête : refonte, migration, ou rien du tout.",
        duration: "Sous 48h (gratuit, sans engagement)"
    },
    {
        step: "2",
        title: "Plan & devis ferme",
        description: "Sur la base de l'audit, je vous propose un plan d'action précis avec un devis ferme. Pas de forfait flou ni de chantier qui s'éternise.",
        duration: "2-3 jours"
    },
    {
        step: "3",
        title: "Réalisation",
        description: "Création, refonte ou migration : je travaille sur une copie, votre site reste en ligne pendant toute la durée du chantier. Vous validez avant la bascule.",
        duration: "2-4 semaines selon le projet"
    },
    {
        step: "4",
        title: "Bascule & formation",
        description: "Mise en production, vérifications techniques (redirections, indexation), et formation pour que vous gériez le contenu vous-même. La maintenance ensuite ? Optionnelle, jamais imposée.",
        duration: "1-2 jours"
    }
];

// Differentiators
const differentiators = [
    {
        icon: "ri-user-voice-line",
        title: "Un seul interlocuteur",
        description: "celui qui audite est celui qui code"
    },
    {
        icon: "ri-price-tag-3-line",
        title: "Tarifs en CHF affichés",
        description: "fourchettes claires, devis ferme après audit"
    },
    {
        icon: "ri-lock-unlock-line",
        title: "Zéro dépendance",
        description: "site documenté, accès complets, maintenance optionnelle"
    },
    {
        icon: "ri-scales-3-line",
        title: "Conseil honnête",
        description: "si votre WordPress tient la route, je vous le dis aussi"
    }
];

// Pricing plans (alignés sur /tarifs)
const pricingPlans = [
    {
        name: "Création WordPress",
        price: "1'490",
        priceLabel: "À partir de",
        features: [
            "Site vitrine 1 à 5 pages",
            "Thème léger sur-mesure",
            "Plugins essentiels uniquement",
            "SEO de base : structure, balises, vitesse",
            "Formation à l'édition"
        ],
        ideal: "Indépendants et PME qui veulent un WordPress propre et gérable.",
        highlighted: false
    },
    {
        name: "Refonte WordPress",
        price: "2'490",
        priceLabel: "À partir de",
        features: [
            "Audit complet inclus",
            "Nettoyage plugins + base de données",
            "Thème refait, design actuel",
            "Performance remise à niveau (90+ visé)",
            "Référencement préservé et renforcé"
        ],
        ideal: "Sites WordPress de 5-10 ans qui rament ou font fuir les visiteurs.",
        highlighted: true
    },
    {
        name: "Migration vers stack moderne",
        price: "Sur devis",
        priceLabel: "",
        features: [
            "Reprise intégrale du contenu",
            "Redirections 301 — SEO conservé",
            "Hébergement quasi gratuit ensuite",
            "Plus aucune maintenance WordPress"
        ],
        ideal: "Sites vitrines qui n'ont plus besoin de WordPress et veulent arrêter les frais.",
        highlighted: false
    }
];

// FAQs (10 questions)
const faqs = [
    {
        question: "WordPress ou site sur-mesure : comment choisir ?",
        answer: "WordPress se justifie si vous publiez souvent, si plusieurs personnes éditent le site, ou si un plugin métier couvre un besoin précis. Pour un site vitrine qui change peu, une stack moderne coûte moins cher à l'usage, va plus vite et ne demande aucune maintenance. L'audit gratuit tranche la question pour votre cas précis."
    },
    {
        question: "Combien coûte un freelance WordPress en Suisse ?",
        answer: "Chez moi : création à partir de CHF 1'490, refonte à partir de CHF 2'490 (audit inclus), migration sur devis. Le marché suisse romand pratique des tarifs très variables — méfiez-vous des forfaits flous sans audit préalable ni périmètre écrit."
    },
    {
        question: "Mon site WordPress est lent : refonte ou migration ?",
        answer: "Ça dépend de l'usage. Si vous publiez régulièrement et que la base est saine : refonte dans WordPress (nettoyage, thème refait). Si c'est un site vitrine qui ne bouge presque jamais : la migration vers une stack moderne élimine le problème à la racine — plus de plugins, plus de lenteur, plus de maintenance. L'audit gratuit vous donne la réponse chiffrée."
    },
    {
        question: "Peut-on migrer un site WordPress sans perdre son référencement ?",
        answer: "Oui, à condition de faire les choses dans l'ordre : inventaire des URLs existantes, redirections 301 systématiques, reprise des balises et des contenus, vérification de l'indexation après bascule. C'est le cœur de ma méthode de migration — votre historique Google est un actif, on ne le jette pas."
    },
    {
        question: "Combien de temps prend une refonte WordPress ?",
        answer: "Entre 2 et 4 semaines après l'audit, selon la taille du site. Votre site actuel reste en ligne pendant tout le chantier : je travaille sur une copie et on bascule seulement quand vous avez validé."
    },
    {
        question: "Faut-il un contrat de maintenance WordPress ?",
        answer: "Si vous restez sur WordPress : oui, un minimum (mises à jour, sauvegardes, sécurité) — soit par moi, soit en interne après formation. Si vous migrez vers une stack moderne : la question disparaît, il n'y a presque rien à maintenir. Dans tous les cas, chez moi la maintenance est optionnelle, jamais un abonnement forcé."
    },
    {
        question: "Pourquoi un freelance plutôt qu'une agence WordPress ?",
        answer: "Vous parlez directement à celui qui audite et qui code. Pas de chef de projet entre nous, pas de couches de facturation. Sur un projet WordPress typique de PME, ça change le budget du simple au double — et la réactivité avec."
    },
    {
        question: "Travaillez-vous avec WooCommerce ?",
        answer: "Oui, pour les boutiques existantes : optimisation, nettoyage, refonte. Pour une nouvelle boutique, je compare d'abord WooCommerce avec les alternatives selon votre catalogue et vos moyens de paiement (TWINT, cartes) — WooCommerce n'est pas toujours la meilleure option en Suisse."
    },
    {
        question: "Reprenez-vous des sites créés par un autre prestataire ?",
        answer: "C'est même la majorité de mes missions WordPress. Site hérité d'une agence fermée, d'un freelance injoignable ou d'un stagiaire parti : je commence par l'audit, je documente ce qui existe, et vous repartez avec un site que vous maîtrisez."
    },
    {
        question: "Webflow ou WordPress en 2026 ?",
        answer: "Webflow pour un site visuel géré en autonomie sans plugins ; WordPress pour le blog intensif et les besoins couverts par des plugins métier. Je travaille avec les deux — voyez aussi ma page développeur Webflow pour comparer les approches."
    }
];
schemas.push(getFAQPageSchema(faqs));

// Local zones
const zones = [
    { name: "Genève", type: "primary", icon: "ri-map-pin-fill" },
    { name: "Vaud", type: "secondary", icon: "ri-map-pin-line" },
    { name: "Valais", type: "secondary", icon: "ri-map-pin-line" },
    { name: "Neuchâtel", type: "secondary", icon: "ri-map-pin-line" },
    { name: "Fribourg", type: "secondary", icon: "ri-map-pin-line" },
    { name: "Toute Suisse romande", type: "tertiary", icon: "ri-global-line" }
];

// Project type options for form
const projectTypes = [
    { value: "creation-wordpress", label: "Création de site WordPress" },
    { value: "refonte-wordpress", label: "Refonte d'un site WordPress existant" },
    { value: "migration-wordpress", label: "Migration vers une stack moderne" },
    { value: "ne-sait-pas", label: "Je ne sais pas encore" }
];

// Budget options for form
const budgetOptions = [
    { value: "moins-1500", label: "< 1'500 CHF" },
    { value: "1500-3000", label: "1'500 - 3'000 CHF" },
    { value: "3000-6000", label: "3'000 - 6'000 CHF" },
    { value: "plus-6000", label: "> 6'000 CHF" },
    { value: "ne-sait-pas", label: "Je ne sais pas" }
];
---

<Layout
    title={seoData.title}
    description={seoData.description}
    schemas={schemas}
>
    <Header />

    <!-- ============================================== -->
    <!-- HERO SECTION -->
    <!-- ============================================== -->
    <section class="hero-section -mt-[120px] pt-[150px] pb-16 md:pt-[160px] md:pb-20 px-4 relative overflow-hidden">
        <!-- Gradient mesh background -->
        <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
            <div class="absolute top-0 -left-20 w-[500px] h-[500px] bg-[var(--blue)] opacity-20 blur-[120px] rounded-full"></div>
            <div class="absolute top-1/3 -right-20 w-[400px] h-[400px] bg-[var(--violet)] opacity-15 blur-[100px] rounded-full"></div>
            <div class="absolute bottom-0 left-1/3 w-[300px] h-[300px] bg-[var(--blue)] opacity-10 blur-[80px] rounded-full"></div>
        </div>

        <div class="max-w-4xl mx-auto relative z-10">
            <!-- Centered text content -->
            <div class="text-center">
                <!-- H1 SEO discret -->
                <h1 class="seo-h1 mb-8 mt-8">Freelance WordPress à Genève : création, refonte et migration</h1>

                <!-- Main title -->
                <p class="text-3xl md:text-4xl lg:text-5xl font-normal tracking-tight mb-6" data-animate="fade-up">
                    Votre site WordPress mérite mieux<br/>
                    <span class="relative inline-block">
                        <span class="relative z-10">que de ramer dans son coin</span>
                    </span>
                </p>

                <!-- Description -->
                <p class="text-lg md:text-xl text-gray-600 mb-8 leading-relaxed max-w-2xl mx-auto" data-animate="fade-up" data-delay="0.1">
                    Vous voulez un site WordPress propre, ou votre site actuel vous pose problème ?<br class="hidden md:block"/>
                    <strong class="text-[var(--text)]">Un freelance WordPress à Genève</strong> qui crée, refait ou migre —<br class="hidden md:block"/>
                    avec un audit gratuit et un avis honnête pour commencer.
                </p>

                <!-- CTAs centered -->
                <div class="flex flex-col sm:flex-row gap-4 justify-center mb-16 md:mb-20" data-animate="fade-up" data-delay="0.2">
                    <a
                        href="#contact"
                        class="
                            bg-[var(--blue)]
                            border-2 border-black
                            px-6 py-4
                            text-lg font-medium
                            shadow-[4px_4px_0px_rgba(0,0,0,1)]
                            transition-all duration-200
                            hover:bg-[var(--yellow)]
                            hover:shadow-[2px_2px_0px_rgba(0,0,0,1)]
                            hover:translate-x-[2px] hover:translate-y-[2px]
                            flex items-center justify-center gap-2
                        "
                    >
                        <i class="ri-stethoscope-line"></i>
                        Obtenir un audit gratuit
                    </a>
                    <a
                        href="#prestations"
                        class="
                            bg-white
                            border-2 border-black
                            px-6 py-4
                            text-lg font-medium
                            transition-all duration-200
                            hover:bg-gray-100
                            flex items-center justify-center gap-2
                        "
                    >
                        Création, refonte ou migration ?
                        <i class="ri-arrow-down-line"></i>
                    </a>
                </div>
            </div>

            <!-- Browser mockup centered -->
            <div class="w-full mx-auto relative" data-animate="scale" data-delay="0.3">
                <div class="bg-white border-3 border-black shadow-[8px_8px_0px_rgba(0,0,0,1)] relative">
                    <!-- Browser bar -->
                    <div class="flex items-center gap-2 p-3 border-b-2 border-black bg-gray-50">
                        <div class="flex gap-1.5">
                            <div class="w-3 h-3 rounded-full bg-red-400 border border-black"></div>
                            <div class="w-3 h-3 rounded-full bg-yellow-400 border border-black"></div>
                            <div class="w-3 h-3 rounded-full bg-green-400 border border-black"></div>
                        </div>
                        <div class="flex-1 bg-white border border-black px-3 py-1 text-xs text-gray-400 font-mono text-center">
                            votresite.ch
                        </div>
                    </div>
                    <!-- Screenshot -->
                    <img
                        src={wordpressHero.src}
                        alt="Refonte d'un site WordPress lent par un freelance à Genève"
                        class="w-full h-auto"
                    />
                </div>
                <!-- Score badge -->
                <div class="absolute -top-4 -left-4 bg-white border-2 border-black px-3 py-2 shadow-[3px_3px_0px_rgba(0,0,0,1)] -rotate-6">
                    <span class="font-mono text-sm font-bold text-[var(--blue)]">90+</span>
                    <span class="text-xs text-gray-500 block">Google</span>
                </div>
                <!-- Speed badge -->
                <div class="absolute -bottom-4 -right-4 bg-[var(--blue)] border-2 border-black px-4 py-2 shadow-[3px_3px_0px_rgba(0,0,0,1)] rotate-3">
                    <span class="font-bold text-sm">Audit 48h</span>
                </div>
            </div>

            <!-- Location badge centered -->
            <div class="flex items-center justify-center gap-2 text-sm text-gray-500 mt-12">
                <i class="ri-map-pin-fill text-[var(--blue)]"></i>
                <span>Basé à Genève | Service en Suisse romande</span>
            </div>
        </div>
    </section>

    <!-- PAIN POINTS SECTION -->
    <section id="problemes" class="py-20 md:py-28 px-4 bg-white border-y-2 border-black relative overflow-hidden">
        <BackgroundGlitchGrid />
        <div class="max-w-5xl mx-auto relative z-10">
            <!-- Section header -->
            <div class="text-center mb-12 md:mb-16" data-animate="fade-up">
                <span class="inline-flex items-center gap-2 text-xs font-mono uppercase tracking-[0.2em] text-gray-500 mb-4">
                    <span class="w-8 h-px bg-gray-400"></span>
                    problèmes
                    <span class="w-8 h-px bg-gray-400"></span>
                </span>
                <h2 class="text-3xl md:text-4xl font-normal tracking-tight mb-4">
                    <span class="relative inline-block">
                        <span class="absolute bg-red-200 w-full h-[40%] left-0 bottom-1 -z-1"></span>
                        Votre WordPress vous fait ça ?
                    </span>
                </h2>
                <p class="text-lg text-gray-600">Quatre situations que je retrouve chez la plupart des PME romandes qui me contactent.</p>
            </div>

            <!-- Pain points grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6 mb-12" data-animate-stagger>
                {painPoints.map((point) => (
                    <div class="pain-card bg-[var(--main-bg)] border-2 border-black p-6 relative transition-all duration-200 hover:-translate-y-1 hover:shadow-[4px_4px_0px_rgba(0,0,0,0.2)]" data-animate-item>
                        <!-- Red X icon -->
                        <div class="w-10 h-10 bg-red-100 border-2 border-red-300 flex items-center justify-center mb-4">
                            <i class="ri-close-line text-red-500 text-xl"></i>
                        </div>
                        <h3 class="text-lg font-bold mb-2">{point.title}</h3>
                        <p class="text-gray-600 text-sm leading-relaxed">{point.description}</p>
                    </div>
                ))}
            </div>

            <!-- Good news callout -->
            <div class="bg-[var(--blue)] bg-opacity-10 border-2 border-[var(--blue)] p-6 md:p-8 text-center" data-animate="fade-up">
                <p class="text-lg md:text-xl font-medium">
                    <i class="ri-lightbulb-line text-[var(--blue)] mr-2"></i>
                    <strong>La bonne nouvelle ?</strong> WordPress mal fait rame. Bien fait, il tient la route. Et quand il ne convient plus, on migre — sans perdre votre référencement.
                </p>
            </div>
        </div>
    </section>

    <!-- 3 INTENTS SECTION -->
    <section id="prestations" class="py-20 md:py-28 px-4 relative overflow-hidden">
        <BackgroundCircuitBoard animated={true} />
        <div class="max-w-5xl mx-auto relative z-10">
            <!-- Section header -->
            <div class="text-center mb-12 md:mb-16" data-animate="fade-up">
                <span class="inline-flex items-center gap-2 text-xs font-mono uppercase tracking-[0.2em] text-gray-500 mb-4">
                    <span class="w-8 h-px bg-gray-400"></span>
                    prestations
                    <span class="w-8 h-px bg-gray-400"></span>
                </span>
                <h2 class="text-3xl md:text-4xl font-normal tracking-tight mb-4">
                    Trois trajectoires pour votre site WordPress
                </h2>
                <p class="text-lg text-gray-600 max-w-2xl mx-auto">
                    Créer proprement, refaire ce qui rame, ou migrer vers du moderne. <strong>L'audit gratuit détermine la bonne trajectoire</strong> — pas mes préférences.
                </p>
            </div>

            <!-- Intent blocks -->
            <div class="space-y-8">
                {intents.map((intent, index) => (
                    <div class="bg-white border-3 border-black p-6 md:p-8 shadow-[6px_6px_0px_rgba(0,0,0,0.2)]" data-animate="fade-up" id={intent.id}>
                        <div class="grid grid-cols-1 md:grid-cols-5 gap-6">
                            <div class="md:col-span-2">
                                <div class="flex items-center gap-3 mb-4">
                                    <span class="w-12 h-12 bg-[var(--blue)] border-2 border-black flex items-center justify-center">
                                        <i class={`${intent.icon} text-2xl`}></i>
                                    </span>
                                    <span class="font-mono text-sm text-gray-400">0{index + 1}</span>
                                </div>
                                <h3 class="text-xl md:text-2xl font-bold mb-3">{intent.title}</h3>
                                <p class="text-gray-600 text-sm leading-relaxed">{intent.intro}</p>
                            </div>
                            <div class="md:col-span-3 md:pl-6 md:border-l-2 md:border-dashed md:border-gray-300">
                                <ul class="space-y-3">
                                    {intent.features.map((feature) => (
                                        <li class="flex items-start gap-2 text-sm text-gray-700">
                                            <i class="ri-check-line text-[var(--blue)] mt-0.5 flex-shrink-0"></i>
                                            <span>{feature}</span>
                                        </li>
                                    ))}
                                </ul>
                            </div>
                        </div>
                    </div>
                ))}
            </div>

            <!-- Bridge note -->
            <div class="bg-white border-2 border-black p-6 text-center mt-8" data-animate="fade-up">
                <p class="text-gray-600">
                    <i class="ri-information-line text-[var(--blue)] mr-2"></i>
                    <strong>La migration vous intrigue ?</strong> C'est le pont vers le <a href="/services/creation-site-web" class="text-[var(--blue)] font-medium hover:underline">site sur-mesure</a> : mêmes contenus, zéro maintenance, vitesse maximale. On en parle à l'audit.
                </p>
            </div>
        </div>
    </section>

    <!-- METHODOLOGY SECTION -->
    <section id="methode" class="py-20 md:py-28 px-4 bg-white border-y-2 border-black relative overflow-hidden">
        <BackgroundProgressFlow />
        <div class="max-w-5xl mx-auto relative z-10">
            <!-- Section header -->
            <div class="text-center mb-12 md:mb-16" data-animate="fade-up">
                <span class="inline-flex items-center gap-2 text-xs font-mono uppercase tracking-[0.2em] text-gray-500 mb-4">
                    <span class="w-8 h-px bg-gray-400"></span>
                    méthode
                    <span class="w-8 h-px bg-gray-400"></span>
                </span>
                <h2 class="text-3xl md:text-4xl font-normal tracking-tight mb-4">
                    Comment ça se passe ?
                </h2>
                <p class="text-lg text-gray-600 max-w-2xl mx-auto">
                    Tout commence par un <strong class="text-[var(--blue)]">audit gratuit</strong> de votre site WordPress. Votre site reste en ligne pendant tout le chantier.
                </p>
            </div>

