    .wp-tier-features { gap: 10px; }
    .wp-tier-features li { font-size: 14px; line-height: 1.45; }
    .co-root .wp-tier-ideal { margin-top: auto; padding-top: 16px; border-top: 1px solid var(--line); font-size: 13px; line-height: 1.5; color: var(--muted); }
    .wp-tier-ideal strong { color: var(--ink); }

    .wp-pricenote { position: relative; margin-top: 28px; padding: 30px 32px; background: var(--surface); border: 1px solid var(--line-2); }
    .wp-pricenote-title { font-size: 1.1rem; display: inline-flex; align-items: center; gap: 8px; }
    .wp-pricenote-title i { color: var(--accent); }
    .wp-pricenote-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px 40px; margin-top: 18px; }
    .wp-pricenote-grid li { font-size: 14px; }

    /* ── FAQ (accordéon natif <details> — smooth via ::details-content, zéro JS) ── */
    .wp-faq { border-top: 1px solid var(--line); }
    .wp-faq details { border-bottom: 1px solid var(--line); }
    .wp-faq summary {
        list-style: none; cursor: pointer; padding: 20px 0;
        display: flex; justify-content: space-between; align-items: center; gap: 20px;
        font-size: 1.1rem; font-weight: 600; letter-spacing: -0.01em; color: var(--ink);
    }
    .wp-faq summary::-webkit-details-marker { display: none; }
    .wp-faq summary i { transition: transform .2s ease-out; color: var(--muted); font-size: 22px; flex: none; }
    .wp-faq details[open] summary i { transform: rotate(180deg); }
