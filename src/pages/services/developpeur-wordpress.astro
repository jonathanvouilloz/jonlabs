    /* ── Étapes méthode ── */
    .wp-steps { display: flex; flex-direction: column; margin-top: 32px; border-top: 1px solid var(--line); }
    .wp-step { display: grid; grid-template-columns: 56px 1fr; gap: 20px; padding: 22px 0; border-bottom: 1px solid var(--line); }
