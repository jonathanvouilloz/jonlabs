<style is:global>
    /* ══ CRÉATION SITE WEB — styles .cr-* (namespace scopé, corps .co-root) ══ */

    /* ── Hero ── */
    .cr-hero-grid { display: grid; grid-template-columns: 1.05fr 0.95fr; gap: 48px; align-items: center; }
    .cr-hero-title { font-size: clamp(2.2rem, 5vw, 3.4rem); }
