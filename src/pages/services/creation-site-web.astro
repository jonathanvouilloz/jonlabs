        display: inline-flex; align-items: center; gap: 7px; padding: 9px 15px;
        font-size: 13.5px; font-weight: 500; background: var(--surface); border: 1px solid var(--line-2); color: var(--ink);
        transition: border-color .18s ease-out, color .18s ease-out;
    }
    .cr-geo-link i { color: var(--muted); font-size: 15px; transition: color .18s ease-out; }
