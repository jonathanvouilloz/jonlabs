    .cr-tier-pricelabel { font-size: 13px; color: var(--muted); width: 100%; }
    .cr-tier-price b { font-size: 2.3rem; font-weight: 700; letter-spacing: -0.03em; line-height: 1; }
    .cr-tier-cur { font-size: 15px; color: var(--muted); font-weight: 500; }
    .cr-tier-features { gap: 10px; }
    .cr-tier-features li { font-size: 14px; line-height: 1.45; }
    .co-root .cr-tier-ideal { margin-top: auto; padding-top: 16px; border-top: 1px solid var(--line); font-size: 13px; line-height: 1.5; color: var(--muted); }
    .cr-tier-ideal strong { color: var(--ink); }

    .cr-pricenote { position: relative; margin-top: 28px; padding: var(--pad-encart); background: var(--surface); border: 1px solid var(--line-2); }
    .cr-pricenote-title { font-size: 1.1rem; display: inline-flex; align-items: center; gap: 8px; }
    .cr-pricenote-title i { color: var(--accent); }
    .cr-pricenote-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px 40px; margin-top: 18px; }
    .cr-pricenote-grid li { font-size: 14px; }
    .co-root .cr-pricenote-pay { margin-top: 18px; font-size: 14px; color: var(--muted); display: flex; align-items: center; gap: 8px; }
    .cr-pricenote-pay i { color: var(--accent); }

    /* ── FAQ (accordéon natif <details> — smooth via ::details-content, zéro JS) ── */
    .cr-faq { border-top: 1px solid var(--line); }
    .cr-faq details { border-bottom: 1px solid var(--line); }
    .cr-faq summary {
        list-style: none; cursor: pointer; padding: 20px 0;
