    .co-root .cr-quote figcaption { margin-top: 16px; font-size: 14px; color: var(--muted); }

    /* ── Tarifs ── */
    .cr-tiers { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; align-items: start; margin-top: 36px; }
    .cr-tier { position: relative; display: flex; flex-direction: column; gap: 18px; padding: 30px 26px; background: var(--surface); border: 1px solid var(--line-2); }
    .cr-tier--reco { border-color: var(--accent); box-shadow: 0 0 0 1px var(--accent); }
