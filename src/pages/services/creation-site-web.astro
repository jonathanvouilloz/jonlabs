    .cr-hero-btns { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 28px; }
    .cr-hero-btns .co-btn i { transition: transform .18s ease-out; }
    .cr-hero-btns .co-btn:hover i { transform: translateY(2px); }
    .co-root .cr-hero-loc { margin-top: 22px; font-size: 13.5px; display: inline-flex; align-items: center; gap: 6px; }
    .cr-hero-loc i { color: var(--accent); }

    /* browser mockup */
    .cr-hero-media { position: relative; }
    .cr-browser { position: relative; background: var(--surface); border: 1px solid var(--line-2); }
    .cr-browser-bar { display: flex; align-items: center; gap: 8px; padding: 11px 14px; border-bottom: 1px solid var(--line); background: var(--bg); }
    .cr-browser-dot { width: 9px; height: 9px; border-radius: 999px; background: var(--line-2); flex: none; }
    .cr-browser-url { flex: 1; text-align: center; font-size: 12px; color: var(--muted); font-variant-numeric: tabular-nums; }
    .cr-browser-img { display: block; width: 100%; height: auto; }
    .cr-badge { position: absolute; z-index: 4; background: var(--surface); border: 1px solid var(--line-2); padding: var(--pad-pill); font-size: 12px; font-weight: 600; }
    .cr-badge--score { top: -16px; left: -14px; display: flex; flex-direction: column; line-height: 1.1; }
    .cr-badge--score b { color: var(--accent); font-size: 15px; }
    .cr-badge--score span { color: var(--muted); font-size: 10px; text-transform: uppercase; letter-spacing: 0.08em; }
    .cr-badge--speed { bottom: -16px; right: -14px; background: var(--accent); border-color: var(--accent); color: #fff; }

    /* ── Cartes génériques (problèmes / résultats / tech) ── */
    .cr-grid { display: grid; gap: 16px; margin-top: var(--space-block); }
    .cr-grid--2 { grid-template-columns: repeat(2, 1fr); }
    .cr-grid--3 { grid-template-columns: repeat(3, 1fr); }
    .cr-card {
        position: relative; display: flex; flex-direction: column; gap: 10px; padding: var(--pad-card);
        background: var(--surface); border: 1px solid var(--line-2);
        transition: box-shadow .18s ease-out, transform .18s ease-out;
    }
    .cr-card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(20,22,26,.07); }
    .cr-card-icon { font-size: 24px; color: var(--accent); line-height: 1; }
    .cr-card-title { font-size: 1.1rem; }
    .cr-card-text { font-size: 14px; line-height: 1.55; color: var(--muted); }
    .cr-card-tag { margin-top: auto; padding-top: 4px; font-size: 12.5px; font-weight: 600; color: var(--accent); display: inline-flex; align-items: center; gap: 5px; }

    /* ── Notes / callouts ── */
    .cr-note { display: flex; align-items: flex-start; gap: 12px; margin-top: 20px; padding: 18px 22px; border: 1px solid var(--line-2); background: var(--surface); }
    .cr-note i { color: var(--accent); font-size: 20px; flex: none; margin-top: 1px; }
