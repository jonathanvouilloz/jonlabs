---
// Développement d'application mobile — sous-page service (blueprint).
// Migrée du brutaliste vers le design system .co-* : sections cadrées, filets fins,
// accent teal unique, Inter Tight × Instrument Serif. Namespace .am-*.
//
// Pas de formulaire embarqué : les CTA pointent vers cal.com (appel découverte) et
// /contact. HARD-PRESERVE : Schema.org (serviceSchemas/breadcrumb/FAQ), tous les
// liens SEO internes (cluster /blog/*, /portfolio/*, /services/*, /about, /contact),
// copywriting réel.

import '../../styles/global.css';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

// Schema.org
import { serviceSchemas, SITE_URL } from '../../data/schema';
import { getFAQPageSchema } from '../../lib/seo';
import { getBreadcrumbSchema } from '../../lib/seo';

// SEO Data
const seoData = {
    title: "Développement d'application mobile à Genève | Jonlabs",
    description: "Développeur freelance à Genève : applications mobiles iOS et Android pour PME et startups romandes. Natif, Flutter, React Native ou PWA. Devis en CHF."
};

// Schema.org data
const breadcrumb = getBreadcrumbSchema([
    { name: "Accueil", url: SITE_URL },
    { name: "Services", url: `${SITE_URL}/services` },
    { name: "Développement application mobile", url: `${SITE_URL}/services/developpement-application-mobile` }
]);
const schemas: any[] = [serviceSchemas["developpement-application-mobile"], breadcrumb];

// Pain points data
const painPoints = [
    {
        icon: "ri-user-voice-line",
        title: "Tes clients réclament une app",
        description: "Tes utilisateurs te demandent une application — pour réserver, suivre une commande, recevoir une notification. Un site responsive ne suffit plus, mais tu ne sais pas par où commencer ni ce que ça implique vraiment."
    },
    {
        icon: "ri-price-tag-3-line",
        title: "Le devis d'agence t'a refroidi",
        description: "Tu as demandé un devis pour une app mobile et le chiffre t'a fait reculer. 60 000 CHF, 8 mois, trois interlocuteurs et un chef de projet entre toi et le code. Il y a forcément un moyen plus direct et plus raisonnable."
    },
    {
        icon: "ri-git-branch-line",
        title: "Tu hésites entre app et site",
        description: "Application native, application hybride, PWA, site mobile… On t'a vendu plein de termes, mais personne ne t'a dit honnêtement ce dont TON projet a besoin. Tu veux un avis franc avant de dépenser un franc."
    },
    {
        icon: "ri-error-warning-line",
        title: "Ton app dort, personne ne la maintient",
        description: "Tu as déjà une application, mais elle plante, elle n'est plus à jour sur les stores, et le prestataire qui l'a faite a disparu. Tu as besoin de quelqu'un qui reprenne les choses en main proprement."
    }
];

// Method steps
const methodSteps = [
    {
        step: "1",
        title: "Cadrage",
        description: "On définit ensemble ce que ton app doit vraiment faire — et sur quelles plateformes (iOS, Android, ou les deux). On tranche la question technique : natif, hybride ou PWA, selon ton usage réel et ton budget. Pas de feature inutile, pas de jargon.",
        duration: "1-2h appel + échanges async"
    },
    {
        step: "2",
        title: "Construction",
        description: "Je développe ton app avec des technologies modernes et durables — Flutter ou React Native pour couvrir iOS et Android avec un seul code. Tu vois des versions testables sur ton téléphone à chaque itération. Tu n'as pas besoin de comprendre le code, juste de me dire ce qui va ou pas.",
        duration: "Quelques semaines selon le périmètre"
    },
    {
        step: "3",
        title: "Lancement",
        description: "Je m'occupe de la publication sur l'App Store et le Google Play Store — comptes développeurs, fiches, captures, validation. Tu repars avec ton app en ligne, une documentation claire, et la possibilité de la faire évoluer sans dépendre de moi.",
        duration: "Publication + passation"
    }
];

// Differentiators
const differentiators = [
    {
        icon: "ri-user-line",
        text: "Un seul interlocuteur : tu parles à celui qui code, pas à un chef de projet"
    },
    {
        icon: "ri-smartphone-line",
        text: "iOS et Android d'un seul code (Flutter / React Native) : tu ne paies pas deux fois"
    },
    {
        icon: "ri-shield-check-line",
        text: "Qualité suisse, flexibilité freelance : réactivité et rigueur, données conformes nLPD"
    },
    {
        icon: "ri-door-open-line",
        text: "Pas de lock-in : tu repars avec un code propre, documenté et publié à ton nom"
    }
];

// Results
const results = [
    {
        icon: "ri-store-2-line",
        title: "Une app publiée sur les stores",
        description: "Pas une maquette cliquable. Une vraie application téléchargeable sur l'App Store et le Play Store, que tes utilisateurs peuvent installer et utiliser."
    },
    {
        icon: "ri-smartphone-line",
        title: "iOS + Android sans doubler le budget",
        description: "Grâce à Flutter ou React Native, ton app tourne sur les deux plateformes à partir d'un seul code. Tu couvres tout le marché sans payer deux développements."
    },
    {
        icon: "ri-links-line",
        title: "Une app connectée à tes outils",
        description: "Ton application peut parler à ton CRM, ton agenda, ta facturation ou tes automatisations. Une app isolée perd l'essentiel de sa valeur — la tienne sera branchée."
    },
    {
        icon: "ri-stack-line",
        title: "Une base solide pour la suite",
        description: "Code propre, documenté, sans dette technique cachée. Tu peux itérer dessus, ajouter des fonctionnalités, ou confier la suite à quelqu'un d'autre. Aucun verrou."
    },
    {
        icon: "ri-shake-hands-line",
        title: "Un avis honnête, dès le départ",
        description: "Si une PWA ou un site suffit pour ton cas, je te le dis. Tu investis dans une app mobile seulement si elle apporte vraiment quelque chose à ton business."
    }
];

// Price factors
const priceFactors = [
    "La complexité et le nombre de fonctionnalités",
    "Le choix technique : natif, hybride ou PWA",
    "Le nombre de plateformes (iOS, Android, ou les deux)",
    "Le besoin d'un backend, d'une API ou d'intégrations métier"
];

// Cluster articles — maillage interne vers le contenu éditorial du cluster mobile
const clusterGroups = [
    {
        label: "Décider",
        icon: "ri-question-answer-line",
        articles: [
            { title: "App mobile pour PME : vaut-il le coup ?", href: "/blog/application-mobile-pme-suisse" },
            { title: "Application mobile ou PWA : comment choisir ?", href: "/blog/application-mobile-ou-pwa" },
            { title: "Freelance ou agence pour votre app mobile ?", href: "/blog/freelance-ou-agence-application-mobile" }
        ]
    },
    {
        label: "Choisir la techno",
        icon: "ri-cpu-line",
        articles: [
            { title: "Flutter vs React Native : lequel choisir ?", href: "/blog/flutter-vs-react-native-pme" },
            { title: "Application native vs hybride : les différences", href: "/blog/application-native-vs-hybride" }
        ]
    },
    {
        label: "Budgéter",
        icon: "ri-coins-line",
        articles: [
            { title: "Prix d'une application mobile en Suisse 2026", href: "/blog/prix-application-mobile-suisse" },
            { title: "MVP application mobile : combien prévoir ?", href: "/blog/budget-mvp-application-mobile" }
        ]
    },
    {
        label: "S'inspirer",
        icon: "ri-lightbulb-line",
        articles: [
            { title: "Application métier sur mesure : 5 cas concrets", href: "/blog/application-metier-pme-sur-mesure" },
            { title: "App mobile + automatisation : connecter son app", href: "/blog/application-mobile-automatisation-pme" }
        ]
    }
];

// FAQs
const faqs = [
    {
        question: "Combien coûte le développement d'une application mobile en Suisse ?",
        answer: "Ça dépend beaucoup du périmètre, mais on parle généralement d'une fourchette à partir de 10 000–15 000 CHF pour une app simple, et qui monte selon la complexité (backend, intégrations, design sur mesure). En passant par un freelance plutôt qu'une agence, tu évites les coûts de structure. Je te détaille tout dans un devis clair, sans surprise. Pour comprendre ce qui fait varier le prix, j'ai écrit un guide complet sur le prix d'une application mobile en Suisse."
    },
    {
        question: "Combien de temps faut-il pour développer une app ?",
        answer: "Pour un MVP ciblé sur les fonctionnalités essentielles, quelques semaines suffisent. Une application plus complète avec backend, comptes utilisateurs et intégrations prend évidemment plus de temps. On avance par itérations courtes : tu testes des versions sur ton téléphone tout au long, pas seulement à la fin."
    },
    {
        question: "Application native ou hybride : laquelle choisir ?",
        answer: "Le natif offre les meilleures performances pour des apps très poussées (jeux, accès matériel intensif). L'hybride — via Flutter ou React Native — couvre iOS et Android avec un seul code, pour un coût et un délai réduits : c'est le meilleur choix pour la grande majorité des projets PME. On tranche ensemble selon ton usage réel."
    },
    {
        question: "Faut-il publier sur l'App Store ET le Play Store ?",
        answer: "Dans la plupart des cas oui, pour toucher à la fois les utilisateurs iPhone et Android. Avec une techno hybride, ça ne double pas le coût de développement. Je m'occupe de la mise en ligne sur les deux stores : comptes développeurs, fiches, captures et validation."
    },
    {
        question: "Et la maintenance une fois l'app lancée ?",
        answer: "Une app n'est jamais \"finie\" : les systèmes iOS et Android évoluent, et les stores demandent des mises à jour régulières. On peut prévoir un suivi léger après le lancement. Et si tu as déjà une app abandonnée, je peux la reprendre et la remettre à niveau."
    },
    {
        question: "App mobile ou PWA : comment savoir ce qu'il me faut ?",
        answer: "Une PWA (application web installable) coûte moins cher et se déploie sans passer par les stores, mais elle a des limites — notamment sur iOS et l'accès au matériel. Pour beaucoup de PME, c'est largement suffisant. Mon rôle, c'est de te le dire honnêtement avant que tu investisses. J'ai détaillé les critères de choix dans un article dédié."
    },
    {
        question: "Pourquoi un freelance à Genève plutôt qu'une agence ou un dev offshore ?",
        answer: "La proximité : on se voit, on parle la même langue, on comprend le contexte suisse. La réactivité : pas de chef de projet intermédiaire, tu parles directement à celui qui code. La confiance : tes données restent en Suisse, conformes à la nLPD, et tu sais exactement qui travaille sur ton app."
    }
];
schemas.push(getFAQPageSchema(faqs));

// Local zones
const zones = [
    { name: "Genève", type: "primary", icon: "ri-map-pin-fill" },
    { name: "Lausanne", type: "secondary", icon: "ri-map-pin-line" },
    { name: "Vaud", type: "secondary", icon: "ri-map-pin-line" },
    { name: "Toute Suisse romande", type: "tertiary", icon: "ri-global-line" }
];
---

<Layout title={seoData.title} description={seoData.description} schemas={schemas}>
    <Header />

    <main class="co-root">

        <!-- ══ HERO ══ -->
        <section class="co-sec co-pad co-hero am-hero" style="padding:64px 40px 56px;">
            <div class="am-hero-grid">
                <div class="am-hero-copy">
                    <h1 class="am-hero-title" data-animate data-delay="0.1">
                        Ton application mobile <span class="co-ser">iOS &amp; Android.</span>
                    </h1>
                    <p class="am-hero-sub" data-animate data-delay="0.15">
                        Pensée pour tes utilisateurs, pas pour une agence.
                    </p>
                    <p class="am-hero-lead" data-animate data-delay="0.2">
                        PME, startup ou indépendant : tu n'as pas besoin d'un tunnel de 6 mois à 60 000 CHF.
                        Tu as besoin d'un <strong>développeur mobile en Suisse romande</strong> qui code ton app,
                        la publie sur les stores et te dit la vérité sur ce qu'il te faut vraiment.
                    </p>
                    <div class="am-hero-btns" data-animate data-delay="0.3">
                        <a href="https://cal.com/jonathan-vouilloz/appel-de-bienvenue" target="_blank" rel="noopener noreferrer" class="co-btn"><i class="ri-smartphone-line"></i> Discuter de mon app</a>
                        <a href="#methode" class="co-btn co-btn--ghost">Voir comment ça fonctionne <i class="ri-arrow-down-line"></i></a>
                    </div>
                    <p class="am-hero-loc co-mut" data-animate data-delay="0.4">
                        <i class="ri-map-pin-fill"></i> Basé à Genève · Service en Suisse romande
                    </p>
                </div>

                <div class="am-hero-media" data-animate="scale" data-delay="0.3">
                    <div class="am-panel co-frame">
                        <span class="co-x tl"></span><span class="co-x tr"></span>
                        <span class="co-x bl"></span><span class="co-x br"></span>
                        <p class="co-eyebrow">Un seul code · deux stores</p>
                        <div class="am-panel-plats">
                            <div class="am-plat"><i class="ri-apple-line" aria-hidden="true"></i><span>iOS · App Store</span></div>
                            <div class="am-plat"><i class="ri-android-line" aria-hidden="true"></i><span>Android · Play Store</span></div>
                        </div>
                        <ul class="co-list co-list--check am-panel-list">
                            <li><i class="ri-check-line"></i><span>Flutter / React Native</span></li>
                            <li><i class="ri-check-line"></i><span>Publication sur les stores incluse</span></li>
                            <li><i class="ri-check-line"></i><span>Code propre, sans lock-in</span></li>
                            <li><i class="ri-check-line"></i><span>Données conformes nLPD</span></li>
                        </ul>
                    </div>
                    <div class="am-badge am-badge--stores">
                        <b>2</b><span>stores</span>
                    </div>
                    <div class="am-badge am-badge--code">1 code</div>
                </div>
            </div>
        </section>

        <!-- ══ 01 · SITUATIONS ══ -->
        <section id="problemes" class="co-sec co-pad" style="padding:56px 40px;">
            <p class="co-eyebrow">01 — Situations</p>
            <h2 style="margin-top:8px;">Tu te <span class="co-ser">reconnais ?</span></h2>
            <p class="co-mut" style="margin-top:10px;max-width:56ch;line-height:1.6;">
                Ces moments où une app devient une vraie question.
            </p>

            <div class="am-grid am-grid--2" data-animate-stagger>
                {painPoints.map((point) => (
                    <div class="am-card co-frame co-frame--reveal" data-animate-item>
                        <i class={`${point.icon} am-card-icon`} aria-hidden="true"></i>
                        <h3 class="am-card-title">{point.title}</h3>
                        <p class="am-card-text">{point.description}</p>
                    </div>
                ))}
            </div>

            <div class="am-story co-frame" data-animate>
                <span class="co-x tl"></span><span class="co-x tr"></span>
                <span class="co-x bl"></span><span class="co-x br"></span>
                <h3 class="am-story-title">Une app, ce n'est pas un site avec des coins arrondis.</h3>
                <p class="am-story-text">
                    La plupart des projets mobiles qui dérapent partent du même endroit :
                    <strong>on construit trop, trop tôt, sans avoir validé que les gens utiliseront vraiment l'app.</strong>
                    Quinze écrans, des fonctionnalités que personne n'ouvrira, et une facture qui gonfle.
                </p>
                <p class="am-story-text">
                    Mon approche est l'inverse : on identifie le cœur de ton app, on le sort vite et bien sur
                    iOS et Android, et on enrichit ensuite — seulement si tes utilisateurs suivent.
                </p>
                <div class="am-story-accent">
                    <p>Une bonne app mobile, c'est d'abord une bonne décision : quoi construire, et surtout quoi ne pas construire.</p>
                </div>
            </div>
        </section>

        <!-- ══ 02 · MÉTHODE ══ -->
        <section id="methode" class="co-sec co-pad" style="padding:56px 40px;">
            <p class="co-eyebrow">02 — Méthode</p>
            <h2 style="margin-top:8px;">Comment ça se passe ?</h2>
            <p class="co-mut" style="margin-top:10px;max-width:60ch;line-height:1.6;">
                Pas de tunnel de développement. Tu testes ton app sur ton téléphone <strong>à chaque étape</strong>.
            </p>

            <div class="am-steps" data-animate-stagger>
                {methodSteps.map((step, index) => (
                    <div class="am-step" data-animate-item>
                        <span class="am-step-num co-index">0{index + 1}</span>
                        <div class="am-step-body">
                            <h3 class="am-step-title">{step.title}</h3>
                            <p class="am-step-text">{step.description}</p>
                            <p class="am-step-dur"><i class="ri-time-line"></i> {step.duration}</p>
                        </div>
                    </div>
                ))}
            </div>

            <div class="am-diff co-frame" data-animate>
                <span class="co-x tl"></span><span class="co-x tr"></span>
                <span class="co-x bl"></span><span class="co-x br"></span>
                <h3 class="am-diff-title">Ce qui change avec Jon Labs</h3>
                <div class="am-diff-grid">
                    {differentiators.map((diff) => (
                        <div class="am-diff-item">
                            <i class={`${diff.icon} am-diff-icon`} aria-hidden="true"></i>
                            <p class="am-diff-text">{diff.text}</p>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <!-- ══ 03 · RÉSULTATS ══ -->
        <section id="resultats" class="co-sec co-pad" style="padding:56px 40px;">
            <p class="co-eyebrow">03 — Résultats</p>
            <h2 style="margin-top:8px;">Ce que tu <span class="co-ser">obtiens.</span></h2>

            <div class="am-grid am-grid--3" data-animate-stagger>
                {results.map((result) => (
                    <div class="am-card co-frame co-frame--reveal" data-animate-item>
                        <i class={`${result.icon} am-card-icon`} aria-hidden="true"></i>
                        <h3 class="am-card-title">{result.title}</h3>
                        <p class="am-card-text">{result.description}</p>
                    </div>
                ))}
            </div>

            <div class="am-note" data-animate>
                <i class="ri-apps-2-line"></i>
                <p>
                    <strong>Un exemple ?</strong> Découvre
                    <a href="/portfolio/isla-plomo" class="am-inline">Isla Plomo</a>,
                    une application web mobile (PWA) installable que j'ai conçue de A à Z, ou l'ensemble de mes
                    <a href="/portfolio" class="am-inline">réalisations</a>.
                </p>
            </div>
        </section>

        <!-- ══ 04 · INVESTISSEMENT ══ -->
        <section id="prix" class="co-sec co-pad" style="padding:56px 40px;">
            <p class="co-eyebrow">04 — Investissement</p>
            <h2 style="margin-top:8px;">Un devis <span class="co-ser">clair.</span></h2>
            <p class="co-mut" style="margin-top:10px;max-width:62ch;line-height:1.6;">
                Chaque app est différente. Une PWA pour tester un usage, ce n'est pas la même chose qu'une
                application native connectée à ton système métier.
            </p>

            <div class="am-pricenote co-frame" data-animate>
                <span class="co-x tl"></span><span class="co-x tr"></span>
                <span class="co-x bl"></span><span class="co-x br"></span>
                <p class="am-pricenote-lead">On en discute, je te fais un devis clair avec un périmètre précis.</p>
                <p class="am-pricenote-sub co-mut">Pas de coûts cachés, pas de surprise en cours de route.</p>

                <h3 class="am-pricenote-title"><i class="ri-information-line"></i> Ce qui influence le prix</h3>
                <ul class="co-list am-pricenote-list">
                    {priceFactors.map((factor) => (<li>{factor}</li>))}
                </ul>
                <p class="am-note-inline">
                    Pour te faire une idée des fourchettes, lis mon guide sur le
                    <a href="/blog/prix-application-mobile-suisse" class="am-inline">prix d'une application mobile en Suisse</a>.
                </p>
            </div>

            <div class="am-cta-row" data-animate>
                <a href="https://cal.com/jonathan-vouilloz/appel-de-bienvenue" target="_blank" rel="noopener noreferrer" class="co-btn"><i class="ri-file-list-3-line"></i> Demander un devis</a>
            </div>
        </section>

        <!-- ══ 05 · RESSOURCES ══ -->
        <section id="ressources" class="co-sec co-pad" style="padding:56px 40px;">
            <p class="co-eyebrow">05 — Ressources</p>
            <h2 style="margin-top:8px;">Tout comprendre avant de te lancer</h2>
            <p class="co-mut" style="margin-top:10px;max-width:64ch;line-height:1.6;">
                Avant de demander un devis, fais-toi ton propre avis. J'ai écrit un dossier complet sur le
                développement d'applications mobiles pour les PME romandes — commence par le
                <a href="/blog/developper-application-mobile-suisse" class="am-inline">guide complet</a>.
            </p>

            <div class="am-grid am-grid--2" data-animate-stagger>
                {clusterGroups.map((group) => (
                    <div class="am-res co-frame" data-animate-item>
                        <div class="am-res-head">
                            <i class={`${group.icon} am-res-icon`} aria-hidden="true"></i>
                            <h3 class="am-res-label">{group.label}</h3>
                        </div>
                        <ul class="am-res-list">
                            {group.articles.map((article) => (
                                <li>
                                    <a href={article.href} class="am-res-link">
                                        <i class="ri-arrow-right-s-line"></i>
                                        <span>{article.title}</span>
                                    </a>
                                </li>
                            ))}
                        </ul>
                    </div>
                ))}
            </div>
        </section>

        <!-- ══ 06 · FAQ (accordéon natif <details>, zéro JS) ══ -->
        <section id="faq" class="co-sec co-pad" style="padding:56px 40px;">
            <p class="co-eyebrow">06 — FAQ</p>
            <h2 style="margin-top:8px;">Questions fréquentes</h2>

            <div class="am-faq" style="margin-top:32px;">
                {faqs.map((faq, index) => (
                    <details open={index === 0}>
                        <summary>
                            {faq.question}
                            <i class="ri-arrow-down-s-line" aria-hidden="true"></i>
                        </summary>
                        <p class="am-faq-answer">{faq.answer}</p>
                    </details>
                ))}
            </div>

            <p class="co-mut" style="margin-top:24px;text-align:center;">
                Autre question ? <a href="/contact" class="am-inline">Contacte-moi directement</a>, je réponds sous 24h.
            </p>
        </section>

        <!-- ══ 07 · À PROPOS ══ -->
        <section id="about" class="co-sec co-pad" style="padding:56px 40px;">
            <p class="co-eyebrow">07 — À propos</p>
            <h2 style="margin-top:8px;">Qui est derrière <span class="co-ser">Jon Labs ?</span></h2>

            <div class="am-about co-frame" data-animate>
                <span class="co-x tl"></span><span class="co-x tr"></span>
                <span class="co-x bl"></span><span class="co-x br"></span>
                <p class="am-about-text">Je suis <strong>Jonathan</strong>, développeur et créateur de solutions digitales basé à Genève.</p>
                <p class="am-about-text">Je ne suis pas une agence avec 15 commerciaux et des juniors qui font le travail. Je suis <strong>ton partenaire technique direct</strong> — celui qui va coder ton application, la publier sur les stores, et t'aider à trancher quand il faut faire des choix.</p>
                <p class="am-about-text">Mon approche : <strong>action plutôt que perfection</strong>. Une app utile entre les mains de tes utilisateurs vaut mieux qu'une roadmap parfaite qui ne sort jamais.</p>
                <p class="am-about-text">J'ai accompagné des entrepreneurs romands, des startups en phase d'amorçage et des PME suisses qui avaient besoin d'outiller leur activité — sans exploser leur budget.</p>
                <a href="/about" class="am-about-link">
                    <i class="ri-user-line"></i> En savoir plus sur mon parcours <i class="ri-arrow-right-line"></i>
                </a>
            </div>
        </section>

