---
import Layout from "../layouts/Layout.astro";
import BlueprintKit from "../components/lab/BlueprintKit.astro";
import { scenarios, serviceSections } from "../data/scenarios";

const pageTitle = "Services Lab — Blueprint";
const pageDescription = "Constellation de scénarios + sections services en blueprint — pairing 04. Page interne de tests.";

// Icônes Remix monochromes par scénario (règle projet : 0 emoji). Clé = scenario.id.
const nodeIcons: Record<string, string> = {
  "website-old": "ri-palette-line",
  "no-presence": "ri-global-line",
  "tools-sync": "ri-links-line",
  "time-lack": "ri-time-line",
  "idea-validation": "ri-lightbulb-line",
  "mvp-urgent": "ri-rocket-line",
};

// Positions statiques des 6 nodes (2 colonnes × 3), ordre = ordre de scenarios[]
const positions = [
  "top:4%;left:15%",
  "top:4%;right:15%",
  "top:39%;left:2%",
  "top:39%;right:2%",
  "bottom:4%;left:15%",
  "bottom:4%;right:15%",
];
---

<Layout title={pageTitle} description={pageDescription} robots="noindex, nofollow">
  <BlueprintKit />

  <div class="co-root">

    <!-- ══ INTRO ══ -->
    <section class="co-sec co-pad" style="padding:52px 40px 40px;">
      <p class="co-eyebrow">Design system · services · interne</p>
      <h1 style="font-size:clamp(2.2rem,5.5vw,3.4rem);margin-top:14px;">
        Services <span class="co-ser">blueprint.</span>
      </h1>
      <p class="co-mut" style="margin-top:14px;max-width:60ch;line-height:1.6;">
        La constellation « clique ta situation » réinterprétée en blueprint : hub cadré crosshairs,
        nodes reliés par filets fins sur fond pointillé, sans néon ni canvas. Clique un scénario pour
        lancer la conversation (vrais messages de <code>scenarios.ts</code>).
      </p>
    </section>

    <!-- ══ 01 · CONSTELLATION ══ -->
    <section class="co-sec co-pad" style="padding:48px 40px 64px;">
      <p class="co-eyebrow">01 — Hero</p>
      <h2 style="margin-top:var(--space-eyebrow);">Dans quelle situation es-tu ?</h2>
      <p class="co-mut" style="margin-top:var(--space-eyebrow);max-width:52ch;">Choisis le scénario qui te ressemble le plus.</p>

      <div class="svc-constellation co-dots" id="svc-constellation">
        <p class="svc-mobilehead co-eyebrow">Clique ta situation</p>

        <svg id="svc-lines" aria-hidden="true"></svg>

        <div class="svc-hub co-frame" id="svc-hub" aria-hidden="true">
          <span class="svc-hub-logo">jonlabs<span style="color:var(--accent);">.</span></span>
        </div>

        {scenarios.map((s, i) => (
          <button class="svc-node co-frame co-frame--reveal" data-scenario-id={s.id} data-i={i} style={positions[i]} data-pillar={s.pillar}>
            <i class={`${nodeIcons[s.id] ?? "ri-focus-3-line"} svc-node-icon`} aria-hidden="true"></i>
            <span class="svc-node-text">
              <strong>{s.title}</strong>
              <span class="co-mut">{s.subtitle}</span>
            </span>
            <i class="ri-arrow-right-up-line svc-node-arrow" aria-hidden="true"></i>
          </button>
        ))}
      </div>
    </section>

    <!-- ══ 02 · SECTIONS DE SERVICES ══ -->
    <section class="co-sec co-pad" id="svc-sections" style="padding:var(--sec-pad-y) var(--sec-pad-x);">
      <p class="co-eyebrow">02 — Offre</p>
      <h2 style="margin-top:var(--space-eyebrow);">Sections de services</h2>

      {serviceSections.map((section) => (
        <div class="svc-section">
          <div class="svc-section-head">
            <h3 class="svc-section-title">{section.title}</h3>
            <p class="co-mut svc-section-accroche">{section.accroche}</p>
          </div>
          <div class="svc-grid">
            {section.subServices.map((sub) => (
              <article class="svc-card">
                <h4 class="svc-card-title">{sub.title}</h4>
                <p class="svc-card-desc">{sub.description}</p>
                <ul class="svc-card-features co-list co-list--check">
                  {sub.features.map((f) => (
                    <li><i class="ri-check-line" aria-hidden="true"></i><span>{f}</span></li>
                  ))}
                </ul>
                <a href={sub.link ?? "#"} class="svc-card-cta">{sub.ctaText} <i class="ri-arrow-right-line"></i></a>
              </article>
            ))}
          </div>
          <a href="/contact" class="co-btn svc-section-cta">{section.ctaText} →</a>
        </div>
      ))}
    </section>

    <!-- ══ 03 · CTA FINAL (primitive .co-cta) ══ -->
    <section class="co-cta">
      <span class="co-x tl"></span><span class="co-x tr"></span>
      <div class="co-cta-inner">
        <h2 class="co-cta-title">Ton projet mérite mieux qu'un <span class="co-ser">devis à rallonge.</span></h2>
        <p class="co-cta-lead">Un premier appel gratuit pour cadrer, un devis clair, une réponse sous 24&nbsp;h.</p>
        <div class="co-cta-btns">
          <a href="/contact" class="co-btn co-cta-btn">Parlons de votre projet <i class="ri-arrow-right-line"></i></a>
          <a href="mailto:contact@jonlabs.ch" class="co-btn co-btn--ghost co-cta-btn co-cta-btn--ghost">contact@jonlabs.ch</a>
        </div>
        <div class="co-cta-trust">
          <span><i class="ri-time-line"></i> Réponse sous 24 h</span>
          <span><i class="ri-phone-line"></i> Premier appel gratuit</span>
          <span><i class="ri-file-list-3-line"></i> Devis clair et détaillé</span>
        </div>
      </div>
    </section>

    <!-- ══ MODALE CONVERSATION ══ -->
    <div id="svc-modal" class="svc-modal hidden" role="dialog" aria-modal="true" aria-label="Conversation avec Jonathan">
      <div class="svc-modal-backdrop" data-svc-close></div>
      <div class="svc-modal-win co-frame">
        <div class="svc-modal-head">
          <div class="svc-modal-id">
            <span class="svc-modal-avatar" aria-hidden="true">JV</span>
            <span class="svc-modal-idtext">
              <strong>Jonathan V.</strong>
              <span class="svc-modal-status"><i></i> en ligne</span>
            </span>
          </div>
          <button class="svc-modal-close" data-svc-close aria-label="Fermer la conversation"><i class="ri-close-line"></i></button>
        </div>
        <div class="svc-modal-msgs" id="svc-modal-msgs">
          <div class="svc-typing" id="svc-typing" aria-hidden="true"><span></span><span></span><span></span></div>
        </div>
        <div class="svc-modal-foot">
          <a href="/contact" class="co-btn co-btn--sm">Me contacter →</a>
          <a href="#svc-sections" class="co-btn co-btn--ghost co-btn--sm" data-svc-close>Voir les services</a>
        </div>
      </div>
    </div>

  </div>

  <style is:global>
    /* ══ SERVICES LAB — styles .svc-* ══ */

    /* Constellation */
    .svc-constellation {
      position: relative; height: 600px; margin-top: var(--space-block);
      border: 1px solid var(--line); background-color: var(--surface);
    }
    .svc-mobilehead { display: none; }
    #svc-lines { position: absolute; inset: 0; width: 100%; height: 100%; pointer-events: none; z-index: 1; overflow: visible; }
    #svc-lines line { stroke: var(--line-2); stroke-width: 1; stroke-dasharray: 4 4; transition: stroke .18s ease-out, stroke-width .18s ease-out; }
    #svc-lines line.is-hot { stroke: var(--accent); stroke-width: 1.5; stroke-dasharray: none; }

    /* Hub */
    .svc-hub {
      position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
      width: 148px; height: 148px; z-index: 3;
      border: 1px solid var(--line-2); background: var(--bg);
      display: grid; place-items: center;
    }
    .svc-hub-logo { font-size: 19px; font-weight: 700; letter-spacing: -0.03em; }

    /* Nodes */
    .svc-node {
      position: absolute; z-index: 2; width: 236px;
      display: flex; align-items: center; gap: 12px; text-align: left;
      padding: 14px 16px; cursor: pointer;
      background: var(--bg); border: 1px solid var(--line-2); font-family: inherit;
      transition: transform .18s ease-out, box-shadow .18s ease-out, border-color .18s ease-out;
    }
    .svc-node:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(20,22,26,.08); border-color: var(--accent); }
    .svc-node-icon { font-size: 22px; flex: none; line-height: 1; color: var(--muted); transition: color .18s ease-out; }
    .svc-node:hover .svc-node-icon { color: var(--accent); }
    .svc-node-text { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
    .svc-node-text strong { font-size: 15px; font-weight: 600; line-height: 1.15; }
    .svc-node-text .co-mut { font-size: 12.5px; line-height: 1.3; }
    .svc-node-arrow { margin-left: auto; font-size: 17px; color: var(--muted); flex: none; transition: color .18s ease-out, transform .18s ease-out; }
    .svc-node:hover .svc-node-arrow { color: var(--accent); transform: translate(2px, -2px); }
    /* crosshairs révélés au hover = .co-frame--reveal (kit) */

    /* Sections services */
    .svc-section { margin-top: var(--space-subsection); }
    .svc-section:first-of-type { margin-top: var(--space-block); }
    .svc-section-head { max-width: 60ch; }
    .svc-section-title { font-size: 1.5rem; }
    .co-root .svc-section-accroche { margin-top: var(--space-eyebrow); line-height: 1.55; }
    .svc-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin: 24px 0; }
    .svc-card {
      display: flex; flex-direction: column; gap: 10px; padding: 22px;
      background: var(--surface); border: 1px solid var(--line-2);
      transition: box-shadow .18s ease-out;
    }
    .svc-card:hover { box-shadow: 0 8px 24px rgba(20,22,26,.07); }
    .svc-card-title { font-size: 1.12rem; }
    .svc-card-desc { font-size: 14px; line-height: 1.55; color: var(--muted); }
    /* structure/coche = .co-list--check (kit) ; ici juste taille + espacement local */
    .svc-card-features { margin-top: 4px; gap: 7px; }
    .svc-card-features li { font-size: 13.5px; line-height: 1.4; }
    .svc-card-cta { display: inline-flex; align-items: center; gap: 6px; margin-top: auto; padding-top: 6px; font-size: 14px; font-weight: 600; color: var(--accent); }
    .svc-card-cta i { transition: transform .18s ease-out; }
    .svc-card-cta:hover i { transform: translateX(3px); }
    .svc-section-cta { margin-top: 6px; }

    /* CTA final = primitive .co-cta (BlueprintKit) */

    /* ══ MODALE ══ */
    .svc-modal { position: fixed; inset: 0; z-index: 1000; display: flex; align-items: center; justify-content: center; }
    .svc-modal.hidden { display: none; }
    .svc-modal-backdrop { position: absolute; inset: 0; background: rgba(20,22,26,0.5); backdrop-filter: blur(2px); }
    .svc-modal-win {
      position: relative; z-index: 1; width: min(94vw, 440px); height: min(80vh, 560px);
      background: var(--bg); border: 1px solid var(--line-2); display: flex; flex-direction: column;
      box-shadow: 0 24px 60px rgba(20,22,26,.25); animation: svcModalIn .24s ease-out;
    }
    @keyframes svcModalIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: none; } }
    .svc-modal-head { display: flex; align-items: center; justify-content: space-between; padding: 14px 16px; border-bottom: 1px solid var(--line); }
    .svc-modal-id { display: flex; align-items: center; gap: 10px; }
    .svc-modal-avatar { width: 38px; height: 38px; border-radius: 999px; background: var(--accent); color: #fff; display: grid; place-items: center; font-weight: 700; font-size: 14px; }
    .svc-modal-idtext { display: flex; flex-direction: column; }
    .svc-modal-idtext strong { font-size: 15px; }
    .svc-modal-status { font-size: 12px; color: var(--muted); display: flex; align-items: center; gap: 5px; }
    .svc-modal-status i { width: 7px; height: 7px; border-radius: 999px; background: var(--accent); display: inline-block; }
    .svc-modal-close { background: none; border: 0; cursor: pointer; color: var(--muted); font-size: 22px; display: inline-flex; }
    .svc-modal-close:hover { color: var(--ink); }
    .svc-modal-msgs { flex: 1; overflow-y: auto; padding: 18px 16px; display: flex; flex-direction: column; gap: 10px; }
    .svc-msg { display: flex; max-width: 82%; }
    .svc-msg.client { align-self: flex-start; }
    .svc-msg.jon { align-self: flex-end; }
    .svc-bubble { padding: 10px 14px; font-size: 14px; line-height: 1.45; }
    .svc-msg.client .svc-bubble { background: var(--surface); border: 1px solid var(--line); color: var(--ink); }
    .svc-msg.jon .svc-bubble { background: var(--accent); color: #fff; }
    .svc-typing { display: none; align-self: flex-start; gap: 4px; padding: var(--pad-chip); background: var(--surface); border: 1px solid var(--line); }
    .svc-typing.is-on { display: flex; }
    .svc-typing span { width: 6px; height: 6px; border-radius: 999px; background: var(--muted); animation: svcTyping 1s infinite; }
    .svc-typing span:nth-child(2) { animation-delay: .15s; }
    .svc-typing span:nth-child(3) { animation-delay: .3s; }
    @keyframes svcTyping { 0%, 60%, 100% { opacity: .3; transform: translateY(0); } 30% { opacity: 1; transform: translateY(-3px); } }
    .svc-modal-foot { display: flex; gap: 10px; padding: 14px 16px; border-top: 1px solid var(--line); }

    /* ══ Responsive ══ */
    @media (max-width: 980px) {
      .svc-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 900px) {
      .svc-constellation { height: auto; display: flex; flex-direction: column; gap: 12px; padding: var(--pad-card); background: transparent; border: 0; }
      .svc-mobilehead { display: block; }
      .svc-hub, #svc-lines { display: none; }
      .svc-node { position: static !important; width: 100%; }
    }
    @media (max-width: 720px) {
      .svc-grid { grid-template-columns: 1fr; }
    }
    @media (prefers-reduced-motion: reduce) {
      .svc-node, .svc-node-arrow, .svc-card, .svc-card-cta i, #svc-lines line { transition: none; }
      .svc-modal-win { animation: none; }
      .svc-typing span { animation: none; }
    }
  </style>

  <script is:inline define:vars={{ scenariosData: scenarios }}>
    window.__svcScenarios = scenariosData;
  </script>

  <script>
    // ══ Lignes de la constellation (hub-bord → node-bord), calculées au load + resize ══
    const container = document.getElementById("svc-constellation");
    const svg = document.getElementById("svc-lines");
    const hub = document.getElementById("svc-hub");
    const nodes = Array.from(document.querySelectorAll<HTMLElement>(".svc-node"));
    const SVG_NS = "http://www.w3.org/2000/svg";
    const lines: SVGLineElement[] = [];

    if (container && svg && hub) {
      nodes.forEach(() => {
        const l = document.createElementNS(SVG_NS, "line");
        svg.appendChild(l);
        lines.push(l);
      });

      const box = (el: Element) => {
        const r = el.getBoundingClientRect();
        return { cx: r.left + r.width / 2, cy: r.top + r.height / 2, hw: r.width / 2, hh: r.height / 2 };
      };
      const edge = (c: { cx: number; cy: number; hw: number; hh: number }, tx: number, ty: number) => {
        const dx = tx - c.cx, dy = ty - c.cy;
        const t = Math.min(c.hw / (Math.abs(dx) || 1e-3), c.hh / (Math.abs(dy) || 1e-3));
        return { x: c.cx + dx * t, y: c.cy + dy * t };
      };

      function updateLines() {
        const cont = container!.getBoundingClientRect();
        const h = box(hub!);
        h.hw *= 0.78; h.hh *= 0.78; // s'arrêter un peu avant le cadre du hub
        nodes.forEach((node, i) => {
          const n = box(node);
          const p1 = edge(h, n.cx, n.cy);
          const p2 = edge(n, h.cx, h.cy);
          const line = lines[i];
          line.setAttribute("x1", String(p1.x - cont.left));
          line.setAttribute("y1", String(p1.y - cont.top));
          line.setAttribute("x2", String(p2.x - cont.left));
          line.setAttribute("y2", String(p2.y - cont.top));
        });
      }

      const isDesktop = () => window.matchMedia("(min-width: 901px)").matches;
      function refresh() {
        if (isDesktop()) { svg!.style.display = ""; updateLines(); }
      }
      // deux passes (fonts/layout) puis resize
      requestAnimationFrame(refresh);
      window.addEventListener("load", refresh);
      window.addEventListener("resize", refresh);

      // hover node ↔ ligne
      nodes.forEach((node, i) => {
        node.addEventListener("mouseenter", () => lines[i]?.classList.add("is-hot"));
        node.addEventListener("mouseleave", () => lines[i]?.classList.remove("is-hot"));
      });
    }

    // ══ Modale conversation (rejoue scenario.messages en typing) ══
    const modal = document.getElementById("svc-modal");
    const msgsEl = document.getElementById("svc-modal-msgs");
    const typing = document.getElementById("svc-typing");
    let timers: number[] = [];

    function clearTimers() { timers.forEach((t) => window.clearTimeout(t)); timers = []; }

    function openModal(id: string) {
      const data = (window as any).__svcScenarios as Array<{ id: string; messages: { speaker: string; text: string }[] }>;
      const scenario = data?.find((s) => s.id === id);
      if (!scenario || !modal || !msgsEl || !typing) return;
      clearTimers();
      // vide les anciennes bulles, garde le typing
      msgsEl.querySelectorAll(".svc-msg").forEach((n) => n.remove());
      modal.classList.remove("hidden");
      document.body.style.overflow = "hidden";

      let delay = 350;
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      scenario.messages.forEach((msg, idx) => {
        const last = idx === scenario.messages.length - 1;
        timers.push(window.setTimeout(() => {
          typing.classList.add("is-on");
          msgsEl.scrollTop = msgsEl.scrollHeight;
        }, delay));
        const typeTime = reduce ? 120 : 700 + Math.min(msg.text.length * 16, 850);
        delay += typeTime;
        timers.push(window.setTimeout(() => {
          const el = document.createElement("div");
          el.className = `svc-msg ${msg.speaker === "jon" ? "jon" : "client"}`;
          el.innerHTML = `<div class="svc-bubble"></div>`;
          el.querySelector(".svc-bubble")!.textContent = msg.text;
          msgsEl.insertBefore(el, typing);
          if (last) typing.classList.remove("is-on");
          msgsEl.scrollTop = msgsEl.scrollHeight;
        }, delay));
        delay += 260;
      });
    }

    function closeModal() {
      if (!modal) return;
      clearTimers();
      typing?.classList.remove("is-on");
      modal.classList.add("hidden");
      document.body.style.overflow = "";
    }

    document.querySelectorAll<HTMLElement>("[data-scenario-id]").forEach((btn) => {
      btn.addEventListener("click", () => openModal(btn.dataset.scenarioId!));
    });
    document.querySelectorAll<HTMLElement>("[data-svc-close]").forEach((el) => {
      el.addEventListener("click", closeModal);
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && modal && !modal.classList.contains("hidden")) closeModal();
    });
  </script>
</Layout>
