---
import '../../styles/global.css';
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import AppHeader from '../../components/Header.astro';
import AppFooter from '../../components/Footer.astro';
import IconChip from '../../components/IconChip.astro';
import { isPublished } from '../../lib/blog';
import { getCollectionPageSchema, getBreadcrumbSchema } from '../../lib/seo';
import { SITE_URL, personData, organizationData } from '../../data/schema';

// Piliers « HOW » (collection pages) — publiés uniquement (pubDate passée), plus récents d'abord.
// Grille vide tant que le 1er pilier n'est pas sorti (release programmée du cluster) → grille masquée.
const pillars = (await getCollection('pages', ({ data }) => isPublished(data)))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// « À lire aussi » — articles IA/automatisation RÉELLEMENT publiés, tirés dynamiquement.
// Auto-alimenté : de nouveaux liens apparaissent au fil des pubDate (cron rebuild), zéro 404.
const aLire = (await getCollection('blog', ({ data }) => isPublished(data) && data.category === 'automatisation'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3)
  .map((post) => ({ label: post.data.title, href: `/blog/${post.slug}`, icon: 'ri-article-line' }));

const pageTitle = 'Guides IA & automatisation pour PME romandes | Jon Labs';
const pageDescription = 'Guides pas-à-pas pour mettre l\'IA et l\'automatisation en place dans ta PME en Suisse romande : méthode, coûts CHF, outils et adoption d\'équipe.';
const pageUrl = `${SITE_URL}/guides`;

const collectionSchema = getCollectionPageSchema({
  url: pageUrl,
  name: 'Guides IA & automatisation',
  description: pageDescription,
});

const breadcrumbSchema = getBreadcrumbSchema([
  { name: 'Accueil', url: SITE_URL },
  { name: 'Guides', url: pageUrl },
]);

const schemas = [personData, organizationData, collectionSchema, breadcrumbSchema];
---

<Layout title={pageTitle} description={pageDescription} schemas={schemas}>
  <AppHeader />

  <main class="mb-20">
    <!-- Hero -->
    <section class="max-w-6xl mx-auto px-4 pt-16 pb-10">
      <p class="seo-h1-eyebrow text-sm font-semibold uppercase tracking-[0.18em] text-accent-strong mb-4">Guides</p>
      <h1 class="text-4xl md:text-6xl font-normal tracking-tight mb-6 max-w-3xl">
        Mettre l'IA et l'automatisation en place, étape par étape
      </h1>
      <p class="text-lg text-muted max-w-2xl">
        Des méthodes concrètes, pensées pour les PME de Suisse romande : par où commencer,
        combien ça coûte en francs, quels outils, et comment embarquer ton équipe.
      </p>
    </section>

    <!-- Grille des piliers (masquée tant qu'aucun guide n'est publié) -->
    {pillars.length > 0 && (
    <section class="max-w-6xl mx-auto px-4">
      <div class="grid gap-6 md:grid-cols-2">
        {pillars.map((guide) => (
          <a
            href={`/guides/${guide.slug}`}
            class="group block bg-white border-2 border-black p-6 shadow-[4px_4px_0px_rgba(0,0,0,0.3)] transition-all duration-200 hover:shadow-[2px_2px_0px_rgba(0,0,0,1)] hover:translate-x-[2px] hover:translate-y-[2px]"
          >
            <div class="flex items-start gap-4">
              <IconChip icon="ri-compass-3-line" size="lg" />
              <div>
                <h2 class="text-xl md:text-2xl font-semibold tracking-tight mb-2 group-hover:text-accent-strong transition-colors">
                  {guide.data.h1 ?? guide.data.title}
                </h2>
                <p class="text-muted mb-4">{guide.data.description}</p>
                <div class="flex flex-wrap items-center gap-3 text-sm text-muted">
                  <span class="inline-flex items-center gap-1">
                    <i class="ri-book-open-line"></i>
                    Guide
                  </span>
                  {guide.data.readingTime && (
                    <span class="inline-flex items-center gap-1">
                      <i class="ri-time-line"></i>
                      {guide.data.readingTime} min
                    </span>
                  )}
                  <span class="inline-flex items-center gap-1 font-medium text-ink group-hover:gap-2 transition-all">
                    Lire le guide
                    <i class="ri-arrow-right-line"></i>
                  </span>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>
    )}

    <!-- Articles IA à lire -->
    {aLire.length > 0 && (
    <section class="max-w-6xl mx-auto px-4 mt-16">
      <h2 class="text-3xl md:text-4xl font-normal tracking-tight mb-6">À lire aussi</h2>
      <ul class="grid gap-3 md:grid-cols-3">
        {aLire.map((item) => (
          <li>
            <a
              href={item.href}
              class="group flex items-center gap-3 bg-panel border-2 border-black px-4 py-3 transition-all duration-200 hover:bg-accent-soft"
            >
              <i class={`${item.icon} text-xl text-accent-strong`}></i>
              <span class="font-medium group-hover:text-accent-strong transition-colors">{item.label}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>
    )}

    <!-- CTA -->
    <section class="max-w-6xl mx-auto px-4 mt-16">
      <div class="bg-dark text-white border-2 border-black p-8 md:p-12 text-center">
        <h2 class="text-2xl md:text-4xl font-normal tracking-tight mb-4">
          Un projet IA concret à cadrer ?
        </h2>
        <p class="text-white/70 max-w-xl mx-auto mb-8">
          Plutôt que de lire dix guides, on peut cadrer ton premier cas d'usage ensemble —
          prix CHF transparents, basé à Genève.
        </p>
        <a
          href="/consultant-ia"
          class="inline-flex items-center gap-2 bg-accent text-ink border-2 border-black px-6 py-3 font-bold shadow-[4px_4px_0px_rgba(0,0,0,1)] transition-all duration-200 hover:shadow-[2px_2px_0px_rgba(0,0,0,1)] hover:translate-x-[2px] hover:translate-y-[2px]"
        >
          Voir l'accompagnement IA
          <i class="ri-arrow-right-line"></i>
        </a>
      </div>
    </section>
  </main>

  <AppFooter />
</Layout>
