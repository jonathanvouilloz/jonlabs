---
import '../styles/global.css'
import { getCollection } from 'astro:content';
import Layout from "../layouts/Layout.astro"
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import PortfolioCardEditorial from '../components/portfolio/PortfolioCardEditorial.astro';

// Schema.org
import { SITE_URL } from '../data/schema';
import { getCollectionPageSchema } from '../lib/seo';

const pageTitle = "Réalisations Web & Études de Cas | Jon Labs";
const pageDescription = "Sites web, SEO local et automatisations : découvrez mes réalisations détaillées pour des clients suisses. Résultats mesurables à l'appui.";

const portfolioSchema = getCollectionPageSchema({
  url: `${SITE_URL}/portfolio`,
  name: pageTitle,
  description: pageDescription
});

const schemas = [portfolioSchema];

// Get portfolio entries from content collection
const portfolioEntries = await getCollection('portfolio', ({ data }) => !data.draft);

// Sort by date (newest first) and featured status
const sortedProjects = portfolioEntries.sort((a, b) => {
  // Featured first
  if (a.data.featured && !b.data.featured) return -1;
  if (!a.data.featured && b.data.featured) return 1;
  // Then by date
  return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
});

// Catégorie d'affichage/filtre (mêmes labels que la carte)
const categoryLabels: Record<string, string> = {
  'site-vitrine': 'Site vitrine',
  'e-commerce': 'E-commerce',
  'application': 'Application',
  'seo': 'SEO',
  'automatisation': 'Automatisation',
  'side-project': 'Projet perso',
};

const getCategoryKey = (project: typeof sortedProjects[number]) =>
  project.data.entryType === 'side-project' ? 'side-project' : project.data.project.category;

// Chips : "Tous" + catégories réellement présentes (ordre d'apparition)
const presentCategories = [...new Set(sortedProjects.map(getCategoryKey))];
const filters = [
  { slug: 'all', name: 'Tous' },
  ...presentCategories.map((slug) => ({ slug, name: categoryLabels[slug] || slug })),
];
---

<Layout
  title={pageTitle}
  description={pageDescription}
  schemas={schemas}
>
  <Header />

  <main>
    <!-- Hero Section -->
    <section class="py-12 md:py-16 px-4">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-3xl md:text-4xl font-normal mb-4 tracking-tight" data-animate>
          Réalisations web & études de cas
        </h1>
        <p class="text-lg text-gray-600 max-w-xl mx-auto" data-animate data-delay="0.1">
          Projets détaillés avec contexte, approche et résultats mesurables
        </p>
      </div>
    </section>

    <!-- Projects List -->
    <section class="py-8 md:py-12 px-4">
      <div class="max-w-6xl mx-auto">
        {sortedProjects.length > 0 ? (
          <>
            <!-- Filtres catégories -->
            <div class="flex flex-wrap justify-center gap-2 mb-8 md:mb-10" id="portfolio-filters" data-animate>
              {filters.map((filter) => (
                <button
                  type="button"
                  data-category={filter.slug}
                  class:list={[
                    'filter-btn px-4 py-2 text-sm font-medium border-2 border-black transition-all duration-200',
                    filter.slug === 'all'
                      ? 'bg-[var(--blue)] shadow-[2px_2px_0px_rgba(0,0,0,1)] active'
                      : 'bg-white hover:bg-gray-100',
                  ]}
                >
                  {filter.name}
                </button>
              ))}
            </div>

            <!-- Grille 2 colonnes -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6" id="portfolio-grid" data-animate-stagger>
              {sortedProjects.map(project => (
                <div data-animate-item data-category={getCategoryKey(project)}>
                  <PortfolioCardEditorial project={project} />
                </div>
              ))}
            </div>
          </>
        ) : (
          <div class="text-center py-16" data-animate>
            <i class="ri-folder-open-line text-6xl text-gray-300 mb-4"></i>
            <p class="text-xl text-gray-500">Études de cas à venir...</p>
          </div>
        )}
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-16 md:py-20 px-4 bg-white border-y border-gray-200">
      <div class="max-w-2xl mx-auto text-center" data-animate>
        <h2 class="text-2xl md:text-3xl font-normal mb-4">
          Un projet en tête ?
        </h2>
        <p class="text-gray-600 mb-8">
          Discutons de tes besoins et voyons comment je peux t'aider à atteindre tes objectifs.
        </p>
        <a
          href="/contact"
          class="inline-block bg-[var(--blue)] border-2 border-black px-8 py-4 font-medium shadow-[3px_3px_0px_rgba(0,0,0,1)] hover:bg-[var(--yellow)] hover:shadow-[1px_1px_0px_rgba(0,0,0,1)] hover:translate-x-[2px] hover:translate-y-[2px] transition-all duration-200"
        >
          Me contacter
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  function initPortfolioFilters() {
    const filterButtons = document.querySelectorAll<HTMLButtonElement>('#portfolio-filters .filter-btn');
    const grid = document.getElementById('portfolio-grid');
    if (!filterButtons.length || !grid) return;

    const items = Array.from(grid.querySelectorAll<HTMLElement>('[data-category]'));

    filterButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const category = btn.getAttribute('data-category') || 'all';

        // État actif des chips
        filterButtons.forEach((b) => {
          b.classList.remove('active', 'bg-[var(--blue)]', 'shadow-[2px_2px_0px_rgba(0,0,0,1)]');
          b.classList.add('bg-white', 'hover:bg-gray-100');
        });
        btn.classList.remove('bg-white', 'hover:bg-gray-100');
        btn.classList.add('active', 'bg-[var(--blue)]', 'shadow-[2px_2px_0px_rgba(0,0,0,1)]');

        // Filtrage
        items.forEach((item) => {
          const itemCategory = item.getAttribute('data-category') || '';
          item.style.display = category === 'all' || itemCategory === category ? '' : 'none';
        });
      });
    });
  }

  initPortfolioFilters();
  document.addEventListener('astro:page-load', initPortfolioFilters);
</script>
