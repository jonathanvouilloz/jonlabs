---
// Bandeau de confiance blueprint — marquee des vrais clients.
const clients = [
  'Le Matin Dimanche',
  'Barber Concept',
  'CPV',
  'Lécureux Conseil',
  'Physio Pommier',
  'Ugo Mighali',
];
// Répété pour remplir la largeur et boucler proprement (translateX -50%).
const set = [...clients, ...clients, ...clients];
---

<section class="co-sec co-pad co-trust hp-trust" data-animate>
  <p class="co-eyebrow">Ils m'ont fait confiance</p>
  <div class="co-marquee">
    <div class="co-marquee-track">
      {set.map((name) => <span>{name}</span>)}
      {set.map((name) => <span aria-hidden="true">{name}</span>)}
    </div>
  </div>
</section>

<style>
  .hp-trust { padding: 22px 40px; }
  @media (max-width: 720px) { .hp-trust { padding: 20px 20px; } }
</style>
