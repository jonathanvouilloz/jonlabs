---
/**
 * Connector — forme signature (Phase 3, aération)
 * Connecteur : courbe de Bézier teal + 2 nœuds. Motif « flux » on-brand.
 * Source : styleguide.astro §6. Couleur = token --color-accent.
 * Positionnable via `class` (ex. "h-24 w-full", "absolute", rotation…).
 */
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---
<svg
  viewBox="0 0 120 112"
  class:list={['pointer-events-none', className]}
  aria-hidden="true"
  fill="none"
>
  <path d="M10 20 C 60 20, 60 92, 110 92" fill="none" stroke="var(--color-accent)" stroke-width="2.5" />
  <circle cx="10" cy="20" r="5" fill="var(--color-accent)" />
  <circle cx="110" cy="92" r="5" fill="var(--color-accent)" />
</svg>
