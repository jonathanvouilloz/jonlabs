---
/**
 * HalfCircle — forme signature (Phase 3, aération)
 * Demi-cercle ouvert (arche) : contour teal 2px, bas ouvert. Zéro coût API.
 * Source : styleguide.astro §6. Couleur = token --color-accent (classe border-accent).
 * Taille par défaut 96×48px ; positionnable/redimensionnable via `class`.
 */
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---
<div
  class:list={[
    'w-24 h-12 rounded-t-full border-2 border-accent border-b-0 pointer-events-none',
    className,
  ]}
  aria-hidden="true"
></div>
