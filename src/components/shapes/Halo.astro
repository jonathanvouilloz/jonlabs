---
/**
 * Halo — forme signature (Phase 3, aération)
 * Halo radial doux teal (wash) qui se fond dans le fond warm. Zéro coût API.
 * Source : styleguide.astro §6. Couleur = token --color-accent-soft.
 * Positionnable via `class` (ex. "absolute -top-20 right-0 w-72 h-72").
 */
interface Props {
  class?: string;
  /** Opacité globale (0–1) — optionnelle, le wash est déjà translucide */
  opacity?: number;
}
const { class: className = '', opacity } = Astro.props;
const style = `background:radial-gradient(circle at 50% 50%, var(--color-accent-soft), transparent 70%)${
  opacity != null ? `;opacity:${opacity}` : ''
}`;
---
<div class:list={['pointer-events-none', className]} aria-hidden="true" style={style}></div>
