---
/**
 * DotGrid — forme signature (Phase 3, aération)
 * Trame de points teal en radial-gradient CSS. Zéro coût API.
 * Source : styleguide.astro §6. Couleur = token --color-accent.
 * Positionnable via `class` (ex. "absolute inset-0", opacité, taille).
 */
interface Props {
  class?: string;
  /** Taille de la tuile en px */
  size?: number;
  /** Rayon du point en px */
  dot?: number;
  /** Opacité globale (0–1) */
  opacity?: number;
}
const { class: className = '', size = 14, dot = 1.5, opacity = 0.7 } = Astro.props;
---
<div
  class:list={['pointer-events-none', className]}
  aria-hidden="true"
  style={`background-image:radial-gradient(var(--color-accent) ${dot}px, transparent ${dot}px);background-size:${size}px ${size}px;opacity:${opacity}`}
></div>
