---
import { services } from '../sample';
---

<section class="co-sec co-pad hp-services" id="services">
  <div class="hp-services-head" data-animate>
    <div>
      <p class="co-eyebrow">Ce que je fais</p>
      <h2 class="hp-services-title">
        Mes expertises : plus que du code, des <span class="co-ser">solutions.</span>
      </h2>
      <p class="co-mut hp-services-lead">
        Un seul interlocuteur, de la première idée à la mise en ligne — et après.
      </p>
    </div>
    <a href="/services" class="hp-services-all">
      Tout voir <i class="ri-arrow-right-line"></i>
    </a>
  </div>

  <div class="co-grid-cells hp-services-grid" data-animate-stagger>
    {services.map((service, i) => (
      <div class="hp-service" data-animate-item>
        <a href={service.link} class="hp-service-link" aria-label={`En savoir plus : ${service.title}`}></a>
        <span class="co-index hp-service-idx">0{i + 1}</span>
        <div class="hp-service-icon">
          <i class={service.icon} aria-hidden="true"></i>
        </div>
        <h3 class="hp-service-title">{service.title}</h3>
        <p class="co-mut hp-service-desc">{service.description}</p>
        <span class="hp-service-more">
          En savoir plus <i class="ri-arrow-right-line"></i>
        </span>
      </div>
    ))}
  </div>
</section>

<style>
  .hp-services { padding: 72px 40px; }
  .hp-services-head { display: flex; align-items: flex-end; justify-content: space-between; gap: 24px; flex-wrap: wrap; max-width: 100%; }
  .hp-services-title { font-size: clamp(1.8rem, 4vw, 2.6rem); margin-top: 12px; max-width: 22ch; }
  .hp-services-lead { margin-top: 12px; font-size: 1.05rem; line-height: 1.6; max-width: 46ch; }
  .hp-services-all {
    display: inline-flex; align-items: center; gap: 6px; flex: none;
    font-size: 13px; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase; color: var(--ink);
    padding-bottom: 3px; border-bottom: 2px solid var(--ink); transition: gap .18s ease-out, border-color .18s ease-out;
  }
  .hp-services-all:hover { gap: 10px; border-color: var(--accent); }

  .hp-services-grid { grid-template-columns: repeat(3, 1fr); margin-top: 44px; }
  .hp-service { position: relative; padding: 32px; transition: background .18s ease-out; }
  .hp-service:hover { background: var(--surface); }
  .hp-service-link { position: absolute; inset: 0; z-index: 1; }
  .hp-service-idx { position: absolute; top: 18px; right: 20px; font-size: 12px; }
  .hp-service-icon {
    width: 46px; height: 46px; display: flex; align-items: center; justify-content: center;
    border: 1px solid var(--line-2); border-radius: 10px; font-size: 21px; color: var(--accent);
  }
  .hp-service-title { font-size: 1.3rem; margin-top: 20px; }
  .hp-service-desc { margin-top: 10px; line-height: 1.6; }
  .hp-service-more {
    display: inline-flex; align-items: center; gap: 7px; margin-top: 20px;
    font-size: 14px; font-weight: 600; color: var(--ink);
  }
  .hp-service-more i { transition: transform .18s ease-out; }
  .hp-service:hover .hp-service-more i { transform: translateX(3px); }

  @media (max-width: 900px) {
    .hp-services-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 720px) {
    .hp-services { padding: 56px 20px; }
    .hp-service { padding: 28px 24px; }
  }
</style>
