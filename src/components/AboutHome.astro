---
import { Image } from 'astro:assets';
import profilePhoto from '../assets/jonathan-vouilloz.webp';

const badges = [
  { icon: 'ri-lightbulb-line', label: 'Conseil stratégique' },
  { icon: 'ri-code-s-slash-line', label: 'Développement Astro/React' },
  { icon: 'ri-loop-left-line', label: 'Automatisation Make' },
  { icon: 'ri-search-line', label: 'Référencement SEO' },
];
---

<section class="co-sec co-pad hp-about" id="about">
  <div class="hp-about-grid">
    <!-- Citation cadrée -->
    <div class="hp-about-quote-wrap" data-animate="fade-left" data-delay="0.1">
      <figure class="hp-about-quote co-frame">
        <span class="co-x tl"></span><span class="co-x tr"></span>
        <span class="co-x bl"></span><span class="co-x br"></span>
        <i class="ri-double-quotes-l hp-about-quote-mark" aria-hidden="true"></i>
        <blockquote class="hp-about-quote-text">
          Un site, ça se mesure : vitesse, visibilité, conversions. Je construis pour
          des chiffres qu'on peut vérifier — pas pour faire joli.
        </blockquote>
        <figcaption class="hp-about-sign">
          <Image
            src={profilePhoto}
            alt="Jonathan Vouilloz"
            width={44}
            height={44}
            quality={80}
            class="hp-about-avatar"
          />
          <span>
            <strong>Jonathan Vouilloz</strong>
            <span class="co-mut">Genève, Suisse</span>
          </span>
        </figcaption>
      </figure>
    </div>

    <!-- Texte -->
    <div class="hp-about-body" data-animate>
      <p class="co-eyebrow">À propos</p>
      <h2 class="hp-about-title">Pourquoi <span class="co-ser">Jon Labs ?</span></h2>
      <p class="hp-about-sub">Partenaire digital, pas juste exécutant.</p>

      <div class="hp-about-text">
        <p>
          Je suis <strong>Jonathan Vouilloz</strong>, informaticien de gestion et entrepreneur
          digital basé à <strong>Genève</strong>.
        </p>
        <p>
          Mon approche ? <strong>L'action &gt; la perfection.</strong>
        </p>
        <p class="co-mut">
          Contrairement aux agences classiques, je ne suis pas là pour vous vendre des heures,
          mais pour apporter une vision globale. Ma polyvalence technique (<strong>Fullstack</strong>,
          <strong>No-Code</strong>) me permet de choisir la meilleure solution pour <em>votre</em>
          budget et vos objectifs.
        </p>
      </div>

      <div class="hp-about-badges" data-animate-stagger>
        {badges.map((b) => (
          <span class="co-badge hp-about-badge" data-animate-item>
            <i class={b.icon} aria-hidden="true"></i> {b.label}
          </span>
        ))}
      </div>

      <a href="/contact" class="co-btn hp-about-cta">
        Travaillons ensemble ? <i class="ri-arrow-right-line"></i>
      </a>

      <p class="co-mut hp-about-seo">
        Tu te demandes
        <a href="/blog/specialiste-developpement-web-suisse">comment choisir un spécialiste en développement web en Suisse</a>
        ? J'ai écrit un guide complet.
      </p>
    </div>
  </div>
</section>

<style>
  .hp-about { padding: 72px 40px; }
  .hp-about-grid { display: grid; grid-template-columns: 0.85fr 1.15fr; gap: 56px; align-items: center; }

  .hp-about-quote { position: relative; background: var(--surface); padding: 34px 32px; }
  .hp-about-quote-mark { font-size: 34px; color: var(--accent); opacity: 0.5; }
  .hp-about-quote-text { font-size: clamp(1.1rem, 2vw, 1.35rem); line-height: 1.5; font-weight: 500; margin-top: 6px; }
  .hp-about-sign { display: flex; align-items: center; gap: 12px; margin-top: 24px; padding-top: 18px; border-top: 1px solid var(--line); }
  .hp-about-avatar { width: 42px; height: 42px; border-radius: 999px; object-fit: cover; flex: none; }
  .hp-about-sign span { display: flex; flex-direction: column; }
  .hp-about-sign strong { font-size: 14px; font-weight: 600; }
  .hp-about-sign .co-mut { font-size: 12px; }

  .hp-about-body { display: flex; flex-direction: column; align-items: flex-start; }
  .hp-about-title { font-size: clamp(1.8rem, 4vw, 2.6rem); margin-top: 12px; }
  .hp-about-sub { font-size: 1.15rem; color: var(--muted); margin-top: 8px; }
  .hp-about-text { display: flex; flex-direction: column; gap: 12px; margin-top: 22px; font-size: 1.05rem; line-height: 1.65; }
  .hp-about-badges { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 24px; }
  .hp-about-badge i { font-size: 13px; color: var(--accent); margin-right: 2px; }
  .hp-about-cta { margin-top: 28px; }
  .hp-about-cta i { transition: transform .18s ease-out; }
  .hp-about-cta:hover i { transform: translateX(3px); }
  .hp-about-seo { margin-top: 16px; font-size: 14px; }
  .hp-about-seo a { color: var(--accent); text-decoration: underline; text-underline-offset: 2px; }

  @media (max-width: 900px) {
    .hp-about-grid { grid-template-columns: 1fr; gap: 40px; }
  }
  @media (max-width: 720px) {
    .hp-about { padding: 56px 20px; }
  }
</style>
