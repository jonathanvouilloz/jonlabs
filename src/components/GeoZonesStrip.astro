---
// Strip de maillage géo blueprint (home → pages ville dédiées).
// Source de vérité unique des villes : src/data/villes-frontalieres.ts
import { villesFrontalieres } from '../data/villes-frontalieres';
---

<section class="co-sec co-pad hp-geo" aria-labelledby="geo-strip-title" data-animate>
  <p class="co-eyebrow">Zones d'intervention</p>
  <h2 id="geo-strip-title" class="hp-geo-title">
    Développement web <span class="co-ser">dans la région</span>
  </h2>
  <p class="co-mut hp-geo-sub">
    Basé à Genève, j'interviens aussi dans les villes frontalières :
  </p>
  <ul class="hp-geo-cities">
    {villesFrontalieres.map((ville) => (
      <li>
        <a href={`/developpement-web/${ville.slug}`} class="hp-geo-chip">
          <i class="ri-map-pin-line" aria-hidden="true"></i>
          {ville.nom}
        </a>
      </li>
    ))}
  </ul>
  <a href="/developpeur-web-freelance-geneve" class="co-btn hp-geo-cta">
    Développeur web freelance à Genève <i class="ri-arrow-right-line"></i>
  </a>
</section>

<style>
  .hp-geo { padding: 64px 40px; text-align: center; display: flex; flex-direction: column; align-items: center; }
  .hp-geo-title { font-size: clamp(1.6rem, 3.4vw, 2.2rem); margin-top: 12px; }
  .hp-geo-sub { margin-top: 12px; font-size: 1.02rem; }
  .hp-geo-cities { display: flex; flex-wrap: wrap; justify-content: center; gap: 10px; margin-top: 26px; }
  .hp-geo-chip {
    display: inline-flex; align-items: center; gap: 7px;
    font-size: 14px; font-weight: 500; color: var(--ink);
    background: var(--surface); border: 1px solid var(--line-2); padding: 9px 16px; border-radius: 999px;
    transition: color .16s ease-out, border-color .16s ease-out, transform .16s ease-out;
  }
  .hp-geo-chip i { color: var(--accent); font-size: 15px; }
  .hp-geo-chip:hover { color: var(--accent); border-color: var(--accent); transform: translateY(-2px); }
  .hp-geo-cta { margin-top: 30px; }
  .hp-geo-cta i { transition: transform .18s ease-out; }
  .hp-geo-cta:hover i { transform: translateX(3px); }

  @media (max-width: 720px) {
    .hp-geo { padding: 56px 20px; }
  }
</style>
