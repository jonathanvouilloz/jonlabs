---
import { getCollection } from 'astro:content';

// Fetch portfolio (études de cas + side-projects) — logique inchangée.
const portfolioProjects = await getCollection('portfolio', ({ data }) => !data.draft);
const projects = portfolioProjects
  .map((project) => ({
    id: project.slug,
    title: project.data.title,
    description: project.data.description,
    imageUrl: project.data.heroImage.url,
    imageAlt: project.data.heroImage.alt,
    tags: project.data.tags,
    category: project.data.entryType === 'side-project' ? 'side-project' : 'etude-de-cas',
    link: `/portfolio/${project.slug}`,
    date: project.data.date,
  }))
  .sort((a, b) => b.date.getTime() - a.date.getTime())
  .slice(0, 3);
---

<section class="co-sec co-pad hp-portfolio" id="portfolio">
  <div class="hp-portfolio-head" data-animate>
    <div>
      <p class="co-eyebrow">Portfolio</p>
      <h2 class="hp-portfolio-title">
        Projets récents &amp; <span class="co-ser">études de cas</span>
      </h2>
    </div>
    <a href="/portfolio" class="hp-portfolio-all">
      Tout voir <i class="ri-arrow-right-line"></i>
    </a>
  </div>

  <div class="hp-portfolio-grid" data-animate-stagger>
    {projects.map((project) => (
      <article class="hp-proj co-frame--reveal" data-animate-item>
        <a href={project.link} class="hp-proj-link" aria-label={`Voir le projet ${project.title}`}></a>
        <div class="hp-proj-media">
          <img
            src={project.imageUrl}
            alt={project.imageAlt}
            width="800"
            height="450"
            class="hp-proj-img"
            loading="lazy"
          />
        </div>
        <div class="hp-proj-body">
          <span class="co-cat hp-proj-cat">{project.category}</span>
          <h3 class="hp-proj-title">{project.title}</h3>
          <p class="co-mut hp-proj-desc">{project.description}</p>
          <div class="hp-proj-tags">
            {project.tags.slice(0, 3).map((tag) => (
              <span class="hp-proj-tag">{tag}</span>
            ))}
          </div>
          <span class="hp-proj-more">
            {project.category === 'etude-de-cas' ? "Voir l'étude de cas" : 'Voir le projet'}
            <i class="ri-arrow-right-line"></i>
          </span>
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .hp-portfolio { padding: 72px 40px; }
  .hp-portfolio-head { display: flex; align-items: flex-end; justify-content: space-between; gap: 24px; flex-wrap: wrap; }
  .hp-portfolio-title { font-size: clamp(1.8rem, 4vw, 2.6rem); margin-top: 12px; }
  .hp-portfolio-all {
    display: inline-flex; align-items: center; gap: 6px; flex: none;
    font-size: 13px; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase; color: var(--ink);
    padding-bottom: 3px; border-bottom: 2px solid var(--ink); transition: gap .18s ease-out, border-color .18s ease-out;
  }
  .hp-portfolio-all:hover { gap: 10px; border-color: var(--accent); }

  .hp-portfolio-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-top: 44px; }
  .hp-proj { position: relative; display: flex; flex-direction: column; border: 1px solid var(--line); background: var(--surface); transition: transform .18s ease-out; }
  .hp-proj:hover { transform: translateY(-4px); }
  .hp-proj-link { position: absolute; inset: 0; z-index: 2; }
  .hp-proj-media { aspect-ratio: 16 / 9; overflow: hidden; border-bottom: 1px solid var(--line); }
  .hp-proj-img { width: 100%; height: 100%; object-fit: cover; transition: transform .5s ease-out; }
  .hp-proj:hover .hp-proj-img { transform: scale(1.06); }
  .hp-proj-body { display: flex; flex-direction: column; align-items: flex-start; gap: 10px; padding: 20px; }
  .hp-proj-cat { margin-bottom: 2px; }
  .hp-proj-title { font-size: 1.15rem; }
  .hp-proj-desc { font-size: 14px; line-height: 1.55; }
  .hp-proj-tags { display: flex; flex-wrap: wrap; gap: 6px; }
  .hp-proj-tag { font-size: 11px; color: var(--muted); border: 1px solid var(--line); padding: 3px 8px; border-radius: 4px; }
  .hp-proj-more {
    display: inline-flex; align-items: center; gap: 7px; margin-top: 4px;
    font-size: 14px; font-weight: 600; color: var(--ink);
  }
  .hp-proj-more i { transition: transform .18s ease-out; }
  .hp-proj:hover .hp-proj-more i { transform: translateX(3px); }

  @media (max-width: 900px) {
    .hp-portfolio-grid { grid-template-columns: 1fr; max-width: 460px; }
  }
  @media (max-width: 720px) {
    .hp-portfolio { padding: 56px 20px; }
  }
</style>
