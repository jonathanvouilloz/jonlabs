---
import logo from '../assets/logo.svg'
import svgPinkStar from '../assets/pink-star.svg'
import { author } from '../sample'
import { mainNav, ctaContact } from '../data/navigation'

const socials = [
    { icon: 'ri-linkedin-fill', link: author.linkedin, label: 'LinkedIn' },
    { icon: 'ri-github-fill', link: author.github, label: 'GitHub' },
    { icon: 'ri-youtube-fill', link: author.youtube, label: 'YouTube' },
    { icon: 'ri-mail-fill', link: author.email, label: 'Email' },
]

// Source de vérité unique : mainNav (data/navigation.ts)
// Fat footer : on expose les liens profonds (services, zones, piliers) en plain HTML,
// crawlables sitewide — vs le méga-menu JS sous-pondéré au crawl.
const solutions = mainNav.find((s) => s.label === 'Solutions')
const ressources = mainNav.find((s) => s.label === 'Ressources')
const col = (section, title) => section?.columns?.find((c) => c.title === title)?.items ?? []

const servicesLinks = [...col(solutions, 'Web & apps'), ...col(solutions, 'SEO local')]
const zonesLinks = col(solutions, 'Zones')
const ressourcesLinks = [
    { label: 'Freelance web à Genève', href: solutions?.spotlight?.href ?? '/developpeur-web-freelance-geneve' },
    ...col(ressources, 'À la une'),
    { label: 'Tous les articles', href: '/blog' },
]
const secondaryLinks = [
    { label: 'Tarifs', href: '/tarifs' },
    { label: 'Réalisations', href: '/portfolio' },
    { label: 'À propos', href: '/about' },
    { label: ctaContact.label, href: ctaContact.href },
    { label: 'CV', href: '/cv' },
]
---

<footer class="border-t-3 border-black bg-white relative overflow-hidden">
    <!-- Decorative elements -->
    <img src={svgPinkStar.src} alt="" width="60" class="absolute top-8 right-8 opacity-40" aria-hidden="true" />

    <div class="max-w-6xl mx-auto px-4 py-12 md:py-16">
        <!-- CTA Section -->
        <div class="text-center mb-12 pb-12 border-b-2 border-dashed border-black">
            <h3 class="text-3xl md:text-4xl font-normal tracking-tight mb-4">
                Travaillons ensemble ?
            </h3>
            <p class="text-gray-600 mb-6">
                Disponible pour de nouveaux projets à <strong>Genève</strong> et en télétravail.
            </p>
            <a
                href="/contact"
                class="
                    inline-flex items-center gap-2
                    bg-[var(--blue)] border-2 border-black
                    px-6 py-3
                    font-bold
                    shadow-[4px_4px_0px_rgba(0,0,0,1)]
                    transition-all duration-200
                    hover:bg-[var(--yellow)]
                    hover:shadow-[2px_2px_0px_rgba(0,0,0,1)]
                    hover:translate-x-[2px] hover:translate-y-[2px]
                "
            >
                Discuter de mon projet
                <i class="ri-arrow-right-line"></i>
            </a>
        </div>

        <!-- Main footer content -->
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-8 md:gap-10 mb-12">

            <!-- Brand column -->
            <div class="col-span-2">
                <a href="/" class="inline-flex items-center mb-4 group">
                    <img
                        src={logo.src}
                        alt="Jon Labs"
                        class="h-8 w-auto transition-transform duration-300"
                    />
                </a>
                <p class="text-gray-600 leading-relaxed max-w-sm mb-6">
                    Développement web, automatisation, applications sur-mesure.
                    J'accompagne entrepreneurs et petites équipes dans leurs projets digitaux.
                </p>

                <!-- Social links -->
                <div class="flex gap-3">
                    {socials.map(item => (
                        <a
                            href={item.link}
                            target={item.link.startsWith('mailto') ? '_self' : '_blank'}
                            rel="noopener noreferrer"
                            aria-label={item.label}
                            class="
                                w-10 h-10
                                flex items-center justify-center
                                bg-white border-2 border-black
                                shadow-[2px_2px_0px_rgba(0,0,0,1)]
                                transition-all duration-200
                                hover:bg-[var(--blue)]
                                hover:shadow-[1px_1px_0px_rgba(0,0,0,1)]
                                hover:translate-x-[1px] hover:translate-y-[1px]
                            "
                        >
                            <i class={`${item.icon} text-lg`}></i>
                        </a>
                    ))}
                </div>
            </div>

            <!-- Coordonnées -->
            <div>
                <h3 class="font-bold text-sm uppercase tracking-wider mb-4 text-gray-500">Coordonnées</h3>
                <ul class="space-y-3 text-sm text-gray-700">
                    <li class="font-medium">Jonathan Vouilloz</li>
                    <li class="flex items-start gap-2">
                        <i class="ri-map-pin-line text-[var(--blue)] mt-0.5 flex-shrink-0"></i>
                        <span>120 chemin de la montagne,<br/>1224 Chêne-Bougeries</span>
                    </li>
                    <li>
                        <a href="tel:+41789447707" class="flex items-center gap-2 hover:text-[var(--blue)] transition-colors duration-200">
                            <i class="ri-phone-line text-[var(--blue)]"></i>
                            078 944 77 07
                        </a>
                    </li>
                    <li>
                        <a href="mailto:contact@jonlabs.ch" class="flex items-center gap-2 hover:text-[var(--blue)] transition-colors duration-200">
                            <i class="ri-mail-line text-[var(--blue)]"></i>
                            contact@jonlabs.ch
                        </a>
                    </li>
                </ul>
            </div>

            <!-- Services -->
            <div>
                <h3 class="font-bold text-sm uppercase tracking-wider mb-4 text-gray-500">Services</h3>
                <ul class="space-y-2">
                    {servicesLinks.map(link => (
                        <li>
                            <a
                                href={link.href}
                                class="text-gray-700 text-sm font-medium transition-colors duration-200 hover:text-[var(--blue)]"
                            >
                                {link.label}
                            </a>
                        </li>
                    ))}
                </ul>
            </div>

            <!-- Zones -->
            <div>
                <h3 class="font-bold text-sm uppercase tracking-wider mb-4 text-gray-500">Zones</h3>
                <ul class="space-y-2">
                    {zonesLinks.map(link => (
                        <li>
                            <a
                                href={link.href}
                                class="text-gray-700 text-sm font-medium transition-colors duration-200 hover:text-[var(--blue)]"
                            >
                                {link.label}
                            </a>
                        </li>
                    ))}
                </ul>
            </div>

            <!-- Ressources -->
            <div>
                <h3 class="font-bold text-sm uppercase tracking-wider mb-4 text-gray-500">Ressources</h3>
                <ul class="space-y-2">
                    {ressourcesLinks.map(link => (
                        <li>
                            <a
                                href={link.href}
                                class="text-gray-700 text-sm font-medium transition-colors duration-200 hover:text-[var(--blue)]"
                            >
                                {link.label}
                            </a>
                        </li>
                    ))}
                </ul>
            </div>

        </div>

        <!-- Bottom bar -->
        <div class="pt-8 border-t-2 border-dashed border-black">
            <nav class="flex flex-wrap gap-x-6 gap-y-2 mb-6 text-sm" aria-label="Navigation secondaire">
                {secondaryLinks.map(link => (
                    <a href={link.href} class="text-gray-700 font-medium hover:text-[var(--blue)] transition-colors duration-200">{link.label}</a>
                ))}
            </nav>
            <div class="flex flex-col md:flex-row justify-between items-center gap-4">
                <p class="text-sm text-gray-500">
                    © {new Date().getFullYear()} {author.nickname} - <strong>Développement Web Genève</strong>
                </p>
                <div class="flex gap-6 text-sm">
                    <a href="/mentions-legales" class="text-gray-500 hover:text-[var(--blue)] transition-colors">Mentions légales</a>
                    <a href="/mentions-legales#confidentialite" class="text-gray-500 hover:text-[var(--blue)] transition-colors">Confidentialité</a>
                </div>
            </div>
        </div>
    </div>
</footer>