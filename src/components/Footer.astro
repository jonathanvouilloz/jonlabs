---
// Footer blueprint (design system .co-chrome) — fat footer crawlable.
// Design porté du Lot 1 (styleguide-nav) FUSIONNÉ avec tout le contenu SEO du
// footer historique : CTA, coordonnées réelles, 5 colonnes de liens profonds,
// socials, mentions. Self-scopé `.co-chrome` → rendu blueprint sur toutes les pages.
import { author } from '../sample'
import Logo from './Logo.astro'
import { mainNav, ctaContact, footerZonesWeb, footerRegionsIA } from '../data/navigation'
import type { NavSection } from '../data/navigation'

const socials = [
    { icon: 'ri-linkedin-fill', link: author.linkedin, label: 'LinkedIn' },
    { icon: 'ri-github-fill', link: author.github, label: 'GitHub' },
    { icon: 'ri-youtube-fill', link: author.youtube, label: 'YouTube' },
    { icon: 'ri-newspaper-fill', link: author.substack, label: 'Substack' },
    { icon: 'ri-mail-fill', link: author.email, label: 'Email' },
]

// Source de vérité unique : mainNav (data/navigation.ts). Liens profonds exposés
// en plain HTML, crawlables sitewide (vs méga-menu JS sous-pondéré au crawl).
const creationWeb = mainNav.find((s) => s.label === 'Création Web')
const iaAuto = mainNav.find((s) => s.label === 'IA & Automatisation')
const ressources = mainNav.find((s) => s.label === 'Ressources')
const col = (section: NavSection | undefined, title: string) =>
    section?.columns?.find((c) => c.title === title)?.items ?? []

const servicesLinks = [
    ...col(creationWeb, 'Sites web'),
    ...col(creationWeb, 'Apps & sur-mesure'),
    ...col(creationWeb, 'SEO local'),
]
const iaLinks = [
    ...col(iaAuto, 'Conseil & agents'),
    ...col(iaAuto, 'Automatiser'),
    ...col(iaAuto, 'Par métier'),
    { label: 'Guides IA', href: '/guides' },
]
const ressourcesLinks = [
    { label: 'Freelance web à Genève', href: creationWeb?.spotlight?.href ?? '/developpeur-web-freelance-geneve' },
    ...col(ressources, 'À la une'),
    { label: 'Tous les articles', href: '/blog' },
]
const zonesLinks = [...footerZonesWeb, ...footerRegionsIA]
const secondaryLinks = [
    { label: 'Tarifs', href: '/tarifs' },
    { label: 'Réalisations', href: '/portfolio' },
    { label: 'À propos', href: '/about' },
    { label: ctaContact.label, href: ctaContact.href },
    { label: 'CV', href: '/cv' },
]
const year = new Date().getFullYear()
---

<footer class="co-chrome co-foot">
    <!-- ══ CTA ══ -->
    <div class="co-foot-cta co-pad">
        <p class="co-eyebrow">Disponible pour de nouveaux projets</p>
        <h2 class="co-foot-cta-title">
            Travaillons <span class="co-ser">ensemble ?</span>
        </h2>
        <p class="co-mut co-foot-cta-lead">
            À <strong>Genève</strong> et en télétravail. Un échange de 20 minutes suffit pour savoir
            si on peut avancer ensemble.
        </p>
        <a href={ctaContact.href} class="co-btn co-foot-cta-btn">
            Discuter de mon projet <i class="ri-arrow-right-line"></i>
        </a>
    </div>

    <!-- ══ COLONNES ══ -->
    <div class="co-foot-grid co-pad">
        <!-- Marque -->
        <div class="co-foot-brand">
            <Logo />
            <p class="co-mut co-foot-baseline">
                Développement web, automatisation, applications sur-mesure. J'accompagne
                entrepreneurs et petites équipes à Genève et en Suisse romande.
            </p>
            <div class="co-foot-socials">
                {socials.map((item) => (
                    <a
                        href={item.link}
                        target={item.link.startsWith('mailto') ? '_self' : '_blank'}
                        rel="noopener noreferrer"
                        aria-label={item.label}
                        class="co-foot-social"
                    >
                        <i class={item.icon} aria-hidden="true"></i>
                    </a>
                ))}
            </div>
        </div>

        <!-- Coordonnées -->
        <div class="co-foot-col">
            <h3 class="co-eyebrow">Coordonnées</h3>
            <ul class="co-foot-coord">
                <li class="co-foot-coord-name">Jonathan Vouilloz</li>
                <li>
                    <i class="ri-map-pin-line" aria-hidden="true"></i>
                    <span>120 chemin de la montagne,<br/>1224 Chêne-Bougeries</span>
                </li>
                <li>
                    <a href="tel:+41789447707" class="co-foot-link">
                        <i class="ri-phone-line" aria-hidden="true"></i> 078 944 77 07
                    </a>
                </li>
                <li>
                    <a href="mailto:contact@jonlabs.ch" class="co-foot-link">
                        <i class="ri-mail-line" aria-hidden="true"></i> contact@jonlabs.ch
                    </a>
                </li>
            </ul>
        </div>

        <!-- Création Web -->
        <div class="co-foot-col">
            <h3 class="co-eyebrow"><a href="/services" class="co-foot-link">Création Web</a></h3>
            <ul>
                {servicesLinks.map((link) => (
                    <li><a href={link.href} class="co-foot-link">{link.label}</a></li>
                ))}
            </ul>
        </div>

        <!-- IA & Automatisation -->
        <div class="co-foot-col">
            <h3 class="co-eyebrow"><a href="/consultant-ia" class="co-foot-link">IA &amp; Automatisation</a></h3>
            <ul>
                {iaLinks.map((link) => (
                    <li><a href={link.href} class="co-foot-link">{link.label}</a></li>
                ))}
            </ul>
        </div>

        <!-- Zones & régions -->
        <div class="co-foot-col">
            <h3 class="co-eyebrow">Zones &amp; régions</h3>
            <ul>
                {zonesLinks.map((link) => (
                    <li><a href={link.href} class="co-foot-link">{link.label}</a></li>
                ))}
            </ul>
        </div>

        <!-- Ressources -->
        <div class="co-foot-col">
            <h3 class="co-eyebrow">Ressources</h3>
            <ul>
                {ressourcesLinks.map((link) => (
                    <li><a href={link.href} class="co-foot-link">{link.label}</a></li>
                ))}
            </ul>
        </div>
    </div>

    <!-- ══ BAS DE PAGE ══ -->
    <div class="co-foot-legal co-pad">
        <nav class="co-foot-secondary" aria-label="Navigation secondaire">
            {secondaryLinks.map((link) => (
                <a href={link.href} class="co-foot-link">{link.label}</a>
            ))}
        </nav>
        <div class="co-foot-copy">
            <p class="co-mut">© {year} {author.nickname} · <strong>Développement Web Genève</strong></p>
            <div class="co-foot-legal-links">
                <a href="/mentions-legales" class="co-foot-link">Mentions légales</a>
                <a href="/mentions-legales#confidentialite" class="co-foot-link">Confidentialité</a>
            </div>
        </div>
    </div>
</footer>

<style>
    .co-foot {
        max-width: 1180px; margin: 0 auto; background: var(--bg);
        border-left: 1px solid var(--line); border-right: 1px solid var(--line);
        border-top: 1px solid var(--line);
    }

    /* CTA */
    .co-foot-cta {
        display: flex; flex-direction: column; align-items: center; text-align: center; gap: 14px;
        padding: 64px 40px; border-bottom: 1px solid var(--line);
    }
    .co-foot-cta-title { font-size: clamp(1.8rem, 4vw, 2.6rem); line-height: 1.08; }
    .co-foot-cta-title .co-ser { color: var(--accent); }
    .co-foot-cta-lead { max-width: 44ch; line-height: 1.6; }
    .co-foot-cta-btn { margin-top: 8px; }
    .co-foot-cta-btn i { transition: transform .18s ease-out; }
    .co-foot-cta-btn:hover i { transform: translateX(3px); }

    /* Colonnes */
    .co-foot-grid {
        display: grid; grid-template-columns: 1.7fr 1.1fr 1fr 1fr 1fr 1fr; gap: 40px;
        padding: 56px 40px; border-bottom: 1px solid var(--line);
    }
    .co-foot-brand .co-foot-baseline { margin-top: 14px; max-width: 34ch; line-height: 1.55; font-size: 14px; }
    .co-foot-socials { display: flex; gap: 10px; margin-top: 18px; }
    .co-foot-social {
        width: 38px; height: 38px; display: inline-flex; align-items: center; justify-content: center;
        border: 1px solid var(--line-2); border-radius: 10px; color: var(--muted); font-size: 17px;
        transition: color .16s ease-out, border-color .16s ease-out;
    }
    .co-foot-social:hover { color: var(--accent); border-color: var(--accent); }

    .co-foot-col h3 { margin-bottom: 14px; }
    .co-foot-col ul { display: flex; flex-direction: column; gap: 9px; }
    .co-foot-link { font-size: 14px; color: var(--muted); transition: color .16s ease-out; }
    .co-foot-link:hover { color: var(--accent); }

    .co-foot-coord { display: flex; flex-direction: column; gap: 10px; font-size: 14px; color: var(--muted); }
    .co-foot-coord li { display: flex; align-items: flex-start; gap: 8px; line-height: 1.5; }
    .co-foot-coord-name { font-weight: 600; color: var(--ink); }
    .co-foot-coord i { color: var(--accent); margin-top: 2px; flex: none; }
    .co-foot-coord .co-foot-link { display: inline-flex; align-items: center; gap: 8px; }

    /* Bas de page */
    .co-foot-legal { padding: 22px 40px; display: flex; flex-direction: column; gap: 16px; }
    .co-foot-secondary { display: flex; flex-wrap: wrap; gap: 8px 22px; }
    .co-foot-copy { display: flex; align-items: center; justify-content: space-between; gap: 12px; flex-wrap: wrap; font-size: 13px; }
    .co-foot-legal-links { display: flex; gap: 20px; }

    @media (max-width: 900px) {
        .co-foot-grid { grid-template-columns: 1fr 1fr 1fr; gap: 32px 24px; }
        .co-foot-brand { grid-column: 1 / -1; }
    }
    @media (max-width: 720px) {
        .co-foot-cta { padding: 48px 20px; }
        .co-foot-grid { grid-template-columns: 1fr 1fr; gap: 28px 20px; padding: 44px 20px; }
        .co-foot-legal { padding: 22px 20px; }
        .co-foot-copy { flex-direction: column; align-items: flex-start; gap: 8px; }
    }
</style>
