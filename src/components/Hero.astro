---
import { Image } from 'astro:assets';
import imgJonathan from '../assets/jonathan-vouilloz.webp';
import { author, cta } from '../sample';

const socials = [
  { icon: 'ri-linkedin-fill', link: author.linkedin, label: 'LinkedIn', ext: true },
  { icon: 'ri-github-fill', link: author.github, label: 'GitHub', ext: true },
  { icon: 'ri-mail-fill', link: author.email, label: 'Email', ext: false },
];
---

<section class="co-sec co-pad hp-hero">
  <div class="co-guides"></div>
  <div class="hp-hero-grid">
    <!-- Texte -->
    <div class="hp-hero-body">
      <p class="co-eyebrow" data-animate>Développeur web &amp; automatisation · Genève</p>
      <h1 class="hp-hero-title" data-animate data-delay="0.1">
        Développeur web &amp; <span class="co-ser">partenaire digital</span> à Genève
      </h1>
      <p class="hp-hero-hook" data-animate data-delay="0.2">
        L'idée que tu repoussais depuis des mois ? Elle peut exister demain.
      </p>
      <p class="co-mut hp-hero-lead" data-animate data-delay="0.25">
        De l'idée au produit fini, j'accompagne <strong>entrepreneurs</strong> et
        <strong>PME en Suisse romande</strong> dans leurs projets digitaux : sites performants,
        applications sur-mesure et workflows automatisés.
      </p>
      <div class="hp-hero-ctas" data-animate data-delay="0.3">
        <a href={cta.primary.link} class="co-btn">
          {cta.primary.text} <i class="ri-arrow-right-line"></i>
        </a>
        <a href={cta.secondary.link} class="co-btn co-btn--ghost">
          {cta.secondary.text}
        </a>
      </div>
      <div class="hp-hero-socials" data-animate data-delay="0.4">
        <span class="co-eyebrow">Me retrouver</span>
        <div class="hp-hero-social-row">
          {socials.map((s) => (
            <a
              href={s.link}
              class="hp-hero-social"
              aria-label={s.label}
              target={s.ext ? '_blank' : undefined}
              rel={s.ext ? 'noopener noreferrer' : undefined}
            >
              <i class={s.icon} aria-hidden="true"></i>
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- Portrait cadré -->
    <div class="hp-hero-media" data-animate="fade-left" data-delay="0.2">
      <div class="hp-hero-frame co-frame">
        <span class="co-x tl"></span><span class="co-x tr"></span>
        <span class="co-x bl"></span><span class="co-x br"></span>
        <Image
          src={imgJonathan}
          alt="Jonathan Vouilloz — développeur web et partenaire digital à Genève"
          width={360}
          height={450}
          quality={85}
          loading="eager"
          class="hp-hero-photo"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .hp-hero { position: relative; overflow: hidden; }
  .hp-hero-grid {
    position: relative;
    display: grid; grid-template-columns: 1.15fr 0.85fr; gap: 56px; align-items: center;
    padding: 72px 40px 64px;
  }
  .hp-hero-body { display: flex; flex-direction: column; align-items: flex-start; gap: 20px; }
  .hp-hero-title { font-size: clamp(2.3rem, 5.2vw, 3.6rem); }
  .hp-hero-hook { font-size: clamp(1.15rem, 2.2vw, 1.4rem); font-weight: 500; line-height: 1.4; max-width: 30ch; }
  .hp-hero-lead { font-size: 1.05rem; line-height: 1.65; max-width: 46ch; }
  .hp-hero-ctas { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 6px; }
  .hp-hero-ctas .co-btn i { transition: transform .18s ease-out; }
  .hp-hero-ctas .co-btn:hover i { transform: translateX(3px); }

  .hp-hero-socials { display: flex; align-items: center; gap: 16px; margin-top: 10px; padding-top: 22px; border-top: 1px solid var(--line); width: 100%; }
  .hp-hero-social-row { display: flex; gap: 10px; }
  .hp-hero-social {
    width: 40px; height: 40px; display: inline-flex; align-items: center; justify-content: center;
    border: 1px solid var(--line-2); border-radius: 10px; color: var(--muted); font-size: 18px;
    transition: color .16s ease-out, border-color .16s ease-out, transform .16s ease-out;
  }
  .hp-hero-social:hover { color: var(--accent); border-color: var(--accent); transform: translateY(-2px); }

  .hp-hero-media { display: flex; justify-content: center; }
  .hp-hero-frame { position: relative; width: 100%; max-width: 340px; }
  .hp-hero-photo { display: block; width: 100%; height: auto; object-fit: cover; }

  @media (max-width: 900px) {
    .hp-hero-grid { grid-template-columns: 1fr; gap: 40px; padding: 56px 40px; }
    .hp-hero-media { order: -1; }
    .hp-hero-frame { max-width: 280px; }
  }
  @media (max-width: 720px) {
    .hp-hero-grid { padding: 48px 20px; }
  }
</style>
