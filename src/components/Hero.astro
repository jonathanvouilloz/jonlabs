---
import { Image } from 'astro:assets';

import svgPinkStar from '../assets/pink-star.svg'
import svgArrowHero from '../assets/arrow-3.svg'
import imgJonathan from '../assets/jonathan-vouilloz.webp'

import { author, cta } from '../sample'
---

<section class="pb-20 relative overflow-hidden">
    <!-- Decorative background elements -->
    <div class="absolute top-20 right-0 w-96 h-96 bg-[var(--blue)] opacity-5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 left-0 w-64 h-64 bg-[var(--violet)] opacity-5 rounded-full blur-3xl"></div>

    <div class="max-w-5xl mx-auto p-4 pt-16 md:pt-24">
      <div class="grid grid-cols-1 md:grid-cols-[60%_40%] items-center gap-8">

        <!-- Left: Text Content -->
        <div class="flex flex-col gap-6 pr-0 md:pr-10">

          <!-- Main heading (SEO optimized) -->
          <h1 class="text-4xl md:text-5xl lg:text-5xl font-normal tracking-tight" data-animate>
            <span>Développeur web &</span>
            <span class="block">
              <span class="relative inline-block">
                <span class="relative z-10">partenaire digital</span>
                <img
                  src={svgArrowHero.src}
                  alt=""
                  class="absolute -bottom-0 left-0 w-full h-8 pointer-events-none"
                  aria-hidden="true"
                />
              </span>
              à Genève
            </span>
          </h1>

          <!-- Hook / Accroche -->
          <p class="text-xl md:text-2xl font-medium text-black max-w-lg" data-animate data-delay="0.1">
            L'idée que tu repoussais depuis des mois ? Elle peut exister demain.
          </p>

          <!-- Lead paragraph -->
          <p class="text-md md:text-md text-gray-700 max-w-lg leading-relaxed" data-animate data-delay="0.2">
            De l'idée au produit fini, j'accompagne <strong>entrepreneurs</strong> et <strong>PME en Suisse Romande</strong> dans leurs projets digitaux : sites performants, applications sur-mesure et workflows automatisés.
          </p>

          <!-- CTAs -->
          <div class="flex flex-col sm:flex-row gap-6 mt-4" data-animate data-delay="0.3">
            <a
              href={cta.primary.link}
              class="
                inline-flex items-center justify-center gap-2
                bg-[var(--blue)] border-2 border-black
                px-6 py-3
                font-bold text-base
                shadow-[4px_4px_0px_rgba(0,0,0,1)]
                transition-all duration-200
                hover:bg-[var(--yellow)]
                hover:shadow-[2px_2px_0px_rgba(0,0,0,1)]
                hover:translate-x-[2px] hover:translate-y-[2px]
                focus:ring-2 focus:ring-black focus:ring-offset-2 focus:outline-none
              "
            >
              {cta.primary.text}
              <i class="ri-arrow-right-line"></i>
            </a>
            <a
              href={cta.secondary.link}
              class="
                inline-flex items-center justify-center gap-2
                px-2 py-3
                font-medium text-base
                transition-all duration-200
                relative
                before:absolute before:left-2 before:bottom-2
                before:h-[2px] before:w-0 before:bg-[var(--accent)]
                before:transition-all before:duration-300
                hover:before:w-[calc(100%-16px)]
                hover:text-[var(--violet)]
              "
            >
              {cta.secondary.text}
              <i class="ri-arrow-right-line"></i>
            </a>
          </div>

          <!-- Social links -->
          <div class="flex items-center gap-4 mt-6 pt-6 border-t-2 border-black border-dashed" data-animate data-delay="0.4">
            <span class="text-sm text-gray-500 font-medium">Me retrouver</span>
            <div class="flex gap-3">
              <a
                href={author.linkedin}
                target="_blank"
                rel="noopener noreferrer"
                class="
                  w-10 h-10 flex items-center justify-center
                  border-2 border-black bg-white
                  transition-all duration-200
                  hover:bg-[var(--blue)] hover:translate-y-[-2px]
                  focus:ring-2 focus:ring-black focus:outline-none
                "
                aria-label="LinkedIn"
              >
                <i class="ri-linkedin-fill text-lg"></i>
              </a>
              <a
                href={author.github}
                target="_blank"
                rel="noopener noreferrer"
                class="
                  w-10 h-10 flex items-center justify-center
                  border-2 border-black bg-white
                  transition-all duration-200
                  hover:bg-[var(--blue)] hover:translate-y-[-2px]
                  focus:ring-2 focus:ring-black focus:outline-none
                "
                aria-label="GitHub"
              >
                <i class="ri-github-fill text-lg"></i>
              </a>
              <a
                href={author.email}
                class="
                  w-10 h-10 flex items-center justify-center
                  border-2 border-black bg-white
                  transition-all duration-200
                  hover:bg-[var(--blue)] hover:translate-y-[-2px]
                  focus:ring-2 focus:ring-black focus:outline-none
                "
                aria-label="Email"
              >
                <i class="ri-mail-fill text-lg"></i>
              </a>
            </div>
          </div>
        </div>

        <!-- Right: Image -->
        <div class="relative mt-8 md:mt-0" data-animate data-delay="0.2">
          <Image
            src={imgJonathan}
            alt="Jonathan Vouilloz - Développeur web et partenaire digital à Genève"
            width={320}
            height={400}
            quality={85}
            loading="eager"
            class="w-full max-w-[280px] mx-auto md:max-w-none object-cover"
          />
        </div>

      </div>
    </div>

    <!-- Bottom decoration -->
    <img src={svgPinkStar.src} alt="" width="50" class="absolute -bottom-4 left-8" aria-hidden="true" />
</section>

