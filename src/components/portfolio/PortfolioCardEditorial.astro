---
/**
 * PortfolioCardEditorial — Carte blueprint pour la page Réalisations
 *
 * Coins nets, filet + crosshairs au survol (.co-frame--reveal), média cadré
 * (ou placeholder hachuré .co-hatch si pas d'image), badge catégorie unique
 * (.co-badge, point teal — pas de couleur par catégorie), 1 résultat clé.
 * Les styles .po-* vivent dans le <style is:global> de portfolio.astro.
 *
 * data-category = utilisé par le JS de filtres de la grille.
 * data-animate-item = ne s'active que sous un ancêtre [data-animate-stagger].
 */

import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'portfolio'>;
}

const { project } = Astro.props;
const { title, description, heroImage, project: projectData, entryType, client, results } = project.data;

const categoryLabels: Record<string, string> = {
  'site-vitrine': 'Site vitrine',
  'e-commerce': 'E-commerce',
  'application': 'Application',
  'seo': 'SEO',
  'automatisation': 'Automatisation',
  'side-project': 'Projet perso',
};

const isSideProject = entryType === 'side-project';
const categoryKey = isSideProject ? 'side-project' : projectData.category;
const categoryLabel = categoryLabels[categoryKey] || categoryKey;
const top = results?.[0];
---

<a
  href={`/portfolio/${project.slug}`}
  class="po-card co-frame co-frame--reveal"
  data-category={categoryKey}
  data-animate-item
  aria-label={`Voir le projet : ${title}`}
>
  <div class="po-card-media">
    {heroImage?.url ? (
      <img src={heroImage.url} alt={heroImage.alt} loading="lazy" />
    ) : (
      <div class="po-card-ph co-hatch"><i class="ri-image-line" aria-hidden="true"></i></div>
    )}
  </div>

  <div class="po-card-body">
    <div class="po-card-meta">
      <span class="co-badge">{categoryLabel}</span>
      {client?.name && <span class="co-mut">{client.name}</span>}
    </div>
    <h3 class="po-card-title">{title}</h3>
    {description && <p class="po-card-desc co-mut">{description}</p>}
    {top && (
      <p class="po-card-result"><strong>{top.value}</strong> {top.label}</p>
    )}
    <span class="po-card-arrow" aria-hidden="true"><i class="ri-arrow-right-line"></i></span>
  </div>
</a>
