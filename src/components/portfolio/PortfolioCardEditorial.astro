---
/**
 * PortfolioCardEditorial - Carte éditoriale plein cadre pour la page Réalisations
 *
 * Grande image, texte en overlay (gradient bas→haut) :
 * catégorie + titre + 1 résultat clé. Au survol : calque sombre +
 * flèche centrale « Voir le projet ».
 */

import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'portfolio'>;
}

const { project } = Astro.props;
const { title, description, heroImage, project: projectData, entryType } = project.data;

const categoryLabels: Record<string, string> = {
  'site-vitrine': 'Site vitrine',
  'e-commerce': 'E-commerce',
  'application': 'Application',
  'seo': 'SEO',
  'automatisation': 'Automatisation',
  'side-project': 'Projet perso',
};

const isSideProject = entryType === 'side-project';
const categoryKey = isSideProject ? 'side-project' : projectData.category;
const categoryLabel = categoryLabels[categoryKey] || categoryKey;

---

<a
  href={`/portfolio/${project.slug}`}
  aria-label={`Voir le projet : ${title}`}
  class="group relative block border-2 border-black shadow-[4px_4px_0px_rgba(0,0,0,0.3)] hover:shadow-[2px_2px_0px_rgba(0,0,0,1)] hover:translate-x-[2px] hover:translate-y-[2px] transition-all duration-200 overflow-hidden"
>
  <!-- Image plein cadre -->
  <div class="relative aspect-[4/3] overflow-hidden bg-gray-100">
    {heroImage.url ? (
      <img
        src={heroImage.url}
        alt={heroImage.alt}
        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 motion-reduce:transform-none"
        loading="lazy"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-gray-100 to-gray-200">
        <i class="ri-image-line text-5xl text-gray-400"></i>
      </div>
    )}

    <!-- Overlay repos : gradient bas→haut -->
    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>

    <!-- Contenu en bas -->
    <div class="absolute inset-x-0 bottom-0 p-5 md:p-6 text-white">
      <span class="inline-block mb-3 px-2.5 py-1 bg-[var(--blue)] text-black text-xs font-medium border border-black uppercase tracking-wide">
        {categoryLabel}
      </span>
      <h3 class="text-xl md:text-2xl font-bold leading-tight">
        {title}
      </h3>
      {description && (
        <p class="mt-2 text-sm text-white/80 leading-snug">
          {description}
        </p>
      )}
    </div>

    <!-- Overlay hover : calque + flèche « Voir le projet » -->
    <div class="absolute inset-0 bg-black/55 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col items-center justify-center gap-3 text-white motion-reduce:transition-none">
      <span class="flex items-center justify-center w-14 h-14 border-2 border-white rounded-full">
        <i class="ri-arrow-right-line text-2xl"></i>
      </span>
      <span class="text-base font-medium tracking-wide">Voir le projet</span>
    </div>
  </div>
</a>
