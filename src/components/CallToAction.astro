---
import svgPinkStar from '../assets/pink-star.svg'
import Button from './Button.astro'
import { buy } from '../sample'

---


<section class="px-3" id="hire">
    <div class="max-w-3xl mx-auto bg-white text-center flex flex-col gap-4 border-3 shadow-[8px_8px_0px_rgba(0,0,0,0.3)]  relative p-10">
     <h2 class="text-3xl md:text-4xl font-bold tracking-tight">Envie de lancer votre projet ?</h2>
     <p class="text-lg max-w-lg mx-auto">Décrivez-moi votre idée en deux lignes — je vous réponds sous 24h.</p>
     <div class="flex justify-center">
       <Button text={buy.title} link={buy.link} target="_blank" />
     </div>
     <img src={svgPinkStar.src} alt="" aria-hidden="true" width="80" class="absolute -top-10 right-20" />
    </div>
  </section>