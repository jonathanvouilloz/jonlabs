---
// Skills section — Section 05
const skillCategories = [
  {
    id: "dev",
    title: "Développement Web",
    icon: "ri-code-s-slash-line",
    skills: ["Astro", "React", "Node.js", "TypeScript", "JavaScript", "HTML/CSS", "Webflow", "Framer"]
  },
  {
    id: "design",
    title: "Design & UI/UX",
    icon: "ri-palette-line",
    skills: ["Figma", "Tailwind CSS", "UI/UX Design", "Responsive", "Identité graphique"]
  },
  {
    id: "backend",
    title: "Backend & BDD",
    icon: "ri-database-2-line",
    skills: ["Supabase", "PostgreSQL", "APIs RESTful", "Auth", "Architecture données"]
  },
  {
    id: "automation",
    title: "Automatisation",
    icon: "ri-settings-3-line",
    skills: ["Make", "Airtable", "Scripts custom", "Intégrations API", "n8n"]
  },
  {
    id: "marketing",
    title: "Marketing Digital",
    icon: "ri-megaphone-line",
    skills: ["SEO/SEM", "Copywriting", "Email Marketing", "Analytics", "Content Strategy"]
  },
  {
    id: "ai",
    title: "Intelligence Artificielle",
    icon: "ri-brain-line",
    skills: ["Prompt Engineering", "Claude", "MCP", "Claude Code", "Workflows IA", "Cursor"]
  },
  {
    id: "blockchain",
    title: "Blockchain & Web3",
    icon: "ri-coin-line",
    skills: ["Analyse fondamentale", "Économie crypto", "Histoire blockchain", "Concepts DeFi", "Veille marché"]
  },
  {
    id: "tools",
    title: "Outils & Workflow",
    icon: "ri-tools-line",
    skills: ["Git/GitHub", "VS Code", "Vercel/Netlify", "Markdown", "Documentation"]
  }
];

const softSkills = [
  { title: "Pédagogie & Formation", description: "Vulgarisation de concepts techniques", icon: "ri-presentation-line" },
  { title: "Gestion de projets", description: "De la conception à la livraison", icon: "ri-task-line" },
  { title: "Communication", description: "Clients techniques et non-techniques", icon: "ri-chat-3-line" },
  { title: "Vision stratégique", description: "Conseil au-delà de l'exécution", icon: "ri-lightbulb-line" },
  { title: "Polyvalence", description: "Tech + business + design", icon: "ri-apps-2-line" },
  { title: "Autonomie", description: "Freelance depuis 2020", icon: "ri-user-star-line" }
];
---

<section class="cv-section cv-skills-section co-sec co-pad cv-sec">
  <div class="cv-wrap-wide">
    <header class="cv-head">
      <p class="co-eyebrow">Section 05</p>
      <h2 class="cv-h2">Stack &amp; compétences</h2>
    </header>

    <!-- Catégories techniques -->
    <div class="cv-sk-grid">
      {skillCategories.map((category) => (
        <div class="cv-sk-cat" data-category={category.id}>
          <div class="cv-sk-cat-head">
            <span class="cv-sk-ic"><i class={category.icon} aria-hidden="true"></i></span>
            <h3 class="cv-sk-cat-title">{category.title}</h3>
          </div>
          <div class="cv-sk-tags">
            {category.skills.map((skill) => (<span class="skill-badge cv-tag">{skill}</span>))}
          </div>
        </div>
      ))}
    </div>

    <!-- Compétences transversales -->
    <div class="cv-soft">
      <h3 class="cv-soft-title">Compétences transversales</h3>
      <div class="cv-soft-grid">
        {softSkills.map((skill) => (
          <div class="cv-soft-item">
            <span class="cv-soft-ic"><i class={skill.icon} aria-hidden="true"></i></span>
            <div class="cv-soft-body">
              <span class="cv-soft-name">{skill.title}</span>
              <span class="cv-soft-desc">{skill.description}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .cv-sec { padding: 64px 40px; }
  .cv-wrap-wide { max-width: 1060px; margin: 0 auto; }
  .cv-head { display: flex; flex-direction: column; gap: 8px; padding-bottom: 40px; }
  .cv-h2 { font-size: clamp(1.7rem, 3.6vw, 2.3rem); }

  .cv-sk-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; margin-bottom: 44px; }
  .cv-sk-cat {
    background: var(--surface); border: 1px solid var(--line); padding: 18px;
    display: flex; flex-direction: column; gap: 14px; transition: border-color .18s ease-out;
  }
  .cv-sk-cat:hover { border-color: var(--line-2); }
  .cv-sk-cat-head { display: flex; align-items: center; gap: 11px; }
  .cv-sk-ic {
    flex: none; width: 36px; height: 36px; display: grid; place-items: center;
    border: 1px solid var(--line-2); color: var(--muted); font-size: 18px;
    transition: color .18s ease-out, border-color .18s ease-out;
  }
  .cv-sk-cat:hover .cv-sk-ic { color: var(--accent); border-color: var(--accent); }
  .cv-sk-cat-title { font-size: 13.5px; font-weight: 700; line-height: 1.25; letter-spacing: -0.01em; }
  .cv-sk-tags { display: flex; flex-wrap: wrap; gap: 6px; }
  .cv-tag {
    display: inline-flex; align-items: center;
    font-size: 11.5px; font-weight: 500; color: var(--ink);
    background: var(--bg); border: 1px solid var(--line-2); padding: 3px 8px; border-radius: 999px;
  }

  .cv-soft { display: flex; flex-direction: column; gap: 20px; padding-top: 40px; border-top: 1px solid var(--line); }
  .cv-soft-title { font-size: 1.15rem; font-weight: 700; letter-spacing: -0.02em; }
  .cv-soft-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
  .cv-soft-item {
    display: flex; align-items: flex-start; gap: 12px;
    background: var(--surface); border: 1px solid var(--line); padding: 15px 16px;
    transition: border-color .18s ease-out;
  }
  .cv-soft-item:hover { border-color: var(--accent); }
  .cv-soft-ic {
    flex: none; width: 34px; height: 34px; display: grid; place-items: center;
    border: 1px solid var(--line-2); color: var(--muted); font-size: 16px;
    transition: color .18s ease-out, border-color .18s ease-out;
  }
  .cv-soft-item:hover .cv-soft-ic { color: var(--accent); border-color: var(--accent); }
  .cv-soft-body { display: flex; flex-direction: column; gap: 2px; }
  .cv-soft-name { font-size: 14px; font-weight: 600; color: var(--ink); }
  .cv-soft-desc { font-size: 12.5px; color: var(--muted); line-height: 1.45; }

  @media (max-width: 980px) {
    .cv-sk-grid { grid-template-columns: repeat(2, 1fr); }
    .cv-soft-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 720px) {
    .cv-sec { padding: 48px 20px; }
    .cv-head { padding-bottom: 28px; }
    .cv-sk-grid { grid-template-columns: 1fr; }
    .cv-soft-grid { grid-template-columns: 1fr; }
  }
</style>
