---
// Formation section — Section 02
const formations = [
  {
    title: "Bachelor HES en Informatique de Gestion",
    school: "Haute École de Gestion (HEG) - Genève",
    years: "2017 - 2020",
    type: "diploma"
  },
  {
    title: "CFC Informaticien de Gestion",
    school: "École Supérieure d'Informatique de Gestion (ESIG) - Genève",
    years: "2015 - 2017",
    type: "diploma"
  }
];

const continuousLearning = [
  { label: "Marketing Digital & Copywriting", sublabel: "École des Copywriters (Stan Leloup)", period: "2024-2025", icon: "ri-megaphone-line", active: true },
  { label: "SEO & Référencement Naturel", period: "2025", icon: "ri-search-eye-line", active: true },
  { label: "Blockchain & Web3", period: "2021-2024", icon: "ri-coin-line" },
  { label: "Intelligence Artificielle & Prompt Engineering", period: "2024-2025", icon: "ri-brain-line", active: true }
];
---

<section class="cv-section cv-formation co-sec co-pad cv-sec">
  <div class="cv-wrap">
    <header class="cv-head">
      <p class="co-eyebrow">Section 02</p>
      <h2 class="cv-h2">Formation</h2>
    </header>

    <!-- Diplômes — fiche technique -->
    <dl class="co-spec cv-formation-spec">
      {formations.map((formation) => (
        <div class="co-spec-row">
          <dt>{formation.years}</dt>
          <dd>
            <span class="cv-dd-title">{formation.title}</span>
            <span class="cv-dd-school">
              <i class="ri-building-line" aria-hidden="true"></i>
              {formation.school}
            </span>
          </dd>
        </div>
      ))}
    </dl>

    <!-- Formations continues -->
    <div class="cv-cl">
      <h3 class="cv-cl-title">
        Formations continues
        <span class="cv-cl-note">autodidacte &amp; certifications</span>
      </h3>

      <div class="cv-cl-grid">
        {continuousLearning.map((item) => (
          <div class={`cv-cl-item ${item.active ? 'is-active' : ''}`}>
            <span class="cv-cl-ic"><i class={item.icon} aria-hidden="true"></i></span>
            <div class="cv-cl-body">
              <span class="cv-cl-label">{item.label}</span>
              {item.sublabel && <span class="cv-cl-sub">{item.sublabel}</span>}
              <span class="cv-cl-period">{item.period}</span>
            </div>
            {item.active && (
              <span class="cv-cl-badge"><span class="cv-cl-dot" aria-hidden="true"></span> En cours</span>
            )}
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .cv-sec { padding: 64px 40px; }
  .cv-wrap { max-width: 860px; margin: 0 auto; }
  .cv-head { display: flex; flex-direction: column; gap: 8px; padding-bottom: 36px; }
  .cv-h2 { font-size: clamp(1.7rem, 3.6vw, 2.3rem); }

  /* Fiche diplômes */
  .cv-formation-spec { margin-bottom: 44px; }
  .cv-formation-spec .co-spec-row { grid-template-columns: 132px 1fr; padding: 16px 0; align-items: start; }
  .cv-dd-title { display: block; font-size: 1.05rem; font-weight: 600; color: var(--ink); line-height: 1.3; }
  .cv-dd-school { display: inline-flex; align-items: center; gap: 7px; margin-top: 5px; font-size: 13px; font-weight: 400; color: var(--muted); }
  .cv-dd-school i { color: var(--accent); }

  /* Formations continues */
  .cv-cl { display: flex; flex-direction: column; gap: 20px; }
  .cv-cl-title { display: flex; align-items: baseline; flex-wrap: wrap; gap: 10px; font-size: 1.15rem; font-weight: 700; letter-spacing: -0.02em; }
  .cv-cl-note { font-size: 12px; font-weight: 500; color: var(--muted); text-transform: none; letter-spacing: 0; }
  .cv-cl-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .cv-cl-item {
    display: flex; align-items: center; gap: 13px;
    padding: 14px 16px; background: var(--surface); border: 1px solid var(--line);
    transition: border-color .18s ease-out;
  }
  .cv-cl-item.is-active { border-color: var(--line-2); }
  .cv-cl-item:hover { border-color: var(--accent); }
  .cv-cl-ic {
    flex: none; width: 38px; height: 38px; display: grid; place-items: center;
    border: 1px solid var(--line-2); color: var(--muted); font-size: 18px;
    transition: color .18s ease-out, border-color .18s ease-out;
  }
  .cv-cl-item:hover .cv-cl-ic { color: var(--accent); border-color: var(--accent); }
  .cv-cl-body { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
  .cv-cl-label { font-size: 14px; font-weight: 600; color: var(--ink); line-height: 1.3; }
  .cv-cl-sub { font-size: 12px; color: var(--muted); }
  .cv-cl-period { font-size: 12px; color: var(--muted); }
  .cv-cl-badge {
    flex: none; margin-left: auto; align-self: flex-start;
    display: inline-flex; align-items: center; gap: 6px; white-space: nowrap;
    font-size: 10px; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase;
    color: var(--accent); padding: 4px 9px; border: 1px solid var(--line-2); border-radius: 999px;
  }
  .cv-cl-dot { width: 5px; height: 5px; border-radius: 999px; background: var(--accent); }

  @media (max-width: 720px) {
    .cv-sec { padding: 48px 20px; }
    .cv-head { padding-bottom: 28px; }
    .cv-formation-spec .co-spec-row { grid-template-columns: 96px 1fr; gap: 12px; }
    .cv-cl-grid { grid-template-columns: 1fr; }
  }
</style>
