---
// CV Footer section — contact (effet pixel explosion préservé)
import { author } from '../../sample'
---

<section class="cv-section cv-footer co-sec co-pad cv-sec">
  <div class="cv-wrap">
    <div class="cv-contact co-frame" id="contact-card">
      <!-- Conteneur pixel explosion (hook JS) -->
      <div class="pixel-explosion-container" id="pixel-explosion"></div>

      <p class="co-eyebrow cv-contact-eyebrow">Contact</p>

      <h2 class="cv-contact-title">Prêt à <span class="co-ser">collaborer</span> ?</h2>

      <p class="cv-contact-lead">
        Que ce soit pour un projet, une opportunité ou simplement échanger, je suis disponible.
      </p>

      <div class="cv-contact-ctas">
        <a href="/contact" class="co-btn cv-contact-primary">
          Discuter d'une opportunité
          <i class="ri-arrow-right-line" aria-hidden="true"></i>
        </a>
        <a href="/cv-pdf" target="_blank" class="co-btn co-btn--ghost cv-contact-secondary">
          <i class="ri-download-2-line" aria-hidden="true"></i>
          Télécharger le CV (PDF)
        </a>
      </div>

      <div class="cv-contact-grid">
        <a href={`mailto:${author.email}`} class="cv-contact-item">
          <span class="cv-contact-ic"><i class="ri-mail-line" aria-hidden="true"></i></span>
          <span class="cv-contact-label">Email</span>
          <span class="cv-contact-value">contact@jonlabs.ch</span>
        </a>

        <a href={author.linkedin} target="_blank" rel="noopener noreferrer" class="cv-contact-item">
          <span class="cv-contact-ic"><i class="ri-linkedin-fill" aria-hidden="true"></i></span>
          <span class="cv-contact-label">LinkedIn</span>
          <span class="cv-contact-value">/jonathan-vouilloz</span>
        </a>

        <a href={author.github} target="_blank" rel="noopener noreferrer" class="cv-contact-item">
          <span class="cv-contact-ic"><i class="ri-github-fill" aria-hidden="true"></i></span>
          <span class="cv-contact-label">GitHub</span>
          <span class="cv-contact-value">/jonathanvouilloz</span>
        </a>

        <a href={author.youtube} target="_blank" rel="noopener noreferrer" class="cv-contact-item">
          <span class="cv-contact-ic"><i class="ri-youtube-fill" aria-hidden="true"></i></span>
          <span class="cv-contact-label">YouTube</span>
          <span class="cv-contact-value">@jonlabs_ia</span>
        </a>

        <a href="/portfolio" class="cv-contact-item">
          <span class="cv-contact-ic"><i class="ri-folder-3-line" aria-hidden="true"></i></span>
          <span class="cv-contact-label">Portfolio</span>
          <span class="cv-contact-value">jonlabs.ch/portfolio</span>
        </a>
      </div>
    </div>

    <p class="cv-footer-note">CV interactif — Dernière mise à jour : Décembre 2024</p>
  </div>
</section>

<style>
  .cv-sec { padding: 64px var(--sec-pad-x); }
  .cv-wrap { max-width: 860px; margin: 0 auto; }

  .cv-contact {
    position: relative; background: var(--surface); border: 1px solid var(--line-2);
    padding: 48px 40px; text-align: center;
    display: flex; flex-direction: column; align-items: center; gap: 16px;
  }
  .pixel-explosion-container { position: absolute; inset: 0; pointer-events: none; z-index: 20; }
  .cv-contact-eyebrow { color: var(--accent); }
  .cv-contact-title { font-size: clamp(1.8rem, 4vw, 2.6rem); line-height: 1.1; }
  .cv-contact-title .co-ser { color: var(--accent); }
  .cv-contact-lead { font-size: 1.0625rem; line-height: 1.65; color: var(--muted); max-width: 44ch; }

  .cv-contact-ctas { display: flex; flex-wrap: wrap; justify-content: center; gap: 12px; margin-top: var(--space-eyebrow); }
  .cv-contact-primary i { transition: transform .18s ease-out; }
  .cv-contact-primary:hover i { transform: translateX(3px); }

  .cv-contact-grid {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px;
    width: 100%; margin-top: 24px; padding-top: 32px; border-top: 1px solid var(--line);
  }
  .cv-contact-item {
    display: flex; flex-direction: column; align-items: center; gap: 6px;
    padding: 16px 10px; border: 1px solid var(--line);
    transition: border-color .18s ease-out;
  }
  .cv-contact-item:hover { border-color: var(--accent); }
  .cv-contact-ic {
    width: 42px; height: 42px; display: grid; place-items: center; margin-bottom: 2px;
    border: 1px solid var(--line-2); color: var(--muted); font-size: 20px;
    transition: color .18s ease-out, border-color .18s ease-out;
  }
  .cv-contact-item:hover .cv-contact-ic { color: var(--accent); border-color: var(--accent); }
  .cv-contact-label { font-size: 13px; font-weight: 600; color: var(--ink); }
  .cv-contact-value { font-size: 11.5px; color: var(--muted); transition: color .18s ease-out; }
  .cv-contact-item:hover .cv-contact-value { color: var(--accent); }

  .cv-footer-note { text-align: center; font-size: 13px; color: var(--muted); margin-top: 20px; }

  @media (max-width: 720px) {
    .cv-sec { padding: 48px 20px; }
    .cv-contact { padding: 36px 22px; }
    .cv-contact-grid { grid-template-columns: 1fr 1fr; }
  }
</style>
