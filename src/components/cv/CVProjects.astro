---
// Projects section — Section 04
import { proofLecureux } from "../../data/proof-lecureux";

const projects = [
  {
    id: "001",
    title: "Application Gestion Camps",
    client: "Centre Protestant de Vacances (CPV)",
    year: "2025",
    type: "Application sur-mesure",
    description: "Application de gestion budgétaire pour optimiser la gestion administrative des camps de vacances. Prototype validé sur le terrain → collaboration officielle.",
    results: [
      { value: "-70%", label: "temps gestion" },
      { value: "2026", label: "déploiement" }
    ],
    stack: ["Astro", "Supabase", "PostgreSQL"],
    status: "active",
    link: "https://camp-manager-three.vercel.app/"
  },
  {
    id: "002",
    title: "Système RDV & Site Web",
    client: "Barber Concept",
    year: "2020-2021",
    type: "Web + Application métier",
    description: "Système complet de prise de rendez-vous, site web et identité graphique pour une chaîne de salons de coiffure.",
    results: [
      { value: "19k", label: "utilisateurs" },
      { value: "6", label: "salons" }
    ],
    stack: ["Node.js", "PostgreSQL", "APIs"],
    status: null,
    link: "https://www.barberconcept.ch/"
  },
  {
    id: "003",
    title: "Séquence Emailing Growth",
    client: "Le Matin Dimanche",
    year: "Mai 2025",
    type: "Marketing digital",
    description: "Conception et rédaction d'une séquence d'onboarding complète pour améliorer la rétention des nouveaux utilisateurs.",
    results: [
      { value: "+25%", label: "rétention" },
      { value: "500+", label: "utilisateurs" }
    ],
    stack: ["Copywriting", "Email Marketing", "Growth"],
    stackType: "marketing"
  },
  {
    id: "004",
    title: "Site & Stratégie SEO — Juriste restauration",
    client: proofLecureux.company,
    year: proofLecureux.year,
    type: "Site web, Branding & SEO",
    description: "Création du site web, identité visuelle et optimisation SEO complète pour générer des leads qualifiés via le référencement naturel. De zéro au #1 sur sa niche (droit de la restauration).",
    results: [
      { value: "10+", label: "leads qualifiés" },
      { value: "5", label: "mois mission" }
    ],
    stack: [proofLecureux.platform, "SEO", "Branding", "Analytics"],
    stackType: "marketing",
    link: "https://lecureux-conseil.ch/"
  },
  {
    id: "005",
    title: "Automatisation Club & Comité Badminton",
    client: "Club local + ACGB (Association Cantonale Genevoise de Badminton)",
    year: "2023-2024",
    type: "Process, Automatisation & Comité",
    description: "Membre du comité ACGB. Création de processus automatisés pour optimiser la gestion administrative d'un club sportif de 100 membres et amélioration côté informatique de l'association.",
    results: [
      { value: "100", label: "membres gérés" },
      { value: "++", label: "heures économisées" }
    ],
    stack: ["Airtable", "Make", "n8n"],
    status: "active",
    link: "https://bcchenois.ch/"
  },
  {
    id: "006",
    title: "Présentation Tokenisation Actifs Réels",
    client: "GEC (Geneva Event Crypto)",
    year: "Été 2024",
    type: "Conférence / Présentation",
    description: "Présentation sur la tokenisation des actifs réels (Real World Assets) lors d'un événement crypto à Genève. Vulgarisation de concepts complexes pour un public mixte.",
    results: [
      { value: "50+", label: "participants" },
      { value: "GEC", label: "événement" }
    ],
    stack: ["Blockchain", "Analyse fondamentale", "Présentation"],
    stackType: "past",
    link: "https://www.linkedin.com/posts/jonathan-vouilloz-3b5741139_crypto-blockchain-activity-7238834575546744832-xdEI"
  }
];
---

<section class="cv-section cv-projects co-sec co-pad cv-sec">
  <div class="cv-wrap-wide">
    <header class="cv-head">
      <p class="co-eyebrow">Section 04</p>
      <h2 class="cv-h2">Projets marquants</h2>
      <p class="cv-lead">
        Sélection de projets illustrant mon approche : comprendre les besoins,
        créer des solutions concrètes, générer des résultats mesurables.
      </p>
    </header>

    <div class="cv-proj-grid">
      {projects.map((project) => (
        <article class="cv-proj co-frame co-frame--reveal">
          <div class="cv-proj-topbar">
            <span class="co-index cv-proj-num">{project.id}</span>
            {project.status === "active" && (
              <span class="cv-proj-live"><span class="cv-proj-live-dot" aria-hidden="true"></span> En cours</span>
            )}
          </div>

          <div class="cv-proj-head">
            <h3 class="cv-proj-title">{project.title}</h3>
            <p class="cv-proj-client">{project.client} · {project.year}</p>
            <span class="cv-proj-cat">{project.type}</span>
          </div>

          <p class="cv-proj-desc">{project.description}</p>

          <div class="cv-proj-results">
            {project.results.map((result) => (
              <div class="cv-proj-res">
                <span class="cv-proj-res-val">{result.value}</span>
                <span class="cv-proj-res-lab">{result.label}</span>
              </div>
            ))}
          </div>

          <div class="cv-proj-stack">
            {project.stack.map((tech) => (<span class="skill-badge cv-tag">{tech}</span>))}
          </div>

          {project.link && (
            <a href={project.link} target="_blank" rel="noopener noreferrer" class="cv-textlink cv-proj-link">
              <span>Voir le projet</span>
              <i class="ri-arrow-right-up-line" aria-hidden="true"></i>
            </a>
          )}
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .cv-sec { padding: 64px 40px; }
  .cv-wrap-wide { max-width: 1060px; margin: 0 auto; }
  .cv-head { display: flex; flex-direction: column; gap: 10px; padding-bottom: 40px; }
  .cv-h2 { font-size: clamp(1.7rem, 3.6vw, 2.3rem); }
  .cv-lead { font-size: 1.0625rem; line-height: 1.7; color: var(--muted); max-width: 60ch; }

  .cv-proj-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .cv-proj {
    position: relative; background: var(--surface); border: 1px solid var(--line);
    padding: 22px 22px 20px; display: flex; flex-direction: column; gap: 16px;
    transition: border-color .18s ease-out;
  }
  .cv-proj:hover { border-color: var(--line-2); }

  .cv-proj-topbar { display: flex; align-items: center; justify-content: space-between; }
  .cv-proj-num { font-size: 13px; font-weight: 600; letter-spacing: 0.08em; color: var(--muted); }
  .cv-proj-live {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 10px; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: var(--accent);
    padding: 4px 9px; border: 1px solid var(--line-2); border-radius: 999px;
  }
  .cv-proj-live-dot { width: 5px; height: 5px; border-radius: 999px; background: var(--accent); }

  .cv-proj-head { display: flex; flex-direction: column; gap: 6px; }
  .cv-proj-title { font-size: 1.1rem; line-height: 1.25; letter-spacing: -0.02em; }
  .cv-proj-client { font-size: 12.5px; color: var(--muted); }
  .cv-proj-cat {
    align-self: flex-start; margin-top: 2px;
    font-size: 11px; font-weight: 500; color: var(--muted);
    padding: 4px 10px; border: 1px solid var(--line); border-radius: 999px;
  }

  .cv-proj-desc { font-size: 13.5px; line-height: 1.6; color: var(--muted); }

  .cv-proj-results { display: flex; flex-wrap: wrap; gap: 22px; padding: 14px 0; border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); }
  .cv-proj-res { display: flex; flex-direction: column; gap: 2px; }
  .cv-proj-res-val { font-size: 1.3rem; font-weight: 700; letter-spacing: -0.02em; color: var(--accent); line-height: 1; }
  .cv-proj-res-lab { font-size: 11.5px; color: var(--muted); }

  .cv-proj-stack { display: flex; flex-wrap: wrap; gap: 7px; }
  .cv-tag {
    display: inline-flex; align-items: center;
    font-size: 11.5px; font-weight: 500; color: var(--ink);
    background: var(--bg); border: 1px solid var(--line-2); padding: 3px 9px; border-radius: 999px;
  }

  .cv-textlink {
    display: inline-flex; align-items: center; gap: 7px; align-self: flex-start; margin-top: auto;
    font-size: 13px; font-weight: 600; color: var(--ink);
    padding-bottom: 3px; border-bottom: 1px solid var(--line-2);
    transition: color .18s ease-out, border-color .18s ease-out;
  }
  .cv-textlink i { transition: transform .18s ease-out; }
  .cv-textlink:hover { color: var(--accent); border-color: var(--accent); }
  .cv-textlink:hover i { transform: translate(2px, -2px); }

  @media (max-width: 980px) {
    .cv-proj-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 720px) {
    .cv-sec { padding: 48px 20px; }
    .cv-head { padding-bottom: 28px; }
    .cv-proj-grid { grid-template-columns: 1fr; }
  }
</style>
