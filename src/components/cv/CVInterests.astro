---
// Interests section — Section 07
const interests = [
  {
    icon: "ri-ping-pong-line",
    title: "Badminton",
    description: "Pratique régulière + support technique et automatisation pour clubs sportifs.",
    skills: "Gestion d'événements, travail d'équipe, process organisationnels"
  },
  {
    icon: "ri-camera-line",
    title: "Photographie",
    description: "Capturer des moments et raconter des histoires visuelles.",
    skills: "Composition, storytelling visuel, design graphique"
  },
  {
    icon: "ri-dice-line",
    title: "Jeux de Société",
    description: "Animation de communauté, newsletter, emploi actuel en ludothèque.",
    skills: "Animation, curation de contenu, gestion de communauté",
    highlight: true
  },
  {
    icon: "ri-coin-line",
    title: "Cryptomonnaies",
    description: "Exploration approfondie de l'écosystème (2021-2024), newsletter passée.",
    skills: "Analyse macro/micro, veille technologique, innovation financière",
    past: true
  }
];
---

<section class="cv-section cv-interests co-sec co-pad cv-sec">
  <div class="cv-wrap">
    <header class="cv-head">
      <p class="co-eyebrow">Section 07</p>
      <h2 class="cv-h2">Au-delà du code</h2>
      <p class="cv-lead">
        Mes passions enrichissent ma vision créative et ma capacité à penser
        différemment les projets.
      </p>
    </header>

    <div class="cv-int-grid">
      {interests.map((interest) => (
        <article class="cv-int co-frame co-frame--reveal">
          <div class="cv-int-head">
            <span class="cv-int-ic"><i class={interest.icon} aria-hidden="true"></i></span>
            <h3 class="cv-int-title">{interest.title}</h3>
            {interest.highlight && (
              <span class="cv-int-tag"><span class="cv-int-dot" aria-hidden="true"></span> Actif</span>
            )}
            {interest.past && <span class="cv-int-tag is-past">2021-24</span>}
          </div>

          <p class="cv-int-desc">{interest.description}</p>

          <p class="cv-int-skills">
            <span class="cv-int-skills-label">Compétences liées :</span> {interest.skills}
          </p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .cv-sec { padding: 64px 40px; }
  .cv-wrap { max-width: 860px; margin: 0 auto; }
  .cv-head { display: flex; flex-direction: column; gap: 10px; padding-bottom: 40px; }
  .cv-h2 { font-size: clamp(1.7rem, 3.6vw, 2.3rem); }
  .cv-lead { font-size: 1.0625rem; line-height: 1.7; color: var(--muted); max-width: 56ch; }

  .cv-int-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .cv-int {
    position: relative; background: var(--surface); border: 1px solid var(--line);
    padding: 22px 24px; display: flex; flex-direction: column; gap: 12px;
    transition: border-color .18s ease-out;
  }
  .cv-int:hover { border-color: var(--line-2); }
  .cv-int-head { display: flex; align-items: center; gap: 12px; }
  .cv-int-ic {
    flex: none; width: 40px; height: 40px; display: grid; place-items: center;
    border: 1px solid var(--line-2); color: var(--muted); font-size: 19px;
    transition: color .18s ease-out, border-color .18s ease-out;
  }
  .cv-int:hover .cv-int-ic { color: var(--accent); border-color: var(--accent); }
  .cv-int-title { font-size: 1.15rem; letter-spacing: -0.02em; }
  .cv-int-tag {
    margin-left: auto; display: inline-flex; align-items: center; gap: 6px; white-space: nowrap;
    font-size: 10px; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: var(--accent);
    padding: 4px 9px; border: 1px solid var(--line-2); border-radius: 999px;
  }
  .cv-int-tag.is-past { color: var(--muted); }
  .cv-int-dot { width: 5px; height: 5px; border-radius: 999px; background: var(--accent); }

  .cv-int-desc { font-size: 14px; line-height: 1.6; color: var(--muted); }
  .cv-int-skills { font-size: 12.5px; line-height: 1.55; color: var(--muted); padding-top: 12px; border-top: 1px solid var(--line); }
  .cv-int-skills-label { font-weight: 600; color: var(--ink); }

  @media (max-width: 720px) {
    .cv-sec { padding: 48px 20px; }
    .cv-head { padding-bottom: 28px; }
    .cv-int-grid { grid-template-columns: 1fr; }
  }
</style>
