---
import { author } from '../../sample'
---

<section class="cv-hero co-sec co-pad">
  <div class="cv-hero-inner">
    <p class="co-eyebrow cv-hero-animate">Curriculum Vitæ</p>

    <h1 class="cv-hero-title cv-hero-animate">Jonathan Vouilloz</h1>

    <p class="cv-hero-role cv-hero-animate">
      Informaticien de gestion <span class="co-ser">&amp; créateur digital</span>
    </p>

    <p class="cv-hero-diploma cv-hero-animate">
      <i class="ri-graduation-cap-line" aria-hidden="true"></i>
      Bachelor HES en Informatique de Gestion
    </p>

    <div class="cv-hero-meta cv-hero-animate">
      <span class="cv-hero-status">
        <span class="cv-hero-dot" aria-hidden="true"></span>
        Disponible pour opportunités
      </span>
      <span class="cv-hero-loc">
        <i class="ri-map-pin-2-line" aria-hidden="true"></i>
        Genève, Suisse
      </span>
    </div>

    <div class="cv-hero-actions cv-hero-animate">
      <a href="/cv-pdf" target="_blank" class="co-btn cv-hero-cta">
        <i class="ri-download-2-line" aria-hidden="true"></i>
        Télécharger le CV (PDF)
      </a>

      <div class="cv-hero-socials">
        <span class="cv-hero-socials-label co-mut">Me contacter</span>
        <a href={`mailto:${author.email}`} class="cv-soc" aria-label="Email">
          <i class="ri-mail-line" aria-hidden="true"></i>
        </a>
        <a href={author.linkedin} target="_blank" rel="noopener noreferrer" class="cv-soc" aria-label="LinkedIn">
          <i class="ri-linkedin-fill" aria-hidden="true"></i>
        </a>
        <a href={author.github} target="_blank" rel="noopener noreferrer" class="cv-soc" aria-label="GitHub">
          <i class="ri-github-fill" aria-hidden="true"></i>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .cv-hero { padding: 78px 40px 60px; }
  .cv-hero-inner {
    display: flex; flex-direction: column; align-items: flex-start; gap: 18px;
    max-width: 860px; margin: 0 auto;
  }
  .cv-hero-title { font-size: clamp(2.4rem, 6vw, 3.6rem); letter-spacing: -0.03em; }
  .cv-hero-role { font-size: clamp(1.15rem, 2.6vw, 1.5rem); font-weight: 500; color: var(--ink); }
  .cv-hero-role .co-ser { color: var(--accent); font-size: 1.08em; }
  .cv-hero-diploma { display: inline-flex; align-items: center; gap: 8px; font-size: 1rem; color: var(--muted); }
  .cv-hero-diploma i { color: var(--accent); font-size: 1.15em; }

  .cv-hero-meta { display: flex; flex-wrap: wrap; align-items: center; gap: 14px; margin-top: 2px; }
  .cv-hero-status {
    display: inline-flex; align-items: center; gap: 9px;
    font-size: 14px; font-weight: 600; color: var(--ink);
    padding: 6px 14px; border: 1px solid var(--line-2); border-radius: 999px;
  }
  .cv-hero-dot { position: relative; width: 7px; height: 7px; border-radius: 999px; background: var(--accent); flex: none; }
  .cv-hero-dot::after {
    content: ""; position: absolute; inset: -4px; border-radius: 999px;
    border: 1px solid var(--accent); animation: cvPulse 2.2s ease-out infinite;
  }
  @keyframes cvPulse { 0% { transform: scale(.5); opacity: .6; } 100% { transform: scale(1.5); opacity: 0; } }
  .cv-hero-loc { display: inline-flex; align-items: center; gap: 6px; font-size: 14px; color: var(--muted); }
  .cv-hero-loc i { color: var(--accent); }

  .cv-hero-actions { display: flex; flex-wrap: wrap; align-items: center; gap: 22px; margin-top: 10px; }
  .cv-hero-socials { display: flex; align-items: center; gap: 10px; }
  .cv-hero-socials-label { font-size: 14px; margin-right: 4px; }
  .cv-soc {
    display: inline-flex; align-items: center; justify-content: center;
    width: 42px; height: 42px; border: 1px solid var(--line-2); border-radius: 10px;
    color: var(--muted); font-size: 1.15rem;
    transition: color .18s ease-out, border-color .18s ease-out;
  }
  .cv-soc:hover { color: var(--accent); border-color: var(--accent); }
  .cv-hero-cta i { font-size: 1.1em; }

  @media (max-width: 720px) {
    .cv-hero { padding: 56px 20px 46px; }
    .cv-hero-actions { gap: 16px; }
  }
  @media (prefers-reduced-motion: reduce) { .cv-hero-dot::after { animation: none; } }
</style>
