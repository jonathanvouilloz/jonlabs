---
// Timeline section — Section 03 (parcours, section phare + animations GSAP)
const experiences = [
  {
    id: 1,
    title: "Fondateur & Développeur Full-Stack",
    company: "Jon Labs - Freelance",
    location: "Genève",
    period: "2024 - Présent",
    current: true,
    missions: [
      "Développement de sites web et applications sur-mesure pour entrepreneurs et PME",
      "Automatisation de processus métiers (workflows, emails, intégrations)",
      "Conseil stratégique digital et accompagnement de projets",
      "Formation et vulgarisation technique"
    ],
    stack: ["Astro", "React", "Node.js", "Supabase", "Make", "Zapier", "MCP", "Claude Code"],
    highlights: "App gestion camps CPV • Stratégie SEO cabinet juridique • Growth marketing Le Matin Dimanche"
  },
  {
    id: 2,
    title: "Employé Ludothèque",
    company: "Secteur du jeu (Temps Partiel)",
    location: "Genève",
    period: "2025 - Présent",
    current: true,
    missions: [
      "Gestion et animation d'activités ludiques",
      "Conseil et recommandations jeux de société",
      "Animation de communauté et gestion d'événements"
    ],
    stack: [],
    highlights: null
  },
  {
    id: 3,
    title: "Co-fondateur & Développeur",
    company: "Kusari Sàrl",
    location: "Genève",
    period: "2021 - 2024",
    current: false,
    missions: [
      "Exploration et développement de projets blockchain/Web3",
      "Formation approfondie sur l'écosystème crypto",
      "Développement de prototypes et applications décentralisées",
      "Veille technologique et analyse de projets innovants"
    ],
    stack: ["Solidity", "Web3.js", "Smart Contracts", "DeFi"],
    stackType: "past"
  },
  {
    id: 4,
    title: "Développeur & Consultant Marketing",
    company: "Barber Concept (Freelance)",
    location: "Genève",
    period: "2020 - Présent",
    current: true,
    missions: [
      "Développement d'un système de prise de rendez-vous en ligne",
      "Création du site web et de l'identité graphique",
      "Support marketing digital et stratégie de croissance"
    ],
    stack: ["Node.js", "PostgreSQL", "APIs"],
    results: {
      users: "19'000",
      salons: "6",
      years: "5 ans"
    }
  },
  {
    id: 5,
    title: "Moniteur de Camps de Vacances",
    company: "Centre Protestant de Vacances (CPV)",
    location: "Valais",
    period: "2015 - Présent",
    current: true,
    missions: [
      "Animation et encadrement de camps de vacances (10 ans d'ancienneté)",
      "Identification de besoins terrain → développement d'une application",
      "Collaboration officielle avec le CPV pour déploiement 2026"
    ],
    stack: []
  }
];
---

<section class="cv-section cv-timeline-section co-sec co-pad cv-sec">
  <div class="cv-wrap">
    <header class="cv-head">
      <p class="co-eyebrow">Section 03</p>
      <h2 class="cv-h2">Parcours <span class="co-ser">professionnel</span></h2>
    </header>

    <div class="cv-tl">
      <!-- Rail + barre de progression (animée via GSAP) -->
      <div class="cv-tl-rail" aria-hidden="true">
        <div class="cv-tl-progress timeline-progress-bar"></div>
      </div>

      <ol class="cv-tl-list">
        {experiences.map((exp) => (
          <li class="cv-tl-item">
            <span class="cv-tl-point timeline-point" aria-hidden="true">
              <span class={`cv-tl-dot ${exp.current ? 'is-current' : ''}`}></span>
            </span>

            <article class="cv-tl-card co-frame">
              <div class="cv-tl-top">
                <div class="cv-tl-ident">
                  <h3 class="cv-tl-title">{exp.title}</h3>
                  <p class="cv-tl-company">
                    {exp.company}
                    <span class="cv-tl-sep">·</span>
                    <span class="cv-tl-loc"><i class="ri-map-pin-line" aria-hidden="true"></i> {exp.location}</span>
                  </p>
                </div>
                <span class={`cv-tl-period ${exp.current ? 'is-current' : ''}`}>{exp.period}</span>
              </div>

              <ul class="co-list cv-tl-missions">
                {exp.missions.map((mission) => (<li>{mission}</li>))}
              </ul>

              {exp.stack && exp.stack.length > 0 && (
                <div class="cv-tl-stack">
                  {exp.stack.map((tech) => (<span class="skill-badge cv-tag">{tech}</span>))}
                </div>
              )}

              {exp.results && (
                <div class="cv-tl-results">
                  <span class="cv-tl-results-label">Résultats</span>
                  <div class="cv-tl-results-grid">
                    <span class="cv-tl-res"><span class="cv-tl-res-val">{exp.results.users}</span> utilisateurs</span>
                    <span class="cv-tl-res"><span class="cv-tl-res-val">{exp.results.salons}</span> salons</span>
                    <span class="cv-tl-res"><span class="cv-tl-res-val">{exp.results.years}</span> relation client</span>
                  </div>
                </div>
              )}

              {exp.highlights && (
                <p class="cv-tl-highlights">
                  <strong>Projets notables :</strong> {exp.highlights}
                </p>
              )}
            </article>
          </li>
        ))}
      </ol>
    </div>
  </div>
</section>

<style>
  .cv-sec { padding: 64px 40px; }
  .cv-wrap { max-width: 860px; margin: 0 auto; }
  .cv-head { display: flex; flex-direction: column; gap: 8px; padding-bottom: 36px; }
  .cv-h2 { font-size: clamp(1.7rem, 3.6vw, 2.3rem); }
  .cv-h2 .co-ser { color: var(--accent); }

  .cv-tl { position: relative; }
  .cv-tl-rail { display: none; }
  .cv-tl-list { display: flex; flex-direction: column; gap: 22px; }
  .cv-tl-item { position: relative; }

  .cv-tl-point { display: none; }
  .cv-tl-dot { width: 8px; height: 8px; border-radius: 999px; background: var(--line-2); }
  .cv-tl-dot.is-current { background: var(--accent); }

  .cv-tl-card {
    position: relative; background: var(--surface); border: 1px solid var(--line);
    padding: 24px 26px; display: flex; flex-direction: column; gap: 16px;
  }
  .cv-tl-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 16px; }
  .cv-tl-ident { display: flex; flex-direction: column; gap: 4px; }
  .cv-tl-title { font-size: 1.2rem; letter-spacing: -0.02em; }
  .cv-tl-company { font-size: 14px; font-weight: 500; color: var(--muted); display: inline-flex; align-items: center; flex-wrap: wrap; gap: 8px; }
  .cv-tl-sep { color: var(--line-2); }
  .cv-tl-loc { display: inline-flex; align-items: center; gap: 4px; }
  .cv-tl-loc i { color: var(--accent); }
  .cv-tl-period {
    flex: none; white-space: nowrap; align-self: flex-start;
    font-size: 12px; font-weight: 600; font-variant-numeric: tabular-nums; color: var(--muted);
    padding: 5px 11px; border: 1px solid var(--line-2); border-radius: 999px;
  }
  .cv-tl-period.is-current { color: var(--accent); border-color: var(--accent); }

  .cv-tl-missions { font-size: 14px; color: var(--muted); }
  .cv-tl-missions li { line-height: 1.55; }

  .cv-tl-stack { display: flex; flex-wrap: wrap; gap: 7px; }
  .cv-tag {
    display: inline-flex; align-items: center;
    font-size: 12px; font-weight: 500; color: var(--ink);
    background: var(--bg); border: 1px solid var(--line-2); padding: 3px 9px; border-radius: 999px;
  }

  .cv-tl-results { border-left: 2px solid var(--accent); padding: 4px 0 4px 16px; display: flex; flex-direction: column; gap: 8px; }
  .cv-tl-results-label { font-size: 11px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); }
  .cv-tl-results-grid { display: flex; flex-wrap: wrap; gap: 20px; font-size: 14px; color: var(--muted); }
  .cv-tl-res { display: inline-flex; align-items: baseline; gap: 6px; }
  .cv-tl-res-val { font-size: 1.15rem; font-weight: 700; color: var(--accent); letter-spacing: -0.02em; }

  .cv-tl-highlights { font-size: 13px; color: var(--muted); line-height: 1.6; padding-top: 14px; border-top: 1px solid var(--line); }
  .cv-tl-highlights strong { color: var(--ink); font-weight: 600; }

  /* Rail visible dès md+ */
  @media (min-width: 768px) {
    .cv-tl-rail { display: block; position: absolute; left: 7px; top: 6px; bottom: 6px; width: 1px; background: var(--line); }
    .cv-tl-progress { position: absolute; inset: 0; background: var(--accent); transform-origin: top center; }
    .cv-tl-item { padding-left: 44px; }
    .cv-tl-point {
      display: grid; place-items: center; position: absolute; left: 0; top: 16px;
      width: 15px; height: 15px; background: var(--surface); border: 1px solid var(--line-2); border-radius: 999px; z-index: 2;
    }
  }

  @media (max-width: 720px) {
    .cv-sec { padding: 48px 20px; }
    .cv-head { padding-bottom: 28px; }
    .cv-tl-card { padding: 20px; }
    .cv-tl-top { flex-direction: column; gap: 10px; }
  }
</style>
