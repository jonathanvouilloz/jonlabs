---
import { getCategoryName, type CategoryKey } from '../../lib/blog';

// Badge catégorie blueprint = primitive .co-badge (pastille filet + point teal).
// UNE seule teinte d'accent : la catégorie se lit dans le texte, jamais par une
// couleur dédiée (getCategoryColor volontairement abandonné — règle « pas de
// couleur par catégorie »). Doit vivre sous un ancêtre .co-root/.co-chrome.
interface Props {
  category: CategoryKey;
  size?: 'sm' | 'md';
}

const { category, size = 'sm' } = Astro.props;
const name = getCategoryName(category);
---

<span class:list={['co-badge', size === 'md' && 'co-badge--md']}>{name}</span>

<style>
  .co-badge--md { font-size: 13.5px; padding: 6px 13px; }
</style>
