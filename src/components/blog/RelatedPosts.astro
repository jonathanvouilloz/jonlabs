---
import type { CollectionEntry } from 'astro:content';
import PostCard from './PostCard.astro';

// Articles similaires — grille blueprint réutilisant PostCard (déjà migré).
// Doit vivre sous un ancêtre .co-root (tokens blueprint).
interface Props {
  posts: CollectionEntry<'blog'>[];
}

const { posts } = Astro.props;
---

{posts.length > 0 && (
  <section class="bl-related-sec co-sec co-pad">
    <div class="bl-related-head">
      <p class="co-eyebrow">Pour continuer</p>
      <h2 class="bl-related-title">Articles similaires</h2>
    </div>

    <div class="bl-related-grid">
      {posts.map((post) => (
        <PostCard post={post} />
      ))}
    </div>

    <a href="/blog" class="bl-related-all">
      Tous les articles
      <i class="ri-arrow-right-line"></i>
    </a>
  </section>
)}

<style is:global>
  .bl-related-sec { padding-top: 56px; padding-bottom: 56px; }
  .bl-related-head { margin-bottom: 28px; }
  .bl-related-title { font-size: clamp(1.6rem, 3vw, 2.1rem); line-height: 1.1; margin-top: 6px; }
  .bl-related-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .bl-related-all {
    display: inline-flex; align-items: center; gap: 8px; margin-top: 28px;
    font-weight: 600; color: var(--accent);
  }
  .bl-related-all i { transition: transform .18s ease-out; }
  .bl-related-all:hover i { transform: translateX(4px); }

  @media (max-width: 980px) { .bl-related-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 720px) { .bl-related-grid { grid-template-columns: 1fr; } }
  @media (prefers-reduced-motion: reduce) { .bl-related-all i { transition: none; } }
</style>
