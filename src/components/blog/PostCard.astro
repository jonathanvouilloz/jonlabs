---
import type { CollectionEntry } from 'astro:content';
import { formatDateShort, getCategorySlug } from '../../lib/blog';

// Signature INCHANGÉE (aussi consommée par src/pages/blog/tag/[tag].astro).
interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, image, category, tags, pubDate, readingTime } = post.data;
---

<article
  class="bl-card"
  data-title={title.toLowerCase()}
  data-tags={tags.join(' ').toLowerCase()}
  data-category={category}
>
  <!-- Overlay cliquable pleine carte -->
  <a href={`/blog/${post.slug}`} class="bl-card-link" aria-label={`Lire : ${title}`}></a>

  <div class="bl-card-cover">
    <img src={image.url} alt={image.alt} loading="lazy" />
  </div>

  <div class="bl-card-body">
    <span class="co-cat">{getCategorySlug(category)}</span>
    <h3 class="bl-card-title">{title}</h3>
    <div class="bl-meta">
      <time datetime={pubDate.toISOString()}>{formatDateShort(pubDate)}</time>
      {readingTime && <span>· {readingTime} min</span>}
    </div>
    <p class="bl-desc">{description}</p>
    {tags.length > 0 && (
      <div class="bl-tags">
        {tags.slice(0, 3).map((tg) => (
          <a href={`/blog/tag/${tg}`} class="bl-tag">#{tg}</a>
        ))}
      </div>
    )}
  </div>

  <span class="bl-card-accent"></span>
</article>

<style is:global>
  /* ══ PostCard blueprint — .bl-card (partagé blog index + tag page) ══
     Les deux pages consommatrices (/blog et /blog/tag/[tag]) sont wrappées
     .co-root → tokens blueprint hérités, aucune redéclaration locale nécessaire. */
  .bl-card {
    position: relative; display: flex; flex-direction: column;
    background: var(--surface); border: 1px solid var(--line-2); overflow: hidden;
    transition: box-shadow .18s ease-out;
  }
  .bl-card:hover { box-shadow: 0 6px 22px rgba(20, 22, 26, .07); }
  .bl-card-link { position: absolute; inset: 0; z-index: 1; }

  .bl-card-cover { position: relative; aspect-ratio: 16 / 9; overflow: hidden; border-bottom: 1px solid var(--line-2); background: var(--bg); }
  .bl-card-cover img { width: 100%; height: 100%; object-fit: cover; transition: transform .4s ease-out; }
  .bl-card:hover .bl-card-cover img { transform: scale(1.05); }

  .bl-card-body { padding: 18px 18px 20px; display: flex; flex-direction: column; gap: 9px; flex: 1; }
  .bl-card-title { font-size: 1.12rem; line-height: 1.2; }
  .bl-meta { display: flex; align-items: center; gap: 6px; font-size: 13px; color: var(--muted); }
  .bl-desc { font-size: 14px; line-height: 1.55; color: var(--muted); display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .bl-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-top: auto; padding-top: 4px; }
  .bl-tag { position: relative; z-index: 2; font-size: 12px; color: var(--muted); padding: 3px 8px; background: rgba(20, 22, 26, .04); transition: background .16s ease-out, color .16s ease-out; }
  .bl-tag:hover { background: rgba(0, 168, 125, .12); color: var(--accent); }

  /* Accent bas au hover — barre DROITE (carte coins nets, jamais bordure partielle sur arrondi) */
  .bl-card-accent { position: absolute; left: 0; bottom: 0; height: 2px; width: 100%; background: var(--accent); transform: scaleX(0); transform-origin: left; transition: transform .3s ease-out; z-index: 2; }
  .bl-card:hover .bl-card-accent { transform: scaleX(1); }

  /* ── Mode liste (toggle sur #posts-list, blog index uniquement) ── */
  #posts-list[data-view="list"] .bl-card { flex-direction: row; border: 0; border-bottom: 1px solid var(--line); background: transparent; }
  #posts-list[data-view="list"] .bl-card:hover { box-shadow: none; background: var(--surface); }
  #posts-list[data-view="list"] .bl-card-cover { flex: none; width: 220px; aspect-ratio: 16 / 10; border-bottom: 0; border-right: 1px solid var(--line-2); }
  #posts-list[data-view="list"] .bl-card-body { justify-content: center; }
  #posts-list[data-view="list"] .bl-desc { -webkit-line-clamp: 3; }
  #posts-list[data-view="list"] .bl-card-accent { top: 0; bottom: auto; height: 100%; width: 2px; transform: scaleY(0); transform-origin: top; }
  #posts-list[data-view="list"] .bl-card:hover .bl-card-accent { transform: scaleY(1); }

  @media (max-width: 720px) {
    #posts-list[data-view="list"] .bl-card { flex-direction: column; }
    #posts-list[data-view="list"] .bl-card-cover { width: 100%; border-right: 0; border-bottom: 1px solid var(--line-2); }
  }
  @media (prefers-reduced-motion: reduce) {
    .bl-card, .bl-card-cover img, .bl-card-accent { transition: none; }
  }
</style>
