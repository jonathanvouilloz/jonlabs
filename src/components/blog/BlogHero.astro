---
import svgRedStar from '../../assets/red-star.svg';
import svgPinkStar from '../../assets/pink-star.svg';
---

<section class="py-10 md:py-14 bg-[var(--main-bg)] relative overflow-hidden">
  <!-- Decorative elements -->
  <img src={svgPinkStar.src} alt="" width="30" class="absolute top-8 right-8 opacity-30 hidden md:block" aria-hidden="true" />
  <img src={svgRedStar.src} alt="" width="35" class="absolute top-12 left-8 opacity-40 hidden md:block" aria-hidden="true" />

  <div class="max-w-6xl mx-auto px-4 relative z-10">
    <div class="text-center">
      <!-- Big expressive title -->
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight leading-[0.95]">
        Blog développement web &
        <span class="relative inline-block">
          <span class="relative z-10">automatisation</span>
          <span class="absolute bg-[var(--accent)] w-full h-[50%] left-0 bottom-0 z-0"></span>
        </span>
      </h1>

      <!-- Subtitle -->
      <p class="text-base md:text-lg text-gray-600 mt-4 max-w-2xl mx-auto">
        Sites web, applications mobiles, automatisation IA et référencement local — des retours concrets pour les PME romandes.
      </p>
    </div>
  </div>
</section>
