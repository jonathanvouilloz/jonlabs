---
// VideoEmbed — embed YouTube responsive (16:9), lazy, sans cookie.
// Usage : piloté par le champ frontmatter `youtubeId` de l'article (voir [slug].astro).
// Blueprint : cadre filet fin + 4 crosshairs (.co-frame). Doit vivre sous .co-root.
interface Props {
  youtubeId: string;
  title?: string;
}

const { youtubeId, title = 'Vidéo YouTube' } = Astro.props;
const src = `https://www.youtube-nocookie.com/embed/${youtubeId}`;
---

<figure class="bl-video co-frame">
  <iframe
    src={src}
    title={title}
    loading="lazy"
    frameborder="0"
    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
    referrerpolicy="strict-origin-when-cross-origin"
    allowfullscreen
  ></iframe>
</figure>

<style>
  .bl-video {
    position: relative;
    margin: 2em 0;
    aspect-ratio: 16 / 9;
    border: 1px solid var(--line-2);
    background: var(--bg);
  }
  .bl-video iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
</style>
