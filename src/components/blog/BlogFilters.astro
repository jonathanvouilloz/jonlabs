---
import { categories } from '../../lib/blog';

const categoryList = [
  { slug: 'all', name: 'Tous' },
  ...Object.entries(categories).map(([slug, data]) => ({ slug, name: data.name })),
];
---

<div class="bl-filters">
  <div class="bl-chips" id="category-filters" role="group" aria-label="Filtrer par catégorie">
    {categoryList.map((cat) => (
      <button
        type="button"
        data-category={cat.slug}
        class:list={['bl-chip filter-btn', cat.slug === 'all' && 'is-active']}
        aria-pressed={cat.slug === 'all' ? 'true' : 'false'}
      >
        {cat.name}
      </button>
    ))}
  </div>
</div>

<style is:global>
  /* ══ Filtres blog blueprint (rendu dans .co-root/index) ══ */
  /* Chips catégories : au-dessus de la grille, là où elles filtrent (la recherche est remontée sous le hero) */
  .bl-filters { display: flex; flex-direction: column; gap: 16px; margin: 24px 0 28px; }

  .bl-chips { display: flex; flex-wrap: wrap; gap: 8px; }
  .bl-chip {
    font-family: inherit; font-size: 13.5px; font-weight: 500; cursor: pointer;
    padding: 7px 14px; border-radius: 999px; border: 1px solid var(--line-2);
    background: transparent; color: var(--muted); transition: all .16s ease-out;
  }
  .bl-chip:hover { color: var(--ink); border-color: var(--ink); }
  .bl-chip.is-active { background: var(--ink); color: #fff; border-color: var(--ink); }
</style>

<script>
  function initBlogFilters() {
    const filterButtons = Array.from(document.querySelectorAll<HTMLElement>('.filter-btn'));
    const searchInput = document.getElementById('blog-search') as HTMLInputElement | null;
    const postsList = document.getElementById('posts-list');
    const noResults = document.getElementById('no-results');
    const pagination = document.getElementById('pagination');
    const pageNumbers = document.getElementById('page-numbers');
    const prevBtn = document.getElementById('prev-page') as HTMLButtonElement | null;
    const nextBtn = document.getElementById('next-page') as HTMLButtonElement | null;
    const viewButtons = Array.from(document.querySelectorAll<HTMLElement>('[data-view-btn]'));
    // Article à la une : non filtré (hors #posts-list) → on le masque dès qu'une recherche/catégorie est active
    const featuredSection = document.getElementById('bl-feature-section');

    if (!postsList) return;

    // Seuls les articles dans #posts-list (l'article à la une reste hors filtrage)
    const listItems = Array.from(postsList.querySelectorAll<HTMLElement>('[data-category]'));

    const ITEMS_PER_PAGE = 9;
    let currentCategory = 'all';
    let currentSearch = '';
    let currentPage = 1;
    let filteredItems: HTMLElement[] = [];

    function getFilteredItems() {
      return listItems.filter((item) => {
        const itemCategory = item.getAttribute('data-category') || '';
        const title = item.getAttribute('data-title')?.toLowerCase() || '';
        const tags = item.getAttribute('data-tags')?.toLowerCase() || '';

        const matchesCategory = currentCategory === 'all' || itemCategory === currentCategory;
        const matchesSearch =
          !currentSearch || title.includes(currentSearch) || tags.includes(currentSearch);

        return matchesCategory && matchesSearch;
      });
    }

    function renderPagination() {
      const totalPages = Math.ceil(filteredItems.length / ITEMS_PER_PAGE);

      if (pagination) pagination.style.display = totalPages <= 1 ? 'none' : 'flex';
      if (prevBtn) prevBtn.disabled = currentPage === 1;
      if (nextBtn) nextBtn.disabled = currentPage === totalPages || totalPages === 0;

      if (pageNumbers) {
        pageNumbers.innerHTML = '';
        for (let i = 1; i <= totalPages; i++) {
          const btn = document.createElement('button');
          btn.className = 'bl-page' + (i === currentPage ? ' is-active' : '');
          if (i === currentPage) btn.setAttribute('aria-current', 'page');
          btn.textContent = String(i);
          btn.addEventListener('click', () => goToPage(i));
          pageNumbers.appendChild(btn);
        }
      }
    }

    function displayPage() {
      const start = (currentPage - 1) * ITEMS_PER_PAGE;
      const end = start + ITEMS_PER_PAGE;

      listItems.forEach((item) => { item.style.display = 'none'; });
      filteredItems.slice(start, end).forEach((item) => { item.style.display = ''; });

      if (noResults) (noResults as HTMLElement).hidden = filteredItems.length !== 0;

      renderPagination();
    }

    function goToPage(page: number) {
      currentPage = page;
      displayPage();
      postsList!.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    function updateFeaturedVisibility() {
      if (!featuredSection) return;
      const isFiltering = currentSearch !== '' || currentCategory !== 'all';
      featuredSection.style.display = isFiltering ? 'none' : '';
    }

    function filterPosts() {
      filteredItems = getFilteredItems();
      currentPage = 1;
      updateFeaturedVisibility();
      displayPage();
    }

    // Filtre catégorie
    filterButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        filterButtons.forEach((b) => { b.classList.remove('is-active'); b.setAttribute('aria-pressed', 'false'); });
        btn.classList.add('is-active');
        btn.setAttribute('aria-pressed', 'true');
        currentCategory = btn.getAttribute('data-category') || 'all';
        filterPosts();
      });
    });

    // Recherche
    searchInput?.addEventListener('input', (e) => {
      currentSearch = (e.target as HTMLInputElement).value.toLowerCase().trim();
      filterPosts();
    });

    // Toggle grille / liste
    viewButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const mode = btn.getAttribute('data-view-btn') || 'grid';
        postsList!.setAttribute('data-view', mode);
        viewButtons.forEach((b) => {
          const on = b === btn;
          b.classList.toggle('is-active', on);
          b.setAttribute('aria-pressed', String(on));
        });
      });
    });

    // Pagination prev/next
    prevBtn?.addEventListener('click', () => { if (currentPage > 1) goToPage(currentPage - 1); });
    nextBtn?.addEventListener('click', () => {
      const totalPages = Math.ceil(filteredItems.length / ITEMS_PER_PAGE);
      if (currentPage < totalPages) goToPage(currentPage + 1);
    });

    filterPosts();
  }

  initBlogFilters();
  document.addEventListener('astro:page-load', initBlogFilters);
</script>
