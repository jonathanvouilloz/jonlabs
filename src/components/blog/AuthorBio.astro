---
import { Image } from 'astro:assets';
import { author } from '../../sample';
import imgJonathan from '../../assets/jonathan-vouilloz.webp';
---

<section class="author-bio-section px-4 py-12">
  <div class="max-w-3xl mx-auto">
    <div class="bg-white border-2 border-black shadow-[6px_6px_0px_rgba(0,0,0,0.3)] p-6 md:p-8 relative">
      <!-- Corner boxes (brutalist decoration) -->
      <div class="size-2 bg-black absolute -top-1 -left-1"></div>
      <div class="size-2 bg-black absolute -top-1 -right-1"></div>
      <div class="size-2 bg-black absolute -bottom-1 -left-1"></div>
      <div class="size-2 bg-black absolute -bottom-1 -right-1"></div>

      <div class="flex flex-col md:flex-row gap-6 items-start">
        <!-- Avatar : photo réelle -->
        <a
          href="/about"
          class="block w-24 h-24 md:w-28 md:h-28 border-2 border-black flex-shrink-0 overflow-hidden hover:shadow-[4px_4px_0px_rgba(0,0,0,0.3)] transition-shadow"
          aria-label={`En savoir plus sur ${author.name}`}
        >
          <Image
            src={imgJonathan}
            alt={`Photo de ${author.name}, développeur web freelance à Genève`}
            width={112}
            height={112}
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </a>

        <!-- Bio content -->
        <div class="flex-1">
          <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">Écrit par</p>
          <h3 class="text-xl md:text-2xl font-bold mb-3">
            <a href="/about" class="hover:underline decoration-2 underline-offset-4">
              {author.name}
            </a>
          </h3>

          <p class="text-gray-700 mb-4 leading-relaxed">
            Développeur web freelance basé à <strong>{author.location}</strong>, 8+ ans à bosser avec des PME romandes. Je couvre trois fronts au quotidien : <strong>sites web sur-mesure</strong> (Astro, React), <strong>automatisation</strong> (Make, Zapier, n8n) et <strong>SEO local</strong>. J'écris ici ce que je vois sur le terrain en mission, pas ce qui sonne bien dans un slide.
          </p>

          <!-- CTA principal : page À propos -->
          <a
            href="/about"
            class="inline-flex items-center gap-2 bg-[var(--blue)] border-2 border-black px-4 py-2 text-sm font-bold hover:bg-[var(--yellow)] hover:shadow-[3px_3px_0px_rgba(0,0,0,0.3)] transition-all mb-4"
          >
            En savoir plus sur Jonathan
            <i class="ri-arrow-right-line"></i>
          </a>

          <!-- Social links -->
          <div class="flex flex-wrap gap-4 pt-4 border-t border-gray-200">
            {author.linkedin && author.linkedin !== '#' && (
              <a
                href={author.linkedin}
                target="_blank"
                rel="noopener noreferrer me"
                class="flex items-center gap-2 text-sm font-medium hover:text-[var(--violet)] transition-colors"
                aria-label="Profil LinkedIn de Jonathan Vouilloz"
              >
                <i class="ri-linkedin-box-fill text-xl"></i>
                <span>LinkedIn</span>
              </a>
            )}
            {author.github && author.github !== '#' && (
              <a
                href={author.github}
                target="_blank"
                rel="noopener noreferrer me"
                class="flex items-center gap-2 text-sm font-medium hover:text-[var(--violet)] transition-colors"
                aria-label="Profil GitHub de Jonathan Vouilloz"
              >
                <i class="ri-github-fill text-xl"></i>
                <span>GitHub</span>
              </a>
            )}
            {author.email && (
              <a
                href={author.email}
                class="flex items-center gap-2 text-sm font-medium hover:text-[var(--violet)] transition-colors"
                aria-label="Contacter Jonathan par email"
              >
                <i class="ri-mail-line text-xl"></i>
                <span>Contact</span>
              </a>
            )}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
