---
// ContactCTA.astro — CTA alternatif LinkedIn, primitive .co-cta (fond sombre).
// Boutons blancs sur ink (.co-cta-btn) — jamais ink-sur-ink. Namespace .ct-*.
import { author } from '../sample'
---

<section class="co-cta">
    <span class="co-x tl"></span><span class="co-x tr"></span>
    <div class="co-cta-inner">
        <p class="co-cta-eyebrow">Alternative</p>
        <h2 class="co-cta-title">Pas encore prêt à me <span class="co-ser">contacter&nbsp;?</span></h2>
        <p class="co-cta-lead">
            Suivez-moi sur LinkedIn pour rester informé de mes projets
            et de mes réflexions sur la création digitale.
        </p>
        <div class="co-cta-btns">
            <a
                href={author.linkedin}
                target="_blank"
                rel="noopener noreferrer"
                class="co-btn co-cta-btn"
            >
                <i class="ri-linkedin-line"></i>
                <span>Suivre sur LinkedIn</span>
                <i class="ri-arrow-right-up-line"></i>
            </a>
        </div>
    </div>
</section>
