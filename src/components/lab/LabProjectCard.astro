---
import LabStatusBadge from './LabStatusBadge.astro';
import { getCategoryInfo, type StatusKey, type CategoryKey } from '../../lib/lab';

interface Props {
  title: string;
  description: string;
  slug: string;
  status: StatusKey;
  category: CategoryKey;
  thumbnail: string;
  tags?: string[];
  featured?: boolean;
}

const { title, description, slug, status, category, thumbnail, tags = [], featured = false } = Astro.props;
const categoryInfo = getCategoryInfo(category);
---

<a
  href={`/lab/${slug}`}
  class:list={[
    "group block bg-white transition-all duration-200",
    featured ? "md:col-span-2 md:row-span-2" : ""
  ]}
>
  <article class="h-full flex flex-col">
    <div class:list={[
      "relative overflow-hidden bg-gray-100",
      featured ? "aspect-[16/10]" : "aspect-video"
    ]}>
      <img
        src={thumbnail}
        alt={title}
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
        loading="lazy"
      />
    </div>

    <div class:list={[
      "flex-1 flex flex-col",
      featured ? "pt-6" : "pt-4"
    ]}>
      <div class="flex items-center gap-3 mb-2">
        <LabStatusBadge status={status} />
        <span class="text-sm text-gray-400">·</span>
        <span class="text-sm text-gray-500">{categoryInfo.name}</span>
      </div>

      <h3 class:list={[
        "font-medium mb-2 group-hover:text-gray-600 transition-colors",
        featured ? "text-2xl" : "text-lg"
      ]}>
        {title}
      </h3>

      <p class:list={[
        "text-gray-600 line-clamp-2",
        featured ? "text-lg" : "text-base"
      ]}>
        {description}
      </p>

      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-4">
          {tags.slice(0, featured ? 5 : 3).map(tag => (
            <span class="text-xs px-2 py-1 bg-gray-100 text-gray-600 rounded">
              {tag}
            </span>
          ))}
        </div>
      )}
    </div>
  </article>
</a>
