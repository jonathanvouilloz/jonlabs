---
// CoutDormantCalculateur.astro
// Calcule le coût d'inaction d'un site web dormant pour indépendants/PME romands.
// Méthodologie : OFS 2024 (tarif horaire ~95 CHF/h) + audit terrain 50 sites romands (2026)
---

<div id="calc-wrapper" class="my-10 border-2 border-black shadow-[4px_4px_0px_rgba(0,0,0,0.3)] bg-white">

  <!-- Header -->
  <div class="bg-[#FFDC58] border-b-2 border-black px-6 py-4">
    <p class="font-black text-lg">Calculateur de coût d'inaction</p>
    <p class="text-sm mt-0.5">3 chiffres — résultat immédiat — pas d'email requis</p>
  </div>

  <!-- Inputs -->
  <div class="px-6 py-6 grid grid-cols-1 md:grid-cols-3 gap-6">

    <div class="flex flex-col gap-2">
      <label for="panier" class="font-bold text-sm uppercase tracking-wide">
        Valeur d'un client (CHF)
      </label>
      <p class="text-xs text-gray-500">Ce qu'un client te rapporte en moyenne (devis, prestation, produit)</p>
      <div class="flex border-2 border-black focus-within:border-[var(--violet,#7C3AED)]">
        <span class="bg-gray-100 border-r-2 border-black px-3 flex items-center text-sm font-mono font-bold">CHF</span>
        <input
          type="number"
          id="panier"
          min="0"
          step="50"
          placeholder="1200"
          class="flex-1 px-3 py-2.5 outline-none text-base font-mono"
        />
      </div>
    </div>

    <div class="flex flex-col gap-2">
      <label for="clients" class="font-bold text-sm uppercase tracking-wide">
        Clients/mois via le site
      </label>
      <p class="text-xs text-gray-500">Combien de clients contactent via ton site par mois (0 si aucun)</p>
      <div class="flex border-2 border-black focus-within:border-[var(--violet,#7C3AED)]">
        <span class="bg-gray-100 border-r-2 border-black px-3 flex items-center text-sm font-mono font-bold">#</span>
        <input
          type="number"
          id="clients"
          min="0"
          step="1"
          placeholder="0"
          class="flex-1 px-3 py-2.5 outline-none text-base font-mono"
        />
      </div>
    </div>

    <div class="flex flex-col gap-2">
      <label for="anciennete" class="font-bold text-sm uppercase tracking-wide">
        Sans mise à jour depuis
      </label>
      <p class="text-xs text-gray-500">Nombre de mois depuis le dernier contenu publié ou refonte</p>
      <div class="flex border-2 border-black focus-within:border-[var(--violet,#7C3AED)]">
        <input
          type="number"
          id="anciennete"
          min="0"
          step="1"
          placeholder="18"
          class="flex-1 px-3 py-2.5 outline-none text-base font-mono"
        />
        <span class="bg-gray-100 border-l-2 border-black px-3 flex items-center text-sm font-mono font-bold">mois</span>
      </div>
    </div>

  </div>

  <!-- Result (hidden until inputs filled) -->
  <div id="calc-result" class="hidden border-t-2 border-black px-6 py-6">

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">

      <div class="border-2 border-black p-4 bg-[#FEFFF0]">
        <p class="text-xs uppercase tracking-wide text-gray-500 mb-1">Frais fixes annuels</p>
        <p class="font-black text-xl font-mono" id="r-frais">CHF 250</p>
        <p class="text-xs text-gray-400 mt-1">hébergement + domaine (estimation)</p>
      </div>

      <div class="border-2 border-black p-4 bg-[#FEFFF0]">
        <p class="text-xs uppercase tracking-wide text-gray-500 mb-1">Clients manqués / an</p>
        <p class="font-black text-xl font-mono" id="r-clients">—</p>
        <p class="text-xs text-gray-400 mt-1">leads qualifiés non captés</p>
      </div>

      <div class="border-2 border-black p-4 bg-[#FEFFF0]">
        <p class="text-xs uppercase tracking-wide text-gray-500 mb-1">Manque à gagner / an</p>
        <p class="font-black text-xl font-mono" id="r-manque">—</p>
        <p class="text-xs text-gray-400 mt-1">clients manqués × valeur client</p>
      </div>

    </div>

    <!-- Total highlight -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

      <div class="border-2 border-black p-5 bg-[#FFDC58]">
        <p class="text-xs uppercase tracking-wide font-bold mb-1">Coût d'inaction — 1 an</p>
        <p class="font-black text-3xl font-mono" id="r-total1">—</p>
      </div>

      <div class="border-2 border-black p-5 bg-[#FEFFF0]">
        <p class="text-xs uppercase tracking-wide font-bold mb-1 text-gray-500">Coût d'inaction — 3 ans</p>
        <p class="font-black text-3xl font-mono text-gray-700" id="r-total3">—</p>
      </div>

    </div>

    <p class="text-xs text-gray-400 mt-4">
      Estimation basée sur un taux de conversion moyen de 1.5% pour un site vitrine local suisse,
      calibrée sur l'audit de 50 sites romands (avril 2026). Chiffres indicatifs — ton cas peut varier.
    </p>

  </div>

  <!-- CTA -->
  <div id="calc-cta" class="hidden border-t-2 border-black px-6 py-4 bg-[#BAE6FF] flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
    <p class="font-bold text-sm">Maintenant que tu connais le chiffre — que faire ?</p>
    <a
      href="/services/refonte-site-web"
      class="inline-flex items-center gap-2 bg-black text-white px-5 py-2.5 text-sm font-bold border-2 border-black hover:bg-[#FFDC58] hover:text-black transition-colors shrink-0"
    >
      Obtenir un audit gratuit →
    </a>
  </div>

</div>

<script>
  function formatCHF(val: number): string {
    return "CHF " + Math.round(val).toLocaleString("fr-CH");
  }

  function getDepreciation(mois: number): number {
    if (mois < 6) return 0.90;
    if (mois < 12) return 0.65;
    if (mois < 24) return 0.40;
    if (mois < 36) return 0.25;
    return 0.10;
  }

  function runCalc() {
    const panierEl = document.getElementById("panier") as HTMLInputElement;
    const clientsEl = document.getElementById("clients") as HTMLInputElement;
    const ancienneteEl = document.getElementById("anciennete") as HTMLInputElement;

    const panier = parseFloat(panierEl.value);
    const clients = parseFloat(clientsEl.value) || 0;
    const mois = parseFloat(ancienneteEl.value);

    // Ne calculer que si au moins panier et ancienneté sont renseignés
    if (isNaN(panier) || panier <= 0 || isNaN(mois) || mois < 0) {
      document.getElementById("calc-result")!.classList.add("hidden");
      document.getElementById("calc-cta")!.classList.add("hidden");
      return;
    }

    const fraisFixes = 250; // CHF/an
    const depr = getDepreciation(mois);

    let clientsManquesMois: number;
    if (clients === 0) {
      // Site à 0 conversion : on estime la perte vs baseline de 2 leads/mois pour un site actif local
      const baselinePotentiel = 2;
      clientsManquesMois = baselinePotentiel;
    } else {
      // Site qui convertit un peu : potentiel = actuels / taux_depreciaton
      const potentiel = clients / depr;
      clientsManquesMois = potentiel - clients;
    }

    const clientsManquesAn = clientsManquesMois * 12;
    const manqueAGagnerAn = clientsManquesAn * panier;
    const total1An = fraisFixes + manqueAGagnerAn;
    const total3Ans = total1An * 3;

    document.getElementById("r-frais")!.textContent = formatCHF(fraisFixes);
    document.getElementById("r-clients")!.textContent = Math.round(clientsManquesAn) + " clients";
    document.getElementById("r-manque")!.textContent = formatCHF(manqueAGagnerAn);
    document.getElementById("r-total1")!.textContent = formatCHF(total1An);
    document.getElementById("r-total3")!.textContent = formatCHF(total3Ans);

    document.getElementById("calc-result")!.classList.remove("hidden");
    document.getElementById("calc-cta")!.classList.remove("hidden");
  }

  ["panier", "clients", "anciennete"].forEach((id) => {
    document.getElementById(id)?.addEventListener("input", runCalc);
  });
</script>
